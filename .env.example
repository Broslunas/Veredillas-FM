# --- BASE DE DATOS ---
# URI de conexión a MongoDB Atlas o local
MONGODB_URI="mongodb://..."

# --- SEGURIDAD Y WEBHOOKS ---
# Secreto para validar peticiones al webhook de contacto
CONTACT_WEBHOOK_SECRET="tu_secreto_aqui"
# Secreto para firmar los tokens JWT de sesión
JWT_SECRET="tu_clave_secreta_fuerte_aqui"
# Secreto para proteger los endpoints de CRON generales
CRON_SECRET="tu_secreto_cron"

# --- GOOGLE SERVICES ---
# Credenciales de Google OAuth para login
GOOGLE_CLIENT_ID="tu_google_client_id"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:4321/api/auth/google/callback"
# Token de refresco para mantener acceso offline (ej. para Calendar)
GOOGLE_REFRESH_TOKEN="tu_google_refresh_token"
# API Key para acceso público o restringido a Google Calendar
GOOGLE_CALENDAR_API_KEY="tu_google_calendar_api_key"
# ID del calendario de Google a sincronizar
GOOGLE_CALENDAR_ID="tu_google_calendar_id"

# --- MAILJET (NEWSLETTER) ---
# Credenciales de Mailjet para el envío de correos
MJ_APIKEY_PUBLIC="tu_mailjet_public_key"
MJ_API_SECRET="tu_mailjet_private_key"
# Secreto específico para proteger el endpoint de envío de newsletter
NEWSLETTER_CRON_SECRET="tu_secreto_newsletter_cron"

# --- DISCORD ---
# Client ID de la aplicación de Discord (público)
PUBLIC_DISCORD_CLIENT_ID="tu_discord_client_id"
# Client Secret de la aplicación de Discord
DISCORD_CLIENT_SECRET="tu_discord_client_secret"
# URI de redirección para el flujo OAuth de Discord
PUBLIC_DISCORD_REDIRECT_URI="http://localhost:4321/discord/callback"

# --- WEB PUSH NOTIFICATIONS ---
# Claves VAPID para notificaciones push en el navegador
PUBLIC_VAPID_KEY="tu_vapid_public_key"
PRIVATE_VAPID_KEY="tu_vapid_private_key"

# --- OTRAS INTEGRACIONES ---
# Token de acceso para la API de Buffer (redes sociales)
BUFFER_ACCESS_TOKEN="tu_buffer_access_token"
# API Key de Deepgram para transcripción de audio
DEEPGRAM_API_KEY="tu_deepgram_api_key"
# Secreto para el puente de autenticación con @canariaseducacion.es
CANARIAS_EDUCACION_BRIDGE_SECRET="tu_secreto_bridge"
# URL del Deploy Hook de Vercel para disparar despliegues manuales
VERCEL_DEPLOY_HOOK_URL="https://api.vercel.com/..."

# --- SPOTIFY ---
# Credenciales de la API de Spotify
SPOTIFY_CLIENT_ID="tu_spotify_client_id"
SPOTIFY_CLIENT_SECRET="tu_spotify_client_secret"
SPOTIFY_REDIRECT_URI="https://tu-dominio.es/api/auth/spotify/callback"

# --- CLOUDFLARE R2 (STORAGE) ---
# Configuración de almacenamiento compatible con S3 (R2)
R2_ACCOUNT_ID="tu_r2_account_id"
R2_ACCESS_KEY_ID="tu_r2_access_key"
R2_SECRET_ACCESS_KEY="tu_r2_secret_key"
R2_BUCKET_NAME="vfm-social"
# URL pública para acceder a los archivos subidos
R2_PUBLIC_URL="https://files.tu-dominio.es"