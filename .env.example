MONGODB_URI="Your MongoDB connection string"
CONTACT_WEBHOOK_SECRET="Your webhook secret"

# Mailjet (Newsletter)
MJ_APIKEY_PUBLIC="Your Mailjet API Key"
MJ_API_SECRET="Your Mailjet API Secret"
MJ_CONTACT_LIST_ID="Your Mailjet Contact List ID"

# Google OAuth (for user authentication)
GOOGLE_CLIENT_ID="Your Google OAuth Client ID"
GOOGLE_CLIENT_SECRET="Your Google OAuth Client Secret"

# JWT Secret (for session tokens)
JWT_SECRET="Your strong JWT secret key"

# Newsletter Cron
NEWSLETTER_CRON_SECRET="A secret random string to protect the newsletter API (Avoid starting with vf_)"

# Discord Activity
PUBLIC_DISCORD_CLIENT_ID="Your Discord Client ID"

# Web Push Notifications
PUBLIC_VAPID_KEY="Your Public VAPID Key"
PRIVATE_VAPID_KEY="Your Private VAPID Key"

# @canariaseducacion.es Auth (Google Apps Script Bridge)
CANARIAS_EDUCACION_BRIDGE_SECRET="token-token-token"

# Vercel Deployment & Crons
# URL del Deploy Hook (Vercel Dashboard > Settings > Git)
VERCEL_DEPLOY_HOOK_URL=
# Secreto para proteger el endpoint cron (puede ser cualquier string largo)
CRON_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"
R2_PUBLIC_URL="https://your-public-r2-url.dev"