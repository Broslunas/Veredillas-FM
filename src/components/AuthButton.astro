---
// AuthButton.astro — Client-side auth button with profile dropdown
---

<div id="auth-button-wrapper" class="flex items-center relative">
  <!-- Loading state -->
  <div class="flex items-center justify-center p-2">
    <div class="w-5 h-5 border-2 border-violet-500/20 border-t-violet-500 rounded-full animate-spin"></div>
  </div>
</div>

<style is:global>
  /* Keep only the complex dropdown transition logic that is harder to do purely with utility classes without extra JS */
  .profile-dropdown-container:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
</style>

<script>
  // Fetch current user and render appropriate button
  async function loadAuthButton() {
    const wrapper = document.getElementById('auth-button-wrapper');
    if (!wrapper) return;

    try {
      const response = await fetch('/api/auth/me');
      const data = await response.json();

      if (data.user) {
        // User is logged in - show profile dropdown
        const initial = data.user.name.charAt(0).toUpperCase();
        
        wrapper.innerHTML = `
          <div class="profile-dropdown-container relative inline-block group">
            <button class="flex items-center gap-2.5 px-3 py-1.5 rounded-full bg-violet-600/10 text-white transition-all duration-300 border border-violet-600/20 cursor-pointer whitespace-nowrap hover:bg-violet-600/20 hover:border-violet-600/40">
              ${data.user.picture 
                ? `<img src="${data.user.picture}" alt="${data.user.name}" class="w-7 h-7 rounded-full object-cover border-2 border-violet-500" />`
                : `<div class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-600 to-pink-500 flex items-center justify-center font-bold text-white text-[0.75rem] border-2 border-violet-500/50">${initial}</div>`
              }
              <span class="font-semibold text-[0.85rem] max-w-[100px] truncate hidden md:block">${data.user.name}</span>
            </button>
            
            <div class="dropdown-menu absolute top-full right-0 mt-2 w-[260px] bg-zinc-900/95 border border-violet-500/20 rounded-xl shadow-[0_10px_40px_rgba(0,0,0,0.4)] backdrop-blur-md opacity-0 invisible -translate-y-[10px] transition-all duration-200 z-[100] p-2 overflow-hidden">
              <div class="px-4 py-3 border-b border-white/5 mb-2">
                <span class="block font-semibold text-white truncate">${data.user.name}</span>
                <span class="block text-[0.75rem] text-zinc-400 mt-0.5 truncate" title="${data.user.email || ''}">${data.user.email || ''}</span>
              </div>
              
              <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 text-zinc-300 hover:bg-violet-600/10 hover:text-violet-400 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 14h7v7H3z"/></svg>
                Mi Dashboard
              </a>

              ${data.user.id ? `
              <a href="/perfil/${data.user.id}" class="flex items-center gap-3 px-4 py-2.5 text-zinc-300 hover:bg-violet-600/10 hover:text-violet-400 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                Mi Perfil Público
              </a>
              ` : ''}
              
              <a href="/logros" class="flex items-center gap-3 px-4 py-2.5 text-zinc-300 hover:bg-violet-600/10 hover:text-violet-400 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                Logros
              </a>

              ${data.user.role === 'admin' || data.user.role === 'owner' ? `
              <a href="/dashboard/admin" class="flex items-center gap-3 px-4 py-2.5 text-zinc-300 hover:bg-violet-600/10 hover:text-violet-400 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                Panel Admin
              </a>
              ` : ''}
              
              <a href="/historial" class="flex items-center gap-3 px-4 py-2.5 text-zinc-300 hover:bg-violet-600/10 hover:text-violet-400 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 10 10 0 0 0-10-10zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm0-13a1 1 0 0 0-1 1v5.59l4.47 2.68a1 1 0 0 0 1.37-.37 1 1 0 0 0-.37-1.37L13 14.16V8a1 1 0 0 0-1-1z"/></svg>
                Mi Historial
              </a>
              
              <div class="h-px bg-white/5 my-2"></div>
              
              <a href="/api/auth/logout" class="flex items-center gap-3 px-4 py-2.5 text-red-400 hover:bg-red-500/10 transition-all rounded-lg text-sm group/item">
                <svg class="w-4 h-4 opacity-70 group-hover/item:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                Cerrar Sesión
              </a>
            </div>
            
            <!-- Invisible bridge to prevent menu from closing when moving cursor -->
            <div class="absolute top-full left-0 w-full h-2"></div>
          </div>
        `;
      } else {
        // No user - show login button
        wrapper.innerHTML = `
          <a href="/login" class="flex items-center gap-2 px-4 py-2 rounded-full font-bold text-[0.85rem] transition-all duration-300 bg-gradient-to-r from-violet-600 to-pink-500 text-white shadow-[0_2px_8px_rgba(139,92,246,0.25)] hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] whitespace-nowrap">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
            </svg>
            <span>Iniciar Sesión</span>
          </a>
        `;
      }
    } catch (error) {
      console.error('Error loading auth button:', error);
      // Default to login button on error
      wrapper.innerHTML = `
        <a href="/login" class="flex items-center gap-2 px-4 py-2 rounded-full font-bold text-[0.85rem] transition-all duration-300 bg-gradient-to-r from-violet-600 to-pink-500 text-white shadow-[0_2px_8px_rgba(139,92,246,0.25)] hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(139,92,246,0.35)] whitespace-nowrap">
          <span>Iniciar Sesión</span>
        </a>
      `;
    }
  }

  // Load on DOMContentLoaded
  document.addEventListener('DOMContentLoaded', loadAuthButton);
  // Also handle Astro page transitions
  document.addEventListener('astro:page-load', loadAuthButton);
</script>

