---

interface Props {
    post: any;
}

const { post } = Astro.props;

// Date formatter
const formatDate = (date: Date) => {
    return date.toLocaleDateString('es-ES', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
    });
};
---


<article class="relative flex flex-col h-full bg-white/3 backdrop-blur-[10px] border border-white/5 rounded-2xl overflow-hidden transition-all duration-300 hover:border-primary hover:shadow-[0_10px_30px_-10px_rgba(0,0,0,0.5)] hover-3d-card group" data-cursor="read">
    <div class="shine"></div>
    <div class="w-full h-[200px] relative overflow-hidden bg-white/5 shimmer-skeleton">
        {post.data.image ? (
            <img 
                src={post.data.image} 
                alt={post.data.title} 
                width={600}
                height={400}
                class="blog-cover w-full h-full object-cover transition-all duration-700 opacity-0 group-hover:scale-105" 
                style="transform: translateZ(20px);"
                loading="lazy"
                onload="this.classList.remove('opacity-0'); this.parentElement.classList.remove('shimmer-skeleton')"
            />
        ) : (
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-white/5 to-white/2">
                <span class="text-5xl opacity-30">📰</span>
            </div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-60 pointer-events-none"></div>
    </div>

    <div class="p-6 flex flex-col flex-grow">
        <div class="flex justify-between items-start mb-4 text-[0.85rem]">
            <time class="text-zinc-400 font-display">{formatDate(post.data.pubDate)}</time>
            {post.data.tags && (
                <div class="flex flex-wrap gap-2 justify-end">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                        <span class="text-secondary text-[0.75rem] font-medium bg-secondary/10 px-1.5 py-0.5 rounded">#{tag}</span>
                    ))}
                </div>
            )}
        </div>
        
        <h3 class="text-xl font-bold mb-3 leading-tight group-hover:text-primary transition-colors">
            <a href={`/blog/${post.slug}`} class="text-white hover:text-primary transition-colors">
                {post.data.title}
            </a>
        </h3>
        
        <p class="text-zinc-400 text-[0.95rem] leading-relaxed mb-6 line-clamp-3">{post.data.description}</p>
        
        <a href={`/blog/${post.slug}`} class="mt-auto inline-flex items-center gap-2 text-primary font-semibold text-[0.9rem] transition-all hover:gap-3 hover:text-accent">
            Leer más 
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
    </div>
    <a 
        href={`/blog/${post.slug}`} 
        class="absolute inset-0 z-[30]" 
        style="transform: translateZ(100px);"
        aria-label={`Leer ${post.data.title}`}
    ></a>
</article>

<script>
    const checkBlogImages = () => {
        document.querySelectorAll('.blog-cover').forEach(img => {
            const image = img as HTMLImageElement;
            if (image.complete) {
                image.classList.remove('opacity-0');
                image.parentElement?.classList.remove('shimmer-skeleton');
            }
        });
    };
    
    document.addEventListener("DOMContentLoaded", checkBlogImages);
    document.addEventListener("astro:page-load", checkBlogImages);
</script>
