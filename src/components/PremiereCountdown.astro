---
interface Props {
  targetDate: Date;
  title: string;
}

const { targetDate, title } = Astro.props;
const isoDate = targetDate.toISOString();
---

<div class="premiere-countdown" data-target={isoDate} data-title={title}>
    <div class="countdown-content">
        <div class="badge">Estreno Oficial</div>
        <h2>{title}</h2>
        
        <button class="voice-toggle-btn enabled" aria-label="Activar/Desactivar voz de locutor" title="Locutor: ON">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mic"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
        </button>
        
        <div class="timer">
            <div class="time-unit">
                <span class="value days">00</span>
                <span class="label">Días</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value hours">00</span>
                <span class="label">Hrs</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value minutes">00</span>
                <span class="label">Min</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value seconds">00</span>
                <span class="label">Seg</span>
            </div>
        </div>
        
        <div class="music-player-wrapper">
            <!-- Grid-based layout for perfect centering (maintained from fix) -->
            <div class="player-grid">
                <!-- Left spacing to balance the volume bar -->
                <div class="grid-side grid-left"></div>
                
                <!-- Center Column: Everything strictly centered -->
                <div class="grid-center">
                    <div class="custom-select-wrapper">
                        <div class="custom-select-trigger" tabindex="0">
                            <span class="selection">Veredillas FM Radio</span>
                            <div class="arrow"></div>
                        </div>
                        <div class="custom-options">
                            <div class="custom-option" data-value="https://radio.veredillasfm.es/stream">Veredillas FM Radio</div>
                            <div class="custom-option" data-value="https://27833.live.streamtheworld.com/LOS40_URBAN.mp3">Los 40 Urban</div>
                            <div class="custom-option selected" data-value="https://stream.zeno.fm/0r0xa792kwzuv">Lofi Chill</div>
                            <div class="custom-option" data-value="https://s1.we4stream.com:2020/stream/locaurban">Loca Urban</div>
                            <div class="custom-option" data-value="https://28503.live.streamtheworld.com/LOS40_CAT.mp3">Los 40</div>
                            <div class="custom-option" data-value="https://listen.technobase.fm/tunein-mp3">Techno</div>
                            <div class="custom-option" data-value="https://sunaer-stream.com:7113/LA_MUEVE_CADENA_HD">La MUEVE FM</div>
                            <div class="custom-option" data-value="https://stream-177.zeno.fm/gwmx5szrc0hvv?zt=eyJhbGciOiJIUzI1NiJ9.eyJzdHJlYW0iOiJnd214NXN6cmMwaHZ2IiwiaG9zdCI6InN0cmVhbS0xNzcuemVuby5mbSIsInJ0dGwiOjUsImp0aSI6Ild6UHlGOHdzUkRLeVRHalhZY004SlEiLCJpYXQiOjE3NzUyMTIwMjEsImV4cCI6MTc3NTIxMjA4MX0.NrAFqkqJUVyckzTl0C0RqzdCDxEkgQxGfBkS47sENnQ">Rock FM</div>
                            <div class="custom-option" data-value="http://streaming.indalteco.net:8002/dial.mp3">Cadena Dial</div>
                        </div>
                    </div>

                    <button class="music-btn music-toggle-btn" aria-label="Activar música de fondo">
                        <div class="equalizer">
                            <span class="bar bar-1"></span>
                            <span class="bar bar-2"></span>
                            <span class="bar bar-3"></span>
                            <span class="bar bar-4"></span>
                        </div>
                        <span class="music-label">Activar Música</span>
                    </button>
                    
                    <button class="dj-trigger-btn" id="dj-trigger-btn" style="display: none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                        Abrir Panel DJ
                    </button>

                    <audio class="waiting-music" preload="none" loop>
                        <source src="https://27833.live.streamtheworld.com/LOS40_URBAN.mp3" type="audio/mpeg">
                    </audio>
                </div>

                <!-- Right Column: Vertical Volume Bar -->
                <div class="grid-side grid-right">
                    <div class="vertical-volume-container">
                        <div class="volume-slider-vertical-wrapper">
                            <input type="range" class="volume-slider vertical" min="0" max="1" step="0.01" value="0.5" aria-label="Volumen">
                        </div>
                        <svg class="volume-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path class="volume-waves" d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path class="volume-waves-outer" d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                    </div>
                </div>
            </div>
        </div>

        <div class="dj-modal-overlay" id="dj-modal-overlay">
            <div class="dj-panel-wrapper">
                <div class="dj-header">
                    <div class="dj-header-title">
                        <h3>🎛️ Panel DJ - Veredillas FM</h3>
                        <div class="dj-status-badge offline" id="dj-status-badge">OFFLINE</div>
                    </div>
                    <button class="dj-close-btn" id="dj-close-btn" aria-label="Cerrar Panel DJ">&times;</button>
                </div>
                
                <div class="dj-now-playing">
                    <span class="dj-label">Sonando ahora:</span>
                    <span class="dj-song-title" id="dj-current-song">Ninguna canción</span>
                </div>

                <div class="dj-controls">
                    <button class="dj-btn play" id="dj-btn-play" title="Iniciar/Recargar emisión">▶️ Emitir</button>
                    <button class="dj-btn stop" id="dj-btn-stop" title="Detener emisión">⏹️ Cortar</button>
                    <button class="dj-btn skip" id="dj-btn-skip" title="Saltar a la siguiente">⏭️ Saltar</button>
                    <button class="dj-btn sync" id="dj-btn-sync" title="Sincronizar stream al directo">🔄 Sincronizar</button>
                </div>

                <div class="dj-search-area">
                    <div class="dj-search-input-group">
                        <input type="text" id="dj-search-input" placeholder="Buscar en la biblioteca local..." />
                        <button class="dj-btn search" id="dj-btn-search">Buscar</button>
                    </div>
                    <div class="dj-results" id="dj-results-list"></div>
                </div>
            </div>
        </div>

        <div class="status-message">Esperando que llegue la hora...</div>
    

<style>
    .voice-settings-container, .voice-settings-panel, .settings-toggle-btn, .close-panel-btn, .panel-header, .panel-section, .section-label, .toggle-control, .control-indicator, .checkbox-grid, .check-item, .panel-actions, .test-voice-btn, .voice-grid, .voice-chip {
        display: none !important;
    }
    .premiere-countdown {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--color-surface) 0%, #000 100%);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--spacing-2xl);
        text-align: center;
        min-height: 400px;
        position: relative;
        overflow: hidden;
    }

    .premiere-countdown::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
        pointer-events: none;
    }

    /* Reverted Badge Styles */
    .badge {
        background: var(--color-primary);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: bold;
        margin-bottom: var(--spacing-md);
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);
    }

    /* Reverted H2 (Episode Title) Styles */
    h2 {
        font-size: clamp(1.5rem, 5vw, 2.5rem);
        margin-bottom: var(--spacing-sm);
        background: linear-gradient(white, #aaa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .subtitle {
        color: var(--color-text-muted);
        font-size: 1.1rem;
        margin-bottom: var(--spacing-xl);
    }

    /* Reverted Timer Styles */
    .voice-toggle-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-text-muted);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 100;
        backdrop-filter: blur(10px);
    }

    .voice-toggle-btn:hover {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        transform: scale(1.05);
    }

    .voice-toggle-btn.enabled {
        border-color: var(--color-primary);
        color: var(--color-primary);
        background: rgba(139, 92, 246, 0.1);
    }

    .timer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-sm);
        font-variant-numeric: tabular-nums;
        margin-bottom: var(--spacing-xl);
    }

    .time-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .value {
        font-size: 2.5rem;
        font-weight: bold;
        line-height: 1;
        color: var(--color-text-main);
    }

    .label {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--color-text-muted);
        margin-top: 5px;
        letter-spacing: 0.05em;
    }

    .separator {
        font-size: 2rem;
        color: var(--color-text-muted);
        margin-bottom: 20px; /* Align with numbers */
    }

    /* Reverted Status Message Styles */
    .status-message {
        font-size: 0.9rem;
        color: var(--color-primary);
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Music Player Layout Improvements (Maintained Centering Logic) */
    .music-player-wrapper {
        width: 100%;
        max-width: 600px;
        margin: 1rem auto 0;
    }

    .player-grid {
        display: grid;
        grid-template-columns: 80px 1fr 80px; 
        align-items: center;
        gap: 1rem;
    }

    .grid-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
    }

    .grid-side {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 80px;
    }

    /* Vertical Volume Bar (Fixed logic) */
    .vertical-volume-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 15px 10px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: scale(0.9) translateX(10px);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .vertical-volume-container.show {
        opacity: 1;
        visibility: visible;
        pointer-events: all;
        transform: scale(1) translateX(0);
    }

    .volume-slider-vertical-wrapper {
        height: 100px;
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .volume-slider.vertical {
        -webkit-appearance: none;
        width: 100px;
        height: 4px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        outline: none;
        transform: rotate(-90deg);
        cursor: pointer;
        position: absolute;
    }

    .volume-slider.vertical::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 14px;
        height: 14px;
        background: white;
        border-radius: 50%;
        cursor: pointer;
    }

    .volume-icon {
        color: var(--color-text-muted);
    }

    /* Dropdown Styles */
    .custom-select-wrapper {
        position: relative;
        user-select: none;
        width: 100%;
        max-width: 280px;
        z-index: 50;
    }

    .custom-select-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 10px 18px;
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(10px);
    }

    .selection {
        font-size: 0.9rem;
        color: var(--color-text-main);
    }

    .arrow {
        width: 8px;
        height: 8px;
        border-bottom: 2px solid rgba(255,255,255,0.5);
        border-right: 2px solid rgba(255,255,255,0.5);
        transform: rotate(45deg);
        transition: all 0.3s ease;
        margin-top: -4px;
    }

    .custom-select-wrapper.open .arrow {
        transform: rotate(-135deg);
        margin-top: 4px;
    }

    .custom-options {
        position: absolute;
        bottom: calc(100% + 12px);
        left: 0;
        right: 0;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        z-index: 100;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(10px);
        transition: all 0.3s;
        backdrop-filter: blur(20px);
        max-height: 200px;
        overflow-y: auto;
    }

    .custom-select-wrapper.open .custom-options {
        opacity: 1;
        visibility: visible;
        pointer-events: all;
        transform: translateY(0);
    }

    .custom-option {
        padding: 12px 20px;
        cursor: pointer;
        color: rgba(255,255,255,0.7);
        font-size: 0.9rem;
    }

    .custom-option:hover {
        background: rgba(139, 92, 246, 0.15);
        color: white;
    }

    .custom-option.selected {
        background: var(--color-primary);
        color: white;
    }

    .music-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 10px 20px;
        border-radius: 100px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--color-text-muted);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .music-btn.playing {
        background: rgba(139, 92, 246, 0.15);
        border-color: var(--color-primary);
        color: white;
    }

    .equalizer {
        display: flex;
        align-items: flex-end;
        height: 12px;
        gap: 2px;
    }

    .bar {
        width: 3px;
        background: currentColor;
        border-radius: 1px;
        animation: eq 1s infinite ease-in-out;
        animation-play-state: paused;
    }

    .music-btn.playing .bar {
        animation-play-state: running;
    }

    .bar-1 { height: 6px; }
    .bar-2 { height: 12px; }
    .bar-3 { height: 8px; }
    .bar-4 { height: 5px; }

    @keyframes eq {
        0%, 100% { height: 4px; }
        50% { height: 12px; }
    }

    .dj-trigger-btn {
        background: rgba(139, 92, 246, 0.15);
        border: 1px solid var(--color-primary);
        padding: 8px 16px;
        border-radius: 100px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        color: white;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.3s ease;
        animation: fadeIn 0.4s ease-out;
    }

    .dj-trigger-btn:hover {
        background: rgba(139, 92, 246, 0.3);
        transform: translateY(-2px);
    }

    .dj-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(8px);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
    }

    .dj-modal-overlay.open {
        opacity: 1;
        visibility: visible;
    }

    .dj-panel-wrapper {
        width: 100%;
        max-width: 500px;
        background: #111;
        border: 1px solid rgba(139, 92, 246, 0.4);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        text-align: left;
        transform: translateY(20px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.05) inset;
    }

    .dj-modal-overlay.open .dj-panel-wrapper {
        transform: translateY(0);
    }

    .dj-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 0.75rem;
    }

    .dj-header-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .dj-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: white;
    }

    .dj-close-btn {
        background: none;
        border: none;
        color: var(--color-text-muted);
        font-size: 1.8rem;
        line-height: 1;
        cursor: pointer;
        padding: 0;
        transition: color 0.2s;
    }

    .dj-close-btn:hover {
        color: white;
    }

    .dj-status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: bold;
        letter-spacing: 0.05em;
    }

    .dj-status-badge.online {
        background: rgba(34, 197, 94, 0.2);
        color: #4ade80;
        border: 1px solid #4ade80;
    }

    .dj-status-badge.offline {
        background: rgba(239, 68, 68, 0.2);
        color: #f87171;
        border: 1px solid #f87171;
    }

    .dj-now-playing {
        margin-bottom: 1.5rem;
    }

    .dj-label {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        display: block;
        margin-bottom: 0.25rem;
    }

    .dj-song-title {
        font-size: 1rem;
        color: var(--color-primary);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
    }

    .dj-controls {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .dj-btn {
        flex: 1;
        padding: 8px 12px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .dj-btn.play { background: rgba(34, 197, 94, 0.2); color: #4ade80; border: 1px solid #4ade80; }
    .dj-btn.play:hover { background: rgba(34, 197, 94, 0.3); }

    .dj-btn.stop { background: rgba(239, 68, 68, 0.2); color: #f87171; border: 1px solid #f87171; }
    .dj-btn.stop:hover { background: rgba(239, 68, 68, 0.3); }

    .dj-btn.skip { background: rgba(255, 255, 255, 0.1); color: white; border: 1px solid rgba(255,255,255,0.2); }
    .dj-btn.skip:hover { background: rgba(255, 255, 255, 0.2); }
    
    .dj-btn.search { background: var(--color-primary); color: white; flex: 0 0 auto; }
    .dj-btn.search:hover { background: #7c3aed; }

    .dj-search-area {
        background: rgba(0, 0, 0, 0.3);
        padding: 1rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .dj-search-input-group {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .dj-search-input-group input {
        flex: 1;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 8px 12px;
        border-radius: 8px;
        color: white;
        font-size: 0.9rem;
    }

    .dj-search-input-group input:focus {
        outline: none;
        border-color: var(--color-primary);
    }

    .dj-results {
        max-height: 250px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding-right: 5px;
    }

    .dj-result-item {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.05);
        padding: 12px;
        border-radius: 10px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.2s ease;
