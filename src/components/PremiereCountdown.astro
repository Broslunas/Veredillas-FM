                        this.djStatusBadge.className = 'px-3 py-1 rounded-full text-[0.65rem] font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_10px_currentColor]';
                        this.djStatusBadge.textContent = 'OFFLINE';
                    }
                }

                if (this.djCurrentSong) {
                    if (data.isPlaying && data.currentSongMeta && data.currentSongMeta.title) {
                        this.djCurrentSong.textContent = data.currentSongMeta.title;
                    } else {
                        this.djCurrentSong.textContent = 'Ninguna canción';
                    }
                }

                if (data.radioSettings) {
                    if (this.djSettingLoop && this.djSettingLoop !== document.activeElement) {
                        this.djSettingLoop.checked = data.radioSettings.loop;
                    }
                    if (this.djSettingShuffle && this.djSettingShuffle !== document.activeElement) {
                        this.djSettingShuffle.checked = data.radioSettings.shuffle;
                    }
                }

                if (data.playQueue) {
                    if (this.djQueueCount) {
                        this.djQueueCount.textContent = data.playQueue.length;
                    }
                    if (this.djQueueList) {
                        if (data.playQueue.length === 0) {
                            this.djQueueList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-10">La cola está vacía</div>';
                        } else {
                            this.djQueueList.innerHTML = '';
                            data.playQueue.forEach((song: any, idx: number) => {
                                const div = document.createElement('div');
                                div.className = 'flex items-center justify-between bg-white/5 border border-white/5 p-3 rounded-xl hover:bg-white/10 transition-colors group';
                                div.innerHTML = `
                                    <div class="flex flex-col overflow-hidden pr-2">
                                        <span class="text-white text-sm font-medium truncate" title="${song.title}">${song.title}</span>
                                        ${song.duration ? `<span class="text-xs text-gray-500 font-mono">${Math.floor(song.duration/60)}:${String(Math.floor(song.duration%60)).padStart(2,'0')}</span>` : ''}
                                    </div>
                                    <button class="dj-btn-remove-queue shrink-0 w-8 h-8 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20 flex items-center justify-center lg:opacity-0 group-hover:opacity-100 hover:bg-red-500/20 transition-all" data-idx="${idx}" title="Eliminar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                    </button>
                                `;
                                this.djQueueList?.appendChild(div);
                            });
                            // Attach remove events
                            this.djQueueList.querySelectorAll('.dj-btn-remove-queue').forEach(btn => {
                                btn.addEventListener('click', (e) => {
                                    const idx = parseInt((e.currentTarget as HTMLElement).dataset.idx || '0');
                                    this.apiRemoveQueue(idx);
                                });
                            });
                        }
                    }
                }

            } catch (err) {
                console.error('Error polling DJ status:', err);
                if (this.djStatusBadge) {
                    this.djStatusBadge.className = 'px-3 py-1 rounded-full text-[0.65rem] font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_10px_currentColor]';
                    this.djStatusBadge.textContent = 'OFFLINE';
                }
                if (this.djCurrentSong) {
                    this.djCurrentSong.textContent = 'Servidor inalcanzable';
                }
            }
        }

        switchGenre(option: HTMLElement) {
            // Update selected visual state
            this.vibeOptions.forEach(opt => opt.classList.remove('selected'));
            option.classList.add('selected');

            const newUrl = option.dataset.value;
            const genreName = option.textContent || "Música";
            
            // Update trigger text
            if(this.selectionText) this.selectionText.textContent = genreName;
            
            if (newUrl && this.audio) {
                this.currentUrl = newUrl;
                
                // Anti-cache para Veredillas FM (forzar directo absoluto)
                if (newUrl === 'https://radio.veredillasfm.es/stream') {
                    this.audio.src = `${newUrl}?t=${new Date().getTime()}`;
                } else {
                    this.audio.src = newUrl;
                }
                
                // DJ Panel Trigger Button visibility logic
                if (newUrl === 'https://radio.veredillasfm.es/stream' && this.djTriggerBtn) {
                    this.djTriggerBtn.style.display = 'flex';
                } else if (this.djTriggerBtn) {
                    this.djTriggerBtn.style.display = 'none';
                    // If modal was open, close it
                    if (this.djModalOverlay && this.djModalOverlay.classList.contains('open')) {
                        this.djModalOverlay.classList.remove('open');
                        if (this.djPollInterval) {
                            clearInterval(this.djPollInterval);
                        }
                    }
                }

                // Save selection to localStorage
                localStorage.setItem('veredillas_last_station', newUrl);
                
                if (this.isPlaying) {
                     if(this.musicLabel) this.musicLabel.textContent = `Conectando con ${genreName}...`;
                     this.audio.play().then(() => {
                         if(this.musicLabel) this.musicLabel.textContent = `Escuchando ${genreName}`;
                         this.startCornerPoll();
                     }).catch(e => {
                         console.error("Switch play failed:", e);
                         this.isPlaying = false;
                         this.musicBtn?.classList.remove('playing');
                         this.updateVolumeVisibility();
                         this.stopCornerPoll();
                     });
                } else {
                    if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
                }
            }
        }

        updateVolumeIcon(volume: number) {
            const waves = this.el.querySelector('.volume-waves') as HTMLElement;
            const outerWaves = this.el.querySelector('.volume-waves-outer') as HTMLElement;
            
            if(!waves || !outerWaves) return;

            if (volume === 0) {
                waves.style.opacity = '0';
                outerWaves.style.opacity = '0';
            } else if (volume < 0.5) {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '0';
            } else {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '1';
            }
        }

        updateVolumeVisibility() {
            if (this.isPlaying) {
                this.volumeContainer?.classList.add('show');
            } else {
                this.volumeContainer?.classList.remove('show');
            }
        }

        toggleMusic() {
            if (!this.audio || !this.musicBtn) return;

            if (this.isPlaying) {
                this.audio.pause();
                this.isPlaying = false;
                this.musicBtn.classList.remove('playing');
                const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
                this.stopCornerPoll();
            } else {
                if(this.musicLabel) this.musicLabel.textContent = "Conectando...";
                
                this.audio.play().then(() => {
                    this.isPlaying = true;
                    this.musicBtn!.classList.add('playing');
                    const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                    if(this.musicLabel) this.musicLabel!.textContent = `Escuchando ${genreName}`;
                    
                    // Trigger TTS when music starts for the first time
                    this.playTTS();
                    this.startCornerPoll();
                }).catch(e => {
                    console.error("Audio play failed:", e);
                    this.isPlaying = false;
                    this.musicBtn!.classList.remove('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = "No disponible";
                    this.stopCornerPoll();
                }).finally(() => {
                    this.updateVolumeVisibility();
                });
            }
            this.updateVolumeVisibility();
        }

        async finish() {
            if(this.interval) clearInterval(this.interval);
            
            if (this.audio && this.isPlaying) {
                const fadeAudio = setInterval(() => {
                    if (this.audio && this.audio.volume > 0.05) {
                        this.audio.volume -= 0.05;
                    } else {
                        clearInterval(fadeAudio);
                        this.audio?.pause();
                    }
                }, 100);
            }
            
            // @ts-ignore
            import('canvas-confetti').then(({ default: confetti }) => {
                 this.fireConfetti(confetti);
            });
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.transition = 'opacity 1s ease-out, transform 1s ease-out';
                countdownWrapper.style.opacity = '0';
                countdownWrapper.style.transform = 'scale(0.95)';
                
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                
                setTimeout(() => {
                    playerWrapper.style.opacity = '1';
                    setTimeout(() => {
                         countdownWrapper.style.display = 'none';
                         document.dispatchEvent(new CustomEvent('premiere-started'));
                    }, 1000);
                }, 100);
            } else {
                 window.location.reload();
            }
        }

        instantFinish() {
            if(this.interval) clearInterval(this.interval);
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.display = 'none';
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                playerWrapper.style.opacity = '1';
                playerWrapper.style.transition = 'none';
                document.dispatchEvent(new CustomEvent('premiere-started'));
            } else {
                 window.location.reload();
            }
        }

        fireConfetti(confetti: any) {
            const count = 200;
            const defaults = { origin: { y: 0.7 } };

            function fire(particleRatio: number, opts: any) {
                confetti({
                    ...defaults,
                    ...opts,
                    particleCount: Math.floor(count * particleRatio)
                });
            }

            fire(0.25, { spread: 26, startVelocity: 55 });
            fire(0.2, { spread: 60 });
            fire(0.35, { spread: 100, decay: 0.91, scalar: 0.8 });
            fire(0.1, { spread: 120, startVelocity: 25, decay: 0.92, scalar: 1.2 });
            fire(0.1, { spread: 120, startVelocity: 45 });
        }

        startCornerPoll() {
            if (this.currentUrl !== 'https://radio.veredillasfm.es/stream' || !this.isPlaying) {
                const cornerWidget = document.getElementById('now-playing-corner');
                if (cornerWidget) cornerWidget.classList.remove('visible');
                return;
            }

            this.updateCornerStatus();
            
            if (!this.cornerPollInterval) {
                this.cornerPollInterval = window.setInterval(() => this.updateCornerStatus(), 5000);
            }
        }

        stopCornerPoll() {
            if (this.cornerPollInterval) {
                clearInterval(this.cornerPollInterval);
                this.cornerPollInterval = undefined;
            }
            const cornerWidget = document.getElementById('now-playing-corner');
            if (cornerWidget) cornerWidget.classList.remove('visible');
        }

        async updateCornerStatus() {
            if (this.currentUrl !== 'https://radio.veredillasfm.es/stream' || !this.isPlaying) {
                this.stopCornerPoll();
                return;
            }

            try {
                const res = await fetch('https://radio.veredillasfm.es/api/status');
                if (!res.ok) throw new Error('Status failed');
                const data = await res.json();
                
                const cornerTitle = document.getElementById('corner-song-title');
                const cornerWidget = document.getElementById('now-playing-corner');
                
                if (data.isPlaying && data.currentSongMeta && data.currentSongMeta.title) {
                    if (cornerTitle) cornerTitle.textContent = data.currentSongMeta.title;
                    if (cornerWidget) cornerWidget.classList.add('visible');
                } else {
                    if (cornerWidget) cornerWidget.classList.remove('visible');
                }
            } catch (err) {
                console.error('Error polling corner status:', err);
                const cornerWidget = document.getElementById('now-playing-corner');
                if (cornerWidget) cornerWidget.classList.remove('visible');
            }
        }
    }

    document.addEventListener('astro:page-load', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });

    // Fallback for non-view-transitions
    document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });
</script>
