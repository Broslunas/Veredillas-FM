                `Se viene el peak content del instituto, literal. Haz la previa en ${stationName}, porque en [time] arranca el estreno de... ${this.title} en Veredillas efe-eme.`,
                `El verdadero glow up de la radio escolar está aquí. Escucha ${stationName} un ratito más, que en [time] damos paso a... ${this.title} en Veredillas efe-eme.`,
                `Hoy venimos a dar una masterclass. Calienta con ${stationName}, que en [time] estrenamos... ${this.title} en Veredillas efe-eme y va a ser una padreada histórica.`,
                `Estamos en modo diablo preparándolo todo en cabina. Aguanta en ${stationName}, ${userName}, que en [time] Veredillas efe-eme lanza en exclusiva... ${this.title}.`,
                `Atentos al drop, familia. Sigue con la sintonía de ${stationName}, porque en [time] soltamos en Veredillas efe-eme el episodio de... ${this.title}. ¡A romperla!`,
                `Deja la chamba un momento, ${userName}, y disfruta de la música en ${stationName}. En [time] empieza lo serio en Veredillas efe-eme: el estreno de... ${this.title}.`,
                `Cero bromas, ${userName}, esto que se viene va a ser muy épico. Sigue de tranquis con ${stationName} que en [time] encendemos Veredillas efe-eme con... ${this.title}.`
            ];

            const transitionVariations = {
                'hour-change': [
                    `¡Atención, ${userName}!! Tachamos una hora en el calendario. Ya solo faltan [time] para el estreno de... ${this.title}. ¡No te lo pierdas en ${stationName}!`,
                    `Una hora menos de espera. En apenas [time] empezaremos el estreno de... ${this.title}. ¡Disfruta de la mejor música en ${stationName}!`,
                    `¡El tiempo vuela en Veredillas efe-eme!! Ya faltan solo [time] para que arranquemos con... ${this.title}.`
                ],
                'ten-minutes': [
                    `¡Solo diez minutos, ${userName}!! Estamos en la recta final para el estreno de... ${this.title}. Asegúrate de tener los cascos bien puestos.`,
                    `¡Esto empieza ya! Faltan 10 minutos exactos para... ${this.title}. Gracias por estar ahí en ${stationName}.`,
                    `¡Cuenta atrás definitiva!! 10 minutos para que el episodio... ${this.title}... vea la luz. ¡Qué emoción!`
                ],
                'one-minute': [
                    `¡UN MINUTO!! ${userName}, prepárate porque en 60 segundos empezamos el estreno de... ${this.title}. ¡Sube el volumen a tope!`,
                    `¡Atención todo el mundo!! Queda solo un minuto para el gran estreno de... ${this.title}. ¡Corre, que empezamos ya mismo!`,
                    `¡Última llamada!! En 60 segundos conectamos con la emisión oficial de... ${this.title}. ¡Gracias por elegir Veredillas efe-eme!`
                ]
            };

            let phrase = "";
            if (trigger !== 'initial' && transitionVariations[trigger as keyof typeof transitionVariations]) {
                const list = transitionVariations[trigger as keyof typeof transitionVariations];
                phrase = list[Math.floor(Math.random() * list.length)];
            } else {
                phrase = variations[Math.floor(Math.random() * variations.length)];
            }

            const cleanTitle = this.title.split('ft.')[0].trim();
            phrase = phrase.replace('[title]', cleanTitle).replace('[time]', timeStr);
            
            try {
                const response = await fetch('/api/tts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: phrase, model: selectedModel })
                });

                if (!response.ok) throw new Error('TTS failed');

                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const ttsAudio = new Audio(url);
                
                // DJ-style transition: Smoothly fade down music even more for clarity
                const originalVolume = this.audio?.volume || 0.5;
                if (this.audio) await this.fadeVolume(this.audio, originalVolume * 0.15, 1000);

                ttsAudio.play();
                ttsAudio.onended = async () => {
                    // Smoothly fade back up
                    if (this.audio) await this.fadeVolume(this.audio, originalVolume, 1200);
                    URL.revokeObjectURL(url);
                };
            } catch (error) {
                console.error('TTS error:', error);
            }
        }

        setupDJControls() {
            if (!this.djBtnPlay || !this.djBtnStop || !this.djBtnSkip || !this.djBtnSearch || !this.djSearchInput) return;

            // Modal logic
            if (this.djTriggerBtn && this.djModalOverlay && this.djCloseBtn) {
                this.djTriggerBtn.addEventListener('click', () => {
                    this.djModalOverlay?.classList.add('open');
                    this.pollStatus();
                    this.djPollInterval = window.setInterval(() => this.pollStatus(), 5000);
                });

                this.djCloseBtn.addEventListener('click', () => {
                    this.djModalOverlay?.classList.remove('open');
                    if (this.djPollInterval) {
                        clearInterval(this.djPollInterval);
                    }
                });

                // Close on click outside the panel
                this.djModalOverlay.addEventListener('click', (e) => {
                    if (e.target === this.djModalOverlay) {
                        this.djModalOverlay?.classList.remove('open');
                        if (this.djPollInterval) {
                            clearInterval(this.djPollInterval);
                        }
                    }
                });
            }

            this.djBtnPlay.addEventListener('click', () => this.apiPlay());
            this.djBtnStop.addEventListener('click', () => this.apiStop());
            this.djBtnSkip.addEventListener('click', () => this.apiSkip());
            if (this.djBtnSync) {
                this.djBtnSync.addEventListener('click', () => this.syncStream());
            }
            
            this.djBtnSearch.addEventListener('click', () => {
                const query = this.djSearchInput?.value || '';
                this.apiSearch(query);
            });

            this.djSearchInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    this.apiSearch(this.djSearchInput?.value || '');
                }
            });
        }

        syncStream() {
            if (this.currentUrl === 'https://radio.veredillasfm.es/stream' && this.audio) {
                // Forzar reconexión sin caché
                this.audio.src = `https://radio.veredillasfm.es/stream?t=${new Date().getTime()}`;
                if (this.isPlaying) {
                    this.audio.play().catch(e => console.error("Error syncing stream:", e));
                }
                
                // Efecto visual en el botón
                if (this.djBtnSync) {
                    const originalText = this.djBtnSync.innerHTML;
                    this.djBtnSync.innerHTML = '✅ Sincronizado';
                    setTimeout(() => {
                        if (this.djBtnSync) this.djBtnSync.innerHTML = originalText;
                    }, 2000);
                }
            }
        }

        async apiPlay() {
            try {
                const res = await fetch('https://radio.veredillasfm.es/api/play', { method: 'POST' });
                if (!res.ok) throw new Error('Network response was not ok');
                this.pollStatus(); // force refresh immediately
            } catch (err) {
                console.error('Error playing DJ radio:', err);
            }
        }

        async apiStop() {
            try {
                const res = await fetch('https://radio.veredillasfm.es/api/stop', { method: 'POST' });
                if (!res.ok) throw new Error('Network response was not ok');
                this.pollStatus(); // force refresh immediately
            } catch (err) {
                console.error('Error stopping DJ radio:', err);
            }
        }

        async apiSkip() {
            try {
                const res = await fetch('https://radio.veredillasfm.es/api/skip', { method: 'POST' });
                if (!res.ok) throw new Error('Network response was not ok');
                this.pollStatus(); // force refresh immediately
            } catch (err) {
                console.error('Error skipping DJ track:', err);
            }
        }

        async apiSearch(query: string) {
            if (!this.djResultsList) return;
            this.djResultsList.innerHTML = '<div style="color: var(--color-text-muted); font-size: 0.85rem; padding: 5px;">Buscando...</div>';
            
            try {
                const url = new URL('https://radio.veredillasfm.es/api/search');
                if (query) url.searchParams.append('q', query);
                
                const res = await fetch(url.toString());
                if (!res.ok) throw new Error('Search failed');
                
                const data = await res.json();
                
                if (data.results && data.results.length > 0) {
                    this.djResultsList.innerHTML = '';
                    data.results.forEach((item: any) => {
                        const div = document.createElement('div');
                        div.className = 'dj-result-item';
                        div.innerHTML = `
                            <span class="dj-result-title" title="${item.title}">${item.title}</span>
                            <div class="dj-result-actions">
                                <button class="dj-action-btn play-now" data-idx="${item.index}" title="Reproducir ahora">▶️</button>
                                <button class="dj-action-btn queue-next" data-idx="${item.index}" title="Cola (Siguiente)">+ Siguiente</button>
                                <button class="dj-action-btn queue-last" data-idx="${item.index}" title="Cola (Final)">+ Final</button>
                            </div>
                        `;
                        this.djResultsList?.appendChild(div);
                    });

                    // Attach events
                    this.djResultsList.querySelectorAll('.play-now').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const idx = parseInt((e.target as HTMLElement).dataset.idx || '0');
                            this.apiQueue(idx, 'play_now');
                        });
                    });
                    this.djResultsList.querySelectorAll('.queue-next').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const idx = parseInt((e.target as HTMLElement).dataset.idx || '0');
                            this.apiQueue(idx, 'queue_next');
                        });
                    });
                    this.djResultsList.querySelectorAll('.queue-last').forEach(btn => {
                        btn.addEventListener('click', (e) => {
                            const idx = parseInt((e.target as HTMLElement).dataset.idx || '0');
                            this.apiQueue(idx, 'queue_last');
                        });
                    });

                } else {
                    this.djResultsList.innerHTML = '<div style="color: var(--color-text-muted); font-size: 0.85rem; padding: 5px;">No se encontraron resultados.</div>';
                }

            } catch (err) {
                console.error('Error searching DJ radio:', err);
                this.djResultsList.innerHTML = '<div style="color: #f87171; font-size: 0.85rem; padding: 5px;">Error al buscar. ¿Servidor Offline?</div>';
            }
        }

        async apiQueue(index: number, action: string) {
            try {
                const res = await fetch('https://radio.veredillasfm.es/api/queue', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index, action })
                });
                if (!res.ok) throw new Error('Queue action failed');
                this.pollStatus(); // force refresh immediately
            } catch (err) {
                console.error(`Error queuing DJ track (${action}):`, err);
            }
        }

        async pollStatus() {
            if (!this.djModalOverlay || !this.djModalOverlay.classList.contains('open')) return;

            try {
                const res = await fetch('https://radio.veredillasfm.es/api/status');
                if (!res.ok) throw new Error('Status failed');
                const data = await res.json();

                if (this.djStatusBadge) {
                    if (data.isPlaying) {
                        this.djStatusBadge.className = 'dj-status-badge online';
                        this.djStatusBadge.textContent = 'ONLINE';
                    } else {
                        this.djStatusBadge.className = 'dj-status-badge offline';
                        this.djStatusBadge.textContent = 'OFFLINE';
                    }
                }

                if (this.djCurrentSong) {
                    if (data.isPlaying && data.currentSongMeta && data.currentSongMeta.title) {
                        this.djCurrentSong.textContent = data.currentSongMeta.title;
                    } else {
                        this.djCurrentSong.textContent = 'Ninguna canción';
                    }
                }
            } catch (err) {
                console.error('Error polling DJ status:', err);
                if (this.djStatusBadge) {
                    this.djStatusBadge.className = 'dj-status-badge offline';
                    this.djStatusBadge.textContent = 'OFFLINE';
                }
                if (this.djCurrentSong) {
                    this.djCurrentSong.textContent = 'Servidor inalcanzable';
                }
            }
        }

        switchGenre(option: HTMLElement) {
            // Update selected visual state
            this.vibeOptions.forEach(opt => opt.classList.remove('selected'));
            option.classList.add('selected');

            const newUrl = option.dataset.value;
            const genreName = option.textContent || "Música";
            
            // Update trigger text
            if(this.selectionText) this.selectionText.textContent = genreName;
            
            if (newUrl && this.audio) {
                this.currentUrl = newUrl;
                
                // Anti-cache para Veredillas FM (forzar directo absoluto)
                if (newUrl === 'https://radio.veredillasfm.es/stream') {
                    this.audio.src = `${newUrl}?t=${new Date().getTime()}`;
                } else {
                    this.audio.src = newUrl;
                }
                
                // DJ Panel Trigger Button visibility logic
                if (newUrl === 'https://radio.veredillasfm.es/stream' && this.djTriggerBtn) {
                    this.djTriggerBtn.style.display = 'flex';
                } else if (this.djTriggerBtn) {
                    this.djTriggerBtn.style.display = 'none';
                    // If modal was open, close it
                    if (this.djModalOverlay && this.djModalOverlay.classList.contains('open')) {
                        this.djModalOverlay.classList.remove('open');
                        if (this.djPollInterval) {
                            clearInterval(this.djPollInterval);
                        }
                    }
                }

                // Save selection to localStorage
                localStorage.setItem('veredillas_last_station', newUrl);
                
                if (this.isPlaying) {
                     if(this.musicLabel) this.musicLabel.textContent = `Conectando con ${genreName}...`;
                     this.audio.play().then(() => {
                         if(this.musicLabel) this.musicLabel.textContent = `Escuchando ${genreName}`;
                     }).catch(e => {
                         console.error("Switch play failed:", e);
                         this.isPlaying = false;
                         this.musicBtn?.classList.remove('playing');
                         this.updateVolumeVisibility();
                     });
                } else {
                    if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
                }
            }
        }

        updateVolumeIcon(volume: number) {
            const waves = this.el.querySelector('.volume-waves') as HTMLElement;
            const outerWaves = this.el.querySelector('.volume-waves-outer') as HTMLElement;
            
            if(!waves || !outerWaves) return;

            if (volume === 0) {
                waves.style.opacity = '0';
                outerWaves.style.opacity = '0';
            } else if (volume < 0.5) {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '0';
            } else {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '1';
            }
        }

        updateVolumeVisibility() {
            if (this.isPlaying) {
                this.volumeContainer?.classList.add('show');
            } else {
                this.volumeContainer?.classList.remove('show');
            }
        }

        toggleMusic() {
            if (!this.audio || !this.musicBtn) return;

            if (this.isPlaying) {
                this.audio.pause();
                this.isPlaying = false;
                this.musicBtn.classList.remove('playing');
                const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
            } else {
                if(this.musicLabel) this.musicLabel.textContent = "Conectando...";
                
                this.audio.play().then(() => {
                    this.isPlaying = true;
                    this.musicBtn!.classList.add('playing');
                    const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                    if(this.musicLabel) this.musicLabel!.textContent = `Escuchando ${genreName}`;
                    
                    // Trigger TTS when music starts for the first time
                    this.playTTS();
                }).catch(e => {
                    console.error("Audio play failed:", e);
                    this.isPlaying = false;
                    this.musicBtn!.classList.remove('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = "No disponible";
                }).finally(() => {
                    this.updateVolumeVisibility();
                });
            }
            this.updateVolumeVisibility();
        }

        async finish() {
            if(this.interval) clearInterval(this.interval);
            
            if (this.audio && this.isPlaying) {
                const fadeAudio = setInterval(() => {
                    if (this.audio && this.audio.volume > 0.05) {
                        this.audio.volume -= 0.05;
                    } else {
                        clearInterval(fadeAudio);
                        this.audio?.pause();
                    }
                }, 100);
            }
            
            // @ts-ignore
            import('canvas-confetti').then(({ default: confetti }) => {
                 this.fireConfetti(confetti);
            });
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.transition = 'opacity 1s ease-out, transform 1s ease-out';
                countdownWrapper.style.opacity = '0';
                countdownWrapper.style.transform = 'scale(0.95)';
                
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                
                setTimeout(() => {
                    playerWrapper.style.opacity = '1';
                    setTimeout(() => {
                         countdownWrapper.style.display = 'none';
                         document.dispatchEvent(new CustomEvent('premiere-started'));
                    }, 1000);
                }, 100);
            } else {
                 window.location.reload();
            }
        }

        instantFinish() {
            if(this.interval) clearInterval(this.interval);
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.display = 'none';
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                playerWrapper.style.opacity = '1';
                playerWrapper.style.transition = 'none';
                document.dispatchEvent(new CustomEvent('premiere-started'));
            } else {
                 window.location.reload();
            }
        }

        fireConfetti(confetti: any) {
            const count = 200;
            const defaults = { origin: { y: 0.7 } };

            function fire(particleRatio: number, opts: any) {
                confetti({
                    ...defaults,
                    ...opts,
                    particleCount: Math.floor(count * particleRatio)
                });
            }

            fire(0.25, { spread: 26, startVelocity: 55 });
            fire(0.2, { spread: 60 });
            fire(0.35, { spread: 100, decay: 0.91, scalar: 0.8 });
            fire(0.1, { spread: 120, startVelocity: 25, decay: 0.92, scalar: 1.2 });
            fire(0.1, { spread: 120, startVelocity: 45 });
        }
    }

    document.addEventListener('astro:page-load', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });

    // Fallback for non-view-transitions
    document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });
</script>
