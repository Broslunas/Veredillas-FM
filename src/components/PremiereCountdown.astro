<script>
    class PremiereCountdown {
        el: HTMLElement;
        targetDate: Date;
        daysEl: HTMLElement | null;
        hoursEl: HTMLElement | null;
        minutesEl: HTMLElement | null;
        secondsEl: HTMLElement | null;
        wrapper: HTMLElement | null;
        interval: number | undefined;
        audio: HTMLAudioElement | null;
        musicBtn: HTMLElement | null;
        musicLabel: HTMLElement | null;
        vibeSelectWrapper: HTMLElement | null;
        vibeSelectTrigger: HTMLElement | null;
        vibeOptions: NodeListOf<HTMLElement>;
        selectionText: HTMLElement | null;
        volumeSlider: HTMLInputElement | null;
        volumeContainer: HTMLElement | null;
        isPlaying: boolean = false;
        currentUrl: string;
        hasPlayedTTS: boolean = false;
        hasPlayedTenMinuteTTS: boolean = false;
        hasPlayedOneMinuteTTS: boolean = false;
        lastDays: number | null = null;
        lastHours: number | null = null;
        lastMinutes: number | null = null;
        title: string;

        // DJ Panel elements
        djModalOverlay: HTMLElement | null;
        djTriggerBtn: HTMLElement | null;
        djCloseBtn: HTMLElement | null;
        djPanelWrapper: HTMLElement | null;
        djStatusBadge: HTMLElement | null;
        djCurrentSong: HTMLElement | null;
        djBtnPlay: HTMLElement | null;
        djBtnStop: HTMLElement | null;
        djBtnSkip: HTMLElement | null;
        djBtnSync: HTMLElement | null;
        djSearchInput: HTMLInputElement | null;
        djBtnSearch: HTMLElement | null;
        djResultsList: HTMLElement | null;
        djPollInterval: number | undefined;

        // Settings
        ttsSettings = {
            enabled: true,
            voice: 'aura-2-selena-es',
            alerts: {
                initial: true,
                'hour-change': true,
                'ten-minutes': true,
                'one-minute': true
            }
        };

        constructor(el: HTMLElement) {
            this.el = el;
            this.targetDate = new Date(el.dataset.target || '');
            this.title = el.dataset.title || 'el estreno';
            this.daysEl = el.querySelector('.days');
            this.hoursEl = el.querySelector('.hours');
            this.minutesEl = el.querySelector('.minutes');
            this.secondsEl = el.querySelector('.seconds');
            this.wrapper = el.querySelector('.premiere-countdown');
            this.audio = el.querySelector('.waiting-music');
            this.musicBtn = el.querySelector('.music-toggle-btn');
            this.musicLabel = el.querySelector('.music-label');
            
            // Custom Select Elements
            this.vibeSelectWrapper = el.querySelector('.custom-select-wrapper');
            this.vibeSelectTrigger = el.querySelector('.custom-select-trigger');
            this.vibeOptions = el.querySelectorAll('.custom-option');
            this.selectionText = el.querySelector('.selection');
            this.volumeSlider = el.querySelector('.volume-slider');
            this.volumeContainer = el.querySelector('.vertical-volume-container');

            this.currentUrl = "https://radio.veredillasfm.es/stream"; // Default

            // DJ Panel elements
            this.djModalOverlay = el.querySelector('#dj-modal-overlay');
            this.djTriggerBtn = el.querySelector('#dj-trigger-btn');
            this.djCloseBtn = el.querySelector('#dj-close-btn');
            this.djPanelWrapper = el.querySelector('.dj-panel-wrapper');
            this.djStatusBadge = el.querySelector('#dj-status-badge');
            this.djCurrentSong = el.querySelector('#dj-current-song');
            this.djBtnPlay = el.querySelector('#dj-btn-play');
            this.djBtnStop = el.querySelector('#dj-btn-stop');
            this.djBtnSkip = el.querySelector('#dj-btn-skip');
            this.djBtnSync = el.querySelector('#dj-btn-sync');
            this.djSearchInput = el.querySelector('#dj-search-input');
            this.djBtnSearch = el.querySelector('#dj-btn-search');
            this.djResultsList = el.querySelector('#dj-results-list');

            this.setupDJControls();
            
            this.loadSettings();
            this.setupAudio();
            this.setupVoiceSettings();
            this.start();
            this.loadLastStation();
        }

        loadSettings() {
            const saved = localStorage.getItem('veredillas_tts_settings');
            if (saved) {
                try {
                    this.ttsSettings = JSON.parse(saved);
                } catch(e) { console.error("Error loading TTS settings", e); }
            }
            this.applySettingsToUI();
        }

        saveSettings() {
            localStorage.setItem('veredillas_tts_settings', JSON.stringify(this.ttsSettings));
        }

        setupVoiceSettings() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            
            toggleBtn?.addEventListener('click', () => {
                this.ttsSettings.enabled = !this.ttsSettings.enabled;
                this.saveSettings();
                this.applySettingsToUI();
                
                // Audio feedback: play a short test phrase or just toggle
                if (this.ttsSettings.enabled) {
                    this.playTTS('initial', true);
                }
            });
        }

        applySettingsToUI() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            if (toggleBtn) {
                if (this.ttsSettings.enabled) {
                    toggleBtn.classList.add('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: ON');
                } else {
                    toggleBtn.classList.remove('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: OFF');
                }
            }
        }

        loadLastStation() {
            const lastUrl = localStorage.getItem('veredillas_last_station');
            if (lastUrl) {
                const optionsArray = Array.from(this.vibeOptions);
                const foundOption = optionsArray.find(opt => opt.dataset.value === lastUrl);
                if (foundOption) {
                    this.switchGenre(foundOption);
                }
            }
        }

        update(isInitial = false) {
            const now = new Date();
            const diff = this.targetDate.getTime() - now.getTime();

            if (diff <= 0) {
                if (isInitial) {
                    this.instantFinish();
                } else {
                    this.finish();
                }
                return;
            }

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            // Check for transitions (day or hour change)
            if (!isInitial && this.isPlaying) {
                if (this.lastDays !== null && days < this.lastDays) {
                    this.playTTS('hour-change'); // We consider day change as a dramatic hour change
                } else if (this.lastHours !== null && hours < this.lastHours) {
                    this.playTTS('hour-change');
                } else if (days === 0 && hours === 0 && minutes === 9 && seconds === 59 && !this.hasPlayedTenMinuteTTS) {
                    this.hasPlayedTenMinuteTTS = true;
                    this.playTTS('ten-minutes');
                } else if (days === 0 && hours === 0 && minutes === 0 && seconds === 59 && !this.hasPlayedOneMinuteTTS) {
                    this.hasPlayedOneMinuteTTS = true;
                    this.playTTS('one-minute');
                }
            }

            // Update trackers
            this.lastDays = days;
            this.lastHours = hours;
            this.lastMinutes = minutes;

            if(this.daysEl) this.daysEl.textContent = String(days).padStart(2, '0');
            if(this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
            if(this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
            if(this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');
        }

        start() {
            this.update(true); // Pass true to indicate initial check
            if (this.targetDate.getTime() - new Date().getTime() > 0) {
                this.interval = window.setInterval(() => this.update(false), 1000);
            }
        }

        setupAudio() {
            if (!this.musicBtn || !this.audio) {
                console.warn('Music elements not found', { btn: this.musicBtn, audio: this.audio });
                return;
            }

            this.musicBtn.addEventListener('click', (e) => {
                e.preventDefault();
                this.toggleMusic();
            });

            // Custom Select Logic
            if(this.vibeSelectTrigger && this.vibeSelectWrapper) {
                this.vibeSelectTrigger.addEventListener('click', () => {
                    this.vibeSelectWrapper?.classList.toggle('open');
                });
                
                // Close on click outside
                document.addEventListener('click', (e) => {
                    if(this.vibeSelectWrapper && !this.vibeSelectWrapper.contains(e.target as Node)) {
                        this.vibeSelectWrapper.classList.remove('open');
                    }
                });
            }

            this.vibeOptions.forEach(option => {
                option.addEventListener('click', () => {
                   this.switchGenre(option);
                   this.vibeSelectWrapper?.classList.remove('open');
                });
            });
            
            this.audio.volume = 0.5;
            
            // Volume Slider Logic
            if(this.volumeSlider) {
                this.volumeSlider.addEventListener('input', (e) => {
                    const val = parseFloat((e.target as HTMLInputElement).value);
                    if(this.audio) this.audio.volume = val;
                    this.updateVolumeIcon(val);
                });
            }
            
            // Handle audio errors
            this.audio.addEventListener('error', (e) => {
                console.error('Audio stream error:', this.audio?.error);
                if(this.musicLabel) this.musicLabel.textContent = "Error de conexión";
                this.isPlaying = false;
                this.musicBtn?.classList.remove('playing');
                this.updateVolumeVisibility();
            });
        }

        async fadeVolume(audio: HTMLAudioElement, target: number, duration: number) {
            const startVolume = audio.volume;
            const diff = target - startVolume;
            const startTime = performance.now();

            return new Promise<void>(resolve => {
                const tick = (now: number) => {
                    const elapsed = now - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    audio.volume = startVolume + diff * progress;

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    } else {
                        resolve();
                    }
                };
                requestAnimationFrame(tick);
            });
        }

        getTimeRemainingStr(): string {
            const now = new Date();
            const diff = this.targetDate.getTime() - now.getTime();
            if (diff <= 0) return "apenas unos segundos";

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

            // Conversational formatting
            if (days === 0 && hours === 0) {
                if (minutes < 1) return "nada y menos... menos de un minuto";
                if (minutes === 1) return "apenas un minuto";
                if (minutes < 5) return "muy poquito... apenas cinco minutos";
                return `unos ${minutes} minutos`;
            }

            const parts: string[] = [];
            if (days > 0) parts.push(`${days} día${days > 1 ? 's' : ''}`);
            if (hours > 0) parts.push(`${hours} hora${hours > 1 ? 's' : ''}`);
            if (minutes > 1) parts.push(`${minutes} minutos`);

            if (parts.length === 0) return "un ratito";
            if (parts.length === 1) return parts[0];
            if (parts.length === 2) return `${parts[0]} y ${parts[1]}`;
            
            const lastPart = parts.pop();
            return `${parts.join(', ')} y ${lastPart}`;
        }

