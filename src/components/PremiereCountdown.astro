---
interface Props {
  targetDate: Date;
  title: string;
}

const { targetDate, title } = Astro.props;
const isoDate = targetDate.toISOString();
---

<div class="premiere-countdown" data-target={isoDate} data-title={title}>
    <div class="countdown-content">
        <div class="badge">Estreno Oficial</div>
        <h2>{title}</h2>
        
        <div class="timer">
            <div class="time-unit">
                <span class="value days">00</span>
                <span class="label">Días</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value hours">00</span>
                <span class="label">Hrs</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value minutes">00</span>
                <span class="label">Min</span>
            </div>
            <span class="separator">:</span>
            <div class="time-unit">
                <span class="value seconds">00</span>
                <span class="label">Seg</span>
            </div>
        </div>
        
        <div class="music-player-wrapper">
            <!-- Grid-based layout for perfect centering (maintained from fix) -->
            <div class="player-grid">
                <!-- Left spacing to balance the volume bar -->
                <div class="grid-side grid-left"></div>
                
                <!-- Center Column: Everything strictly centered -->
                <div class="grid-center">
                    <div class="custom-select-wrapper">
                        <div class="custom-select-trigger" tabindex="0">
                            <span class="selection">Los 40 Urban</span>
                            <div class="arrow"></div>
                        </div>
                        <div class="custom-options">
                            <div class="custom-option" data-value="https://27833.live.streamtheworld.com/LOS40_URBAN.mp3">Los 40 Urban</div>
                            <div class="custom-option selected" data-value="https://stream.zeno.fm/0r0xa792kwzuv">Lofi Chill</div>
                            <div class="custom-option" data-value="https://s1.we4stream.com:2020/stream/locaurban">Loca Urban</div>
                            <div class="custom-option" data-value="https://28503.live.streamtheworld.com/LOS40_CAT.mp3">Los 40</div>
                            <div class="custom-option" data-value="https://listen.technobase.fm/tunein-mp3">Techno</div>
                            <div class="custom-option" data-value="https://sunaer-stream.com:7113/LA_MUEVE_CADENA_HD">La MUEVE FM</div>
                            <div class="custom-option" data-value="https://stream-177.zeno.fm/gwmx5szrc0hvv?zt=eyJhbGciOiJIUzI1NiJ9.eyJzdHJlYW0iOiJnd214NXN6cmMwaHZ2IiwiaG9zdCI6InN0cmVhbS0xNzcuemVuby5mbSIsInJ0dGwiOjUsImp0aSI6Ild6UHlGOHdzUkRLeVRHalhZY004SlEiLCJpYXQiOjE3NzUyMTIwMjEsImV4cCI6MTc3NTIxMjA4MX0.NrAFqkqJUVyckzTl0C0RqzdCDxEkgQxGfBkS47sENnQ">Rock FM</div>
                            <div class="custom-option" data-value="http://streaming.indalteco.net:8002/dial.mp3">Cadena Dial</div>
                        </div>
                    </div>

                    <button class="music-btn music-toggle-btn" aria-label="Activar música de fondo">
                        <div class="equalizer">
                            <span class="bar bar-1"></span>
                            <span class="bar bar-2"></span>
                            <span class="bar bar-3"></span>
                            <span class="bar bar-4"></span>
                        </div>
                        <span class="music-label">Activar Música</span>
                    </button>
                    
                    <audio class="waiting-music" preload="none" loop>
                        <source src="https://27833.live.streamtheworld.com/LOS40_URBAN.mp3" type="audio/mpeg">
                    </audio>
                </div>

                <!-- Right Column: Vertical Volume Bar -->
                <div class="grid-side grid-right">
                    <div class="vertical-volume-container">
                        <div class="volume-slider-vertical-wrapper">
                            <input type="range" class="volume-slider vertical" min="0" max="1" step="0.01" value="0.5" aria-label="Volumen">
                        </div>
                        <svg class="volume-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path class="volume-waves" d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path class="volume-waves-outer" d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                    </div>
                </div>
            </div>
        </div>

        <div class="status-message">Esperando que llegue la hora...</div>
    </div>
</div>

<style>
    .premiere-countdown {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--color-surface) 0%, #000 100%);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--spacing-2xl);
        text-align: center;
        min-height: 400px;
        position: relative;
        overflow: hidden;
    }

    .premiere-countdown::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
        pointer-events: none;
    }

    /* Reverted Badge Styles */
    .badge {
        background: var(--color-primary);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: bold;
        margin-bottom: var(--spacing-md);
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.5);
    }

    /* Reverted H2 (Episode Title) Styles */
    h2 {
        font-size: clamp(1.5rem, 5vw, 2.5rem);
        margin-bottom: var(--spacing-sm);
        background: linear-gradient(white, #aaa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .subtitle {
        color: var(--color-text-muted);
        font-size: 1.1rem;
        margin-bottom: var(--spacing-xl);
    }

    /* Reverted Timer Styles */
    .timer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-sm);
        font-variant-numeric: tabular-nums;
        margin-bottom: var(--spacing-xl);
    }

    .time-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .value {
        font-size: 2.5rem;
        font-weight: bold;
        line-height: 1;
        color: var(--color-text-main);
    }

    .label {
        font-size: 0.7rem;
        text-transform: uppercase;
        color: var(--color-text-muted);
        margin-top: 5px;
        letter-spacing: 0.05em;
    }

    .separator {
        font-size: 2rem;
        color: var(--color-text-muted);
        margin-bottom: 20px; /* Align with numbers */
    }

    /* Reverted Status Message Styles */
    .status-message {
        font-size: 0.9rem;
        color: var(--color-primary);
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Music Player Layout Improvements (Maintained Centering Logic) */
    .music-player-wrapper {
        width: 100%;
        max-width: 600px;
        margin: 1rem auto 0;
    }

    .player-grid {
        display: grid;
        grid-template-columns: 80px 1fr 80px; 
        align-items: center;
        gap: 1rem;
    }

    .grid-center {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
    }

    .grid-side {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 80px;
    }

    /* Vertical Volume Bar (Fixed logic) */
    .vertical-volume-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 15px 10px;
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: scale(0.9) translateX(10px);
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .vertical-volume-container.show {
        opacity: 1;
        visibility: visible;
        pointer-events: all;
        transform: scale(1) translateX(0);
    }

    .volume-slider-vertical-wrapper {
        height: 100px;
        width: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .volume-slider.vertical {
        -webkit-appearance: none;
        width: 100px;
        height: 4px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        outline: none;
        transform: rotate(-90deg);
        cursor: pointer;
        position: absolute;
    }

    .volume-slider.vertical::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 14px;
        height: 14px;
        background: white;
        border-radius: 50%;
        cursor: pointer;
    }

    .volume-icon {
        color: var(--color-text-muted);
    }

    /* Dropdown Styles */
    .custom-select-wrapper {
        position: relative;
        user-select: none;
        width: 100%;
        max-width: 280px;
        z-index: 50;
    }

    .custom-select-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 10px 18px;
        border-radius: 100px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(10px);
    }

    .selection {
        font-size: 0.9rem;
        color: var(--color-text-main);
    }

    .arrow {
        width: 8px;
        height: 8px;
        border-bottom: 2px solid rgba(255,255,255,0.5);
        border-right: 2px solid rgba(255,255,255,0.5);
        transform: rotate(45deg);
        transition: all 0.3s ease;
        margin-top: -4px;
    }

    .custom-select-wrapper.open .arrow {
        transform: rotate(-135deg);
        margin-top: 4px;
    }

    .custom-options {
        position: absolute;
        bottom: calc(100% + 12px);
        left: 0;
        right: 0;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        z-index: 100;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(10px);
        transition: all 0.3s;
        backdrop-filter: blur(20px);
        max-height: 200px;
        overflow-y: auto;
    }

    .custom-select-wrapper.open .custom-options {
        opacity: 1;
        visibility: visible;
        pointer-events: all;
        transform: translateY(0);
    }

    .custom-option {
        padding: 12px 20px;
        cursor: pointer;
        color: rgba(255,255,255,0.7);
        font-size: 0.9rem;
    }

    .custom-option:hover {
        background: rgba(139, 92, 246, 0.15);
        color: white;
    }

    .custom-option.selected {
        background: var(--color-primary);
        color: white;
    }

    .music-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 10px 20px;
        border-radius: 100px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--color-text-muted);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .music-btn.playing {
        background: rgba(139, 92, 246, 0.15);
        border-color: var(--color-primary);
        color: white;
    }

    .equalizer {
        display: flex;
        align-items: flex-end;
        height: 12px;
        gap: 2px;
    }

    .bar {
        width: 3px;
        background: currentColor;
        border-radius: 1px;
        animation: eq 1s infinite ease-in-out;
        animation-play-state: paused;
    }

    .music-btn.playing .bar {
        animation-play-state: running;
    }

    .bar-1 { height: 6px; }
    .bar-2 { height: 12px; }
    .bar-3 { height: 8px; }
    .bar-4 { height: 5px; }

    @keyframes eq {
        0%, 100% { height: 4px; }
        50% { height: 12px; }
    }

    @media (max-width: 630px) {
        .player-grid {
            grid-template-columns: 1fr;
            justify-items: center;
        }
        .grid-left { display: none; }
        .grid-side { width: auto; }
        .vertical-volume-container {
            flex-direction: row;
            padding: 8px 16px;
        }
        .volume-slider-vertical-wrapper {
            height: 30px;
            width: 100px;
        }
        .volume-slider.vertical {
            transform: none;
            width: 100%;
            position: relative;
        }
    }
</style>

<script>
    class PremiereCountdown {
        el: HTMLElement;
        targetDate: Date;
        daysEl: HTMLElement | null;
        hoursEl: HTMLElement | null;
        minutesEl: HTMLElement | null;
        secondsEl: HTMLElement | null;
        wrapper: HTMLElement | null;
        interval: number | undefined;
        audio: HTMLAudioElement | null;
        musicBtn: HTMLElement | null;
        musicLabel: HTMLElement | null;
        vibeSelectWrapper: HTMLElement | null;
        vibeSelectTrigger: HTMLElement | null;
        vibeOptions: NodeListOf<HTMLElement>;
        selectionText: HTMLElement | null;
        volumeSlider: HTMLInputElement | null;
        volumeContainer: HTMLElement | null;
        isPlaying: boolean = false;
        currentUrl: string;
        hasPlayedTTS: boolean = false;

        constructor(el: HTMLElement) {
            this.el = el;
            this.targetDate = new Date(el.dataset.target || '');
            this.title = el.dataset.title || 'el estreno';
            this.daysEl = el.querySelector('.days');
            this.hoursEl = el.querySelector('.hours');
            this.minutesEl = el.querySelector('.minutes');
            this.secondsEl = el.querySelector('.seconds');
            this.wrapper = el.querySelector('.premiere-countdown');
            this.audio = el.querySelector('.waiting-music');
            this.musicBtn = el.querySelector('.music-toggle-btn');
            this.musicLabel = el.querySelector('.music-label');
            
            // Custom Select Elements
            this.vibeSelectWrapper = el.querySelector('.custom-select-wrapper');
            this.vibeSelectTrigger = el.querySelector('.custom-select-trigger');
            this.vibeOptions = el.querySelectorAll('.custom-option');
            this.selectionText = el.querySelector('.selection');
            this.volumeSlider = el.querySelector('.volume-slider');
            this.volumeContainer = el.querySelector('.vertical-volume-container');

            this.currentUrl = "https://27833.live.streamtheworld.com/LOS40_URBAN.mp3"; // Default
            
            this.setupAudio();
            this.start();
            this.loadLastStation();
        }

        loadLastStation() {
            const lastUrl = localStorage.getItem('veredillas_last_station');
            if (lastUrl) {
                const optionsArray = Array.from(this.vibeOptions);
                const foundOption = optionsArray.find(opt => opt.dataset.value === lastUrl);
                if (foundOption) {
                    this.switchGenre(foundOption);
                }
            }
        }

        update(isInitial = false) {
            const now = new Date();
            const diff = this.targetDate.getTime() - now.getTime();

            if (diff <= 0) {
                if (isInitial) {
                    this.instantFinish();
                } else {
                    this.finish();
                }
                return;
            }

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((diff % (1000 * 60)) / 1000);

            if(this.daysEl) this.daysEl.textContent = String(days).padStart(2, '0');
            if(this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
            if(this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
            if(this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');
        }

        start() {
            this.update(true); // Pass true to indicate initial check
            if (this.targetDate.getTime() - new Date().getTime() > 0) {
                this.interval = window.setInterval(() => this.update(false), 1000);
            }
        }

        setupAudio() {
            if (!this.musicBtn || !this.audio) {
                console.warn('Music elements not found', { btn: this.musicBtn, audio: this.audio });
                return;
            }

            this.musicBtn.addEventListener('click', (e) => {
                e.preventDefault();
                this.toggleMusic();
            });

            // Custom Select Logic
            if(this.vibeSelectTrigger && this.vibeSelectWrapper) {
                this.vibeSelectTrigger.addEventListener('click', () => {
                    this.vibeSelectWrapper?.classList.toggle('open');
                });
                
                // Close on click outside
                document.addEventListener('click', (e) => {
                    if(this.vibeSelectWrapper && !this.vibeSelectWrapper.contains(e.target as Node)) {
                        this.vibeSelectWrapper.classList.remove('open');
                    }
                });
            }

            this.vibeOptions.forEach(option => {
                option.addEventListener('click', () => {
                   this.switchGenre(option);
                   this.vibeSelectWrapper?.classList.remove('open');
                });
            });
            
            this.audio.volume = 0.5;
            
            // Volume Slider Logic
            if(this.volumeSlider) {
                this.volumeSlider.addEventListener('input', (e) => {
                    const val = parseFloat((e.target as HTMLInputElement).value);
                    if(this.audio) this.audio.volume = val;
                    this.updateVolumeIcon(val);
                });
            }
            
            // Handle audio errors
            this.audio.addEventListener('error', (e) => {
                console.error('Audio stream error:', this.audio?.error);
                if(this.musicLabel) this.musicLabel.textContent = "Error de conexión";
                this.isPlaying = false;
                this.musicBtn?.classList.remove('playing');
                this.updateVolumeVisibility();
            });
        }

        async fadeVolume(audio: HTMLAudioElement, target: number, duration: number) {
            const startVolume = audio.volume;
            const diff = target - startVolume;
            const startTime = performance.now();

            return new Promise<void>(resolve => {
                const tick = (now: number) => {
                    const elapsed = now - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    audio.volume = startVolume + diff * progress;

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    } else {
                        resolve();
                    }
                };
                requestAnimationFrame(tick);
            });
        }

        getTimeRemainingStr(): string {
            const now = new Date();
            const diff = this.targetDate.getTime() - now.getTime();
            if (diff <= 0) return "apenas unos segundos";

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

            const parts: string[] = [];
            if (days > 0) parts.push(`${days} día${days > 1 ? 's' : ''}`);
            if (hours > 0) parts.push(`${hours} hora${hours > 1 ? 's' : ''}`);
            if (minutes > 0) parts.push(`${minutes} minuto${minutes > 1 ? 's' : ''}`);

            if (parts.length === 0) return "menos de un minuto";
            if (parts.length === 1) return parts[0];
            if (parts.length === 2) return `${parts[0]} y ${parts[1]}`;
            
            const lastPart = parts.pop();
            return `${parts.join(', ')} y ${lastPart}`;
        }

        async playTTS() {
            if (this.hasPlayedTTS) return;
            this.hasPlayedTTS = true;

            const models = [
                'aura-2-selena-es', 'aura-2-javier-es', 'aura-2-nestor-es', 
                'aura-2-carina-es', 'aura-2-alvaro-es', 'aura-2-celeste-es'
            ];
            
            const selectedModel = models[Math.floor(Math.random() * models.length)];
            const timeStr = this.getTimeRemainingStr();
            const stationName = this.selectionText?.textContent || "la radio";
            
            // --- PERSONALIZATION DATA ---
            let userName = "amigo";
            let userLevel = "oyente";
            let cardsCount = 0;
            let totalHours = 0;
            let currentListeners = document.getElementById('listener-number')?.textContent || "varios";
            
            try {
                // User Session
                const sessionStr = localStorage.getItem('user-session');
                if (sessionStr) {
                    const session = JSON.parse(sessionStr);
                    if (session.name) userName = session.name.split(' ')[0];
                }

                // Cards (Cromos)
                const cardsStr = localStorage.getItem('veredillas_unlocked_cards') || '[]';
                cardsCount = JSON.parse(cardsStr).length;

                // Listening Time
                const seconds = parseInt(localStorage.getItem('veredillas_total_listening_time') || '0');
                totalHours = Math.round(seconds / 3600);

                // Levels (Approximate logic from gamification.ts)
                if (seconds > 90000) userLevel = "una auténtica leyenda";
                else if (seconds > 54000) userLevel = "un adicto a Veredillas";
                else if (seconds > 21600) userLevel = "un gran fan";
                else if (seconds > 7200) userLevel = "un seguidor fiel";
            } catch(e) { console.error("Error parsing user data for TTS", e); }

            const variations = [
                `¡Muy buenas, ${userName}! Qué alegría saludarte. Estás escuchando ${stationName} en Veredillas FM. Te damos la bienvenida al estreno de [title]. Estamos a solo [time] de arrancar. ¡Quédate con nosotros!`,
                `Sintonizas ${stationName} para amenizar la espera, ${userName}. En apenas [time] daremos paso a la emisión oficial de [title]. Ahora mismo hay ${currentListeners} personas conectadas con nosotros.`,
                `¡Hola, hola! Qué bueno tenerte al otro lado en ${stationName}, ${userName}. Falta muy poquito, exactamente [time] para que empiece [title]. ¡Sube el volumen y disfruta de Veredillas FM!`,
                `¡Atención audiencia! En tan solo [time] el estreno de [title] será una realidad. ${userName}, tú que ya eres ${userLevel}, sabes que lo bueno se hace esperar. Sigue con la sintonía de ${stationName}.`,
                `Estás en el lugar exacto, escuchando ${stationName}. En [time] abrimos micrófonos para el gran estreno de [title]. Por cierto, ${userName}, llevas ya ${totalHours} horas disfrutando con nosotros. ¡Gracias por tu fidelidad!`,
                `¡Bienvenidos a Veredillas FM! Disfruta de ${stationName} mientras esperamos. Faltan apenas [time] para el estreno de [title]. Somos ya ${currentListeners} oyentes esperando el momento.`,
                `¿Preparado para lo que viene en Veredillas FM? Estás escuchando ${stationName}. ${userName}, en solo [time] empezamos con [title].`,
                `Veredillas FM, la radio del instituto. Gracias por elegir ${stationName}, ${userName}. El estreno de [title] arranca en apenas [time].`,
                `¡No desconectes ni un segundo de ${stationName}! En [time] lanzamos [title]. ${userName}, prepárate en Veredillas FM porque esto empieza ya mismo.`,
                `Hola de nuevo, ${userName}. Quédate por aquí con ${stationName} porque en [time] el estreno de [title] entrará en el aire por todo lo alto.`,
                `¡Atención comunidad! En apenas [time] daremos paso a [title]. ${userName}, con tus ${cardsCount} cromos coleccionados, seguro que no te quieres perder este episodio. ¡Disfruta de ${stationName}!`,
                `¡Sube el audio de ${stationName}! En solo [time] el estreno de [title] va a sonar aquí mismo, en Veredillas FM. ${userName}, prepárate para disfrutar.`,
                `Estamos a un suspiro. Solo [time] para el estreno oficial de [title]. Sigue en sintonía de ${stationName}, como buen ${userLevel} que eres.`,
                `¡Bienvenidos todos a Veredillas FM! Gracias por acompañarnos en ${stationName}, ${userName}. Faltan [time] para que empiece el show oficial de [title].`,
                `Veredillas FM siempre contigo en ${stationName}. En solo [time] comenzamos con [title], ${userName}. ¡La espera va a valer la pena!`,
                `¡Ya casi lo tenemos! Solo [time] nos separan en ${stationName} del esperado estreno de [title]. Somos ${currentListeners} preparados para el lanzamiento.`,
                `¡Hola, ${userName}! Muchísimas gracias por elegir ${stationName}. En [time] el episodio [title] se hará realidad para todos vosotros en Veredillas FM.`,
                `¡Ey! No te vayas muy lejos de ${stationName}. En [time] el programa [title] entra en el aire con mucha fuerza. Por cierto, ${userName}, nos encanta que seas un ${userLevel} en nuestra comunidad.`,
                `¡Atención! Estamos de estreno absoluto en Veredillas FM. Disfruta de ${stationName}. En apenas [time] arrancamos con [title].`,
                `¡Sintonía perfecta la que tenemos hoy en ${stationName}! En [time] [title] te espera aquí, en Veredillas FM, con ${currentListeners} oyentes en directo.`,
                `¡Qué bien se siente la energía en ${stationName}, ${userName}! En solo [time] el estreno de [title] cobrará vida en tus oídos.`,
                `¡Bienvenidos al canal de audio de Veredillas FM! En ${stationName}, en tan solo [time] [title] dará comienzo. Ponte cómodo y disfruta.`,
                `¡Prepárate para la mejor radio escolar! Disfruta de ${stationName}. En [time] llega el gran estreno de [title], el programa que todos estábamos esperando.`,
                `¡Hola a todos los oyentes fieles de ${stationName}! En [time] lanzamos lo nuevo de [title]. ${userName}, sigue coleccionando cromos, ¡ya llevas ${cardsCount}!`,
                `¡Veredillas FM al habla en ${stationName}! En apenas [time] [title] empezará a sonar por todo lo alto para nuestros ${currentListeners} oyentes.`,
                `¡Oye, ${userName}! Gracias por sintonizar ${stationName}. Faltan solo [time] para dar comienzo a [title]. Disfruta de la música.`,
                `¡Qué ganas de pulsar el play en Veredillas FM! En ${stationName} la espera es mejor. ${userName}, en solo [time] [title] estará disponible.`,
                `¡Atención audiencia de ${stationName}! En exactamente [time] el estreno de [title] se asomará a tus altavoces con la mejor calidad.`,
                `¡Sube la radio al máximo! Estás escuchando ${stationName}. En solo [time] [title] entra en acción para ${userName} y todos nosotros.`,
                `¡Hola de nuevo! Estamos en la recta final en ${stationName}. El gran estreno de [title] empieza en apenas [time]. ¡No te lo pierdas!`,
                `¡Veredillas FM, la radio que nos une! Disfruta de ${stationName}. En [time] arranca el esperado estreno de [title] para toda la comunidad.`,
                `¡Prepárate junto a ${stationName}, ${userName}! En solo [time] daremos luz verde a [title]. ¡Estás invitado a escucharlo antes que nadie!`,
                `¡No te lo vas a creer! En apenas [time] arranca [title]. Disfruta de la mejor música en ${stationName} mientras llega el momento.`,
                `¡Hola de nuevo, ${userName}! Qué gran tarde tenemos en ${stationName}. En tan solo [time] [title] estará sonando por fin.`,
                `¡Atención! Ya falta muy poquito. Escuchas ${stationName} en Veredillas FM y en solo [time] llega el estreno de [title]. Ya somos un montón de oyentes en línea.`,
                `¡Ey, familia Veredillas! En solo [time] [title] llega con muchísima ilusión a ${stationName}. ${userName}, prepárate para lo que viene.`,
                `¡Bienvenido a la espera más apasionante en ${stationName}! En [time] el episodio [title] despega oficialmente para ti y tus amigos.`,
                `¡Atención! Estás en ${stationName}. En solo [time] el estreno de [title] se hará realidad en Veredillas FM para nuestros ${currentListeners} oyentes.`,
                `¡Veredillas FM te saluda con energía desde ${stationName}, ${userName}! En [time] el estreno de [title] será todo vuestro.`,
                `¡Falta nada y menos! Sigue en ${stationName}. En [time] [title] empieza a sonar. ${userName}, ¡gracias por ser ${userLevel}!`,
                `¡Ya está aquí lo que estabais esperando! Escuchas ${stationName}. En solo [time] lanzamos el estreno de [title] para toda la audiencia.`,
                `¡No parpadees! Sintoniza ${stationName} en Veredillas FM. En [time] arranca [title] con toda su fuerza para sorprendernos a todos.`,
                `¡Hola! En apenas [time] el estreno de [title] te va a sorprender en ${stationName}, ${userName}. ¡No te despegues de la sintonía!`,
                `¡Qué tal comunidad! En solo [time] de espera con ${stationName} comenzamos el estreno oficial de [title], un episodio inolvidable.`,
                `¡Ey, ${userName}! Que no se te escape. Escuchas ${stationName} y en solo [time] [title] entra a escena finalmente.`,
                `¡Qué ganas teníamos de este momento en ${stationName}! Solo [time] más para el estreno de [title]. Somos ya una gran multitud esperando.`,
                `¡Hola, hola! Ya casi estamos listos en ${stationName}. En solo [time] [title] se hace realidad ante los ${currentListeners} oyentes actuales.`,
                `¡Veredillas FM, conectando con vuestras emociones a través de ${stationName}! En [time] arranca oficialmente [title].`,
                `¡No te desconectes nunca de ${stationName}, ${userName}! En tan solo [time] el gran estreno de [title] te espera aquí con nosotros.`,
                `¡Aquí estamos en ${stationName}, con los nervios del estreno! En solo [time] el magnífico programa [title] comienza. ¡Disfrútalo!`
            ];

            const phrase = variations[Math.floor(Math.random() * variations.length)]
                .replace('[title]', this.title)
                .replace('[time]', timeStr);

            try {
                const response = await fetch('/api/tts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: phrase, model: selectedModel })
                });

                if (!response.ok) throw new Error('TTS failed');

                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const ttsAudio = new Audio(url);
                
                // DJ-style transition: Smoothly fade down music
                const originalVolume = this.audio?.volume || 0.5;
                if (this.audio) await this.fadeVolume(this.audio, originalVolume * 0.2, 800);

                ttsAudio.play();
                ttsAudio.onended = async () => {
                    // Smoothly fade back up
                    if (this.audio) await this.fadeVolume(this.audio, originalVolume, 1200);
                    URL.revokeObjectURL(url);
                };
            } catch (error) {
                console.error('TTS error:', error);
            }
        }

        switchGenre(option: HTMLElement) {
            // Update selected visual state
            this.vibeOptions.forEach(opt => opt.classList.remove('selected'));
            option.classList.add('selected');

            const newUrl = option.dataset.value;
            const genreName = option.textContent || "Música";
            
            // Update trigger text
            if(this.selectionText) this.selectionText.textContent = genreName;
            
            if (newUrl && this.audio) {
                this.currentUrl = newUrl;
                this.audio.src = newUrl;
                
                // Save selection to localStorage
                localStorage.setItem('veredillas_last_station', newUrl);
                
                if (this.isPlaying) {
                     if(this.musicLabel) this.musicLabel.textContent = `Conectando con ${genreName}...`;
                     this.audio.play().then(() => {
                         if(this.musicLabel) this.musicLabel.textContent = `Escuchando ${genreName}`;
                     }).catch(e => {
                         console.error("Switch play failed:", e);
                         this.isPlaying = false;
                         this.musicBtn?.classList.remove('playing');
                         this.updateVolumeVisibility();
                     });
                } else {
                    if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
                }
            }
        }

        updateVolumeIcon(volume: number) {
            const waves = this.el.querySelector('.volume-waves') as HTMLElement;
            const outerWaves = this.el.querySelector('.volume-waves-outer') as HTMLElement;
            
            if(!waves || !outerWaves) return;

            if (volume === 0) {
                waves.style.opacity = '0';
                outerWaves.style.opacity = '0';
            } else if (volume < 0.5) {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '0';
            } else {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '1';
            }
        }

        updateVolumeVisibility() {
            if (this.isPlaying) {
                this.volumeContainer?.classList.add('show');
            } else {
                this.volumeContainer?.classList.remove('show');
            }
        }

        toggleMusic() {
            if (!this.audio || !this.musicBtn) return;

            if (this.isPlaying) {
                this.audio.pause();
                this.isPlaying = false;
                this.musicBtn.classList.remove('playing');
                const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                if(this.musicLabel) this.musicLabel.textContent = `Activar ${genreName}`;
            } else {
                if(this.musicLabel) this.musicLabel.textContent = "Conectando...";
                
                this.audio.play().then(() => {
                    this.isPlaying = true;
                    this.musicBtn!.classList.add('playing');
                    const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                    if(this.musicLabel) this.musicLabel!.textContent = `Escuchando ${genreName}`;
                    
                    // Trigger TTS when music starts for the first time
                    this.playTTS();
                }).catch(e => {
                    console.error("Audio play failed:", e);
                    this.isPlaying = false;
                    this.musicBtn!.classList.remove('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = "No disponible";
                }).finally(() => {
                    this.updateVolumeVisibility();
                });
            }
            this.updateVolumeVisibility();
        }

        async finish() {
            if(this.interval) clearInterval(this.interval);
            
            if (this.audio && this.isPlaying) {
                const fadeAudio = setInterval(() => {
                    if (this.audio && this.audio.volume > 0.05) {
                        this.audio.volume -= 0.05;
                    } else {
                        clearInterval(fadeAudio);
                        this.audio?.pause();
                    }
                }, 100);
            }
            
            // @ts-ignore
            import('canvas-confetti').then(({ default: confetti }) => {
                 this.fireConfetti(confetti);
            });
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.transition = 'opacity 1s ease-out, transform 1s ease-out';
                countdownWrapper.style.opacity = '0';
                countdownWrapper.style.transform = 'scale(0.95)';
                
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                
                setTimeout(() => {
                    playerWrapper.style.opacity = '1';
                    setTimeout(() => {
                         countdownWrapper.style.display = 'none';
                         document.dispatchEvent(new CustomEvent('premiere-started'));
                    }, 1000);
                }, 100);
            } else {
                 window.location.reload();
            }
        }

        instantFinish() {
            if(this.interval) clearInterval(this.interval);
            
            const countdownWrapper = document.getElementById('premiere-countdown-wrapper');
            const playerWrapper = document.getElementById('premiere-player-wrapper');

            if(countdownWrapper && playerWrapper) {
                countdownWrapper.style.display = 'none';
                playerWrapper.classList.remove('hidden');
                playerWrapper.style.display = 'block';
                playerWrapper.style.opacity = '1';
                playerWrapper.style.transition = 'none';
                document.dispatchEvent(new CustomEvent('premiere-started'));
            } else {
                 window.location.reload();
            }
        }

        fireConfetti(confetti: any) {
            const count = 200;
            const defaults = { origin: { y: 0.7 } };

            function fire(particleRatio: number, opts: any) {
                confetti({
                    ...defaults,
                    ...opts,
                    particleCount: Math.floor(count * particleRatio)
                });
            }

            fire(0.25, { spread: 26, startVelocity: 55 });
            fire(0.2, { spread: 60 });
            fire(0.35, { spread: 100, decay: 0.91, scalar: 0.8 });
            fire(0.1, { spread: 120, startVelocity: 25, decay: 0.92, scalar: 1.2 });
            fire(0.1, { spread: 120, startVelocity: 45 });
        }
    }

    document.addEventListener('astro:page-load', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });

    // Fallback for non-view-transitions
    document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('.premiere-countdown');
        els.forEach(el => new PremiereCountdown(el as HTMLElement));
    });
</script>
