      background: none; border: none; color: var(--text-mut); padding: 6px; border-radius: 6px; cursor: pointer; transition: all 0.2s;
  }
  .align-btn:hover { background: rgba(255,255,255,0.05); color: white; }
  .align-btn.active { background: var(--card-accent); color: white; }

  .premium-input {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px;
      padding: 0.875rem 1rem; color: white; font-size: 0.95rem; transition: all 0.2s; font-family: inherit; resize: vertical; outline: none;
  }
  .premium-input:focus { border-color: var(--card-accent); background: rgba(255,255,255,0.06); box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1); }

  /* Background picker */
  .bg-picker { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .bg-preset {
      width: 50px; height: 50px; border-radius: 14px; padding: 3px; border: 2px solid transparent; cursor: pointer; transition: all 0.2s;
  }
  .bg-preset:hover { transform: scale(1.05); }
  .bg-preset.active { border-color: var(--card-accent); }
  .preview-dot { display: block; width: 100%; height: 100%; border-radius: 10px; }

  .color-input-wrapper { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 1rem; }
  input[type="color"] { -webkit-appearance: none; border: none; width: 30px; height: 30px; padding: 0; background: none; cursor: pointer; border-radius: 50%; overflow: hidden; }
  input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
  input[type="color"]::-webkit-color-swatch { border: none; border-radius: 50%; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.2); }

  /* Color buttons */
  .color-options { display: flex; gap: 0.75rem; }
  .color-btn {
      width: 36px; height: 36px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); box-shadow: inset 0 2px 4px rgba(255,255,255,0.3), 0 2px 4px rgba(0,0,0,0.5);
  }
  .color-btn:hover { transform: translateY(-2px); }
  .color-btn.active { transform: scale(1.15); border-color: white; box-shadow: 0 0 15px rgba(255,255,255,0.3); }

  /* Toggles */
  .toggles-grid { display: flex; flex-direction: column; gap: 1rem; }
  .toggle-item { display: flex; align-items: center; justify-content: space-between; background: rgba(255,255,255,0.02); padding: 0.75rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); }
  .toggle-item label { font-size: 0.9rem; color: var(--text-main); font-weight: 500; }
  
  .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
  .switch input { opacity: 0; width: 0; height: 0; }
  .slider { position: absolute; cursor: pointer; inset: 0; background-color: rgba(255,255,255,0.1); transition: .3s; border-radius: 24px; }
  .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .3s cubic-bezier(0.4, 0, 0.2, 1); border-radius: 50%; }
  input:checked + .slider { background-color: var(--card-accent); }
  input:checked + .slider:before { transform: translateX(20px); }

  .setting-divider { height: 1px; background: var(--border-color); margin: 2rem 0; }

  /* Layouts Grid */
  .layouts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 2rem; }
  .layout-preset {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px;
      padding: 1rem; cursor: pointer; transition: all 0.2s; display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
  }
  .layout-preset:hover { background: rgba(255,255,255,0.06); transform: translateY(-2px); }
  .layout-preset.active { border-color: var(--card-accent); background: rgba(139, 92, 246, 0.1); }
  
  .layout-mini { width: 60px; height: 100px; background: #000; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); position: relative; padding: 10px; display: flex; flex-direction: column; gap: 5px; }
  .layout-mini span { height: 4px; background: rgba(255,255,255,0.3); border-radius: 2px; width: 100%; }
  
  .layout-mini.default span:nth-child(2) { height: 40px; margin: 5px 0; }
  .layout-mini.centered { align-items: center; justify-content: center; }
  .layout-mini.centered span:nth-child(2) { height: 30px; width: 30px; border-radius: 50%; }
  .layout-mini.minimal span:nth-child(1) { height: 20px; }
  .layout-mini.minimal span:nth-child(2) { height: 10px; width: 10px; }
  .layout-mini.split span:nth-child(1) { height: 50px; border-radius: 0; position: absolute; top: 0; left: 0; right: 0; }
  
  .layout-name { color: var(--text-main); font-size: 0.85rem; font-weight: 600; }
  .layout-tip { color: var(--text-mut); font-size: 0.8rem; line-height: 1.4; padding: 1rem; background: rgba(255,255,255,0.03); border-radius: 12px; }

  /* Export Tab */
  .export-desc { color: var(--text-mut); font-size: 0.9rem; line-height: 1.5; margin-bottom: 2rem; }
  .actions-grid { display: flex; flex-direction: column; gap: 1rem; }
  
  .export-btn {
      width: 100%; padding: 1rem 1.5rem; border-radius: 14px; font-weight: 600; font-size: 0.95rem;
