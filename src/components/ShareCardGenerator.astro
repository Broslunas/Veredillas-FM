---
interface Props {
  title: string;
  image?: string;
  guests?: string[];
  url?: URL | string;
  triggerId?: string;
}

const { title, image = '/logo.webp', guests = [], url = Astro.url, triggerId } = Astro.props;

// Process title to remove "ft. X" since we show featuring below
let displayTitle = title;
const lowerTitle = displayTitle.toLowerCase();
[' ft.', ' feat.', ' ft ', ' feat '].forEach(str => {
    const idx = lowerTitle.indexOf(str);
    if (idx !== -1) {
        displayTitle = displayTitle.substring(0, idx).trim();
    }
});
---

<!-- Trigger Button (Only if no external trigger ID provided) -->
{!triggerId && (
<button class="share-btn generator-btn" id="open-generator-btn" aria-label="Crear Story">
  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
    <circle cx="8.5" cy="8.5" r="1.5"></circle>
    <polyline points="21 15 16 10 5 21"></polyline>
  </svg>
</button>
)}

<!-- Generator Modal -->
<div id="generator-modal" class="generator-backdrop" data-trigger-id={triggerId}>
    <div class="generator-dialog">
        <!-- Close button floating -->
        <button class="close-btn" id="close-generator-btn" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>

        <div class="generator-content">
            <!-- Controls Sidebar -->
            <div class="controls-panel custom-scrollbar">
                <div class="controls-header">
                    <h3>Creador de Stories</h3>
                    <p>Diseña y comparte un fragmento visual</p>
                </div>

                <div class="tabs-container">
                    <button class="tab-btn active" data-tab="content">Contenido</button>
                    <button class="tab-btn" data-tab="design">Diseño</button>
                    <button class="tab-btn" data-tab="layout">Distribución</button>
                    <button class="tab-btn" data-tab="export">Exportar</button>
                </div>

                <div class="tab-content custom-scrollbar" id="tab-content" style="display: block;">
                    <!-- Section: Content -->
                    <div class="control-section">
                        <div class="input-group">
                            <label for="card-title">Título del Episodio</label>
                            <div class="input-with-actions">
                                <textarea id="card-title" rows="2" class="premium-input">{displayTitle}</textarea>
                                <div class="align-controls" data-target="title">
                                    <button class="align-btn active" data-align="left" title="Izquierda"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"></line><line x1="21" y1="6" x2="3" y2="6"></line><line x1="21" y1="14" x2="3" y2="14"></line><line x1="17" y1="18" x2="3" y2="18"></line></svg></button>
                                    <button class="align-btn" data-align="center" title="Centro"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="10" x2="6" y2="10"></line><line x1="21" y1="6" x2="3" y2="6"></line><line x1="21" y1="14" x2="3" y2="14"></line><line x1="18" y1="18" x2="6" y2="18"></line></svg></button>
                                    <button class="align-btn" data-align="right" title="Derecha"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="10" x2="7" y2="10"></line><line x1="21" y1="6" x2="3" y2="6"></line><line x1="21" y1="14" x2="3" y2="14"></line><line x1="21" y1="18" x2="7" y2="18"></line></svg></button>
                                </div>
                            </div>
                        </div>
                        
                        <div class="input-group">
                            <label for="card-guest">Invitado(s)</label>
                            <div class="input-with-actions">
                                <input type="text" id="card-guest" class="premium-input" value={guests.join(', ') || ''} placeholder="ft. Nombre del invitado" />
                                <div class="align-controls" data-target="guest">
                                    <button class="align-btn active" data-align="left"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"></line><line x1="17" y1="18" x2="3" y2="18"></line></svg></button>
                                    <button class="align-btn" data-align="center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="10" x2="6" y2="10"></line><line x1="18" y1="18" x2="6" y2="18"></line></svg></button>
                                    <button class="align-btn" data-align="right"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="10" x2="7" y2="10"></line><line x1="21" y1="18" x2="7" y2="18"></line></svg></button>
                                </div>
                            </div>
                        </div>
                        
                        <div class="input-group">
                            <label for="card-quote">Frase Destacada</label>
                            <div class="input-with-actions">
                                <textarea id="card-quote" class="premium-input" rows="3" placeholder="Escribe una cita inspiradora del episodio..."></textarea>
                                <div class="align-controls" data-target="quote">
                                    <button class="align-btn active" data-align="left"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="17" y1="10" x2="3" y2="10"></line></svg></button>
                                    <button class="align-btn" data-align="center"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="10" x2="6" y2="10"></line></svg></button>
                                    <button class="align-btn" data-align="right"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="21" y1="10" x2="7" y2="10"></line></svg></button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-content custom-scrollbar" id="tab-design" style="display: none;">
                    <!-- Section: Background -->
                    <div class="control-section">
                        <h4 class="section-title">Estilo de Fondo</h4>
                        <div class="bg-picker">
                            <div class="bg-preset active" data-bg="cover" title="Portada Borrosa">
                                <span class="preview-dot" style="background: url('/logo.webp') center/cover; filter: blur(2px);"></span>
                            </div>
                            <div class="bg-preset" data-bg="gradient-aurora" title="Aurora">
                                <span class="preview-dot" style="background: linear-gradient(135deg, #1e3a8a 0%, #a21caf 100%);"></span>
                            </div>
                            <div class="bg-preset" data-bg="gradient-sunset" title="Sunset">
                                <span class="preview-dot" style="background: linear-gradient(135deg, #f97316 0%, #db2777 100%);"></span>
                            </div>
                            <div class="bg-preset" data-bg="gradient-midnight" title="Midnight">
                                <span class="preview-dot" style="background: linear-gradient(0deg, #09090b 0%, #18181b 100%); border: 1px solid #333;"></span>
                            </div>
                            <div class="bg-preset" data-bg="solid" title="Color Sólido">
                                <span class="preview-dot" style="background: #000;"></span>
                            </div>
                        </div>

                        <div id="solid-color-picker" class="input-group hidden" style="margin-top: 15px;">
                            <label for="bg-color">Color de Fondo</label>
                            <div class="color-input-wrapper premium-input">
                                <input type="color" id="bg-color" value="#0f0f0f" />
                                <span class="color-value font-mono">#0f0f0f</span>
                            </div>
                        </div>
                    </div>

                    <div class="setting-divider"></div>

                    <!-- Section: Colors -->
                    <div class="control-section">
                        <h4 class="section-title">Color de Acento</h4>
                        <div class="color-options">
                            <button class="color-btn active" data-color="#8b5cf6" style="background: #8b5cf6;"></button>
                            <button class="color-btn" data-color="#E1306C" style="background: #E1306C;"></button>
                            <button class="color-btn" data-color="#22c55e" style="background: #22c55e;"></button>
                            <button class="color-btn" data-color="#fbbf24" style="background: #fbbf24;"></button>
                            <button class="color-btn" data-color="#ffffff" style="background: #ffffff;"></button>
                        </div>
                    </div>

                    <div class="setting-divider"></div>

                    <!-- Section: Elements -->
                    <div class="control-section">
                        <h4 class="section-title">Elementos Visuales</h4>
                        <div class="toggles-grid">
                            <div class="toggle-item">
                                <label for="show-cover">Portada</label>
                                <label class="switch"><input type="checkbox" id="show-cover" checked><span class="slider round"></span></label>
                            </div>
                            <div class="toggle-item">
                                <label for="show-wave">Ondas de Audio</label>
                                <label class="switch"><input type="checkbox" id="show-wave" checked><span class="slider round"></span></label>
                            </div>
                            <div class="toggle-item">
                                <label for="show-logo">Logo Veredillas</label>
                                <label class="switch"><input type="checkbox" id="show-logo" checked><span class="slider round"></span></label>
                            </div>
                            <div class="toggle-item">
                                <label for="show-website">Sitio Web</label>
                                <label class="switch"><input type="checkbox" id="show-website" checked><span class="slider round"></span></label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-content custom-scrollbar" id="tab-layout" style="display: none;">
                    <div class="control-section">
                        <h4 class="section-title">Ajustes Rápidos</h4>
                        <div class="layouts-grid">
                            <button class="layout-preset active" data-layout="default">
                                <div class="layout-mini default"><span></span><span></span><span></span></div>
                                <span class="layout-name">Clásico</span>
                            </button>
                            <button class="layout-preset" data-layout="centered">
                                <div class="layout-mini centered"><span></span><span></span><span></span></div>
                                <span class="layout-name">Centrado</span>
                            </button>
                            <button class="layout-preset" data-layout="minimal">
                                <div class="layout-mini minimal"><span></span><span></span><span></span></div>
                                <span class="layout-name">Mínimo</span>
                            </button>
                            <button class="layout-preset" data-layout="split">
                                <div class="layout-mini split"><span></span><span></span><span></span></div>
                                <span class="layout-name">Dividido</span>
                            </button>
                        </div>
                        <p class="layout-tip">💡 <strong>Truco:</strong> Puedes arrastrar cualquier elemento en la vista previa para colocarlo donde quieras.</p>
                        
                        <div class="setting-divider"></div>
                        
                        <button id="reset-layout-btn" class="secondary-btn-outline w-full py-3 rounded-xl border border-white/10 text-sm font-semibold hover:bg-white/5 transition-all">
                            Restablecer Posiciones
                        </button>
                    </div>
                </div>

                <div class="tab-content custom-scrollbar" id="tab-export" style="display: none;">
                    <div class="export-options">
                        <p class="export-desc">Comparte tu fragmento directamente en tus redes o descárgalo a tu dispositivo.</p>
                        
                        <div class="actions-grid">
                            <button id="share-native-btn" class="export-btn primary-action">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
                                <span>Compartir (Móvil)</span>
                            </button>

                            <button id="copy-card-btn" class="export-btn secondary-action">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                                <span>Copiar al Portapapeles</span>
                            </button>

                            <button id="download-card-btn" class="export-btn outline-action">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                                <span>Guardar Imagen</span>
                            </button>
                        </div>
                        
                        <div id="export-status" class="export-status hidden"></div>
                    </div>
                </div>

            </div>

            <!-- Preview Area -->
            <div class="preview-panel">
                <div class="preview-hint">Vista Previa <strong>(1080x1920)</strong></div>
                <div class="canvas-wrapper">
                    <div class="canvas-container">
                        <div id="share-card" class="share-card">
                            <!-- Background Mode Layers -->
                            <div class="card-bg" id="card-bg-layer">
                                 <img src={image} alt="" class="bg-image blurred" />
                                 <div class="bg-overlay"></div>
                                 <div class="bg-solid" style="display: none;"></div>
                            </div>
                            
                            <!-- Snap Guides -->
                            <div id="guide-v-center" class="guide-line v-center"></div>
                            <div id="guide-h-center" class="guide-line h-center"></div>
                            <div id="guide-edge-l" class="guide-line edge-l"></div>
                            <div id="guide-edge-r" class="guide-line edge-r"></div>
                            <div id="guide-edge-t" class="guide-line edge-t"></div>
                            <div id="guide-edge-b" class="guide-line edge-b"></div>

                            <!-- Audio Wave Decoration -->
                            <div class="audio-wave-decoration" id="wave-decoration">
                                <div class="wave"></div><div class="wave"></div><div class="wave"></div>
                                <div class="wave"></div><div class="wave"></div><div class="wave"></div>
                            </div>

                            <!-- Content -->
                            <div class="card-content">
                                <!-- Top Bar -->
                                <div class="card-top-bar">
                                    <div class="brand-badge frosted-glass draggable-item" id="el-logo" data-drag-id="logo">
                                        <img src="/logo.webp" alt="Logo" class="brand-logo" />
                                        <span class="brand-name">VEREDILLAS FM</span>
                                    </div>
                                    <div class="episode-pill draggable-item" id="el-tag" data-drag-id="tag">
                                        <span class="pulse-dot"></span> NUEVO EPISODIO
                                    </div>
                                </div>

                                <!-- Visual Center -->
                                <div class="main-visual" id="visual-container">
                                     <div class="cover-wrapper glass-border" id="cover-wrapper" data-drag-id="cover">
                                         <img src={image} alt="Cover" class="cover-image" id="card-cover-img" />
                                         <div class="cover-glow"></div>
                                     </div>
                                </div>

                                <!-- Typography Bottom -->
                                <div class="text-content">
                                    <h1 class="card-title-text draggable-item" id="preview-title" data-drag-id="title">{displayTitle}</h1>
                                    
                                    <div class="card-guest-text draggable-item" id="preview-guest" data-drag-id="guest" style={guests.length === 0 ? 'display:none' : ''}>
                                        <div class="guest-label-wrapper">
                                            <span class="guest-label accent-bg">FEATURING</span>
                                        </div>
                                        <span class="guest-name accent-text">{guests.join(', ')}</span>
                                    </div>
                                    
                                    <div class="card-quote-container frosted-glass glass-border draggable-item" id="preview-quote-container" data-drag-id="quote" style="display:none">
                                        <svg class="quote-icon accent-fill" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
                                        <p class="card-quote-text" id="preview-quote"></p>
                                    </div>
                                </div>
                                
                                 <!-- Footer -->
                                 <div class="card-footer" id="el-website">
                                    <div class="website-pill frosted-glass draggable-item" data-drag-id="website">
                                        <div class="play-icon-circle accent-bg">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="black" stroke="black" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                        </div>
                                        <span class="website-text">Escucha ahora en <strong class="accent-text">vrdfm.es</strong></span>
                                    </div>
                                 </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    import { toPng, toBlob } from 'html-to-image';

    const modal = document.getElementById('generator-modal');
    const openBtn = document.getElementById('open-generator-btn');
    const closeBtn = document.getElementById('close-generator-btn');
    
    // Tabs
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    // Inputs
    const titleInput = document.getElementById('card-title') as HTMLTextAreaElement;
    const guestInput = document.getElementById('card-guest') as HTMLInputElement;
    const quoteInput = document.getElementById('card-quote') as HTMLTextAreaElement;
    
    // Groups & Controls
    const solidColorPicker = document.getElementById('solid-color-picker');
    const showCoverInput = document.getElementById('show-cover') as HTMLInputElement;
    const bgColorInput = document.getElementById('bg-color') as HTMLInputElement;

    // Toggles
    const showLogoInput = document.getElementById('show-logo') as HTMLInputElement;
    const showWebsiteInput = document.getElementById('show-website') as HTMLInputElement;
    const showWaveInput = document.getElementById('show-wave') as HTMLInputElement;

    // Preview Elements
    const previewTitle = document.getElementById('preview-title');
    const previewGuest = document.getElementById('preview-guest');
    const previewGuestName = previewGuest?.querySelector('.guest-name');
    const previewQuoteContainer = document.getElementById('preview-quote-container');
    const previewQuote = document.getElementById('preview-quote');
    const cardBgLayer = document.getElementById('card-bg-layer');
    const visualContainer = document.getElementById('visual-container');
    
    const cardCoverImg = document.getElementById('card-cover-img');
    const coverWrapper = document.querySelector('.cover-wrapper') as HTMLElement;
    const coverGlow = document.querySelector('.cover-glow') as HTMLElement;

    const elLogo = document.getElementById('el-logo');
    const elWebsite = document.getElementById('el-website');
    const elWave = document.getElementById('wave-decoration');
    
    // Presets
    const bgPresets = document.querySelectorAll('.bg-preset');
    const colorBtns = document.querySelectorAll('.color-btn');

    // Exports & Status
    const downloadBtn = document.getElementById('download-card-btn');
    const shareNativeBtn = document.getElementById('share-native-btn');
    const copyCardBtn = document.getElementById('copy-card-btn');
    const exportStatus = document.getElementById('export-status');
    const resetLayoutBtn = document.getElementById('reset-layout-btn');
    const alignBtns = document.querySelectorAll('.align-btn');
    
    // Guides
    const guides = {
        vCenter: document.getElementById('guide-v-center'),
        hCenter: document.getElementById('guide-h-center'),
        edgeL: document.getElementById('guide-edge-l'),
        edgeR: document.getElementById('guide-edge-r'),
        edgeT: document.getElementById('guide-edge-t'),
        edgeB: document.getElementById('guide-edge-b')
    };
    
    // Layout Presets
    const layoutPresets = document.querySelectorAll('.layout-preset');

    // --- Tab Switching ---
    tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            tabBtns.forEach(b => b.classList.remove('active'));
            tabContents.forEach(c => (c as HTMLElement).style.display = 'none');
            
            btn.classList.add('active');
            const target = document.getElementById(`tab-${btn.getAttribute('data-tab')}`);
            if (target) target.style.display = 'block';
        });
    });

    // --- State Management ---
    const toggleModal = (show: boolean) => {
        if (show) {
            modal?.classList.add('visible');
            setTimeout(fitPreview, 100);
            
            // Re-render check for Web Share API
            if (!navigator.canShare) {
                if (shareNativeBtn) (shareNativeBtn as HTMLElement).style.display = 'none';
            }
        } else {
            modal?.classList.remove('visible');
        }
    };

    const fitPreview = () => {
        const wrapper = document.querySelector('.canvas-wrapper') as HTMLElement;
        const container = document.querySelector('.canvas-container') as HTMLElement;
        if (!wrapper || !container) return;

        // Reset for measurement
        container.style.transform = 'scale(1)';
        
        const padding = 60;
        const availableW = wrapper.parentElement!.clientWidth - padding;
        const availableH = wrapper.parentElement!.clientHeight - padding;
        
        const scaleW = availableW / 1080;
        const scaleH = availableH / 1920;
        const scale = Math.min(scaleW, scaleH, 1);
        
        container.style.transform = `translate(-50%, -50%) scale(${scale})`;
    };

    window.addEventListener('resize', fitPreview);

    // --- Global State ---
    interface ElementState {
        x: number; y: number; s: number; align: 'left' | 'center' | 'right';
    }

    const getInitialStates = (): Record<string, ElementState> => ({
        logo: { x: 0, y: 0, s: 1, align: 'left' },
        tag: { x: 0, y: 0, s: 1, align: 'left' },
        cover: { x: 0, y: 0, s: 1, align: 'left' },
        title: { x: 0, y: 0, s: 1, align: 'left' },
        guest: { x: 0, y: 0, s: 1, align: 'left' },
        quote: { x: 0, y: 0, s: 1, align: 'left' },
        website: { x: 0, y: 0, s: 1, align: 'left' }
    });
    
    let elementStates = getInitialStates();

    const updateAllTransforms = () => {
        Object.keys(elementStates).forEach(id => {
            const el = document.querySelector(`[data-drag-id="${id}"]`) as HTMLElement;
            if (el) {
                const state = elementStates[id];
                el.style.transform = `translate(${state.x}px, ${state.y}px) scale(${state.s})`;
                
                // Apply alignment classes
                if (['title', 'guest', 'quote'].includes(id)) {
                    el.classList.remove('text-left', 'text-center', 'text-right', 'items-center', 'items-end', 'justify-center', 'justify-end');
                    if (state.align === 'center') {
                        el.classList.add('text-center', 'items-center', 'justify-center');
                    } else if (state.align === 'right') {
                        el.classList.add('text-right', 'items-end', 'justify-end');
                    }
                }
            }
        });
    };

    window.openStoryGenerator = (data) => {
        if (titleInput && data.title !== undefined) {
             let cleanTitle = data.title;
             [' ft.', ' feat.', ' ft ', ' feat '].forEach(str => {
                 const idx = cleanTitle.toLowerCase().indexOf(str);
                 if (idx !== -1) cleanTitle = cleanTitle.substring(0, idx).trim();
             });
             titleInput.value = cleanTitle;
        }
        if (guestInput && data.guests !== undefined) {
             guestInput.value = Array.isArray(data.guests) ? data.guests.join(', ') : data.guests;
        }
        if (quoteInput && data.quote !== undefined) quoteInput.value = data.quote;
        if (data.image) {
             const bgImg = cardBgLayer?.querySelector('.bg-image') as HTMLImageElement;
             if (bgImg) bgImg.src = data.image; 
             if (cardCoverImg) (cardCoverImg as HTMLImageElement).src = data.image;
        }
        
        applyLayout('default');
        updatePreview();
        toggleModal(true);
    };

    // --- Generic Draggable System ---
    let dragTargetId = null;
    let isDragging = false;
    let lastX = 0, lastY = 0;

    const startDrag = (e: MouseEvent | TouchEvent) => {
        const target = (e.target as HTMLElement).closest('[data-drag-id]') as HTMLElement;
        if (!target) return;
        
        dragTargetId = target.dataset.dragId as string;
        isDragging = true;
        
        const clientX = 'touches' in e ? (e as TouchEvent).touches[0].clientX : (e as MouseEvent).clientX;
        const clientY = 'touches' in e ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
        lastX = clientX;
        lastY = clientY;
    };

    const SNAP_THRESHOLD = 20;

    const onDrag = (e: MouseEvent | TouchEvent) => {
        if (!isDragging || !dragTargetId) return;
        
        const clientX = 'touches' in e ? (e as TouchEvent).touches[0].clientX : (e as MouseEvent).clientX;
        const clientY = 'touches' in e ? (e as TouchEvent).touches[0].clientY : (e as MouseEvent).clientY;
        
        const container = document.querySelector('.canvas-container') as HTMLElement;
        const transformScaleMatch = container?.style.transform.match(/scale\(([^)]+)\)/);
        const transformScale = transformScaleMatch ? parseFloat(transformScaleMatch[1]) : 1;
        
        const dx = (clientX - lastX) / transformScale;
        const dy = (clientY - lastY) / transformScale;
        
        elementStates[dragTargetId].x += dx;
        elementStates[dragTargetId].y += dy;
        
        lastX = clientX;
        lastY = clientY;
        
        checkSnapping(dragTargetId);
        updateAllTransforms();
    };

    const checkSnapping = (id: string) => {
        const el = document.querySelector(`[data-drag-id="${id}"]`) as HTMLElement;
        const card = document.getElementById('share-card');
        if (!el || !card) return;

        const rect = el.getBoundingClientRect();
        const cardRect = card.getBoundingClientRect();
        
        const centerCardX = cardRect.left + cardRect.width / 2;
        const centerCardY = cardRect.top + cardRect.height / 2;
        const centerElX = rect.left + rect.width / 2;
        const centerElY = rect.top + rect.height / 2;

        let snappedV = false, snappedH = false;

        // Snapping Horizontal Center
        if (Math.abs(centerElX - centerCardX) < SNAP_THRESHOLD) {
            snappedV = true;
            guides.vCenter?.classList.add('visible');
        } else {
            guides.vCenter?.classList.remove('visible');
        }

        // Snapping Vertical Center
        if (Math.abs(centerElY - centerCardY) < SNAP_THRESHOLD) {
            snappedH = true;
            guides.hCenter?.classList.add('visible');
        } else {
            guides.hCenter?.classList.remove('visible');
        }

        // Edge Detection
        const paddingX = 80 * (cardRect.width / 1080);
        const paddingY_T = 120 * (cardRect.height / 1920);
        const paddingY_B = 100 * (cardRect.height / 1920);

        guides.edgeL?.classList.toggle('visible', Math.abs(rect.left - (cardRect.left + paddingX)) < SNAP_THRESHOLD);
        guides.edgeR?.classList.toggle('visible', Math.abs(rect.right - (cardRect.right - paddingX)) < SNAP_THRESHOLD);
        guides.edgeT?.classList.toggle('visible', Math.abs(rect.top - (cardRect.top + paddingY_T)) < SNAP_THRESHOLD);
        guides.edgeB?.classList.toggle('visible', Math.abs(rect.bottom - (cardRect.bottom - paddingY_B)) < SNAP_THRESHOLD);
    };

    const stopDrag = () => { 
        isDragging = false; 
        dragTargetId = null; 
        Object.values(guides).forEach(g => g?.classList.remove('visible'));
    };

    const card = document.getElementById('share-card');
    if (card) {
        card.addEventListener('mousedown', startDrag);
        card.addEventListener('touchstart', startDrag, { passive: false });
        window.addEventListener('mousemove', onDrag);
        window.addEventListener('touchmove', onDrag, { passive: false });
        window.addEventListener('mouseup', stopDrag);
        window.addEventListener('touchend', stopDrag);
        
        card.addEventListener('wheel', (e) => {
            const target = (e.target as HTMLElement).closest('[data-drag-id]') as HTMLElement;
            if (!target) return;
            e.preventDefault();
            const id = target.dataset.dragId as string;
            const delta = e.deltaY > 0 ? -0.05 : 0.05;
            elementStates[id].s = Math.max(0.1, Math.min(elementStates[id].s + delta, 5));
            updateAllTransforms();
        }, { passive: false });
    }

    // --- Alignment Logic ---
    alignBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
            const controls = (e.currentTarget as HTMLElement).parentElement;
            const target = controls?.dataset.target as string;
            const align = (e.currentTarget as HTMLElement).dataset.align as 'left' | 'center' | 'right';
            
            if (target && elementStates[target]) {
                elementStates[target].align = align;
                updateAllTransforms();
                
                // UI feedback
                controls?.querySelectorAll('.align-btn').forEach(b => b.classList.toggle('active', b === e.currentTarget));
            }
        });
    });

    // --- Layout Presets Logic ---
    const applyLayout = (name: string) => {
        const shareCard = document.getElementById('share-card');
        if (shareCard) shareCard.className = `share-card layout-${name}`;
        
        elementStates = getInitialStates(); // Basic reset
        
        if (name === 'centered') {
            elementStates.title.y = -200;
            elementStates.title.align = 'center';
            elementStates.guest.align = 'center';
            elementStates.quote.align = 'center';
            elementStates.cover.y = 80;
        } else if (name === 'minimal') {
            elementStates.cover.s = 0.5;
            elementStates.cover.y = -400;
            elementStates.title.s = 1.3;
        } else if (name === 'split') {
            elementStates.cover.y = -400;
            elementStates.cover.s = 1.27;
            elementStates.title.y = 400;
        }
        
        updateAllTransforms();
        layoutPresets.forEach(b => b.classList.toggle('active', b.getAttribute('data-layout') === name));

        // Sync align buttons UI
        document.querySelectorAll('.align-controls').forEach(ctrl => {
            const target = (ctrl as HTMLElement).dataset.target;
            if (target && elementStates[target]) {
                const align = elementStates[target].align;
                ctrl.querySelectorAll('.align-btn').forEach(b => b.classList.toggle('active', (b as HTMLElement).dataset.align === align));
            }
        });
    };

    layoutPresets.forEach(btn => {
        btn.addEventListener('click', () => applyLayout(btn.getAttribute('data-layout')));
    });

    resetLayoutBtn?.addEventListener('click', () => applyLayout('default'));
    
    // External Trigger
    const triggerId = modal?.dataset.triggerId;
    if (triggerId) {
        const extBtn = document.getElementById(triggerId);
        extBtn?.addEventListener('click', () => toggleModal(true));
    }

    openBtn?.addEventListener('click', () => toggleModal(true));
    closeBtn?.addEventListener('click', () => toggleModal(false));
    modal?.addEventListener('click', (e) => {
        if (e.target === modal) toggleModal(false);
    });

    // --- Updates ---
    const updatePreview = () => {
        if (previewTitle) previewTitle.textContent = titleInput?.value || '';
        
        if (previewGuest && previewGuestName && guestInput) {
            const val = guestInput.value.trim();
            if (val) {
                previewGuestName.textContent = val;
                previewGuest.style.display = 'flex';
            } else {
                previewGuest.style.display = 'none';
            }
        }
        
        if (previewQuote && previewQuoteContainer && quoteInput) {
            const val = quoteInput.value.trim();
            if (val) {
                previewQuote.textContent = `${val}`;
                previewQuoteContainer.style.display = 'flex';
            } else {
                previewQuoteContainer.style.display = 'none';
            }
        }

        if (visualContainer && showCoverInput) {
             visualContainer.style.display = showCoverInput.checked ? 'flex' : 'none';
        }
        
        if (elLogo && showLogoInput) elLogo.style.opacity = showLogoInput.checked ? '1' : '0';
        if (elWebsite && showWebsiteInput) elWebsite.style.opacity = showWebsiteInput.checked ? '1' : '0';
        if (elWave && showWaveInput) elWave.style.opacity = showWaveInput.checked ? '1' : '0';

        if (bgColorInput && solidColorPicker && !solidColorPicker.classList.contains('hidden')) {
            const solidLayer = cardBgLayer?.querySelector('.bg-solid') as HTMLElement;
            if (solidLayer) {
                solidLayer.style.backgroundColor = bgColorInput.value;
            }
            const valDisplay = solidColorPicker.querySelector('.color-value');
            if (valDisplay) valDisplay.textContent = bgColorInput.value;
        }
    };

    [titleInput, guestInput, quoteInput, bgColorInput]
        .forEach(el => el?.addEventListener('input', updatePreview));
    
    [showCoverInput, showLogoInput, showWebsiteInput, showWaveInput]
        .forEach(el => el?.addEventListener('change', updatePreview));

    bgPresets.forEach(btn => {
        btn.addEventListener('click', () => {
            bgPresets.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            const bgType = btn.getAttribute('data-bg');
            if (cardBgLayer) {
                cardBgLayer.className = 'card-bg';
                const bgImg = cardBgLayer.querySelector('.bg-image') as HTMLElement;
                const bgSolid = cardBgLayer.querySelector('.bg-solid') as HTMLElement;
                
                if (bgImg) bgImg.style.display = 'block';
                if (bgSolid) bgSolid.style.display = 'none';
                if (solidColorPicker) solidColorPicker.classList.add('hidden');

                if (bgType === 'solid') {
                    if (bgImg) bgImg.style.display = 'none';
                    if (bgSolid) bgSolid.style.display = 'block';
                    if (solidColorPicker) solidColorPicker.classList.remove('hidden');
                    updatePreview();
                } else if (bgType && bgType !== 'cover') {
                    cardBgLayer.classList.add(bgType);
                     if (bgImg) bgImg.style.display = 'none';
                }
            }
        });
    });

    // Accent Color
    colorBtns.forEach(btn => {
        btn.addEventListener('click', () => {
             colorBtns.forEach(b => b.classList.remove('active'));
             btn.classList.add('active');
             const color = btn.getAttribute('data-color') || '#8b5cf6';
             
             document.documentElement.style.setProperty('--card-accent', color);
             
             const accentEls = document.querySelectorAll('.accent-text');
             accentEls.forEach((el) => (el as HTMLElement).style.color = color);
             const accentBgs = document.querySelectorAll('.accent-bg');
             accentBgs.forEach((el) => (el as HTMLElement).style.backgroundColor = color);
             const accentFills = document.querySelectorAll('.accent-fill');
             accentFills.forEach((el) => (el as HTMLElement).style.fill = color);

             if (coverGlow) {
                 coverGlow.style.boxShadow = `0 0 100px 20px ${color}80`;
             }
        });
    });

    // --- Export Logic ---
    const showStatus = (msg: string, isError = false) => {
        if (!exportStatus) return;
        exportStatus.textContent = msg;
        exportStatus.className = `export-status ${isError ? 'error' : 'success'}`;
        setTimeout(() => { exportStatus.className = 'export-status hidden'; }, 3000);
    };

    const getRenderOptions = () => ({
        quality: 0.95,
        width: 1080,
        height: 1920,
        cacheBust: true,
        skipAutoScale: true,
        style: { transform: 'none' },
        pixelRatio: 1
    });

    const setExportingState = (btn: HTMLElement, isExporting: boolean, originalHTML: string) => {
        if (isExporting) {
            btn.innerHTML = '<span class="loading-spinner"></span> <span>Procesando...</span>';
            (btn as HTMLButtonElement).disabled = true;
            btn.classList.add('exporting');
        } else {
            btn.innerHTML = originalHTML;
            (btn as HTMLButtonElement).disabled = false;
            btn.classList.remove('exporting');
        }
    };

    downloadBtn?.addEventListener('click', async () => {
        const card = document.getElementById('share-card');
        if (!card) return;
        const originalHTML = downloadBtn.innerHTML;
        setExportingState(downloadBtn, true, originalHTML);
        try {
            const dataUrl = await toPng(card, getRenderOptions());
            const link = document.createElement('a');
            link.download = `Veredillas_Story_${Date.now()}.png`;
            link.href = dataUrl;
            link.click();
            showStatus('¡Imagen descargada con éxito!');
        } catch (err) {
            console.error(err);
            showStatus('Error al generar la imagen', true);
        } finally {
            setExportingState(downloadBtn, false, originalHTML);
        }
    });

    shareNativeBtn?.addEventListener('click', async () => {
        const card = document.getElementById('share-card');
        if (!card) return;
        const originalHTML = shareNativeBtn.innerHTML;
        setExportingState(shareNativeBtn, true, originalHTML);
        try {
            const blob = await toBlob(card, getRenderOptions());
            if (!blob) throw new Error('Blob is null');
            
            const file = new File([blob], `Veredillas_Story_${Date.now()}.png`, { type: 'image/png' });
            
            if (navigator.canShare && navigator.canShare({ files: [file] })) {
                await navigator.share({
                    title: titleInput.value || 'Veredillas FM',
                    text: '¡Mira este episodio de Veredillas FM!',
                    files: [file]
                });
                showStatus('¡Compartido!');
            } else {
                showStatus('Tu navegador no soporta compartir imágenes directamente', true);
            }
        } catch (err) {
            console.error(err);
            if ((err as Error).name !== 'AbortError') {
                showStatus('Error al compartir', true);
            }
        } finally {
            setExportingState(shareNativeBtn, false, originalHTML);
        }
    });

    copyCardBtn?.addEventListener('click', async () => {
        const card = document.getElementById('share-card');
        if (!card) return;
        const originalHTML = copyCardBtn.innerHTML;
        setExportingState(copyCardBtn, true, originalHTML);
        try {
            const blob = await toBlob(card, getRenderOptions());
            if (!blob) throw new Error('Blob is null');
            
            await navigator.clipboard.write([
                new ClipboardItem({ 'image/png': blob })
            ]);
            showStatus('¡Imagen copiada al portapapeles!');
        } catch (err) {
            console.error(err);
            showStatus('Tu navegador no soporta copiar imágenes', true);
        } finally {
            setExportingState(copyCardBtn, false, originalHTML);
        }
    });

</script>

<style>
