  .input-group { margin-bottom: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .input-group label { color: var(--text-main); font-size: 0.85rem; font-weight: 500; }
  
  .input-with-actions { display: flex; flex-direction: column; gap: 0.5rem; }
  .align-controls { display: flex; gap: 0.25rem; background: rgba(255,255,255,0.03); padding: 4px; border-radius: 8px; width: fit-content; }
