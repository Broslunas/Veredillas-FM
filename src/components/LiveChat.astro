---
interface Props {
  slug: string;
}

const { slug } = Astro.props;

import { verifyToken } from '../lib/auth';
import dbConnect from '../lib/mongodb';
import User from '../models/User';

// Safe serializable user object for the client
interface SafeUser {
    name: string;
    role: string;
    picture?: string;
}

let currentUserSafe: SafeUser | null = null;
try {
    const token = Astro.cookies.get('auth-token')?.value;
    if (token) {
        const payload = verifyToken(token);
        if (payload) {
             await dbConnect();
             const dbUser = await User.findById(payload.userId).select('name role picture').lean();
             if (dbUser) {
                 currentUserSafe = {
                     name: dbUser.name,
                     role: dbUser.role as string,
                     picture: dbUser.picture as string | undefined
                 };
             }
        }
    }
} catch(e) {
    console.error('[LiveChat] Auth helper error', e);
}

// Encode safely to avoid HTML attribute issues with quotes
const currentUserEncoded = currentUserSafe ? btoa(unescape(encodeURIComponent(JSON.stringify(currentUserSafe)))) : '';
---

<div 
    class="flex flex-col h-[500px] bg-slate-900/40 backdrop-blur-md border border-white/10 rounded-2xl overflow-hidden relative shadow-2xl" 
    id="live-chat-widget" 
    data-slug={slug} 
    data-current-user={currentUserEncoded}
>
    <!-- Overlay de Carga -->
    <div id="chat-load-overlay" class="absolute inset-0 bg-slate-950/80 backdrop-blur-xl flex items-center justify-center z-[100] p-6 text-center transition-all duration-500">
        <div class="max-width-[260px] animate-fade-in-up">
            <div class="text-5xl mb-4 filter drop-shadow-[0_0_15px_rgba(139,92,246,0.5)] animate-bounce">💬</div>
            <p class="text-white text-lg font-medium mb-6 leading-relaxed">Únete a la conversación en directo.</p>
            <button id="load-chat-btn" class="bg-primary hover:bg-primary/90 text-white py-3 px-10 rounded-full font-bold transition-all duration-300 shadow-lg shadow-primary/30 hover:scale-105 active:scale-95 uppercase tracking-widest text-xs">
                Cargar Chat
            </button>
        </div>
    </div>
    
    <!-- Header -->
    <div class="p-3 px-5 bg-black/40 border-b border-white/5 flex justify-between items-center backdrop-blur-md">
        <div class="flex items-center gap-2.5 text-[0.65rem] font-bold text-red-500 bg-red-500/10 px-3 py-1 rounded-full uppercase tracking-widest">
            <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
            EN DIRECTO
        </div>
        <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-tighter">Chat de Estreno</h3>
    </div>
    
    <!-- Área de Mensajes -->
    <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-4 scroll-smooth custom-scrollbar" id="chat-messages">
        <div id="pinned-message-container" class="hidden"></div>
        <div class="text-center text-[0.75rem] text-slate-500 opacity-60 mb-2 italic">Bienvenido al chat en directo. Sé respetuoso.</div>
        <!-- Mensajes inyectados aquí -->
    </div>

    <!-- Área de Input -->
    <div class="p-4 bg-black/40 border-t border-white/5 backdrop-blur-xl">
        {(!currentUserSafe) && (
            <input 
                type="text" 
                id="guest-name-input" 
                placeholder="Tu nombre para chatear..." 
                class="w-full mb-3 p-2.5 px-4 rounded-xl border border-white/10 bg-black/20 text-white text-sm focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/30 transition-all" 
                autocomplete="off" 
            />
        )}
        <div class="flex gap-2.5">
            <input 
                type="text" 
                id="chat-input" 
                placeholder={currentUserSafe ? `Escribe como ${currentUserSafe.name}...` : "Escribe un mensaje..."} 
                class="flex-1 p-2.5 px-5 rounded-full border border-white/10 bg-black/20 text-white text-sm focus:outline-none focus:border-primary/50 focus:ring-1 focus:ring-primary/30 transition-all"
                autocomplete="off" 
            />
            <button 
                id="send-btn" 
                type="button" 
                aria-label="Enviar"
                class="bg-primary text-white w-10 h-10 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110 active:scale-95 shadow-lg shadow-primary/20"
            >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M22 2L11 13M22 2L15 22L11 13L2 9L22 2Z" />
                </svg>
            </button>
        </div>
        
        <!-- Reacciones -->
        <div class="flex justify-center gap-4 mt-4">
            <button class="reaction-btn text-xl p-1.5 transition-all duration-200 hover:scale-125 hover:rotate-6 active:scale-90" data-type="heart">❤️</button>
            <button class="reaction-btn text-xl p-1.5 transition-all duration-200 hover:scale-125 hover:rotate-6 active:scale-90" data-type="fire">🔥</button>
            <button class="reaction-btn text-xl p-1.5 transition-all duration-200 hover:scale-125 hover:rotate-6 active:scale-90" data-type="clap">👏</button>
            <button class="reaction-btn text-xl p-1.5 transition-all duration-200 hover:scale-125 hover:rotate-6 active:scale-90" data-type="100">💯</button>
        </div>
        
        <div id="reactions-container" class="fixed inset-0 pointer-events-none overflow-hidden z-[9999]"></div>
        <div id="live-chat-toast" class="fixed bottom-10 left-1/2 -translate-x-1/2 bg-slate-900/95 text-white p-3 px-6 rounded-xl text-sm z-[1000] shadow-2xl border border-white/10 transition-all duration-300 opacity-0 translate-y-4 pointer-events-none"></div>
        
        <div id="live-chat-confirm" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden items-center justify-center z-[2000] p-4">
             <div class="bg-slate-900 p-6 rounded-2xl border border-white/10 w-full max-w-[320px] shadow-2xl text-center animate-fade-in-up">
                 <p id="confirm-text" class="mb-6 text-white font-medium leading-relaxed"></p>
                 <div class="flex gap-3 justify-center">
                     <button id="confirm-cancel" class="flex-1 p-2.5 rounded-xl bg-white/5 text-slate-400 hover:bg-white/10 transition-all text-sm font-semibold">Cancelar</button>
                     <button id="confirm-ok" class="flex-1 p-2.5 rounded-xl bg-primary text-white hover:bg-primary/90 transition-all text-sm font-semibold">Confirmar</button>
                 </div>
             </div>
        </div>
    </div>
</div>

<style is:global>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
    @keyframes floatUp {
        0% { transform: translateY(0) scale(1); opacity: 1; }
        100% { transform: translateY(-30vh) scale(1.5) rotate(15deg); opacity: 0; }
    }
    .floating-emoji {
        position: absolute;
        font-size: 24px;
        animation: floatUp 2s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
        bottom: 0;
        pointer-events: none;
    }
</style>

<script>
    interface ChatUser {
        name: string;
        avatar: string;
        isVerified: boolean;
        userId?: string;
    }

    interface ChatMessage {
        _id: string;
        user: ChatUser;
        content: string;
        createdAt: string;
        isPinned?: boolean;
    }

    interface SafeUser {
        name: string;
        role: string;
        picture?: string;
    }

    class LiveChat {
        el: HTMLElement;
        slug: string;
        currentUser: SafeUser | null;
        msgArea: HTMLElement;
        input: HTMLInputElement;
        guestInput: HTMLInputElement | null;
        sendBtn: HTMLElement;
        lastPollTime: number = 0;
        polling: number | undefined;
        reactionsContainer: HTMLElement | null;
        pinnedContainer: HTMLElement | null;
        toastEl: HTMLElement | null;
        confirmEl: HTMLElement | null;
        confirmCallback: (() => void) | null = null;
        isLoaded: boolean = false;
        overlay: HTMLElement | null;
        loadBtn: HTMLElement | null;
    
        // POLLING CONFIG
        baseInterval = 20000;
        idleInterval = 60000;
        idleThreshold = 120000;
        currentInterval = 20000;
        lastInteractionTime = Date.now();
        isTabVisible = true;
    
        constructor(el: HTMLElement) {
            this.el = el;
            this.slug = el.dataset.slug || '';
            const encoded = el.dataset.currentUser || '';
            try {
                this.currentUser = encoded ? JSON.parse(decodeURIComponent(escape(atob(encoded)))) : null;
            } catch(e) {
                this.currentUser = null;
            }
            
            this.msgArea = el.querySelector('#chat-messages') as HTMLElement;
            this.input = el.querySelector('#chat-input') as HTMLInputElement;
            this.guestInput = el.querySelector('#guest-name-input') as HTMLInputElement | null;
            this.sendBtn = el.querySelector('#send-btn') as HTMLElement;
            this.reactionsContainer = el.querySelector('#reactions-container');
            this.pinnedContainer = el.querySelector('#pinned-message-container');
            this.toastEl = el.querySelector('#live-chat-toast');
            this.confirmEl = el.querySelector('#live-chat-confirm');
            this.overlay = el.querySelector('#chat-load-overlay');
            this.loadBtn = el.querySelector('#load-chat-btn');
            
            this.init();
        }

        init() {
            if (this.loadBtn) {
                this.loadBtn.addEventListener('click', () => {
                    this.enableChat();
                });
            }

            // Interaction tracking
            const track = () => this.recordInteraction();
            this.el.addEventListener('mousemove', track);
            this.el.addEventListener('click', track);
            this.el.addEventListener('touchstart', track);

            // Visibility detection
            document.addEventListener('visibilitychange', () => {
                this.isTabVisible = document.visibilityState === 'visible';
                if (this.isTabVisible && this.isLoaded) {
                    this.resetInterval();
                    this.fetchMessages();
                } else {
                    this.stopPolling();
                }
            });
            
            // Reaction Buttons
            const reactionBtns = this.el.querySelectorAll('.reaction-btn');
            reactionBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                   this.recordInteraction();
                   const type = (btn as HTMLElement).dataset.type;
                   if(type) this.sendReaction(type); 
                });
            });
            
            // Modal Events
            this.el.querySelector('#confirm-cancel')?.addEventListener('click', () => {
                if(this.confirmEl) this.confirmEl.style.display = 'none';
            });
            
            this.el.querySelector('#confirm-ok')?.addEventListener('click', () => {
                if(this.confirmCallback) this.confirmCallback();
                if(this.confirmEl) this.confirmEl.style.display = 'none';
            });
        }

        recordInteraction() {
            if (!this.isLoaded) return;
            this.lastInteractionTime = Date.now();
            if (this.currentInterval !== this.baseInterval && this.isTabVisible) {
                this.resetInterval();
            }
        }

        enableChat() {
            this.isLoaded = true;
            if (this.overlay) {
                this.overlay.classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => this.overlay?.remove(), 500);
            }
            
            this.sendBtn.addEventListener('click', () => {
                this.recordInteraction();
                this.sendMessage();
            });
            this.input.addEventListener('keypress', (e) => {
                this.recordInteraction();
                if(e.key === 'Enter') this.sendMessage();
            });

            this.fetchMessages();
            this.startPolling();
        }

        resetInterval() {
            this.currentInterval = this.baseInterval;
            this.startPolling();
        }

        startPolling() {
            this.stopPolling();
            if (!this.isTabVisible || !this.isLoaded) return;
            this.polling = window.setInterval(() => {
                const idleTime = Date.now() - this.lastInteractionTime;
                if (idleTime > this.idleThreshold) {
                    if (this.currentInterval !== this.idleInterval) {
                        this.currentInterval = this.idleInterval;
                        this.startPolling();
                    }
                }
                this.fetchMessages();
            }, this.currentInterval);
        }

        stopPolling() {
            if (this.polling) clearInterval(this.polling);
            this.polling = undefined;
        }

        animateMessageDelete(id: string) {
            const el = this.msgArea.querySelector(`[data-id="${id}"]`) as HTMLElement;
            if (el) {
                el.classList.add('opacity-0', 'translate-x-10');
                setTimeout(() => el.remove(), 300);
            }
        }
        
        showToast(msg: string, type: 'success' | 'error' = 'success') {
            if(!this.toastEl) return;
            this.toastEl.textContent = msg;
            this.toastEl.classList.remove('opacity-0', 'translate-y-4');
            this.toastEl.classList.add('opacity-100', 'translate-y-0');
            if (type === 'error') this.toastEl.classList.add('border-red-500/50');
            else this.toastEl.classList.add('border-emerald-500/50');
            
            setTimeout(() => {
                if(this.toastEl) {
                   this.toastEl.classList.add('opacity-0', 'translate-y-4');
                   this.toastEl.classList.remove('opacity-100', 'translate-y-0', 'border-red-500/50', 'border-emerald-500/50');
                }
            }, 3000);
        }
        
        showConfirm(msg: string, onConfirm: () => void) {
            if(!this.confirmEl) return;
            const txt = this.confirmEl.querySelector('#confirm-text');
            if(txt) txt.textContent = msg;
            this.confirmCallback = onConfirm;
            this.confirmEl.style.display = 'flex';
        }
        
        async sendReaction(type: string) {
            this.spawnFloatingEmoji(type);
            try {
                fetch(`/api/live-chat/${this.slug}/reaction`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type })
                });
            } catch(e) {
                console.error("Reaction error", e);
            }
        }
        
        spawnFloatingEmoji(type: string) {
            if(!this.reactionsContainer) return;
            const emojiMap: Record<string, string> = { 'heart': '❤️', 'fire': '🔥', 'clap': '👏', '100': '💯' };
            const el = document.createElement('div');
            el.className = 'floating-emoji';
            el.textContent = emojiMap[type] || '❤️';
            el.style.left = `${Math.random() * 80 + 10}%`;
            el.style.animationDuration = `${1.5 + Math.random()}s`;
            this.reactionsContainer.appendChild(el);
            setTimeout(() => el.remove(), 2500);
        }

        async fetchMessages() {
            if (!this.isTabVisible || !this.isLoaded) return;
            try {
                let url = `/api/live-chat/${this.slug}`;
                if (this.lastPollTime > 0) url += `?since=${this.lastPollTime}`;
                
                const res = await fetch(url);
                const data = await res.json();
                
                if(data.success) {
                    if (data.timestamp) this.lastPollTime = data.timestamp;
                    this.renderPinnedMessage(data.pinnedMessage || null);
                    if (data.messages && Array.isArray(data.messages)) this.renderMessages(data.messages);
                    
                    if (data.deletedIds && Array.isArray(data.deletedIds)) {
                        data.deletedIds.forEach((id: string) => this.animateMessageDelete(id));
                    }

                    if (data.reactions && Object.keys(data.reactions).length > 0) {
                        Object.keys(data.reactions).forEach(type => {
                            const count = Math.min(data.reactions[type], 5);
                            for(let i=0; i<count; i++) {
                                setTimeout(() => this.spawnFloatingEmoji(type), Math.random() * 2000);
                            }
                        });
                    }
                }
            } catch(e) {
                console.error("Chat fetch error", e);
            }
        }

        async sendMessage() {
            const text = this.input.value.trim();
            if(!text) return;
            
            let guestName = null;
            if(!this.currentUser) {
                if(this.guestInput) {
                    guestName = this.guestInput.value.trim();
                    if(!guestName) {
                        this.showToast("Introduce tu nombre.", "error");
                        this.guestInput.focus();
                        return;
                    }
                }
            }

            const originalValue = this.input.value;
            this.input.value = '';
            
            try {
                const res = await fetch(`/api/live-chat/${this.slug}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text, guestName })
                });
                const data = await res.json();
                if(data.success && data.message) {
                    this.renderMessages([data.message]);
                } else {
                    this.input.value = originalValue;
                    this.showToast(data.error || "Error enviando", "error");
                }
            } catch(e) {
                this.input.value = originalValue;
                this.showToast("Error de conexión.", "error");
            }
        }

        renderMessages(messages: ChatMessage[]) {
            messages.forEach(msg => {
                const exists = this.msgArea.querySelector(`[data-id="${msg._id}"]`);
                if(!exists) {
                    const msgEl = this.createMessageElement(msg);
                    this.msgArea.appendChild(msgEl);
                    this.msgArea.scrollTop = this.msgArea.scrollHeight;
                }
            });
        }

        renderPinnedMessage(msg: ChatMessage | null) {
            if (!this.pinnedContainer) return;
            if (!msg) {
                this.pinnedContainer.classList.add('hidden');
                this.pinnedContainer.innerHTML = '';
                return;
            }
            
            this.pinnedContainer.classList.remove('hidden');
            this.pinnedContainer.className = 'flex items-start gap-3 bg-primary/10 border-l-4 border-primary p-3 rounded-lg sticky top-0 z-10 backdrop-blur-md mb-4 animate-fade-in-up';
            this.pinnedContainer.innerHTML = `
                <div class="text-primary mt-1">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M16 2a2 2 0 0 1 2 2v6h2a1 1 0 0 1 1 1v2H3v-2a1 1 0 0 1 1-1h2V4a2 2 0 0 1 2-2h8zM6 14v-2h12v2H6zm0 2h12v2a1 1 0 0 1-1 1h-4v4h-2v-4H7a1 1 0 0 1-1-1v-2z"/></svg>
                </div>
                <div class="flex-1">
                    <div class="text-[0.7rem] font-bold text-primary uppercase tracking-wider">${this.escapeHtml(msg.user.name)}</div>
                    <div class="text-xs text-white leading-tight">${this.escapeHtml(msg.content)}</div>
                </div>
                ${this.currentUser && (this.currentUser.role === 'admin' || this.currentUser.role === 'owner') ? `
                <button class="unpin-btn text-white/40 hover:text-white transition-colors">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
                ` : ''}
            `;
            
            this.pinnedContainer.querySelector('.unpin-btn')?.addEventListener('click', () => {
                this.togglePin(msg._id, false);
            });
        }

        createMessageElement(msg: ChatMessage) {
            const div = document.createElement('div');
            div.className = 'flex gap-3 animate-fade-in-up transition-all duration-300';
            div.dataset.id = msg._id;
            
            const isAdmin = this.currentUser && (this.currentUser.role === 'admin' || this.currentUser.role === 'owner');
            
            div.innerHTML = `
                <img src="${this.escapeHtml(msg.user.avatar)}" alt="${this.escapeHtml(msg.user.name)}" class="w-8 h-8 rounded-full bg-slate-800 shadow-md">
                <div class="flex-1 min-w-0">
                    <div class="flex items-baseline gap-2 mb-0.5">
                        <span class="text-xs font-bold ${msg.user.isVerified ? 'text-primary' : 'text-slate-400'} truncate">
                            ${this.escapeHtml(msg.user.name)}
                            ${msg.user.isVerified ? '✓' : ''}
                        </span>
                        ${isAdmin ? `
                        <div class="ml-auto flex gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button class="pin-msg-btn p-1 rounded-full bg-blue-500/10 text-blue-400 hover:bg-blue-500 hover:text-white transition-all" title="Fijar">
                                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
                            </button>
                            <button class="ban-user-btn p-1 rounded-full bg-yellow-500/10 text-yellow-500 hover:bg-yellow-500 hover:text-white transition-all" title="Bloquear">
                                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                            </button>
                            <button class="del-msg-btn p-1 rounded-full bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-all" title="Borrar">
                                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </button>
                        </div>` : ''}
                    </div>
                    <div class="text-[0.85rem] text-slate-200 leading-relaxed break-words">${this.escapeHtml(msg.content)}</div>
                </div>
            `;
            
            if(isAdmin) {
                div.classList.add('group');
                div.querySelector('.del-msg-btn')?.addEventListener('click', () => this.deleteMessage(msg._id, div));
                div.querySelector('.ban-user-btn')?.addEventListener('click', () => this.banUser(msg._id, msg.user.name));
                div.querySelector('.pin-msg-btn')?.addEventListener('click', () => this.togglePin(msg._id, true));
            }
            return div;
        }
        
        async banUser(messageId: string, userName: string) {
            this.showConfirm(`¿Bloquear permanentemente a ${userName}?`, async () => {
                try {
                    const res = await fetch(`/api/live-chat/${this.slug}/ban`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ messageId })
                    });
                    const data = await res.json();
                    if(data.success) this.showToast(`Usuario bloqueado.`, "success");
                    else this.showToast('Error: ' + data.error, "error");
                } catch(e) { this.showToast('Error de conexión', "error"); }
            });
        }
        
        async togglePin(messageId: string, isPinned: boolean) {
            try {
                const res = await fetch(`/api/live-chat/message/${messageId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ isPinned })
                });
                const data = await res.json();
                if(data.success) {
                    this.renderPinnedMessage(isPinned ? data.message : null);
                    this.showToast(isPinned ? "Fijado" : "Desfijado", "success");
                } else this.showToast(data.error || "Error", "error");
            } catch(e) { this.showToast("Error de conexión", "error"); }
        }

        async deleteMessage(id: string, el: HTMLElement) {
            el.style.opacity = '0.3';
            try {
                const res = await fetch(`/api/live-chat/message/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if(data.success) {
                    this.animateMessageDelete(id);
                    this.showToast("Eliminado", "success");
                } else {
                    el.style.opacity = '1';
                    this.showToast(data.error || "Error", "error");
                }
            } catch(e) {
                el.style.opacity = '1';
                this.showToast("Error de conexión", "error");
            }
        }

        escapeHtml(text: string): string {
             const div = document.createElement('div');
             div.textContent = text;
             return div.innerHTML;
        }

        destroy() {
             this.stopPolling();
        }
    }

    let activeChat: LiveChat | null = null;
    const initChat = () => {
        if(activeChat) {
            activeChat.destroy();
            activeChat = null;
        }
        const el = document.getElementById('live-chat-widget');
        if(el) activeChat = new LiveChat(el);
    };

    document.addEventListener('DOMContentLoaded', initChat);
    document.addEventListener('astro:page-load', initChat);
</script>
