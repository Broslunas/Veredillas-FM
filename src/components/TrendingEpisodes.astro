---
// src/components/TrendingEpisodes.astro
---


<section id="trending-section" class="py-16 relative overflow-hidden contain-content">
  <!-- Background Elements -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-primary blur-[80px] opacity-10 rounded-full -z-10"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-500 blur-[80px] opacity-10 rounded-full -z-10"></div>

  <div class="w-full max-w-[1280px] mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8">
      <h2 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-white to-purple-200 bg-clip-text text-transparent">
        Tendencias
      </h2>
      
      <!-- Time Period Toggle -->
      <div class="flex items-center gap-2 bg-white/5 p-1 rounded-full border border-white/10 backdrop-blur-sm mt-4 md:mt-0">
        <button id="trend-week-btn" class="px-4 py-1.5 rounded-full text-sm font-medium transition-all text-zinc-400 hover:text-white hover:bg-white/5 active [&.active]:bg-primary [&.active]:text-white [&.active]:shadow-[0_10px_15px_-3px_rgba(124,58,237,0.2)] bg-transparent border-none cursor-pointer">
          Semana
        </button>
        <button id="trend-month-btn" class="px-4 py-1.5 rounded-full text-sm font-medium transition-all text-zinc-400 hover:text-white hover:bg-white/5 active [&.active]:bg-primary [&.active]:text-white [&.active]:shadow-[0_10px_15px_-3px_rgba(124,58,237,0.2)] bg-transparent border-none cursor-pointer">
          Mes
        </button>
      </div>
    </div>

    <!-- Loading State -->
    <div id="trending-loading" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        {[1,2,3].map(i => (
            <div class="h-24 bg-white/5 rounded-xl border border-white/5 animate-pulse"></div>
        ))}
    </div>

    <!-- Content Grid -->
    <div id="trending-grid" class="hidden grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        <!-- Filled by JS -->
    </div>

  </div>
</section>

<script>
  let currentPeriod = 'week';
  
  const section = document.getElementById('trending-section');
  const grid = document.getElementById('trending-grid');
  const loading = document.getElementById('trending-loading');
  const btnWeek = document.getElementById('trend-week-btn');
  const btnMonth = document.getElementById('trend-month-btn');

  async function fetchTrending(period: string) {
    if(!grid || !loading || !section) return;
    
    // UI Loading
    loading.classList.remove('hidden');
    grid.classList.add('hidden');
    section.style.display = ''; 
    
    try {
        const res = await fetch(`/api/episodes/trending?period=${period}`);
        const data = await res.json();
        
        loading.classList.add('hidden');
        
        if (!data || data.length === 0) {
            section.style.display = 'none';
            return;
        }
        
        renderTrending(data);
        grid.classList.remove('hidden');
        grid.style.display = 'grid'; // Ensure it shows as grid
        
    } catch(e) {
        console.error("Error fetching trending:", e);
        loading.classList.add('hidden');
        section.style.display = 'none';
    }
  }

  function renderTrending(items: any[]) {
      if(!grid) return;
      grid.innerHTML = '';
      
      items.forEach((item: any, index: number) => {
          const rank = index + 1;
          const isTop3 = rank <= 3;
          
          const card = document.createElement('a');
          card.href = `/ep/${item.slug}`;
          card.className = `flex items-center gap-4 p-3 rounded-xl border border-white/5 bg-white/5 cursor-pointer overflow-hidden relative text-decoration-none transition-all duration-300 hover:bg-white/10 hover:border-purple-500/30 hover:shadow-[0_10px_15px_-3px_rgba(168,85,247,0.1)] hover-3d-card group`;
          card.setAttribute('data-cursor', 'play');
          
          card.innerHTML = `
            <div class="shine"></div>
            <!-- Rank Badge -->
            <div class="flex-shrink-0 w-8 text-center font-bold text-xl ${isTop3 ? 'text-purple-400' : 'text-zinc-500'}">
                ${rank}
            </div>
            
            <!-- Image -->
            <div class="relative w-16 h-16 rounded-lg overflow-hidden flex-shrink-0 shadow-md">
                <img src="${item.image || '/logo.webp'}" alt="${item.title}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" style="transform: translateZ(10px);" loading="lazy" />
                <div class="absolute inset-0 bg-black/20 group-hover:bg-transparent transition-colors duration-300"></div>
            </div>
            
            <!-- Info -->
            <div class="flex-1 min-w-0">
                <h3 class="text-white font-medium whitespace-nowrap overflow-hidden text-ellipsis pr-2 transition-colors duration-300 group-hover:text-purple-300 m-0 text-base" title="${item.title}">
                    ${item.title}
                </h3>
                <p class="text-[0.75rem] text-zinc-400 whitespace-nowrap overflow-hidden text-ellipsis mt-0.5 m-0">${item.author || 'Veredillas FM'}</p>
                
                <div class="flex items-center gap-3 mt-1.5 opacity-80">
                    <span class="text-[0.625rem] text-zinc-500 flex items-center gap-1 bg-black/20 px-1.5 py-0.5 rounded">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                        ${item.count}
                    </span>
                    <span class="text-[0.625rem] text-zinc-500">
                       ${item.duration ? (isNaN(item.duration) ? item.duration : Math.floor(item.duration/60) + ' min') : ''}
                    </span>
                </div>
            </div>
            
            <!-- Play Action -->
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white opacity-0 translate-x-4 transition-all duration-300 shadow-lg group-hover:opacity-100 group-hover:translate-x-0 group-hover:bg-purple-500 group-hover:scale-105" aria-label="Reproducir">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </div>
          `;
          
          grid.appendChild(card);
      });
  }

  // Event Listeners
  if(btnWeek && btnMonth) {
      btnWeek.onclick = () => {
          if(currentPeriod === 'week') return;
          currentPeriod = 'week';
          updateToggleUI();
          fetchTrending('week');
      };
      
      btnMonth.onclick = () => {
          if(currentPeriod === 'month') return;
          currentPeriod = 'month';
          updateToggleUI();
          fetchTrending('month');
      };
  }

  function updateToggleUI() {
      if(currentPeriod === 'week') {
          btnWeek?.classList.add('active');
          btnMonth?.classList.remove('active');
      } else {
          btnMonth?.classList.add('active');
          btnWeek?.classList.remove('active');
      }
  }

  // Init
  fetchTrending('week');
  document.addEventListener('astro:page-load', () => fetchTrending(currentPeriod));

</script>
