---
import ShareCardGenerator from './ShareCardGenerator.astro';
import { getProxiedAudioUrl } from '../utils/audioProxy';

interface Props {
  title: string;
  audioUrl?: string;
  image?: string;
  guests?: string[];
  slug?: string;
  duration?: number | string;
  className?: string;
}

const { title, audioUrl, image, guests, slug, duration, className = '' } = Astro.props;
const normImage = image ? (image.startsWith('http') || image.startsWith('/') ? image : `/${image}`) : '/logo.webp';
---

<div class:list={["flex flex-wrap items-center justify-center gap-3 max-[600px]:grid max-[600px]:grid-cols-1", className]}>
    <!-- Create Clip -->
    <button 
        id="action-create-clip" 
        class="inline-flex items-center justify-center gap-[10px] bg-[#27272a] border border-white/10 px-6 py-3 rounded-[100px] color-white cursor-pointer no-underline transition-all duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] text-[0.95rem] font-semibold min-w-[140px] hover:bg-[#3f3f46] hover:border-white/20 hover:-translate-y-0.5 max-[600px]:w-full max-[600px]:py-3.5 max-[600px]:text-base" 
        data-audio-url={getProxiedAudioUrl(audioUrl)} 
        data-title={title} 
        data-image={image} 
        data-duration={duration}
    >
        <span class="flex items-center justify-center text-inherit max-[600px]:w-5 max-[600px]:h-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"></circle><path d="M8.12 8.12 12 12"></path><circle cx="6" cy="18" r="3"></circle><path d="M14.8 14.8 20 20"></path><path d="M8.12 15.88 12 12"></path><path d="M14.8 9.2 20 4"></path></svg>
        </span>
        <span>Crear Clip</span>
    </button>

    <!-- Create Story -->
    <button 
        id="action-create-story" 
        class="inline-flex items-center justify-center gap-[10px] bg-[#27272a] border border-white/10 px-6 py-3 rounded-[100px] color-white cursor-pointer no-underline transition-all duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] text-[0.95rem] font-semibold min-w-[140px] hover:bg-[#3f3f46] hover:border-white/20 hover:-translate-y-0.5 max-[600px]:w-full max-[600px]:py-3.5 max-[600px]:text-base"
    >
        <span class="flex items-center justify-center text-inherit max-[600px]:w-5 max-[600px]:h-5">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
        </span>
        <span>Historia</span>
    </button>

    <!-- Comments -->
    <a 
        href="#comments-wrapper" 
        class="inline-flex items-center justify-center gap-[10px] bg-[#27272a] border border-white/10 px-6 py-3 rounded-[100px] color-white cursor-pointer no-underline transition-all duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] text-[0.95rem] font-semibold min-w-[140px] hover:bg-[#3f3f46] hover:border-white/20 hover:-translate-y-0.5 max-[600px]:w-full max-[600px]:py-3.5 max-[600px]:text-base"
    >
        <span class="flex items-center justify-center text-inherit max-[600px]:w-5 max-[600px]:h-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
        </span>
        <span>Comentarios</span>
    </a>

    <!-- Share Modal Trigger -->
    <button 
        id="action-share-episode" 
        class="inline-flex items-center justify-center gap-[10px] bg-[#27272a] border border-white/10 px-6 py-3 rounded-[100px] color-white cursor-pointer no-underline transition-all duration-200 ease-[cubic-bezier(0.4,0,0.2,1)] text-[0.95rem] font-semibold min-w-[140px] hover:bg-primary/20 hover:border-primary/30 hover:-translate-y-0.5 max-[600px]:w-full max-[600px]:py-3.5 max-[600px]:text-base"
    >
        <span class="flex items-center justify-center text-inherit max-[600px]:w-5 max-[600px]:h-5">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
        </span>
        <span>Compartir</span>
    </button>
</div>


<!-- The Hidden Generator Component -->
<ShareCardGenerator 
    title={title} 
    image={normImage} 
    guests={guests} 
    triggerId="action-create-story" 
/>

<script>
    declare global {
        interface Window {
            playerCurrentUrl: string | null;
            playerMeta: any;
        }
    }

    const setupActions = () => {
        const shareBtn = document.getElementById('action-share-episode');
        console.log('[EpisodeActions] Setup. Share button found:', !!shareBtn);
        
        if (shareBtn) {
            shareBtn.addEventListener('click', (e) => {
                 e.preventDefault();
                 console.log('[EpisodeActions] Share button clicked. Dispatching event.');
                 window.dispatchEvent(new CustomEvent('veredillas:open-share-modal'));
            });
        }

        const clipBtn = document.querySelector('#action-create-clip');
        if (clipBtn) {
            clipBtn.addEventListener('click', () => {
                const url = clipBtn.getAttribute('data-audio-url');
                const title = clipBtn.getAttribute('data-title');
                const image = clipBtn.getAttribute('data-image');
                const duration = clipBtn.getAttribute('data-duration');
                
                if (url) {
                    const evt = new CustomEvent('veredillas:open-clip-editor', {
                         detail: {
                             audioUrl: url,
                             title: title || 'Episodio',
                             author: 'Veredillas FM',
                             cover: image || '/logo.webp',
                             duration: duration ? parseFloat(duration) : 0
                         }
                     });
                     window.dispatchEvent(evt);
                } else {
                    if (window.playerCurrentUrl) {
                         alert('Esta función solo está disponible si hay un archivo de audio directo (no Spotify).');
                    } else {
                         alert('No hay fuente de audio disponible para clips.');
                    }
                }
            });
        }
    };

    // Run on initial load and on view transitions navigation
    setupActions();
    document.addEventListener('astro:page-load', setupActions);
</script>

