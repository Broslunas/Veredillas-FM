---
import { Headphones, Trophy, TrendingUp, Sparkles, X, ChevronRight } from 'lucide-astro';
---

<div id="auth-prompt-modal" class="fixed inset-0 bg-zinc-950/75 backdrop-blur-xl z-[20000] flex items-center justify-center p-4 opacity-0 transition-opacity duration-500 pointer-events-none aria-[hidden=false]:opacity-100 aria-[hidden=false]:pointer-events-auto" style="display: none;" aria-hidden="true">
    <div class="auth-prompt-wrapper w-full max-w-[520px] perspective-[1000px]">
        <div class="auth-prompt-content glass-panel bg-zinc-900/90 border border-white/10 p-0 rounded-[2rem] relative overflow-hidden transition-transform duration-700 ease-out translate-y-10 -rotate-x-5 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.7),inset_0_0_80px_rgba(139,92,246,0.05)] max-h-[calc(100vh-2rem)] overflow-y-auto scrollbar-thin scrollbar-thumb-violet-600 scrollbar-track-transparent">
            <button id="close-auth-prompt" class="absolute top-5 right-5 w-9 h-9 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-zinc-400 cursor-pointer transition-all hover:bg-red-500/10 hover:text-red-500 hover:border-red-500/20 hover:rotate-90 z-20" aria-label="Cerrar">
                <X size={20} />
            </button>
            
            <div class="prompt-visual h-[140px] bg-gradient-to-br from-violet-600/20 to-pink-500/20 relative flex items-center justify-center overflow-hidden">
                <div class="visual-glow absolute w-[150px] h-[150px] bg-[radial-gradient(circle,rgba(139,92,246,0.5)_0%,transparent_70%)] blur-[20px] animate-[pulse_4s_ease-in-out_infinite]"></div>
                <div class="visual-icon-container relative z-[2] bg-white/10 backdrop-blur-sm w-20 h-20 rounded-[24px] flex items-center justify-center border border-white/20 shadow-xl -rotate-[5deg] animate-[floatIcon_6s_ease-in-out_infinite]">
                    <Sparkles class="text-white drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]" size={48} />
                </div>
                <!-- Blobs -->
                <div class="absolute inset-0 z-[1] overflow-hidden pointer-events-none">
                    <div class="absolute -top-5 -left-5 w-[120px] h-[120px] bg-violet-600 rounded-full blur-[40px] opacity-30"></div>
                    <div class="absolute -bottom-5 -right-5 w-[100px] h-[100px] bg-pink-500 rounded-full blur-[40px] opacity-30"></div>
                </div>
            </div>

            <div class="prompt-text p-8 md:p-10 pb-6 text-center">
                <div class="prompt-header">
                    <span class="inline-block px-3 py-1 bg-violet-600/15 text-violet-400 rounded-full text-[0.75rem] font-bold uppercase tracking-wider mb-3 border border-violet-600/20">Estatus de Oyente</span>
                    <h3 class="text-2xl md:text-2xl font-black leading-tight mb-4 bg-gradient-to-br from-white to-zinc-400 bg-clip-text text-transparent">¡Lleva tu experiencia al siguiente nivel!</h3>
                </div>
                
                <p class="text-zinc-400 mb-8 leading-relaxed text-[0.95rem]">
                    Únete a la comunidad de <strong class="text-white font-semibold">Veredillas FM</strong> para desbloquear funciones exclusivas y seguir tu progreso.
                </p>
                
                <div class="grid grid-cols-1 gap-3 text-left mb-4">
                    <div class="flex items-start gap-4 bg-white/[0.03] p-4 rounded-2xl border border-white/5 transition-all hover:bg-white/[0.06] hover:border-white/10 hover:translate-x-1 group">
                        <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-xl bg-gradient-to-br from-violet-600/20 to-violet-600/10 text-violet-400 border border-violet-600/10">
                            <Headphones size={20} strokeWidth={2.5} />
                        </div>
                        <div>
                            <h4 class="text-[0.9rem] font-bold text-white">Biblioteca Personal</h4>
                            <p class="text-[0.8rem] text-zinc-500 mt-0.5">Guarda tus episodios favoritos.</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4 bg-white/[0.03] p-4 rounded-2xl border border-white/5 transition-all hover:bg-white/[0.06] hover:border-white/10 hover:translate-x-1 group">
                        <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-xl bg-gradient-to-br from-violet-600/20 to-violet-600/10 text-violet-400 border border-violet-600/10">
                            <Trophy size={20} strokeWidth={2.5} />
                        </div>
                        <div>
                            <h4 class="text-[0.9rem] font-bold text-white">Logros y Rangos</h4>
                            <p class="text-[0.8rem] text-zinc-500 mt-0.5">Gana insignias por escuchar.</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4 bg-white/[0.03] p-4 rounded-2xl border border-white/5 transition-all hover:bg-white/[0.06] hover:border-white/10 hover:translate-x-1 group">
                        <div class="w-10 h-10 shrink-0 flex items-center justify-center rounded-xl bg-gradient-to-br from-violet-600/20 to-violet-600/10 text-violet-400 border border-violet-600/10">
                            <TrendingUp size={20} strokeWidth={2.5} />
                        </div>
                        <div>
                            <h4 class="text-[0.9rem] font-bold text-white">Estadísticas</h4>
                            <p class="text-[0.8rem] text-zinc-500 mt-0.5">Analiza tus hábitos de escucha.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="px-8 md:px-10 pb-4 flex flex-col gap-3">
                <a href="/login" class="group relative flex items-center justify-center gap-2 px-6 py-4 bg-gradient-to-r from-violet-600 to-pink-500 text-white rounded-[1.25rem] font-bold shadow-[0_10px_25px_-5px_rgba(139,92,246,0.5)] transition-all hover:-translate-y-0.5 hover:shadow-[0_15px_35px_-5px_rgba(139,92,246,0.6)] hover:brightness-110 overflow-hidden">
                    <span class="relative z-10">Crear mi cuenta gratis</span>
                    <ChevronRight class="relative z-10" size={18} />
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                </a>
                <button id="dismiss-auth-prompt" class="px-6 py-3.5 bg-white/5 border border-white/10 text-zinc-400 rounded-[1.25rem] font-semibold text-sm cursor-pointer transition-all hover:bg-white/10 hover:text-white hover:border-white/20">
                    Continuar como invitado
                </button>
            </div>
            
            <div class="px-8 md:px-10 py-8 pt-4 text-center text-[0.85rem] text-zinc-500">
                <p>¿Ya tienes cuenta? <a href="/login" class="text-violet-500 font-extrabold ml-1 hover:text-pink-500 hover:underline transition-colors">Inicia sesión</a></p>
            </div>
        </div>
    </div>
</div>

<style is:global>
    @keyframes floatIcon {
        0%, 100% { transform: translateY(0) rotate(-5deg); }
        50% { transform: translateY(-10px) rotate(5deg); }
    }

    #auth-prompt-modal[aria-hidden="false"] .auth-prompt-content {
        transform: translateY(0) rotateX(0);
    }
</style>

<script>
    const SHOW_DELAY = 45000; 
    const STORAGE_KEY = 'veredillas_auth_prompt_dismissed_v2'; 
    const VIEW_COUNT_KEY = 'veredillas_auth_prompt_views';

    function isUserLoggedIn() {
        return document.cookie.includes('user-session') || 
               localStorage.getItem('user-session') !== null ||
               (window as any).currentUser !== undefined;
    }

    function initAuthPrompt() {
        if (isUserLoggedIn()) return;

        const lastDismissed = localStorage.getItem(STORAGE_KEY);
        if (lastDismissed) {
            const timeSinceDismissal = Date.now() - parseInt(lastDismissed);
            const ONE_WEEK = 7 * 24 * 60 * 60 * 1000;
            if (timeSinceDismissal < ONE_WEEK) return;
        }

        if (sessionStorage.getItem(STORAGE_KEY)) return;

        if ((window as any).authPromptTimeout) clearTimeout((window as any).authPromptTimeout);

        (window as any).authPromptTimeout = setTimeout(() => {
            showPrompt();
        }, SHOW_DELAY);
    }
    
    function showPrompt() {
        const modal = document.getElementById('auth-prompt-modal');
        if (modal && !isUserLoggedIn() && !sessionStorage.getItem(STORAGE_KEY)) {
            modal.style.display = 'flex';
            modal.offsetHeight; 
            modal.setAttribute('aria-hidden', 'false');
            
            const views = parseInt(localStorage.getItem(VIEW_COUNT_KEY) || '0') + 1;
            localStorage.setItem(VIEW_COUNT_KEY, views.toString());
        }
    }

    function dismissPrompt(permanent = false) {
        const modal = document.getElementById('auth-prompt-modal');
        if (modal) {
            modal.setAttribute('aria-hidden', 'true');
            setTimeout(() => {
                modal.style.display = 'none';
            }, 600);
            
            sessionStorage.setItem(STORAGE_KEY, 'true');
            
            if (permanent) {
                localStorage.setItem(STORAGE_KEY, Date.now().toString());
            }
        }
    }

    // Initialize
    document.addEventListener('astro:page-load', initAuthPrompt);
    document.addEventListener('DOMContentLoaded', initAuthPrompt);

    // Event Delegation
    document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const closeBtn = target.closest('#close-auth-prompt');
        const dismissBtn = target.closest('#dismiss-auth-prompt');
        
        if (closeBtn || dismissBtn) {
            dismissPrompt(true); 
        }
        
        if (target.id === 'auth-prompt-modal') {
             dismissPrompt(false); 
        }
    });

    (window as any).triggerAuthPrompt = () => {
        if (!isUserLoggedIn()) {
            showPrompt();
        }
    };
</script>

