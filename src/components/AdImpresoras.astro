---
/**
 * AdImpresoras.astro
 * Componente de anuncio profesional para impresoras.veredillasfm.es
 * Soporta múltiples layouts: 'leaderboard', 'square', 'skyscraper', 'hero', 'minimal'
 */

interface Props {
  variant?: 'leaderboard' | 'square' | 'skyscraper' | 'hero' | 'minimal';
  class?: string;
  theme?: 'dark' | 'light' | 'dynamic';
}

const { 
  variant = 'hero', 
  class: className = '',
  theme = 'dynamic'
} = Astro.props;

const AD_URL = "https://impresoras.veredillasfm.es";

// Mapping of variants to dimensions/styles
const variantStyles = {
  leaderboard: "ad-leaderboard", // 728x90 approx
  square: "ad-square",           // 300x250 approx
  skyscraper: "ad-skyscraper",   // 160x600 or 300x600
  hero: "ad-hero",                 // Large featured area
  minimal: "ad-minimal"           // Small text-based or icon-based
};

const currentVariantClass = variantStyles[variant] || variantStyles.hero;
---

<div class={`ad-container ${currentVariantClass} ${theme === 'dynamic' ? 'theme-dynamic' : `theme-${theme}`} ${className}`} id="ad-impresoras">
  <a href={AD_URL} target="_blank" rel="noopener noreferrer" class="ad-link">
    
    <!-- Background Elements - Subtler -->
    <div class="ad-bg">
      <div class="ad-gradient-overlay"></div>
    </div>

    <!-- Content -->
    <div class="ad-content">
      {variant === 'hero' && (
        <div class="ad-hero-layout">
          <div class="ad-text-content">
            <span class="ad-badge">Servicio de Impresión Profesional</span>
            <h2 class="ad-title">Calidad que puedes <span class="text-gradient">tocar</span></h2>
            <p class="ad-desc">Desde documentos impecables hasta prototipos 3D. Rapidez y precisión para tus proyectos más exigentes.</p>
            <div class="ad-cta">Empezar ahora <span class="arrow">→</span></div>
          </div>
          <div class="ad-visual">
            <div class="ad-image-container">
              <img src="/ad-printer.png" alt="Impresión Profesional" class="ad-main-img" />
            </div>
          </div>
        </div>
      )}

      {variant === 'leaderboard' && (
        <div class="ad-leaderboard-layout">
          <div class="ad-lb-img">
            <img src="/ad-printer.png" alt="Printer" />
          </div>
          <div class="ad-lb-text">
            <h3 class="ad-title-lb">Impresión Láser y 3D Veredillas</h3>
            <p class="ad-desc-lb">Resultados profesionales. Visita impresoras.veredillasfm.es</p>
          </div>
          <div class="ad-cta-lb">Ver servicios</div>
        </div>
      )}

      {variant === 'square' && (
        <div class="ad-square-layout">
          <div class="ad-image-sq">
            <img src="/ad-printer.png" alt="Printer" />
          </div>
          <div class="ad-text-sq">
            <h3 class="ad-title-sq">¿Necesitas imprimir?</h3>
            <p class="ad-desc-sq">Láser, 3D y gran formato con acabado premium.</p>
            <div class="ad-cta-sq">Saber más</div>
          </div>
        </div>
      )}

      {variant === 'skyscraper' && (
        <div class="ad-skyscraper-layout">
          <div class="ad-logo-sky">
            <img src="/logo.webp" alt="VFM" />
          </div>
          <div class="ad-visual-sky">
             <img src="/ad-printer.png" alt="Printer" />
          </div>
          <div class="ad-text-sky">
             <h2>IMPRIME CON NOSOTROS</h2>
             <p>Calidad industrial a tu alcance.</p>
          </div>
          <div class="ad-cta-sky">Ver precios</div>
        </div>
      )}

      {variant === 'minimal' && (
        <div class="ad-minimal-layout">
          <img src="/logo.webp" alt="" class="min-logo" />
          <span class="min-sep"></span>
          <span>Impresión Profesional:</span>
          <span class="url">impresoras.veredillasfm.es</span>
        </div>
      )}
    </div>
  </a>
</div>

<style>
  /* Base Container */
  .ad-container {
    --primary: #8b5cf6;
    --secondary: #ec4899;
    --bg-dark: #0f0f12;
    --bg-light: #ffffff;
    --text-white: #ffffff;
    --text-black: #1a1a1b;
    
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    font-family: 'Outfit', 'Inter', system-ui, sans-serif;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: var(--bg-dark);
  }

  .ad-container:hover {
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);
  }

  .ad-link {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
  }

  /* Themes */
  .theme-light {
    background: var(--bg-light);
    color: var(--text-black);
    border-color: rgba(0,0,0,0.1);
  }
  
  :global([data-theme="light"]) .theme-dynamic {
    background: var(--bg-light);
    color: var(--text-black);
    border-color: rgba(0,0,0,0.1);
  }

  /* Background - More subtle */
  .ad-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .ad-gradient-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(139, 92, 246, 0.05), transparent 60%);
  }

  /* HERO VARIANT - Recalibrated */
  .ad-hero {
    min-height: 350px;
    padding: 2.5rem;
  }

  .ad-hero-layout {
    display: grid;
    grid-template-cols: 1.1fr 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .ad-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--primary);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .ad-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    letter-spacing: -0.03em;
    color: #fff;
  }

  :global([data-theme="light"]) .theme-dynamic .ad-title { color: var(--text-black); }

  .text-gradient {
    background: linear-gradient(135deg, #a78bfa, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .ad-desc {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 440px;
  }

  :global([data-theme="light"]) .theme-dynamic .ad-desc { color: #555; }

  .ad-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.75rem;
    background: #fff;
    color: #000;
    font-weight: 800;
    border-radius: 8px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  :global([data-theme="light"]) .theme-dynamic .ad-cta {
    background: var(--primary);
    color: #fff;
  }

  .ad-container:hover .ad-cta {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }

  .ad-image-container {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 30px 60px -12px rgba(0,0,0,0.5);
    background: #151518;
  }

  .ad-main-img { width: 100%; height: auto; display: block; object-fit: cover; }

  /* LEADERBOARD - Improved with image */
  .ad-leaderboard {
    height: 100px;
    padding: 0 1rem;
  }

  .ad-leaderboard-layout {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .ad-lb-img {
    width: 140px;
    height: 70px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .ad-lb-img img { width: 100%; height: 100%; object-fit: cover; }

  .ad-lb-text { flex: 1; }
  .ad-title-lb { font-weight: 800; font-size: 1.1rem; margin: 0 0 0.25rem 0; color: #fff; }
  :global([data-theme="light"]) .theme-dynamic .ad-title-lb { color: var(--text-black); }
  .ad-desc-lb { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin: 0; }
  :global([data-theme="light"]) .theme-dynamic .ad-desc-lb { color: #666; }

  .ad-cta-lb {
    padding: 0.5rem 1.25rem;
    background: var(--primary);
    color: #fff;
    border-radius: 6px;
    font-weight: 800;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  /* SQUARE */
  .ad-square {
    width: 300px;
    height: 250px;
    padding: 1rem;
  }
  
  .ad-square-layout {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.75rem;
    position: relative;
    z-index: 2;
  }

  .ad-image-sq {
    height: 120px;
    border-radius: 8px;
    overflow: hidden;
  }
  .ad-image-sq img { width: 100%; height: 100%; object-fit: cover; }
  .ad-title-sq { font-weight: 800; font-size: 1.1rem; margin: 0; color: #fff; }
  :global([data-theme="light"]) .theme-dynamic .ad-title-sq { color: var(--text-black); }
  .ad-desc-sq { font-size: 0.85rem; color: rgba(255,255,255,0.5); margin: 0; line-height: 1.4; }
  .ad-cta-sq { margin-top: auto; background: rgba(255,255,255,0.05); color: #fff; text-align: center; padding: 0.6rem; border-radius: 6px; font-weight: 700; border: 1px solid rgba(255,255,255,0.1); }
  :global([data-theme="light"]) .theme-dynamic .ad-cta-sq { background: #f3f4f6; color: #111; border-color: rgba(0,0,0,0.05); }

  /* SKYSCRAPER */
  .ad-skyscraper { width: 160px; height: 600px; padding: 1.25rem 1rem; }
  .ad-skyscraper-layout { display: flex; flex-direction: column; height: 100%; gap: 1.25rem; text-align: center; }
  .ad-logo-sky img { width: 40px; height: 40px; margin: 0 auto; border-radius: 8px; }
  .ad-visual-sky { flex: 1; border-radius: 6px; overflow: hidden; }
  .ad-visual-sky img { width: 100%; height: 100%; object-fit: cover; }
  .ad-text-sky h2 { font-size: 0.85rem; font-weight: 900; color: #fff; margin-bottom: 0.5rem; }
  .ad-text-sky p { font-size: 0.75rem; color: rgba(255,255,255,0.5); }
  .ad-cta-sky { padding: 0.75rem; background: var(--primary); color: #fff; border-radius: 6px; font-weight: 800; font-size: 0.8rem; }

  /* MINIMAL */
  .ad-minimal { padding: 0.6rem 1.25rem; border-radius: 30px; }
  .ad-minimal-layout { display: flex; align-items: center; gap: 0.75rem; font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,0.6); }
  :global([data-theme="light"]) .theme-dynamic .ad-minimal-layout { color: #555; }
  .min-logo { width: 18px; height: 18px; border-radius: 4px; }
  .min-sep { width: 1px; height: 12px; background: rgba(255,255,255,0.1); }
  .ad-minimal-layout .url { color: var(--primary); font-weight: 800; }

  @media (max-width: 768px) {
    .ad-hero-layout { grid-template-cols: 1fr; gap: 2rem; text-align: center; }
    .ad-desc { margin-left: auto; margin-right: auto; }
    .ad-leaderboard { height: auto; padding: 1.25rem; }
    .ad-leaderboard-layout { flex-direction: column; text-align: center; }
    .ad-lb-img { width: 100%; height: 100px; }
    .ad-cta-lb { width: 100%; }
  }
</style>

