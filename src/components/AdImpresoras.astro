---
/**
 * AdImpresoras.astro — Veredillas FM Impresiones @ Veredillas FM
 * Variantes: hero | leaderboard | square | skyscraper | minimal
 */
interface Props {
  variant?: 'hero' | 'leaderboard' | 'square' | 'skyscraper' | 'minimal';
  class?: string;
}

const { variant = 'leaderboard', class: className = '' } = Astro.props;
const URL = 'https://impresoras.veredillasfm.es';
---

{variant === 'hero' && (
  <a href={URL} target="_blank" rel="noopener noreferrer" class={`ad-hero ${className}`}>
    <div class="ad-hero__inner">
      <div class="ad-hero__content">
        <span class="ad-hero__tag">🖨️ Veredillas FM Impresiones</span>
        <h2 class="ad-hero__title">Impresión 3D <br/>de alta precisión</h2>
        <p class="ad-hero__desc">Lleva tus ideas al mundo físico con la tecnología más avanzada. Rápido, preciso y asequible.</p>
        <span class="ad-hero__btn">Solicitar impresión <span>→</span></span>
      </div>
      <div class="ad-hero__visual">
        <img src="/ad-printer.webp" alt="Bambu Lab 3D Printer" class="ad-hero__img" />
        <div class="ad-hero__pill">impresoras.veredillasfm.es</div>
      </div>
    </div>
  </a>
)}

{variant === 'leaderboard' && (
  <a href={URL} target="_blank" rel="noopener noreferrer" class={`ad-lb ${className}`}>
    <div class="ad-lb__img-wrap">
      <img src="/ad-printer.webp" alt="Bambu Lab" />
    </div>
    <div class="ad-lb__divider"></div>
    <div class="ad-lb__body">
      <span class="ad-lb__tag">Veredillas FM Impresiones</span>
      <p class="ad-lb__title">Impresión 3D en el IES Las Veredillas</p>
    </div>
    <span class="ad-lb__cta">Ver catálogo →</span>
  </a>
)}

{variant === 'square' && (
  <a href={URL} target="_blank" rel="noopener noreferrer" class={`ad-sq ${className}`}>
    <div class="ad-sq__img-wrap">
      <img src="/ad-printer.webp" alt="Bambu Lab" />
      <div class="ad-sq__overlay">
        <span class="ad-sq__tag">Veredillas FM Impresiones</span>
      </div>
    </div>
    <div class="ad-sq__body">
      <p class="ad-sq__title">¿Necesitas <strong>impresión 3D</strong>?</p>
      <p class="ad-sq__desc">Precisión industrial, entrega rápida.</p>
      <span class="ad-sq__btn">Empezar →</span>
    </div>
  </a>
)}

{variant === 'skyscraper' && (
  <a href={URL} target="_blank" rel="noopener noreferrer" class={`ad-sky ${className}`}>
    <div class="ad-sky__logo">
      <img src="/logo.webp" alt="Veredillas FM" />
    </div>
    <div class="ad-sky__img">
      <img src="/ad-printer.webp" alt="Bambu Lab" />
    </div>
    <div class="ad-sky__body">
      <p class="ad-sky__title">Veredillas FM Impresiones</p>
      <p class="ad-sky__sub">Impresión 3D de alta gama en el Veredillas</p>
    </div>
    <span class="ad-sky__btn">Solicitar 3D</span>
    <span class="ad-sky__url">impresoras.veredillasfm.es</span>
  </a>
)}

{variant === 'minimal' && (
  <a href={URL} target="_blank" rel="noopener noreferrer" class={`ad-min ${className}`}>
    <img src="/logo.webp" alt="" class="ad-min__logo" />
    <span class="ad-min__text">Veredillas FM Impresiones</span>
    <span class="ad-min__sep">·</span>
    <span class="ad-min__url">impresoras.veredillasfm.es</span>
    <span class="ad-min__arrow">→</span>
  </a>
)}

<style>
  /* ─── SHARED TOKENS ─────────────────────────────────────── */
  :root {
    --ad-accent: #00c896;
    --ad-accent-dark: #00a57c;
    --ad-bg: #0d0d10;
    --ad-border: rgba(255,255,255,0.07);
    --ad-text: #f0f0f0;
    --ad-muted: rgba(240,240,240,0.5);
    --ad-font: 'Inter', 'Outfit', system-ui, sans-serif;
    --ad-radius: 14px;
  }

  /* ─── HERO ───────────────────────────────────────────────── */
  .ad-hero {
    display: block;
    text-decoration: none;
    background: linear-gradient(115deg, #0d0d10 0%, #111317 100%);
    border: 1px solid var(--ad-border);
    border-radius: var(--ad-radius);
    overflow: hidden;
    font-family: var(--ad-font);
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .ad-hero:hover {
    border-color: rgba(0, 200, 150, 0.3);
    box-shadow: 0 0 0 1px rgba(0,200,150,0.1), 0 24px 48px rgba(0,0,0,0.4);
  }
  .ad-hero__inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    align-items: center;
    gap: 0;
  }
  .ad-hero__content {
    padding: 2.25rem 2.5rem;
  }
  .ad-hero__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ad-accent);
    background: rgba(0,200,150,0.08);
    border: 1px solid rgba(0,200,150,0.2);
    border-radius: 99px;
    padding: 0.25rem 0.75rem;
    margin-bottom: 1.25rem;
  }
  .ad-hero__title {
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--ad-text);
    margin: 0 0 1rem 0;
  }
  .ad-hero__desc {
    font-size: 0.95rem;
    color: var(--ad-muted);
    line-height: 1.6;
    margin: 0 0 1.75rem 0;
    max-width: 380px;
  }
  .ad-hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: var(--ad-accent);
    color: #000;
    font-weight: 800;
    font-size: 0.85rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.2s;
  }
  .ad-hero:hover .ad-hero__btn {
    background: var(--ad-accent-dark);
    transform: translateY(-2px);
  }
  .ad-hero__visual {
    position: relative;
    height: 220px;
    overflow: hidden;
    border-left: 1px solid var(--ad-border);
  }
  .ad-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }
  .ad-hero:hover .ad-hero__img { transform: scale(1.04); }
  .ad-hero__pill {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.7);
    font-size: 0.65rem;
    font-weight: 600;
    font-family: var(--ad-font);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    white-space: nowrap;
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* ─── LEADERBOARD ───────────────────────────────────────── */
  .ad-lb {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    background: #0d0d10;
    border: 1px solid var(--ad-border);
    border-radius: var(--ad-radius);
    padding: 0.75rem 1.25rem 0.75rem 0.75rem;
    font-family: var(--ad-font);
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  .ad-lb:hover {
    border-color: rgba(0,200,150,0.3);
    box-shadow: 0 8px 24px rgba(0,0,0,0.35);
  }
  .ad-lb__img-wrap {
    width: 100px;
    height: 64px;
    border-radius: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .ad-lb__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .ad-lb__divider {
    width: 1px;
    height: 36px;
    background: var(--ad-border);
    flex-shrink: 0;
  }
  .ad-lb__body { flex: 1; min-width: 0; }
  .ad-lb__tag {
    display: block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ad-accent);
    margin-bottom: 0.2rem;
  }
  .ad-lb__title {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--ad-text);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ad-lb__cta {
    flex-shrink: 0;
    font-size: 0.8rem;
    font-weight: 800;
    color: var(--ad-accent);
    white-space: nowrap;
    transition: letter-spacing 0.2s;
  }
  .ad-lb:hover .ad-lb__cta { letter-spacing: 0.02em; }

  /* ─── SQUARE ────────────────────────────────────────────── */
  .ad-sq {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background: #0d0d10;
    border: 1px solid var(--ad-border);
    border-radius: var(--ad-radius);
    overflow: hidden;
    font-family: var(--ad-font);
    width: 280px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ad-sq:hover {
    border-color: rgba(0,200,150,0.3);
    box-shadow: 0 12px 32px rgba(0,0,0,0.4);
  }
  .ad-sq__img-wrap {
    position: relative;
    height: 140px;
    overflow: hidden;
  }
  .ad-sq__img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
  .ad-sq:hover .ad-sq__img-wrap img { transform: scale(1.05); }
  .ad-sq__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(13,13,16,0.8) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
  }
  .ad-sq__tag {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ad-accent);
    background: rgba(0,200,150,0.1);
    border: 1px solid rgba(0,200,150,0.25);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }
  .ad-sq__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1rem;
    gap: 0.4rem;
  }
  .ad-sq__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ad-text);
    margin: 0;
    line-height: 1.3;
  }
  .ad-sq__title strong { color: var(--ad-accent); font-weight: 900; }
  .ad-sq__desc {
    font-size: 0.8rem;
    color: var(--ad-muted);
    margin: 0;
  }
  .ad-sq__btn {
    margin-top: auto;
    display: block;
    text-align: center;
    padding: 0.55rem;
    background: var(--ad-accent);
    color: #000;
    font-weight: 800;
    font-size: 0.8rem;
    border-radius: 7px;
    transition: background 0.2s;
  }
  .ad-sq:hover .ad-sq__btn { background: var(--ad-accent-dark); }

  /* ─── SKYSCRAPER ────────────────────────────────────────── */
  .ad-sky {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    background: #0d0d10;
    border: 1px solid var(--ad-border);
    border-radius: var(--ad-radius);
    padding: 1.25rem 1rem;
    gap: 1rem;
    font-family: var(--ad-font);
    width: 160px;
    text-align: center;
    transition: border-color 0.2s;
  }
  .ad-sky:hover { border-color: rgba(0,200,150,0.3); }
  .ad-sky__logo img { width: 36px; height: 36px; border-radius: 8px; }
  .ad-sky__img {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    flex: 1;
    max-height: 280px;
  }
  .ad-sky__img img { width: 100%; height: 100%; object-fit: cover; }
  .ad-sky__body {}
  .ad-sky__title {
    font-size: 0.9rem;
    font-weight: 900;
    color: var(--ad-text);
    margin: 0 0 0.3rem;
    line-height: 1.2;
  }
  .ad-sky__sub {
    font-size: 0.72rem;
    color: var(--ad-muted);
    margin: 0;
    line-height: 1.4;
  }
  .ad-sky__btn {
    display: block;
    width: 100%;
    padding: 0.6rem;
    background: var(--ad-accent);
    color: #000;
    font-weight: 800;
    font-size: 0.78rem;
    border-radius: 7px;
    transition: background 0.2s;
  }
  .ad-sky:hover .ad-sky__btn { background: var(--ad-accent-dark); }
  .ad-sky__url {
    font-size: 0.6rem;
    color: var(--ad-muted);
    word-break: break-all;
  }

  /* ─── MINIMAL ───────────────────────────────────────────── */
  .ad-min {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--ad-border);
    border-radius: 99px;
    padding: 0.45rem 1rem 0.45rem 0.5rem;
    font-family: var(--ad-font);
    font-size: 0.8rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .ad-min:hover {
    border-color: rgba(0,200,150,0.3);
    background: rgba(0,200,150,0.05);
  }
  .ad-min__logo { width: 20px; height: 20px; border-radius: 50%; }
  .ad-min__text { font-weight: 700; color: var(--ad-text); }
  .ad-min__sep { color: var(--ad-muted); }
  .ad-min__url { color: var(--ad-accent); font-weight: 600; }
  .ad-min__arrow { color: var(--ad-muted); font-size: 0.75rem; transition: transform 0.2s; }
  .ad-min:hover .ad-min__arrow { transform: translateX(3px); }

  /* ─── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .ad-hero__inner { grid-template-columns: 1fr; }
    .ad-hero__visual { height: 180px; border-left: none; border-top: 1px solid var(--ad-border); }
    .ad-hero__content { padding: 1.75rem; }
    .ad-hero__title { font-size: 1.5rem; }

    .ad-lb { flex-wrap: wrap; }
    .ad-lb__img-wrap { width: 80px; height: 52px; }
    .ad-lb__divider { display: none; }

    .ad-sq { width: 100%; }
  }
</style>
