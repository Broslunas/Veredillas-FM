---
interface Props { yearListeningMinutes: number; yearListeningHours: number; percentile: number; avgMinutesPerSession: number; }
const { yearListeningMinutes, yearListeningHours, percentile, avgMinutesPerSession } = Astro.props;
---
<div class="story-slide bg-gradient-to-tr from-pink-600 via-rose-500 to-orange-500">
    <div class="absolute inset-0 bg-[url('/noise.png')] opacity-30 mix-blend-overlay"></div>
    <div class="absolute inset-0 pointer-events-none" id="particles-container"></div>
    <div class="slide-content text-center p-8 flex flex-col justify-center h-full relative z-10">
        <p class="text-2xl font-bold text-white mb-2 slide-fade">⏱ Pasamos juntos</p>
        <div class="text-[5rem] font-black text-white mb-1 slide-pop leading-none" style="text-shadow:0 0 40px rgba(255,255,255,0.5)">{yearListeningMinutes}</div>
        <p class="text-2xl font-bold text-white/90 slide-fade mb-2">minutos</p>
        {yearListeningHours > 0 && (
            <p class="text-white/70 slide-fade mb-4">Eso son <strong class="text-white">{yearListeningHours}h {yearListeningMinutes % 60}min</strong> de tu vida</p>
        )}
        <div class="grid grid-cols-2 gap-3 slide-fade-up">
            <div class="bg-black/20 backdrop-blur-md rounded-2xl p-4 border border-white/20">
                <h3 class="text-xs font-bold text-orange-200 uppercase tracking-widest mb-1">Lealtad Global</h3>
                <p class="text-4xl font-black text-white">Top {percentile}%</p>
                <p class="text-[10px] text-white/60 mt-1">entre todos los oyentes</p>
            </div>
            <div class="bg-black/20 backdrop-blur-md rounded-2xl p-4 border border-white/20">
                <h3 class="text-xs font-bold text-orange-200 uppercase tracking-widest mb-1">Media/Sesión</h3>
                <p class="text-4xl font-black text-white">{avgMinutesPerSession}</p>
                <p class="text-[10px] text-white/60 mt-1">minutos por sesión</p>
            </div>
        </div>
    </div>
</div>
