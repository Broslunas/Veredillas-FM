---
interface Props {
    academicLabel: string;
}
const { academicLabel } = Astro.props;
---

<!-- Music Player Bar -->
<div class="absolute bottom-0 left-0 right-0 z-[100] hidden bg-[rgba(10,8,20,0.95)] backdrop-blur-xl border-t border-white/10 px-4 py-2.5" id="music-bar">
    <div class="flex items-center justify-between gap-3 max-w-[480px] mx-auto">
        <div class="flex items-center gap-2.5 min-w-0 flex-1">
            <span class="text-xl flex-shrink-0">🎵</span>
            <div class="min-w-0">
                <p class="text-[0.85rem] font-bold text-white truncate" id="music-title">Veredillas FM Premier</p>
                <p class="text-[0.7rem] text-white/50" id="music-subtitle">En directo</p>
            </div>
        </div>
        <div class="flex items-center gap-2.5">
            <button class="w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors" id="music-toggle-btn" title="Play/Pause">
                <svg id="music-play-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                <svg id="music-pause-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
            </button>
            <div class="flex items-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/50"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                <input type="range" id="music-volume" min="0" max="1" step="0.05" value="0.4" class="vol-slider">
            </div>
            <button class="bg-transparent border-none text-white/40 hover:text-white cursor-pointer text-base transition-colors" id="music-close-btn" title="Cerrar">✕</button>
        </div>
    </div>
</div>

<!-- Station Selector Modal -->
<div class="station-modal fixed inset-0 z-[200] bg-black/80 backdrop-blur-lg flex items-end justify-center opacity-0 pointer-events-none" id="station-modal">
    <div class="station-modal-inner bg-[#111] border border-white/10 rounded-t-3xl p-5 pb-7 w-full max-w-[480px] max-h-[85vh] overflow-y-auto translate-y-5">
        <h3 class="text-xl font-extrabold text-white mb-1">🎙️ Elige tu música de fondo</h3>
        <p class="text-sm text-white/50 mb-4">Escucha una emisora mientras revives tu curso {academicLabel}</p>
        <div class="grid grid-cols-3 gap-2 max-sm:grid-cols-2" id="station-grid">
            <button class="station-card station-featured col-span-full flex-row justify-center gap-2.5 px-5 py-3 bg-gradient-to-br from-violet-500/20 to-pink-500/20 border border-violet-500/40 rounded-xl flex items-center cursor-pointer relative overflow-hidden hover:from-violet-500/35 hover:to-pink-500/35 hover:border-violet-500/70 hover:-translate-y-0.5 transition-all" data-stream="https://live.veredillasfm.es/stream-pro.m3u8" data-name="Veredillas FM Premier" data-type="hls" data-desc="Tu radio en directo">
                <span class="text-3xl">📻</span>
                <span class="text-sm font-bold text-white">Veredillas FM</span>
                <span class="text-[0.7rem] text-white/40">Premier · En directo</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40_URBAN.mp3" data-name="LOS40 Urban" data-type="direct" data-desc="Urban & Hip-Hop">
                <span class="text-2xl">🏙️</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">LOS40 Urban</span><span class="text-[0.6rem] text-white/40 text-center">Urban · Hip-Hop</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="https://s3.we4stream.com:2020/stream/locaurban" data-name="Loca FM Urban" data-type="direct" data-desc="Trap & Reggaetón">
                <span class="text-2xl">🔊</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">Loca Urban</span><span class="text-[0.6rem] text-white/40 text-center">Trap · Reggaetón</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40_ES.mp3" data-name="LOS40" data-type="direct" data-desc="Los 40 Principales">
                <span class="text-2xl">🔥</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">LOS40</span><span class="text-[0.6rem] text-white/40 text-center">Hits del momento</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40_DANCE.mp3" data-name="LOS40 Dance" data-type="direct" data-desc="Electronic & Dance">
                <span class="text-2xl">💃</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">LOS40 Dance</span><span class="text-[0.6rem] text-white/40 text-center">Electronic · Dance</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="https://playerservices.streamtheworld.com/api/livestream-redirect/LOS40_CLASSIC.mp3" data-name="LOS40 Classic" data-type="direct" data-desc="Grandes éxitos">
                <span class="text-2xl">⭐</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">LOS40 Classic</span><span class="text-[0.6rem] text-white/40 text-center">Clásicos</span>
            </button>
            <button class="station-card bg-white/5 border border-white/10 rounded-xl py-3 px-1.5 cursor-pointer flex flex-col items-center gap-1 relative overflow-hidden hover:bg-white/[.12] hover:border-white/30 hover:-translate-y-0.5 transition-all" data-stream="" data-name="" data-type="" data-desc="">
                <span class="text-2xl">🔕</span><span class="text-[0.72rem] font-bold text-white text-center leading-tight">Sin música</span><span class="text-[0.6rem] text-white/40 text-center">Modo silencioso</span>
            </button>
        </div>
    </div>
</div>

<!-- Hidden audio element -->
<audio id="bg-audio" loop preload="none" crossorigin="anonymous"></audio>
