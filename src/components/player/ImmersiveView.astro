---
---
<!-- Immersive Mode: Aurora Fluid Style -->
<div id="immersive-player" class="immersive-overlay hidden">
    <!-- Animated Aurora Background -->
    <div class="sky-background">
        <div class="aurora aurora-1"></div>
        <div class="aurora aurora-2"></div>
        <div class="aurora aurora-3"></div>
        <div class="sky-overlay"></div>
    </div>
    
    <!-- Top Bar -->
    <div class="top-nav">
        <div class="nav-brand">
            <span class="live-tag">VEREDILLAS FM</span>
        </div>
        <button id="collapse-player" class="btn-close-minimal" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            <span>CERRAR</span>
        </button>
    </div>

    <div class="aurora-content">
        <!-- Main Layout: Row for Desktop, Column for Mobile -->
        <div class="main-grid">
            
            <!-- Side 1: Cover Focus -->
            <div class="cover-focus">
                <div class="cover-art-container">
                    <img id="immersive-cover" src="/logo.webp" alt="Cover" />
                    <div class="reflection"></div>
                </div>
            </div>

            <!-- Side 2: Meta info -->
            <div class="meta-focus">
                <div class="info-stack">
                    <span id="immersive-author" class="author-label">PODCAST SERIES</span>
                    <h2 id="immersive-title" class="title-display">Título del Episodio</h2>
                </div>

                <!-- Subtle Visualizer -->
                <div class="visualizer-container">
                    <canvas id="audio-visualizer" width="400" height="80"></canvas>
                </div>

                <!-- Controls & Progress -->
                <div class="transport-focus">
                    <div class="timeline">
                        <span id="imm-current-time" class="time-digit">00:00</span>
                        <div class="seek-track">
                            <div class="seek-fill" id="imm-range-fill"></div>
                            <input type="range" id="imm-seek-bar" value="0" step="0.1">
                        </div>
                        <span id="imm-duration" class="time-digit">00:00</span>
                    </div>

                    <div class="action-buttons">
                        <button id="imm-back-btn" class="btn-util">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M11 18V6l-8.5 6 8.5 6zm.5-6l8.5 6V6l-8.5 6z"></path></svg>
                        </button>
                        
                        <button id="imm-play-btn" class="btn-play-aurora">
                            <div id="imm-icon-play" class="icon-wrap">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                            </div>
                            <div id="imm-icon-pause" class="icon-wrap hidden">
                                <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                            </div>
                        </button>
                        
                        <button id="imm-fwd-btn" class="btn-util">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M4 18l8.5-6L4 6v12zm9-12v12l8.5-6L13 6z"></path></svg>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
  /* --- GLOBAL COLORS --- */
  :root {
      --aurora-p: var(--color-primary, #8b5cf6);
      --aurora-s: var(--color-secondary, #0ea5e9);
      --aurora-a: var(--color-accent, #ec4899);
      --text-main: #ffffff;
      --text-dim: rgba(255,255,255,0.5);
  }

  .immersive-overlay {
      position: fixed;
      inset: 0;
      z-index: 10000;
      background: #000;
      display: flex;
      flex-direction: column;
      opacity: 0;
      pointer-events: none;
      transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      overflow: hidden;
      font-family: var(--font-body, 'Outfit', sans-serif);
  }

  .immersive-overlay:not(.hidden) { opacity: 1; pointer-events: auto; }
  .hidden { display: none !important; }

  /* --- AURORA BACKGROUND --- */
  .sky-background {
      position: absolute;
      inset: 0;
      background: #030303;
      overflow: hidden;
      z-index: 0;
  }

  .sky-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 50% 50%, transparent 0%, rgba(0,0,0,0.4) 100%);
      z-index: 5;
  }

  .aurora {
      position: absolute;
      width: 150%;
      height: 100vh;
      opacity: 0.4;
      filter: blur(80px);
      transition: 1s ease;
  }

  .aurora-1 {
      top: -20%; left: -25%;
      background: linear-gradient(120deg, var(--aurora-p), transparent);
      animation: aurora-float 20s infinite alternate;
  }
  .aurora-2 {
      bottom: -20%; right: -25%;
      background: linear-gradient(300deg, var(--aurora-s), transparent);
      animation: aurora-float 25s infinite alternate-reverse;
  }
  .aurora-3 {
      top: 20%; left: 10%;
      background: linear-gradient(180deg, var(--aurora-a), transparent);
      animation: aurora-float 15s infinite linear;
      opacity: 0.2;
  }

  @keyframes aurora-float {
      0% { transform: translate(0,0) scale(1) rotate(0deg); }
      50% { transform: translate(5%, 5%) scale(1.1) rotate(5deg); }
      100% { transform: translate(-5%, -2%) scale(0.9) rotate(-3deg); }
  }

  /* --- TOP NAV --- */
  .top-nav {
      position: relative;
      z-index: 100;
      padding: 30px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
  }

  .live-tag {
      background: var(--aurora-p);
      padding: 4px 12px;
      border-radius: 4px;
      font-size: 0.7rem;
      font-weight: 800;
      letter-spacing: 0.15em;
      box-shadow: 0 0 15px var(--aurora-p);
  }

  .btn-close-minimal {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      color: #fff;
      padding: 8px 16px;
      border-radius: 99px;
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      font-size: 0.75rem;
      font-weight: 700;
      backdrop-filter: blur(10px);
      transition: all 0.3s;
  }
  .btn-close-minimal:hover {
      background: rgba(239, 68, 68, 0.4);
      transform: translateY(-2px);
  }

  /* --- MAIN CONTENT --- */
  .aurora-content {
      position: relative;
      z-index: 10;
      flex: 1;
      display: flex;
      align-items: center;
      padding: 0 80px 80px;
  }

  .main-grid {
      display: grid;
      grid-template-columns: 1.2fr 1.8fr;
      gap: 80px;
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      align-items: center;
  }

  /* SIDE 1: COVER */
  .cover-focus {
      display: flex;
      justify-content: center;
  }

  .cover-art-container {
      position: relative;
      width: 100%;
      max-width: 450px;
      aspect-ratio: 1/1;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 50px 100px -20px rgba(0,0,0,0.8);
      transform: perspective(1000px) rotateY(-5deg);
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cover-art-container:hover { transform: perspective(1000px) rotateY(0deg) scale(1.02); }

  .cover-art-container img { width:100%; height:100%; object-fit:cover; }

  .reflection {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 50%);
      pointer-events: none;
  }

  /* SIDE 2: META */
  .meta-focus {
      display: flex;
      flex-direction: column;
      gap: 40px;
  }

  .author-label {
      color: var(--aurora-p);
      font-weight: 800;
      font-size: 0.9rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
  }

  .title-display {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 4.5rem);
      font-weight: 800;
      margin: 10px 0 0;
      line-height: 1;
      color: #fff;
      text-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }

  .visualizer-container {
      width: 100%;
      height: 80px;
      opacity: 0.4;
      mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
  }

  /* TRANSPORT */
  .transport-focus {
      display: flex;
      flex-direction: column;
      gap: 30px;
  }

  .timeline {
      display: flex;
      align-items: center;
      gap: 20px;
  }

  .time-digit {
      font-variant-numeric: tabular-nums;
      font-weight: 600;
      color: var(--text-dim);
      font-size: 0.9rem;
  }

  .seek-track {
      flex: 1;
      height: 4px;
      background: rgba(255,255,255,0.1);
      border-radius: 2px;
      position: relative;
  }

  .seek-fill {
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, var(--aurora-p), var(--aurora-s));
      width: 0%;
      border-radius: 2px;
  }

  .seek-track input {
      position: absolute;
      inset: -10px 0;
      width: 100%;
      opacity: 0;
      cursor: pointer;
      z-index: 2;
  }

  .action-buttons {
      display: flex;
      align-items: center;
      gap: 40px;
  }

  .btn-util {
      background: none; border: none;
      color: var(--text-dim);
      cursor: pointer;
      transition: all 0.2s;
  }
  .btn-util:hover { color: #fff; transform: scale(1.2); }

  .btn-play-aurora {
      width: 72px; height: 72px;
      border-radius: 20px; /* Squircle */
      background: #fff;
      color: #000;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  }
  .btn-play-aurora:hover {
      transform: scale(1.1) rotate(3deg);
      box-shadow: 0 15px 40px rgba(0,0,0,0.4);
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
      .aurora-content { padding: 40px; }
      .main-grid { grid-template-columns: 1fr; gap: 40px; text-align: center; }
      .cover-art-container { max-width: 320px; transform: none; }
      .meta-focus { align-items: center; }
      .action-buttons { justify-content: center; }
      .timeline { width: 100%; max-width: 500px; margin: 0 auto; }
      .title-display { font-size: 2.5rem; }
  }

  @media (max-width: 640px) {
      .top-nav { padding: 20px; }
      .aurora-content { padding: 20px; }
      .cover-art-container { max-width: 250px; }
      .title-display { font-size: 1.8rem; }
      .visualizer-container { display: none; }
  }
</style>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const player = document.getElementById('immersive-player');
        const collapseBtn = document.getElementById('collapse-player');
        const rangeFill = document.getElementById('imm-range-fill');
        const seekBar = document.getElementById('imm-seek-bar');

        if (collapseBtn) {
            collapseBtn.onclick = () => {
                player?.classList.add('hidden');
            };
        }

        const syncFill = () => {
             if (seekBar && rangeFill) {
                const max = parseFloat(seekBar.max) || 100;
                const current = parseFloat(seekBar.value) || 0;
                const percent = (current / max) * 100;
                rangeFill.style.width = percent + '%';
             }
        };

        if (seekBar && rangeFill) {
            seekBar.addEventListener('input', syncFill);
        }

        const updateLoop = () => {
            if (player && !player.classList.contains('hidden')) {
                syncFill();
            }
            requestAnimationFrame(updateLoop);
        };
        updateLoop();

        // Reactivity Sync
        document.addEventListener('veredillas:audio-level', (e) => {
            if (player && !player.classList.contains('hidden')) {
                const level = e.detail.level; 
                
                // Pulsing Aurora
                const auroras = player.querySelectorAll('.aurora');
                auroras.forEach((a, i) => {
                    const brightness = 0.3 + (level * 0.7);
                    const scale = 1 + (level * 0.1 * (i + 1));
                    a.style.opacity = brightness.toString();
                    a.style.transform = `scale(${scale})`;
                });

                // Pulsing cover
                const cover = player.querySelector('.cover-art-container');
                if (cover) {
                    const pulse = 1 + (level * 0.03);
                    cover.style.transform = `scale(${pulse})`;
                }
            }
        });
    });
</script>
