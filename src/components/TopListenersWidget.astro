---
// src/components/TopListenersWidget.astro
---


<div class="p-6 flex flex-col bg-white/3 backdrop-blur-[10px] border border-white/10 rounded-2xl shadow-xl gs-fade-up top-listeners-widget">
    <div class="mb-6 space-y-3">
        <div class="flex items-center gap-2 text-emerald-400 font-black tracking-[0.2em] uppercase text-[0.6rem]">
            <span class="w-8 h-[2px] bg-emerald-500 rounded-full"></span>
            Comunidad
        </div>
        <div class="flex justify-between items-end">
            <h3 class="text-2xl font-black text-white leading-none tracking-tighter m-0">
                Top <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Oyentes</span>
            </h3>
            <span class="text-[0.65rem] font-bold px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-emerald-400 uppercase tracking-wider">
                Histórico
            </span>
        </div>
    </div>

    <div id="leaderboard-list" class="flex flex-col gap-3">
        <!-- Loading Skeleton -->
        {[1, 2, 3, 4, 5].map((i) => (
            <div class="grid grid-cols-[24px_44px_1fr_60px] items-center gap-3 p-3 rounded-xl bg-white/2 border border-transparent">
                <div class="w-full h-5 bg-white/5 rounded"></div>
                <div class="w-full h-11 bg-white/5 rounded-full"></div>
                <div class="w-[70%] h-4 bg-white/5 rounded"></div>
            </div>
        ))}
    </div>
</div>

<script>
    import { getLevel } from '../lib/gamification';

    interface Listener {
        _id: string;
        name: string;
        picture?: string;
        listeningTime: number;
    }

    function formatTime(seconds: number): string {
        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        if (h > 0) return `${h}h ${m}m`;
        return `${m}m`;
    }

    async function loadLeaderboard() {
        const listContainer = document.getElementById('leaderboard-list');
        if (!listContainer) return;

        try {
            const response = await fetch('/api/stats/leaderboard');
            if (!response.ok) throw new Error('Failed to fetch');
            
            const listeners: Listener[] = await response.json();
            
            if (listeners.length === 0) {
                listContainer.innerHTML = `
                    <div class="p-8 text-center text-zinc-500">
                        <p>Sé el primero en aparecer aquí.</p>
                        <a href="/ep" class="text-primary underline cursor-pointer">Empieza a escuchar</a>
                    </div>
                `;
                return;
            }

            listContainer.innerHTML = listeners.map((listener, index) => {
                const rank = index + 1;
                const isTop3 = rank <= 3;
                
                const getGradient = (name: string) => {
                    const colors = [
                        'linear-gradient(135deg, #FF6B6B, #EE5D5D)',
                        'linear-gradient(135deg, #4FACFE, #00F2FE)',
                        'linear-gradient(135deg, #43E97B, #38F9D7)',
                        'linear-gradient(135deg, #FA709A, #FEE140)',
                        'linear-gradient(135deg, #667EEA, #764BA2)'
                    ];
                    const charCode = name.charCodeAt(0) || 0;
                    return colors[charCode % colors.length];
                };

                const level = getLevel(listener.listeningTime);
                const profileUrl = listener._id ? `/perfil/${listener._id}` : null;
                
                const rankColors = {
                    1: 'text-amber-400 text-lg',
                    2: 'text-zinc-300 text-lg',
                    3: 'text-amber-700 text-lg'
                };
                
                const bgColors = {
                    1: 'bg-gradient-to-r from-amber-400/5 to-transparent',
                    2: 'bg-gradient-to-r from-zinc-300/5 to-transparent',
                    3: 'bg-gradient-to-r from-amber-700/5 to-transparent'
                };

                const rowClasses = `grid grid-cols-[24px_44px_1fr_auto] items-center gap-3 p-3 rounded-xl bg-white/2 border border-transparent transition-all group ${profileUrl ? 'cursor-pointer hover:bg-primary/10 hover:border-primary/20 hover:translate-x-1' : 'hover:bg-white/5 hover:border-white/5'} ${bgColors[rank] || ''}`;
                
                const tagOpen = profileUrl
                    ? `<a href="${profileUrl}" class="${rowClasses}" title="Ver perfil de ${listener.name}">`
                    : `<div class="${rowClasses}">`;
                const tagClose = profileUrl ? '</a>' : '</div>';

                return `
                    ${tagOpen}
                        <div class="font-display font-bold text-zinc-500 text-center ${rankColors[rank] || ''}">${rank}</div>
                        
                        <div class="relative w-11 h-11">
                            ${listener.picture 
                                ? `<img src="${listener.picture}" alt="${listener.name}" class="w-full h-full rounded-full object-cover shadow-lg" loading="lazy" />`
                                : `<div class="w-full h-full rounded-full flex items-center justify-center font-bold text-white shadow-lg" style="background: ${getGradient(listener.name)}">${listener.name.charAt(0)}</div>`
                            }
                            ${rank === 1 ? '<div class="absolute -top-3 left-1/2 -translate-x-1/2 -rotate-12 text-base drop-shadow-md animate-bounce-subtle">👑</div>' : ''}
                        </div>

                        <div class="min-w-0 flex flex-col gap-0.5">
                            <span class="font-semibold text-white whitespace-nowrap overflow-hidden text-ellipsis text-[0.95rem] leading-tight group-hover:text-primary transition-colors">${listener.name}</span>
                            <span class="text-[0.7rem] font-medium tracking-wide opacity-90" style="color: ${level.color}">
                                ${level.name} ${level.icon}
                            </span>
                        </div>
                        
                        <div class="text-right flex items-center justify-end gap-1.5">
                            <span class="inline-block font-display font-bold text-[0.9rem] text-primary bg-primary/10 px-2.5 py-1 rounded-md transition-colors group-hover:bg-primary group-hover:text-white">${formatTime(listener.listeningTime)}</span>
                            ${profileUrl ? '<svg class="text-primary/50 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>' : ''}
                        </div>
                    ${tagClose}
                `;
            }).join('');
        } catch (error) {
            console.error(error);
            listContainer.innerHTML = `
                <div class="p-8 text-center text-zinc-500">
                    <p>No se pudieron actualizar los datos.</p>
                </div>
            `;
        }
    }

    // Load on idle
    if ('requestIdleCallback' in window) {
        requestIdleCallback(() => loadLeaderboard());
    } else {
        setTimeout(loadLeaderboard, 100);
    }
    document.addEventListener('astro:page-load', loadLeaderboard);
</script>
