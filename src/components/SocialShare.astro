---
import { getShortLink } from '@/utils/shortLink';

interface Props {
  title: string;
  image?: string;
  url?: URL | string;
  isModal?: boolean;
  triggerId?: string;
  variant?: 'floating' | 'sidebar' | 'inline';
}

const { title, image, url = Astro.url, isModal = false, triggerId, variant = 'floating' } = Astro.props;
const shortUrl = getShortLink(url);
const shareUrl = encodeURIComponent(shortUrl);
const shareTitle = encodeURIComponent(title);
---

{isModal ? (
  <div id="social-share-modal" class="share-modal-backdrop" data-trigger-id={triggerId} data-title={title} data-image={image}>
    <div class="share-modal-dialog">
        <div class="share-modal-header">
            <h3>Compartir</h3>
            <button class="close-share-modal" id="close-share-modal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        
        <div class="share-modal-content">
            <p class="share-modal-subtitle">Difunde este episodio en tus redes sociales</p>
            
            <div class="modal-share-grid">
                <!-- WhatsApp -->
                <a href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`} target="_blank" rel="noopener noreferrer" class="modal-share-item whatsapp" aria-label="Compartir en WhatsApp">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg></div>
                   <span>WhatsApp</span>
                </a>

                <!-- Telegram -->
                <a href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="modal-share-item telegram" aria-label="Compartir en Telegram">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg></div>
                   <span>Telegram</span>
                </a>

                <!-- Facebook -->
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="modal-share-item facebook" aria-label="Compartir en Facebook">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></div>
                   <span>Facebook</span>
                </a>

                <!-- X -->
                <a href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="modal-share-item twitter" aria-label="Compartir en X">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg></div>
                   <span>X (Twitter)</span>
                </a>

                <!-- LinkedIn -->
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="modal-share-item linkedin" aria-label="Compartir en LinkedIn">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg></div>
                   <span>LinkedIn</span>
                </a>

                <!-- Instagram Stories -->
                <button class="modal-share-item story" id="modal-story-trigger" aria-label="Diseñar Historia">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></div>
                   <span>Historia</span>
                </button>            

                <!-- Email -->
                <button class="modal-share-item email" id="modal-email-trigger" aria-label="Compartir por Email">
                   <div class="icon-circle"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg></div>
                   <span>Email</span>
                </button>
            </div>

            <!-- Email Form (Hidden by default) -->
            <div id="email-share-form" class="share-modal-form">
                <p class="form-title">Enviar por Email</p>
                <div class="form-group">
                    <input type="email" id="share-recipient-email" placeholder="correo@ejemplo.com" class="modal-input" />
                    <button id="send-mailjet-btn" class="modal-primary-btn">
                        <span>Enviar</span>
                        <div class="btn-loader hidden"></div>
                    </button>
                </div>
                <p id="email-status-msg" class="status-msg"></p>
            </div>

            <div class="share-modal-footer-actions">
                <button id="modal-open-embed" class="secondary-modal-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                    Insertar Episodio
                </button>
            </div>

            <div class="share-modal-actions">
                <div class="url-copy-box">
                    <input type="text" value={shortUrl} readonly id="modal-share-url" />
                    <button id="modal-copy-btn">Copiar</button>
                </div>
            </div>
        </div>
    </div>
  </div>
) : (

<aside class:list={["social-share-area", variant]} data-title={title} data-image={image}>
  <div class="share-buttons">
    <!-- WhatsApp -->
    <a href={`https://wa.me/?text=${shareTitle}%20${shareUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn whatsapp" aria-label="Compartir en WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    </a>

    <!-- Telegram -->
    <a href={`https://t.me/share/url?url=${shareUrl}&text=${shareTitle}`} target="_blank" rel="noopener noreferrer" class="share-btn telegram" aria-label="Compartir en Telegram">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </a>

    <!-- Facebook -->
    <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn facebook" aria-label="Compartir en Facebook">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
    </a>

    <!-- X (Twitter) -->
    <a href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`} target="_blank" rel="noopener noreferrer" class="share-btn twitter" aria-label="Compartir en X">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg>
    </a>

    <!-- Copy Link -->
    <button class="share-btn copy-link" id="copy-link-btn" aria-label="Copiar enlace">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
    </button>

    <!-- Instagram Stories / Story Generator -->
    <button class="share-btn story-btn" id="blog-story-trigger" aria-label="Diseñar Historia">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
    </button>

    <!-- Embed Widget -->
    <button class="share-btn embed-btn" id="open-embed-btn" aria-label="Insertar Widget">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
    </button>
  </div>
</aside>
)}

<!-- Embed Modal -->
<div id="embed-modal" class="embed-backdrop">
    <div class="embed-dialog">
        <div class="embed-header">
            <h3>Insertar Episodio</h3>
            <button class="close-btn" id="close-embed-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
        </div>
        
        <div class="embed-tabs">
            <button class="tab-btn active" data-type="latest">Último (Dinámico)</button>
            <button class="tab-btn" data-type="current">Este Episodio</button>
        </div>
        
        <div class="embed-preview-info">
            <p id="embed-desc">Muestra siempre el episodio más reciente. Ideal para la portada de tu web.</p>
        </div>
        
        <!-- Live Preview -->
        <div class="live-preview-container">
            <iframe id="preview-frame" title="Previsualización del Widget" width="100%" height="160" frameborder="0"></iframe>
        </div>
        
        <!-- Customization Options -->
        <div class="embed-customization">
            <label class="custom-label">Color de Acento</label>
            <div class="color-options">
                <button class="color-btn active" data-color="#8b5cf6" style="background: #8b5cf6;"></button>
                <button class="color-btn" data-color="#ec4899" style="background: #ec4899;"></button>
                <button class="color-btn" data-color="#10b981" style="background: #10b981;"></button>
                <button class="color-btn" data-color="#f59e0b" style="background: #f59e0b;"></button>
                <button class="color-btn" data-color="#ef4444" style="background: #ef4444;"></button>
            </div>
            
            <label class="custom-label">Tema</label>
            <div class="theme-options">
                <button class="theme-btn active" data-theme="dark">Oscuro</button>
                <button class="theme-btn" data-theme="light">Claro</button>
            </div>
            
            <div class="row-options">
                <div>
                     <label class="custom-label">Borde</label>
                     <select id="radius-select" class="custom-select">
                         <option value="12">12px (Suave)</option>
                         <option value="0">0px (Recto)</option>
                         <option value="24">24px (Redondo)</option>
                     </select>
                </div>
                <div>
                     <label class="custom-label">Fondo (Personalizado)</label>
                     <div class="bg-input-wrapper">
                         <input type="color" id="bg-color-picker" value="#121212">
                         <input type="text" id="bg-color-text" value="#121212" placeholder="#121212">
                     </div>
                </div>
            </div>
        </div>

        <div class="code-block">
            <textarea id="embed-code" readonly></textarea>
            <button id="copy-code-btn">Copiar Código</button>
        </div>
    </div>
</div>

<script>
  import { getShortLink } from '@/utils/shortLink';

  // Global listener for opening the share modal - outside setup to avoid duplicates
  window.addEventListener('veredillas:open-share-modal', () => {
      const modal = document.getElementById('social-share-modal');
      if (modal) {
          modal.classList.add('visible');
      } else {
          console.warn('[SocialShare] Modal element not found in DOM.');
      }
  });

  const setup = () => {
      // Copy Link Logic
      const copyBtn = document.getElementById('copy-link-btn');
      if (copyBtn) {
          copyBtn.addEventListener('click', () => {
            const shortUrl = getShortLink(window.location.href);
            navigator.clipboard.writeText(shortUrl).then(() => {
                const original = copyBtn.innerHTML;
                copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                setTimeout(() => {
                    copyBtn.innerHTML = original;
                }, 2000);
            });
          });
      }

      // Modal Share Logic
      const shareModal = document.getElementById('social-share-modal');
      const closeShareBtn = document.getElementById('close-share-modal');
      const modalTriggerId = shareModal?.dataset.triggerId;
      const modalCopyBtn = document.getElementById('modal-copy-btn');
      const modalUrlInput = document.getElementById('modal-share-url') as HTMLInputElement;

      if (modalTriggerId) {
          const trigger = document.getElementById(modalTriggerId);
          trigger?.addEventListener('click', () => {
              shareModal?.classList.add('visible');
          });
      }

      closeShareBtn?.addEventListener('click', () => {
          shareModal?.classList.remove('visible');
      });

      shareModal?.addEventListener('click', (e) => {
          if (e.target === shareModal) shareModal.classList.remove('visible');
      });

      modalCopyBtn?.addEventListener('click', () => {
          if (modalUrlInput) {
              modalUrlInput.select();
              navigator.clipboard.writeText(modalUrlInput.value).then(() => {
                  const original = modalCopyBtn.innerText;
                  modalCopyBtn.innerText = "¡Copiado!";
                  modalCopyBtn.classList.add('copied');
                  setTimeout(() => {
                      modalCopyBtn.innerText = original;
                      modalCopyBtn.classList.remove('copied');
                  }, 2000);
              });
          }
      });

      const modalOpenEmbed = document.getElementById('modal-open-embed');
      modalOpenEmbed?.addEventListener('click', () => {
          shareModal?.classList.remove('visible');
          document.getElementById('embed-modal')?.classList.add('visible');
      });

      // Mailjet Email Sharing Logic
      const emailTrigger = document.getElementById('modal-email-trigger');
      const emailForm = document.getElementById('email-share-form');
      const sendEmailBtn = document.getElementById('send-mailjet-btn');
      const recipientInput = document.getElementById('share-recipient-email') as HTMLInputElement;
      const statusMsg = document.getElementById('email-status-msg');

      emailTrigger?.addEventListener('click', () => {
          emailForm?.classList.toggle('visible');
          if (emailForm?.classList.contains('visible')) {
              recipientInput?.focus();
          }
      });

      sendEmailBtn?.addEventListener('click', async () => {
          const email = recipientInput?.value.trim();
          if (!email) {
              if (statusMsg) {
                  statusMsg.innerText = "Introduce un email válido.";
                  statusMsg.className = "status-msg error visible";
              }
              return;
          }

          const loader = sendEmailBtn.querySelector('.btn-loader');
          const btnText = sendEmailBtn.querySelector('span');

          try {
              loader?.classList.remove('hidden');
              btnText?.classList.add('hidden');
              sendEmailBtn.setAttribute('disabled', 'true');

              const response = await fetch('/api/share/email', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({
                      to: email,
                      title: shareModal?.getAttribute('data-title') || document.title,
                      image: shareModal?.getAttribute('data-image') || '',
                      url: document.getElementById('modal-share-url')?.getAttribute('value') || window.location.href
                  })
              });

              const result = await response.json();

              if (statusMsg) {
                  statusMsg.innerText = result.message;
                  statusMsg.className = result.success ? "status-msg success visible" : "status-msg error visible";
                  
                  if (result.success) {
                      recipientInput.value = "";
                      setTimeout(() => {
                          emailForm?.classList.remove('visible');
                          statusMsg.className = "status-msg";
                      }, 3000);
                  }
              }
          } catch (err) {
              if (statusMsg) {
                  statusMsg.innerText = "Error de conexión.";
                  statusMsg.className = "status-msg error visible";
              }
          } finally {
              loader?.classList.add('hidden');
              btnText?.classList.remove('hidden');
              sendEmailBtn.removeAttribute('disabled');
          }
      });

      // Story Generator Integration
      const storyTrigger = document.getElementById('modal-story-trigger');
      const blogStoryTrigger = document.getElementById('blog-story-trigger');
      
      const handleStoryClick = () => {
          const dataSource = document.getElementById('social-share-modal') || document.querySelector('.social-share-floating');
          shareModal?.classList.remove('visible');
          
          const storyData = {
              title: dataSource?.getAttribute('data-title') || document.title,
              image: dataSource?.getAttribute('data-image') || '',
          };
          
          if (typeof (window as any).openStoryGenerator === 'function') {
              (window as any).openStoryGenerator(storyData);
          } else {
              // Fallback if not globally defined - find the local trigger and click it
              const localStoryBtn = document.getElementById('action-create-story');
              localStoryBtn?.click();
          }
      };

      storyTrigger?.addEventListener('click', handleStoryClick);
      blogStoryTrigger?.addEventListener('click', handleStoryClick);

      // Embed Modal Logic
      const modal = document.getElementById('embed-modal');
      const openBtn = document.getElementById('open-embed-btn');
      const closeBtn = document.getElementById('close-embed-btn');
      const codeArea = document.getElementById('embed-code') as HTMLTextAreaElement;
      const copyCodeBtn = document.getElementById('copy-code-btn');
      const tabs = document.querySelectorAll('.tab-btn');
      const desc = document.getElementById('embed-desc');
      const previewFrame = document.getElementById('preview-frame') as HTMLIFrameElement;

      // Customization Elements
      const colorBtns = document.querySelectorAll('.color-btn');
      const themeBtns = document.querySelectorAll('.theme-btn');
      const radiusSelect = document.getElementById('radius-select') as HTMLSelectElement;
      const bgColorPicker = document.getElementById('bg-color-picker') as HTMLInputElement;
      const bgColorText = document.getElementById('bg-color-text') as HTMLInputElement;

      let currentType = 'latest';
      let settings = {
          color: '#8b5cf6',
          theme: 'dark',
          radius: '12',
          bg: '#121212'
      };

      function getEmbedSrc() {
          const origin = window.location.origin;
          let src = '';
          if (currentType === 'latest') {
              src = `${origin}/embed/latest`;
          } else {
              const path = window.location.pathname;
              const cleanPath = path.replace(/\/$/, '');
              const embedPath = cleanPath.replace('/ep/', '/embed/');
              src = `${origin}${embedPath}`;
          }
          
          // Append params
          const params = new URLSearchParams();
          if (settings.color !== '#8b5cf6') params.append('color', settings.color.replace('#', ''));
          if (settings.theme !== 'dark') params.append('theme', settings.theme);
          if (settings.bg !== '#121212') params.append('bg', settings.bg.replace('#', ''));
          
          const paramStr = params.toString();
          if (paramStr) src += `?${paramStr}`;
          
          return src;
      }

      function generateCode() {
          const src = getEmbedSrc();
          const iframeHtml = `<iframe 
  src="${src}" 
  width="100%" 
  height="160" 
  frameborder="0" 
  scrolling="no" 
  style="border-radius: ${settings.radius}px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
</iframe>`;
          return iframeHtml;
      }

      function updateState() {
          const newSrc = getEmbedSrc();
          
          if (codeArea) codeArea.value = generateCode();
          
          if (previewFrame) {
             if (previewFrame.src !== newSrc) {
                 previewFrame.src = newSrc;
             }
             previewFrame.style.borderRadius = `${settings.radius}px`;
             // Ensure box-shadow matches generated code
             previewFrame.style.boxShadow = "0 4px 6px -1px rgba(0, 0, 0, 0.1)";
          }

          if (desc) {
              if (currentType === 'latest') {
                  desc.textContent = "Muestra siempre el episodio más reciente. Ideal para la portada de tu web.";
              } else {
                  desc.textContent = "Muestra permanentemente este episodio específico.";
              }
          }
      }

      // Event Listeners for Customization
      colorBtns.forEach(btn => {
          btn.addEventListener('click', () => {
              colorBtns.forEach(b => b.classList.remove('active'));
              btn.classList.add('active');
              settings.color = btn.getAttribute('data-color') || '#8b5cf6';
              updateState();
          });
      });

      themeBtns.forEach(btn => {
          btn.addEventListener('click', () => {
              themeBtns.forEach(b => b.classList.remove('active'));
              btn.classList.add('active');
              settings.theme = btn.getAttribute('data-theme') || 'dark'; // dark or light
              
              if (settings.theme === 'light') {
                 // Update bg inputs to white default for light
                 if (settings.bg === '#121212' || settings.bg === '') {
                     settings.bg = '#ffffff';
                     if(bgColorPicker) bgColorPicker.value = '#ffffff';
                     if(bgColorText) bgColorText.value = '#ffffff';
                 }
              } else {
                  // Update bg inputs to dark default
                  if (settings.bg === '#ffffff') {
                     settings.bg = '#121212';
                     if(bgColorPicker) bgColorPicker.value = '#121212';
                     if(bgColorText) bgColorText.value = '#121212';
                  }
              }
              
              updateState();
          });
      });

      radiusSelect?.addEventListener('change', (e) => {
          settings.radius = (e.target as HTMLSelectElement).value;
          updateState();
      });

      const updateBg = (val: string) => {
          settings.bg = val;
          if(bgColorPicker) bgColorPicker.value = val;
          if(bgColorText) bgColorText.value = val;
          updateState();
      };

      bgColorPicker?.addEventListener('input', (e) => updateBg((e.target as HTMLInputElement).value));
      bgColorText?.addEventListener('change', (e) => updateBg((e.target as HTMLInputElement).value));


      openBtn?.addEventListener('click', () => {
          modal?.classList.add('visible');
          updateState();
      });

      closeBtn?.addEventListener('click', () => {
          modal?.classList.remove('visible');
      });

      modal?.addEventListener('click', (e) => {
          if (e.target === modal) modal.classList.remove('visible');
      });

      tabs.forEach(tab => {
          tab.addEventListener('click', () => {
              tabs.forEach(t => t.classList.remove('active'));
              tab.classList.add('active');
              currentType = tab.getAttribute('data-type') || 'latest';
              updateState();
          });
      });

      copyCodeBtn?.addEventListener('click', () => {
          codeArea?.select();
          navigator.clipboard.writeText(codeArea.value).then(() => {
              if (copyCodeBtn) {
                  const original = copyCodeBtn.innerText;
                  copyCodeBtn.innerText = "¡Copiado!";
                  setTimeout(() => copyCodeBtn.innerText = original, 2000);
              }
          });
      });
  };

  // Run on initial load
  setup();

  // Run on view transitions navigation
  document.addEventListener('astro:page-load', setup);
</script>

