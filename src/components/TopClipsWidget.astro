---
// src/components/TopClipsWidget.astro
---

<section class="py-24 relative overflow-hidden bg-gradient-to-b from-white/[0.03] to-transparent">
    <!-- Decorative background elements -->
    <div class="absolute top-1/2 left-0 -translate-y-1/2 w-96 h-96 bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-1/4 right-0 w-64 h-64 bg-accent/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="w-full max-w-[1400px] mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-8 px-4">
            <div class="space-y-3">
                <div class="flex items-center gap-3 text-primary font-black tracking-[0.3em] uppercase text-[0.65rem] md:text-xs">
                    <span class="w-12 h-[2px] bg-primary rounded-full"></span>
                    Momentos Epicos
                </div>
                <h2 class="text-4xl md:text-7xl font-black text-white leading-[0.9] tracking-tighter">
                    Mejores <span class="text-gradient">Clips</span>
                </h2>
            </div>
            
            <div class="flex items-center gap-4">
                <button class="clip-prev w-14 h-14 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_0_30px_rgba(var(--color-primary-rgb),0.4)] disabled:opacity-20 disabled:pointer-events-none group">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="transition-transform group-hover:-translate-x-1"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button class="clip-next w-14 h-14 flex items-center justify-center rounded-2xl bg-white/5 border border-white/10 text-white transition-all duration-300 hover:bg-primary hover:border-primary hover:shadow-[0_0_30px_rgba(var(--color-primary-rgb),0.4)] disabled:opacity-20 disabled:pointer-events-none group">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="transition-transform group-hover:translate-x-1"><path d="M9 18l6-6-6-6"/></svg>
                </button>
            </div>
        </div>

        <div id="clips-loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 px-4">
            {[1, 2, 3].map(i => (
                <div class="aspect-video bg-white/5 rounded-[2rem] border border-white/5 animate-pulse"></div>
            ))}
        </div>

        <div id="clips-container" class="swiper clips-swiper !overflow-visible hidden">
            <div class="swiper-wrapper" id="clips-wrapper">
                <!-- Filled by JS -->
            </div>
            <!-- Custom Pagination -->
            <div class="clip-pagination mt-12 flex justify-center gap-2"></div>
        </div>
    </div>
</section>

<style is:global>
    .clips-swiper .swiper-slide {
        transition: opacity 0.5s ease, transform 0.5s ease-out, filter 0.5s ease;
    }
    .clips-swiper .swiper-slide:not(.swiper-slide-active) {
        opacity: 1;
        transform: scale(0.9);
    }
    
    @keyframes blur-in {
        from { filter: blur(10px); opacity: 0; transform: translateY(10px); }
        to { filter: blur(0); opacity: 1; transform: translateY(0); }
    }

    .blur-in {
        animation: blur-in 0.8s ease forwards;
    }

    .clip-pagination .swiper-pagination-bullet-active {
        @apply !w-12 !bg-primary shadow-[0_0_15px_rgba(var(--color-primary-rgb),0.5)];
    }
</style>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay, EffectCoverflow } from 'swiper/modules';

    interface Clip {
        _id: string;
        videoId: string;
        likes: number;
        title: string;
        thumbnail: string;
        videoUrl: string;
        duration?: string;
        episodeTitle?: string;
    }

    async function loadClips() {
        const wrapper = document.getElementById('clips-wrapper');
        const container = document.getElementById('clips-container');
        const loading = document.getElementById('clips-loading');

        if (!wrapper || !container || !loading) return;

        try {
            const response = await fetch('/api/clips/top');
            if (!response.ok) throw new Error('Failed to fetch clips');
            
            const clips: Clip[] = await response.json();
            
            if (clips.length === 0) {
                loading.style.display = 'none';
                return;
            }

            wrapper.innerHTML = clips.map((clip, index) => `
                <div class="swiper-slide h-auto py-10 px-4">
                    <div class="hover-3d-card relative group h-full flex flex-col bg-white/[0.03] backdrop-blur-xl border border-white/10 rounded-[2.5rem] overflow-hidden transition-all duration-500 hover:border-primary/50 hover:shadow-[0_0_60px_-15px_rgba(var(--color-primary-rgb),0.4)]">
                        <div class="shine"></div>
                        
                        <!-- Rank & Likes Bagde -->
                        <div class="absolute top-6 left-6 z-20 flex flex-wrap items-center gap-2">
                            <div class="bg-primary/90 backdrop-blur-md text-white text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-[0.2em] shadow-2xl border border-white/10">
                                #${index + 1} TOP CLIP
                            </div>
                            <div class="bg-white/10 backdrop-blur-md text-white text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-[0.2em] shadow-2xl border border-white/10 flex items-center gap-1.5">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="text-accent"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                                ${clip.likes || 0} Likes
                            </div>
                        </div>

                        <!-- Thumbnail Container -->
                        <div class="relative aspect-video overflow-hidden">
                            <img src="${clip.thumbnail}" alt="${clip.title}" class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 group-hover:rotate-2" loading="lazy" />
                            
                            <!-- Premium Play Overlay -->
                            <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/10 transition-all duration-500">
                                <div class="w-20 h-20 rounded-full bg-white/10 backdrop-blur-2xl border border-white/20 text-white flex items-center justify-center shadow-2xl transition-all duration-500 transform group-hover:scale-125 group-hover:bg-primary group-active:scale-95 group-hover:shadow-[0_0_40px_rgba(var(--color-primary-rgb),0.6)]">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>

                            <!-- Duration/Label -->
                            <div class="absolute bottom-6 left-6 right-6 flex justify-between items-center z-20">
                                 ${clip.duration ? `
                                    <div class="bg-black/60 backdrop-blur-md px-3 py-1.5 rounded-xl text-[0.7rem] font-bold text-white tracking-widest border border-white/10 uppercase shadow-lg">
                                        ${clip.duration}
                                    </div>
                                 ` : ''}
                            </div>
                        </div>

                        <!-- Content Section -->
                        <div class="p-8 pb-10 flex flex-col flex-grow relative z-10">
                            ${clip.episodeTitle ? `
                                <div class="text-[0.75rem] font-black text-primary/80 uppercase tracking-[0.25em] mb-3 line-clamp-1 blur-in">
                                    ${clip.episodeTitle}
                                </div>
                            ` : ''}
                            <h3 class="text-xl md:text-2xl font-black text-white line-clamp-2 leading-[1.1] group-hover:text-primary transition-colors duration-300 mb-6 tracking-tight">
                                ${clip.title}
                            </h3>
                            
                            <div class="mt-auto pt-6 border-t border-white/5 flex items-center justify-end text-zinc-400">
                                <div class="text-primary font-black text-[0.7rem] uppercase tracking-widest group-hover:translate-x-2 transition-transform duration-300 flex items-center gap-1">
                                    Ver Ahora <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M9 18l6-6-6-6"/></svg>
                                </div>
                            </div>
                        </div>

                        <a href="/clips?watch=${clip.videoId || ''}" class="absolute inset-0 z-30" aria-label="Ver clip ${clip.title}"></a>
                    </div>
                </div>
            `).join('');

            loading.classList.add('hidden');
            container.classList.remove('hidden');

            new Swiper('.clips-swiper', {
                modules: [Navigation, Pagination, Autoplay, EffectCoverflow],
                slidesPerView: 1.1,
                spaceBetween: 0, // Handled by padding in slides
                centeredSlides: true,
                grabCursor: true,
                loop: true,
                speed: 800,
                autoplay: {
                    delay: 4000,
                    disableOnInteraction: true,
                },
                navigation: {
                    nextEl: '.clip-next',
                    prevEl: '.clip-prev',
                },
                pagination: {
                    el: '.clip-pagination',
                    clickable: true,
                    renderBullet: function (index, className) {
                        return '<span class="' + className + ' !w-8 !h-1.5 !rounded-full !bg-white/10 !transition-all duration-300 hover:!bg-primary"></span>';
                    },
                },
                breakpoints: {
                    768: { 
                        slidesPerView: 2.1,
                    },
                    1280: { 
                        slidesPerView: 3.1,
                    }
                }
            });

        } catch (error) {
            console.error('Error loading clips:', error);
            loading.style.display = 'none';
        }
    }

    // Initialize
    loadClips();
    document.addEventListener('astro:page-load', loadClips);
</script>
