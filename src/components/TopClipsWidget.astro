---
// src/components/TopClipsWidget.astro
---

<section class="py-16 relative overflow-hidden bg-gradient-to-b from-white/2 to-transparent border-t border-white/5">
    <div class="w-full max-w-[1280px] mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
            <div class="space-y-2">
                <div class="flex items-center gap-2 text-primary font-bold tracking-wider uppercase text-xs">
                    <span class="w-8 h-[2px] bg-primary rounded-full"></span>
                    Momentos Destacados
                </div>
                <h2 class="text-3xl md:text-5xl font-black text-white leading-none">Mejores Clips</h2>
            </div>
            
            <div class="flex items-center gap-4">
                <button class="clip-prev w-12 h-12 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-white transition-all hover:bg-primary hover:border-primary hover:shadow-[0_0_20px_rgba(var(--color-primary-rgb),0.3)] disabled:opacity-30 disabled:pointer-events-none">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
                </button>
                <button class="clip-next w-12 h-12 flex items-center justify-center rounded-full bg-white/5 border border-white/10 text-white transition-all hover:bg-primary hover:border-primary hover:shadow-[0_0_20px_rgba(var(--color-primary-rgb),0.3)] disabled:opacity-30 disabled:pointer-events-none">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
                </button>
            </div>
        </div>

        <div id="clips-loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {[1, 2, 3, 4].map(i => (
                <div class="aspect-video bg-white/5 rounded-2xl border border-white/5 animate-pulse"></div>
            ))}
        </div>

        <div id="clips-container" class="swiper clips-swiper !overflow-visible hidden">
            <div class="swiper-wrapper" id="clips-wrapper">
                <!-- Filled by JS -->
            </div>
        </div>
    </div>
</section>

<script>
    import Swiper from 'swiper';
    import { Navigation, Pagination, Autoplay } from 'swiper/modules';

    interface Clip {
        _id: string;
        title: string;
        thumbnail: string;
        videoUrl: string;
        duration?: string;
        episodeTitle?: string;
    }

    async function loadClips() {
        const wrapper = document.getElementById('clips-wrapper');
        const container = document.getElementById('clips-container');
        const loading = document.getElementById('clips-loading');

        if (!wrapper || !container || !loading) return;

        try {
            const response = await fetch('/api/clips/top');
            if (!response.ok) throw new Error('Failed to fetch clips');
            
            const clips: Clip[] = await response.json();
            
            if (clips.length === 0) {
                loading.style.display = 'none';
                return;
            }

            wrapper.innerHTML = clips.map(clip => `
                <div class="swiper-slide h-auto">
                    <div class="relative group h-full flex flex-col bg-white/3 border border-white/5 rounded-2xl overflow-hidden transition-all duration-300 hover:border-primary/50 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)]">
                        <!-- Thumbnail -->
                        <div class="relative aspect-video overflow-hidden bg-black">
                            <img src="${clip.thumbnail}" alt="${clip.title}" class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:blur-[2px] opacity-80 group-hover:opacity-100" loading="lazy" />
                            
                            <!-- Overlay/Play Button -->
                            <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-all duration-300">
                                <div class="w-14 h-14 rounded-full bg-primary/90 text-white flex items-center justify-center shadow-[0_0_30px_rgba(var(--color-primary-rgb),0.5)] transition-all duration-300 transform group-hover:scale-110 group-hover:bg-accent group-active:scale-95">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                                </div>
                            </div>

                            ${clip.duration ? `<div class="absolute bottom-2 right-2 bg-black/80 backdrop-blur-md px-2 py-0.5 rounded text-[0.65rem] font-bold text-white tracking-widest border border-white/10 uppercase">${clip.duration}</div>` : ''}
                        </div>

                        <!-- Info -->
                        <div class="p-4 flex flex-col flex-grow">
                            ${clip.episodeTitle ? `<div class="text-[0.65rem] font-bold text-primary uppercase tracking-[0.1em] mb-1 line-clamp-1 opacity-80">${clip.episodeTitle}</div>` : ''}
                            <h3 class="text-sm md:text-base font-bold text-white line-clamp-2 leading-snug group-hover:text-primary transition-colors">${clip.title}</h3>
                        </div>

                        <a href="/clips/${clip._id || ''}" class="absolute inset-0 z-10" aria-label="Ver clip ${clip.title}"></a>
                    </div>
                </div>
            `).join('');

            loading.classList.add('hidden');
            container.classList.remove('hidden');

            new Swiper('.clips-swiper', {
                modules: [Navigation, Pagination, Autoplay],
                slidesPerView: 1.2,
                spaceBetween: 20,
                grabCursor: true,
                loop: false,
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: true,
                },
                navigation: {
                    nextEl: '.clip-next',
                    prevEl: '.clip-prev',
                },
                breakpoints: {
                    640: { slidesPerView: 2.2, spaceBetween: 24 },
                    1024: { slidesPerView: 3.2, spaceBetween: 24 },
                    1280: { slidesPerView: 4, spaceBetween: 24 }
                }
            });

        } catch (error) {
            console.error('Error loading clips:', error);
            loading.style.display = 'none';
        }
    }

    // Initialize
    loadClips();
    document.addEventListener('astro:page-load', loadClips);
</script>
