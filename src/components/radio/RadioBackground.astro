---
---

<!-- Animated Geometric Background Visuals -->
<div class="absolute inset-0 overflow-hidden pointer-events-none bass-reactive-container">
    <div class="absolute top-[10%] left-[5%] opacity-20 bass-reactive">
        <svg class="animate-spin-slow" width="300" height="300" viewBox="0 0 100 100" fill="none" stroke="var(--color-primary)" stroke-width="0.5"><polygon points="50,10 90,90 10,90"/></svg>
    </div>
    <div class="absolute top-[50%] right-[10%] opacity-30 animation-delay-2000 bass-reactive">
        <svg class="animate-float-geo" width="250" height="250" viewBox="0 0 100 100" fill="none" stroke="#06b6d4" stroke-width="0.5"><polygon points="50,5 95,38 78,95 22,95 5,38"/></svg>
    </div>
    <div class="absolute bottom-[-5%] left-[25%] opacity-20 animation-delay-4000 bass-reactive">
        <svg class="animate-spin-reverse-slow" width="400" height="400" viewBox="0 0 100 100" fill="none" stroke="#7c3aed" stroke-width="0.3"><rect x="20" y="20" width="60" height="60" transform="rotate(45 50 50)"/></svg>
    </div>
    <div class="absolute top-[20%] left-[40%] opacity-30 animation-delay-4000 bass-reactive">
        <svg class="animate-float-geo" width="350" height="350" viewBox="0 0 100 100" stroke="rgba(255,255,255,0.15)" stroke-width="0.3" fill="none">
            <polyline points="10,10 40,50 90,20" />
            <polyline points="40,50 50,90 90,20" />
            <polyline points="10,10 50,90" />
            <circle cx="10" cy="10" r="1.5" fill="var(--color-primary)" />
            <circle cx="40" cy="50" r="1.5" fill="#06b6d4" />
            <circle cx="90" cy="20" r="1.5" fill="#7c3aed" />
            <circle cx="50" cy="90" r="1.5" fill="white" />
        </svg>
    </div>
    <div class="absolute bottom-[30%] right-[30%] opacity-20 bass-reactive">
        <svg class="animate-spin-slow" width="200" height="200" viewBox="0 0 100 100" stroke="var(--color-primary)" stroke-width="0.5" fill="none">
            <polygon points="50,0 100,25 100,75 50,100 0,75 0,25" />
        </svg>
    </div>
</div>

<style>
    .animation-delay-2000 { animation-delay: 2s; }
    .animation-delay-4000 { animation-delay: 4s; }
    
    .bass-reactive {
        transform: scale(var(--bass-scale, 1));
        transition: transform 0.05s ease-out;
        transform-origin: center;
        will-change: transform;
    }
</style>
