---
interface Props {
  title: string;
  id?: string;
  isOpen?: boolean;
  class?: string;
  extraHeader?: string; // HTML string for extra buttons if really needed
}

const { title, id, isOpen = true, class: className = "" } = Astro.props;
---

<div class:list={["sidebar-widget-collapsible", className]} id={id} data-is-open={isOpen ? "true" : "false"}>
  <div class="widget-header">
      <h3 class="leading-tight break-words">{title}</h3>
      <div class="header-actions">
           <slot name="header-actions" />
           <button class="toggle-btn" aria-label="Colapsar/Expandir">
             <svg class="chevron-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
           </button>
      </div>
  </div>
  
  <div class="widget-content">
      <slot />
  </div>
</div>

<script>
    // Simple script to handle all collapsible widgets
    document.addEventListener('DOMContentLoaded', () => {
        const widgets = document.querySelectorAll('.sidebar-widget-collapsible');
        
        widgets.forEach(widget => {
            const header = widget.querySelector('.widget-header');
            const content = widget.querySelector('.widget-content') as HTMLElement;
            
            if(header && content) {
                header.addEventListener('click', () => {
                    const isOpen = widget.getAttribute('data-is-open') === 'true';
                    widget.setAttribute('data-is-open', isOpen ? "false" : "true");
                });
            }
        });
    });
</script>

<style>
  .sidebar-widget-collapsible {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: var(--spacing-lg);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  [data-theme="light"] .sidebar-widget-collapsible {
    background: rgba(0, 0, 0, 0.02);
    border-color: rgba(0, 0, 0, 0.06);
  }
  
  .widget-header {
      padding: 1.25rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(255, 255, 255, 0.02);
      border-bottom: 1px solid transparent;
      transition: all 0.3s;
      cursor: pointer;
      position: relative;
  }

  .widget-header::before {
      content: "";
      position: absolute;
      left: 0;
      top: 30%;
      bottom: 30%;
      width: 3px;
      background: var(--color-primary);
      border-radius: 0 4px 4px 0;
      opacity: 0;
      transition: all 0.3s ease;
      box-shadow: 0 0 10px var(--color-primary);
  }

  .sidebar-widget-collapsible[data-is-open="true"] .widget-header::before {
      opacity: 1;
      top: 25%;
      bottom: 25%;
  }

  .widget-header:hover {
      background: rgba(255, 255, 255, 0.04);
  }
  
  .sidebar-widget-collapsible[data-is-open="true"] .widget-header {
      border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  h3 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text-main);
    font-weight: 800;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    opacity: 0.9;
  }
  
  .header-actions {
      display: flex;
      align-items: center;
      gap: 8px;
  }

  .toggle-btn {
      background: transparent;
      border: none;
      color: var(--color-text-muted);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 4px;
      border-radius: 4px;
      transition: all 0.2s;
  }
  
  .toggle-btn:hover {
      background: rgba(255,255,255,0.05);
      color: white;
  }
  
  .chevron-icon {
      transition: transform 0.3s ease;
  }
  
  /* Rotation logic */
  .sidebar-widget-collapsible[data-is-open="false"] .chevron-icon {
      transform: rotate(-90deg);
  }
  
  .widget-content {
      padding: 1.5rem;
      transition: all 0.3s ease;
      display: block;
  }
  
  .sidebar-widget-collapsible[data-is-open="false"] .widget-content {
      display: none;
      padding: 0;
  }

  @media (max-width: 640px) {
      .widget-header {
          padding: 1rem 1.25rem;
      }
      .widget-content {
          padding: 1.25rem;
      }
  }
</style>
