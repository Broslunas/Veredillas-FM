---
import mongoose from 'mongoose';
import User from '@/models/User';

interface Props {
  episodeSlug: string;
  className?: string;
}

const { episodeSlug, className = '' } = Astro.props;

let initialCount = 0;
try {
  if (mongoose.connection.readyState !== 1) {
    const MONGODB_URI = import.meta.env.MONGODB_URI;
    if (MONGODB_URI) await mongoose.connect(MONGODB_URI);
  }
  initialCount = await User.countDocuments({ favorites: episodeSlug });
} catch (e) {
  // fail silently
}
---

<button 
  class:list={[
    "favorite-premium-btn group relative inline-flex items-center gap-3 max-sm:gap-2 px-5 py-[0.625rem] max-sm:px-[0.875rem] bg-transparent border-none cursor-pointer transition-all duration-400 ease-[cubic-bezier(0.2,0.8,0.2,1)] min-h-[48px] group-[.loading]:opacity-60 group-[.loading]:pointer-events-none [-webkit-tap-highlight-color:transparent]",
    className
  ]}
  data-episode-slug={episodeSlug}
  aria-label="Agregar a favoritos"
  title="Agregar a favoritos"
>
  <div class="btn-background absolute inset-0 bg-white/4 [data-theme=light]_&:bg-black/3 backdrop-blur-xl border border-white/8 [data-theme=light]_&:border-black/7 rounded-2xl z-[1] transition-all duration-400 group-hover:bg-white/8 group-hover:border-white/15 group-hover:-translate-y-[1px] group-[.favorited]:bg-red-500/10 group-[.favorited]:border-red-500/30 shadow-sm"></div>
  <div class="btn-glow absolute -inset-[2px] bg-gradient-to-br from-pink-500 to-red-500 rounded-[18px] opacity-0 blur-lg z-0 transition-opacity duration-400 group-[.favorited]:group-hover:opacity-20"></div>
  
  <span class="icon-wrapper relative z-[2] flex items-center justify-center w-6 h-6">
    <svg class="heart-icon w-5 h-5 text-white/40 [data-theme=light]_&:text-black/20 transition-all duration-400 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] group-[.favorited]:text-red-500 group-[.favorited]:fill-red-500 group-[.favorited]:scale-110 group-[.favorited]:drop-shadow-[0_0_8px_rgba(239,68,68,0.4)]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
    </svg>
    <div class="pulse-ring absolute w-full h-full rounded-full border-2 border-red-500 opacity-0 pointer-events-none group-[.favorited]:animate-[pulse-ring_0.6s_cubic-bezier(0.215,0.61,0.355,1)]"></div>
  </span>

  <span class="btn-labels relative z-[2] flex items-center gap-2">
    <span class="label-main max-sm:hidden text-[0.95rem] font-bold text-white [data-theme=light]_&:text-[#1a1a2e] tracking-tight">Favorito</span>
    <span class="label-count text-[0.75rem] font-extrabold text-white/40 [data-theme=light]_&:text-black/40 bg-white/5 [data-theme=light]_&:bg-black/3 px-1.5 py-0.5 rounded-md min-w-[1.5rem] text-center transition-all duration-300 group-[.favorited]:bg-red-500/15 group-[.favorited]:text-red-500" data-count={initialCount}>{initialCount}</span>
  </span>
</button>

<style is:global>
  @keyframes pulse-ring {
    0% { transform: scale(0.5); opacity: 1; }
    100% { transform: scale(3); opacity: 0; }
  }
</style>

<script>
  function initFavoriteButtons() {
    window.vfmStateCache = window.vfmStateCache || {};
    
    async function fetchEpisodeState(slug: string) {
      if (window.vfmStateCache[slug]) return window.vfmStateCache[slug];
      window.vfmStateCache[slug] = fetch(`/api/episodes/state?slug=${encodeURIComponent(slug)}`).then(r => r.json());
      return window.vfmStateCache[slug];
    }

    async function loadState() {
      const buttons = document.querySelectorAll('.favorite-premium-btn');
      for (const button of buttons) {
        const slug = button.getAttribute('data-episode-slug');
        if (!slug) continue;

        try {
          const data = await fetchEpisodeState(slug);
          
          if (data.userState?.isFavorite) {
            button.classList.add('favorited');
          }

          if (data.globalStats?.favoritesCount !== undefined) {
             const countEl = button.querySelector('.label-count');
             if (countEl) countEl.textContent = data.globalStats.favoritesCount;
          }

          const newBtn = button.cloneNode(true);
          button.parentNode?.replaceChild(newBtn, button);
          
          newBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            await toggleFavorite(newBtn as HTMLButtonElement);
          });
        } catch (error) {
          console.error(error);
        }
      }
    }

    async function toggleFavorite(button: HTMLButtonElement) {
      const slug = button.getAttribute('data-episode-slug');
      if (!slug) return;

      const wasFavorited = button.classList.contains('favorited');
      button.classList.add('loading');

      try {
        const response = await fetch('/api/favorites/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ episodeSlug: slug }),
        });

        const data = await response.json();

        if (!response.ok) {
          if (response.status === 401) {
            if (window.showToast) window.showToast('Inicia sesión para esto ❤️', 'info');
            return;
          }
          throw new Error();
        }

        if (data.isFavorite) {
          button.classList.add('favorited');
          if ((window as any).showToast) (window as any).showToast('¡Guardado!', 'success');
        } else {
          button.classList.remove('favorited');
          if ((window as any).showToast) (window as any).showToast('Eliminado', 'info');
        }

        // We can just manually increment or decrement client side, but since other components might
        // want freshness, let's force a refetch by clearing the cache and refetching.
        delete window.vfmStateCache[slug];
        const freshData = await fetchEpisodeState(slug);
        if (freshData.globalStats?.favoritesCount !== undefined) {
             const countEl = button.querySelector('.label-count');
             if (countEl) countEl.textContent = freshData.globalStats.favoritesCount;
        }
      } catch (error) {
        if (window.showToast) window.showToast('Error de conexión', 'error');
      } finally {
        button.classList.remove('loading');
      }
    }

    loadState();
  }

  document.addEventListener('DOMContentLoaded', initFavoriteButtons);
  document.addEventListener('astro:page-load', initFavoriteButtons);
</script>
