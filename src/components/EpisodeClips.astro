---
interface Clip {
  title: string;
  url: string;
}

interface Props {
  clips?: Clip[];
}

const { clips } = Astro.props;

function toEmbedUrl(url: string): string {
  const patterns = [
    /youtube\.com\/shorts\/([^?&]+)/,
    /(?:youtube\.com\/watch\?v=|youtube\.com\/watch\?.+&v=)([^&]+)/,
    /youtu\.be\/([^?&]+)/,
    /youtube\.com\/embed\/([^?&]+)/,
  ];
  for (const pattern of patterns) {
    const match = url.match(pattern);
    if (match) return `https://www.youtube.com/embed/${match[1]}`;
  }
  return url;
}

const embedClips = clips?.map(clip => ({
  title: clip.title,
  embedUrl: toEmbedUrl(clip.url),
})) ?? [];
---

{embedClips.length > 0 && (
  <>
    <button 
      class="group relative w-full p-3 sm:p-4 bg-primary/5 border border-primary/20 rounded-xl sm:rounded-[20px] cursor-pointer overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.2,0.8,0.2,1)] mb-6 sm:mb-8 hover:bg-primary/10 hover:border-primary/40 hover:-translate-y-0.5 hover:shadow-[0_15px_30px_-10px_rgba(139,92,246,0.2)] active:scale-[0.98]" 
      id="clips-open-btn"
    >
      <div 
        class="absolute inset-0 opacity-0 transition-opacity duration-500 pointer-events-none group-hover:opacity-100"
        style="background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(139, 92, 246, 0.15), transparent 70%);"
      ></div>
      <div class="relative z-10 flex items-center gap-3 sm:gap-4">
        <div class="w-10 h-10 sm:w-11 sm:h-11 bg-primary rounded-lg sm:rounded-xl flex items-center justify-center text-white shadow-[0_4px_15px_rgba(139,92,246,0.4)] transition-all duration-300 group-hover:scale-110 group-hover:rotate-6 group-hover:shadow-[0_6px_20px_rgba(139,92,246,0.5)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="play-icon sm:w-5 sm:h-5"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
        </div>
        <div class="flex-1 text-left flex flex-col gap-0.5">
          <span class="text-sm sm:text-base font-extrabold text-white tracking-tight">Clips Destacados</span>
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse shadow-[0_0_0_0_rgba(239,68,68,0.7)]"></span>
            <span class="text-[0.7rem] sm:text-[0.8rem] font-semibold text-white/50">{embedClips.length} momentos clave</span>
          </div>
        </div>
        <svg class="text-white/30 transition-all duration-300 group-hover:translate-x-1 group-hover:text-primary w-5 h-5 sm:w-6 sm:h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </div>
    </button>

    <!-- Cinematic Clips Modal -->
    <div class="fixed inset-0 z-[10000] flex flex-col opacity-0 invisible transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] [&.active]:opacity-100 [&.active]:visible" id="clips-modal-overlay">
      <div class="absolute inset-0 bg-[#050508] z-0 bg-[radial-gradient(circle_at_10%_10%,rgba(139,92,246,0.1)_0%,transparent_40%),radial-gradient(circle_at_90%_90%,rgba(239,68,68,0.05)_0%,transparent_40%)]"></div>
      <div class="absolute inset-0 opacity-[0.03] z-[1] pointer-events-none bg-[url('data:image/svg+xml,%3Csvg_viewBox=%220_0_200_200%22_xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter_id=%22n%22%3E%3CfeTurbulence_type=%22fractalNoise%22_baseFrequency=%220.65%22_numOctaves=%223%22_stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect_width=%22100%25%22_height=%22100%25%22_filter=%22url(%23n)%22/%3E%3C/svg%3E')]"></div>
      
      <div class="relative z-10 h-full flex flex-col pt-[env(safe-area-inset-top)] pb-[env(safe-area-inset-bottom)] overflow-hidden">
        <header class="flex items-center justify-between px-4 sm:px-8 py-3 sm:py-5 shrink-0 border-b border-white/5">
          <div class="flex items-center gap-3 sm:gap-4">
            <div class="w-9 h-9 sm:w-11 sm:h-11 border-2 border-white/10 rounded-full flex items-center justify-center">
              <span class="text-[0.6rem] sm:text-[0.7rem] font-black text-primary tracking-widest uppercase">VFM</span>
            </div>
            <div class="flex flex-col">
              <span class="text-[0.55rem] sm:text-[0.65rem] font-extrabold uppercase text-primary tracking-[0.1em] sm:tracking-[0.15em]">Clips & Momentos</span>
              <h3 class="m-0 text-sm sm:text-base font-bold text-white line-clamp-1">Destacados del episodio</h3>
            </div>
          </div>
          
          <button class="w-9 h-9 sm:w-11 sm:h-11 rounded-full bg-white/5 border border-white/10 text-white flex items-center justify-center cursor-pointer transition-all duration-300 hover:bg-red-500/10 hover:border-red-500/30 hover:text-red-500 hover:rotate-90" id="clips-close-btn" aria-label="Cerrar cinemática">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </header>

        <main class="flex-1 flex flex-col items-center justify-center relative min-h-0 touch-none overflow-hidden" id="clips-swipe-area">
          <div class="w-full h-full flex items-center overflow-hidden">
            <div class="flex w-full h-full transition-transform duration-600 ease-[cubic-bezier(0.16,1,0.3,1)]" id="clips-carousel">
              {embedClips.map((clip, i) => (
                <div class="flex-[0_0_100%] px-4 py-6 sm:px-8 sm:py-8 flex flex-col items-center justify-center gap-4 sm:gap-6 min-h-0" data-index={i}>
                  <div class="relative h-[min(55vh,500px)] aspect-[9/16] flex-shrink-0 group/video">
                    <div class="w-full h-full bg-black rounded-xl sm:rounded-[24px] overflow-hidden relative z-10 shadow-[0_0_0_1px_rgba(255,255,255,0.1),0_20px_40px_-10px_rgba(0,0,0,0.8)] transition-transform duration-500 group-hover/video:scale-[1.01]">
                      <iframe
                        class="w-full h-full border-none pointer-events-auto"
                        data-src={clip.embedUrl}
                        title={clip.title}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                      ></iframe>
                    </div>
                    <div class="absolute -bottom-[10%] left-[5%] right-[5%] h-[20%] bg-gradient-to-b from-primary/20 to-transparent blur-[25px] sm:blur-[35px] z-[1] opacity-60 pointer-events-none"></div>
                  </div>
                  
                  <div class="text-center px-4 w-full max-w-[600px] shrink-0">
                    <div class="mb-1">
                      <span class="text-[0.6rem] sm:text-[0.75rem] font-extrabold text-white/40 uppercase tracking-[0.2em]">Momento {String(i + 1).padStart(2, '0')}</span>
                    </div>
                    <h4 class="mt-1 sm:mt-2 mb-0 text-base sm:text-xl lg:text-2xl font-extrabold text-white leading-tight bg-gradient-to-r from-white to-white/70 bg-clip-text text-transparent line-clamp-2">{clip.title}</h4>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <nav class="absolute inset-x-0 top-1/2 -translate-y-1/2 pointer-events-none z-50 flex items-center justify-between px-2 sm:px-6 lg:px-12">
            {embedClips.length > 1 && (
              <>
                <button 
                  class="w-10 h-10 sm:w-12 sm:h-14 bg-black/40 sm:bg-white/[0.03] border border-white/10 sm:border-white/[0.08] rounded-full sm:rounded-2xl text-white flex items-center justify-center cursor-pointer pointer-events-auto backdrop-blur-md sm:backdrop-blur-xl transition-all duration-400 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:bg-primary/20 hover:border-primary/40 hover:scale-110 active:scale-90 shadow-lg" 
                  id="clips-prev" 
                  aria-label="Anterior"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <button 
                  class="w-10 h-10 sm:w-12 sm:h-14 bg-black/40 sm:bg-white/[0.03] border border-white/10 sm:border-white/[0.08] rounded-full sm:rounded-2xl text-white flex items-center justify-center cursor-pointer pointer-events-auto backdrop-blur-md sm:backdrop-blur-xl transition-all duration-400 ease-[cubic-bezier(0.2,0.8,0.2,1)] hover:bg-primary/20 hover:border-primary/40 hover:scale-110 active:scale-90 shadow-lg" 
                  id="clips-next" 
                  aria-label="Siguiente"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="sm:w-6 sm:h-6"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              </>
            )}
          </nav>
        </main>

        <footer class="p-3 sm:p-6 flex flex-col items-center gap-2 sm:gap-3 shrink-0 border-t border-white/5">
          <div class="flex gap-2 sm:gap-3" id="clips-dots">
            {embedClips.map((_, i) => (
              <button class:list={["w-5 sm:w-8 h-1 bg-white/10 border-none p-0 rounded-full cursor-pointer relative overflow-hidden group/dot", { active: i === 0 }]} data-dot-index={i} aria-label={`Ir al clip ${i + 1}`}>
                <span class="absolute inset-0 bg-primary scale-x-0 origin-left transition-transform duration-400 ease-in-out group-[.active]/dot:scale-x-100"></span>
              </button>
            ))}
          </div>
          <span class="text-[0.55rem] sm:text-[0.65rem] text-white/30 font-bold md:hidden uppercase tracking-[0.15em]">Desliza para explorar</span>
        </footer>

      </div>
    </div>
  </>
)}

<script>
  function initClips() {
    const openBtn = document.getElementById('clips-open-btn');
    const overlay = document.getElementById('clips-modal-overlay');
    const closeBtns = document.querySelectorAll('#clips-close-btn');
    const track = document.getElementById('clips-carousel');
    const swipeArea = document.getElementById('clips-swipe-area');
    const prevBtn = document.getElementById('clips-prev');
    const nextBtn = document.getElementById('clips-next');
    const dotsContainer = document.getElementById('clips-dots');

    if (!openBtn || !overlay || !track) return;

    const slides = Array.from(track.querySelectorAll('[data-index]'));
    const segments = dotsContainer ? Array.from(dotsContainer.querySelectorAll('[data-dot-index]')) : [];
    let currentIndex = 0;

    // Swipe Support
    let touchStartX = 0;
    let touchEndX = 0;

    function handleGesture() {
      const threshold = 50;
      if (touchEndX < touchStartX - threshold) updateView(currentIndex + 1);
      if (touchEndX > touchStartX + threshold) updateView(currentIndex - 1);
    }

    if (swipeArea) {
      swipeArea.addEventListener('touchstart', (e) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      }, { passive: true });

      swipeArea.addEventListener('touchend', (e) => {
        touchEndX = (e as TouchEvent).changedTouches[0].screenX;
        handleGesture();
      }, { passive: true });
    }

    function loadIframe(index: number, shouldPlay: boolean = false) {
      const slide = slides[index];
      if (!slide) return;
      const iframe = slide.querySelector('iframe');
      if (iframe && iframe.dataset.src) {
        let targetSrc = iframe.dataset.src;
        if (shouldPlay) {
          // Add autoplay=1 and mute=0 to ensure it starts playing
          const connector = targetSrc.includes('?') ? '&' : '?';
          targetSrc = `${targetSrc}${connector}autoplay=1`;
        }
        
        // Only update if it's different to avoid unnecessary reloads
        if (iframe.getAttribute('src') !== targetSrc) {
          iframe.src = targetSrc;
        }
      }
    }

    function updateView(index: number) {
      if (index < 0 || index >= slides.length) return;
      
      // Stop previous video by clearing its src
      const prevSlide = slides[currentIndex];
      if (prevSlide && index !== currentIndex) {
        const prevIframe = prevSlide.querySelector('iframe');
        if (prevIframe) prevIframe.removeAttribute('src');
      }

      currentIndex = index;

      // Smooth slide transition
      track!.style.transform = `translateX(${-index * 100}%)`;

      // Update progress segments
      segments.forEach((seg, i) => {
        seg.classList.toggle('active', i === index);
      });

      // Load and play current iframe
      loadIframe(index, true);
      
      // Pre-load neighbors WITHOUT playing
      if (index > 0) loadIframe(index - 1, false);
      if (index < slides.length - 1) loadIframe(index + 1, false);
    }

    function unloadAll() {
      slides.forEach(slide => {
        const iframe = slide.querySelector('iframe');
        if (iframe) iframe.removeAttribute('src');
      });
    }

    openBtn.addEventListener('click', () => {
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      updateView(0);
    });

    closeBtns.forEach(btn => btn.addEventListener('click', () => {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      setTimeout(unloadAll, 400); // Wait for transition
    }));

    if (prevBtn) prevBtn.addEventListener('click', () => updateView(currentIndex - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => updateView(currentIndex + 1));

    segments.forEach(seg => {
      seg.addEventListener('click', () => {
        const idx = parseInt((seg as HTMLElement).dataset.dotIndex || '0');
        updateView(idx);
      });
    });

    // Keys
    document.addEventListener('keydown', (e) => {
      if (!overlay.classList.contains('active')) return;
      if (e.key === 'Escape') {
         overlay.classList.remove('active');
         document.body.style.overflow = '';
         setTimeout(unloadAll, 400);
      }
      if (e.key === 'ArrowLeft') updateView(currentIndex - 1);
      if (e.key === 'ArrowRight') updateView(currentIndex + 1);
    });

    // Mouse movement for glow effect
    openBtn.addEventListener('mousemove', (e) => {
      const rect = openBtn.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      openBtn.style.setProperty('--mouse-x', `${x}%`);
      openBtn.style.setProperty('--mouse-y', `${y}%`);
    });
  }

  document.addEventListener('DOMContentLoaded', initClips);
  document.addEventListener('astro:page-load', initClips);
</script>
