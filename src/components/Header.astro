<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header   = document.getElementById('site-header');
    const ham      = document.getElementById('sh-ham') as HTMLButtonElement;
    const overlay  = document.querySelector('.sh-overlay') as HTMLElement;
    const closeBtn = document.getElementById('sh-overlay-close') as HTMLButtonElement;

    // ── Scroll: hide on down, show on up ──
    let lastY      = window.scrollY;
    let ticking    = false;
    const HIDE_THRESHOLD = 80;  // px scrolled before we start hiding
    const DELTA          = 6;   // minimum scroll delta to react

    function handleScroll() {
      const y     = window.scrollY;
      const delta = y - lastY;

      // Scrolled state (glassmorphism intensity)
      header?.classList.toggle('is-scrolled', y > 20);

      // Hide / show – only if menu is NOT open
      if (!overlay?.classList.contains('is-open')) {
        if (y < HIDE_THRESHOLD) {
          // Always visible near top
          header?.classList.remove('is-hidden');
        } else if (delta > DELTA) {
          // Scrolling DOWN → hide
          header?.classList.add('is-hidden');
        } else if (delta < -DELTA) {
          // Scrolling UP → show
          header?.classList.remove('is-hidden');
        }
      }

      lastY    = y;
      ticking  = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(handleScroll);
        ticking = true;
      }
    }, { passive: true });

    handleScroll();

    // ── Mobile overlay ────────────────────
    function open() {
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      ham.classList.add('is-open');
      ham.setAttribute('aria-expanded', 'true');
      // Always show header when menu is open
      header?.classList.remove('is-hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      ham.classList.remove('is-open');
      ham.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    ham?.addEventListener('click', () => overlay.classList.contains('is-open') ? close() : open());
    closeBtn?.addEventListener('click', close);

    // Close on link click
    overlay?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
  });
</script>

<script define:vars={{ premieres }}>
  const STREAM_URL = 'https://live.veredillasfm.es/stream-pro.m3u8';
  let isStreamOnline = false;

  function parseDuration(d) {
    if (!d) return 0;
    const h = d.match(/(\d+)\s*h/),  m = d.match(/(\d+)\s*min/);
    return (h ? +h[1]*3600000 : 0) + (m ? +m[1]*60000 : 0) || 600000;
  }

  function updateBanner() {
    const banner  = document.getElementById('sh-live');
    const labelEl = document.getElementById('sh-live-label');
    const titleEl = document.getElementById('sh-live-title');
    if (!banner) return;

    if (isStreamOnline) {
      banner.classList.remove('hidden');
      banner.href = '/live';
      if (labelEl) labelEl.textContent = 'EN DIRECTO';
      if (titleEl) titleEl.textContent = 'Emisión en Directo desde el Estudio';
      return;
    }

    const now = Date.now(), SOON = 7200000;
    let active = null, soon = null;
    premieres.forEach(p => {
      const end = p.date + parseDuration(p.duration);
      if (now >= p.date && now < end) active = p;
      if (p.date > now && p.date - now <= SOON && (!soon || p.date < soon.date)) soon = p;
    });

    const t = active || soon;
    if (t) {
      banner.classList.remove('hidden');
      banner.href = `/ep/${t.slug}`;
      if (titleEl) titleEl.textContent = t.title;
      if (active) {
        if (labelEl) labelEl.textContent = 'EN DIRECTO';
      } else {
        const mins = Math.ceil((t.date - now) / 60000);
        const time = mins >= 60 ? `${Math.floor(mins/60)}h ${mins%60}m` : `${mins}m`;
        if (labelEl) labelEl.textContent = `ESTRENO EN ${time}`;
      }
    } else {
      banner.classList.add('hidden');
    }
  }

  fetch(STREAM_URL, { method: 'HEAD' })
    .then(r => { isStreamOnline = r.ok; updateBanner(); })
    .catch(() => updateBanner());

  updateBanner();
  setInterval(updateBanner, 60000);
</script>
