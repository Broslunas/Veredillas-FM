---
import ThemeToggle from './ThemeToggle.astro';
import CommandPalette from './CommandPalette.astro';
import AuthButton from './AuthButton.astro';
import { getCollection } from 'astro:content';

const navItems = [
  // Links directos prominentes
  { label: 'Episodios',  href: '/ep' },
  { label: 'Blog',       href: '/blog' },

  // Dropdown: dónde escuchar + clips
  {
    label: 'Escuchar',
    dropdown: [
      { label: 'Clips destacados',  href: '/clips',   badge: 'Nuevo' },
      { label: 'Galería',           href: '/galeria' },
      { label: 'Estadísticas',      href: '/stats' },
      { label: '─', href: '#', divider: true },
      { label: 'Spotify',           href: 'https://open.spotify.com/show/6mXWyLhzhET5EHk1p72j18',   external: true },
      { label: 'Amazon Music',      href: 'https://music.amazon.es/podcasts/8d708ffa-7ef7-42f0-878d-fe3575491bef/veredillas-fm', external: true },
      { label: 'Apple Podcasts',    href: 'https://podcasts.apple.com/es/podcast/veredillas-fm/id1870103081', external: true },
    ]
  },

  // Dropdown: personas
  {
    label: 'Personas',
    dropdown: [
      { label: 'El Equipo',   href: '/equipo' },
      { label: 'Invitados',   href: '/invitados' },
      { label: 'Oyentes',     href: '/usuarios' },
      { label: 'Ranking Top', href: '/top' },
    ]
  },

  // Dropdown: agenda y participación
  {
    label: 'Participa',
    dropdown: [
      { label: 'Calendario',          href: '/calendario' },
      { label: 'Solicitar entrevista', href: '/solicitar-entrevista', badge: '🎙️' },
      { label: 'Preguntas frecuentes', href: '/faq' },
      { label: 'Contacto',             href: '/contacto' },
    ]
  },
];

const premieres = (await getCollection('episodios'))
  .filter(e => e.data.isPremiere)
  .map(e => ({
    title: e.data.title,
    date: e.data.pubDate.getTime(),
    duration: e.data.duration || '0min',
    slug: e.slug
  }));

const currentPath = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
const isDropdownActive = (items: any[]) => items?.some(i => isActive(i.href));
---

<!-- ============================
     HEADER
     ============================ -->
<header id="site-header" class="sh">

  <!-- Accent line -->
  <div class="sh-accent" aria-hidden="true"></div>

  <div class="sh-inner">
    <div class="sh-inner-wrap">

      <!-- ── Logo ───────────────────────────── -->
      <a href="/" class="sh-logo" aria-label="Veredillas FM – Inicio">
        <span class="sh-logo-ring" aria-hidden="true"></span>
        <img src="/logo.webp" alt="" width="36" height="36" class="sh-logo-img" />
        <span class="sh-logo-text">Veredillas<b>FM</b></span>
      </a>

      <!-- ── Desktop Nav ────────────────────── -->
      <nav class="sh-nav" aria-label="Navegación principal">
        {navItems.map((item) => (
          <div class={`sh-nav-item${'dropdown' in item && item.dropdown ? ' has-dd' : ''}${'dropdown' in item && item.dropdown ? (isDropdownActive(item.dropdown) ? ' is-active' : '') : (isActive(item.href ?? '') ? ' is-active' : '')}`}>
            {'dropdown' in item && item.dropdown ? (
              <>
                <button class="sh-nav-btn" aria-haspopup="true">
                  {item.label}
                  <svg class="sh-caret" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="sh-dd" role="menu">
                  <div class="sh-dd-inner">
                    {item.dropdown.map(sub => (
                      sub.divider ? (
                        <div class="sh-dd-divider" aria-hidden="true"></div>
                      ) : (
                        <a
                          href={sub.href}
                          class={`sh-dd-link${isActive(sub.href) ? ' is-active' : ''}${sub.external ? ' is-external' : ''}`}
                          role="menuitem"
                          target={sub.external ? '_blank' : undefined}
                          rel={sub.external ? 'noopener noreferrer' : undefined}
                        >
                          <span class="sh-dd-dot" aria-hidden="true"></span>
                          <span class="sh-dd-label">{sub.label}</span>
                          {sub.badge && !sub.external && <span class="sh-dd-badge">{sub.badge}</span>}
                          {sub.external && (
                            <svg class="sh-dd-ext" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                          )}
                        </a>
                      )
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a href={item.href} class="sh-nav-link">{item.label}</a>
            )}
          </div>
        ))}
      </nav>

      <!-- ── Right Actions ──────────────────── -->
      <div class="sh-actions">
        <!-- CTA Directo -->
        <a href="/live" class="sh-cta" aria-label="Ir al directo">
          <span class="sh-cta-dot" aria-hidden="true"></span>
          En Directo
        </a>

        <div class="sh-sep" aria-hidden="true"></div>

        <CommandPalette />
        <AuthButton />
        <ThemeToggle />

        <!-- Hamburger -->
        <button id="sh-ham" class="sh-ham" aria-label="Abrir menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </div>

  <!-- ── Live Banner ────────────────────── -->
  <a id="sh-live" class="sh-live hidden" href="#">
    <span class="sh-live-dot"></span>
    <span id="sh-live-label">EN DIRECTO</span>
    <span id="sh-live-title" class="sh-live-title">Emisión en directo</span>
    <span class="sh-live-arrow">→</span>
  </a>

</header>

<!-- ── Mobile Overlay ─────────────────────── -->
<div id="sh-overlay" class="sh-overlay" aria-hidden="true">
  <div class="sh-overlay-top">
    <a href="/" class="sh-overlay-logo">
      <img src="/logo.webp" alt="Veredillas FM" width="32" height="32" />
      <span>Veredillas<b>FM</b></span>
    </a>
    <button id="sh-overlay-close" class="sh-overlay-close" aria-label="Cerrar menú">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <nav class="sh-overlay-nav">
    <!-- Direct links -->
    <div class="sh-ov-group" style="--i:0">
      <a href="/ep"   class={`sh-ov-big${isActive('/ep')   ? ' is-active' : ''}`}>Episodios</a>
      <a href="/blog" class={`sh-ov-big${isActive('/blog') ? ' is-active' : ''}`}>Blog</a>
    </div>

    <!-- Grouped sections -->
    {navItems.filter(i => 'dropdown' in i && i.dropdown).map((item, i) => (
      <div class="sh-ov-group" style={`--i:${i + 1}`}>
        <span class="sh-ov-label">{item.label}</span>
        <div class="sh-ov-links">
          {item.dropdown!.filter(s => !s.divider).map(sub => (
            <a
              href={sub.href}
              class={`sh-ov-link${isActive(sub.href) ? ' is-active' : ''}${sub.external ? ' is-external' : ''}`}
              target={sub.external ? '_blank' : undefined}
              rel={sub.external ? 'noopener noreferrer' : undefined}
            >
              {sub.label}
              {sub.badge && !sub.external && <span class="sh-ov-badge">{sub.badge}</span>}
              {sub.external && <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>}
            </a>
          ))}
        </div>
      </div>
    ))}
  </nav>

  <div class="sh-overlay-foot">
    <a href="https://open.spotify.com/show/6mXWyLhzhET5EHk1p72j18" target="_blank" class="sh-ov-chip sh-ov-chip--spotify">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.6 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
      Spotify
    </a>
    <a href="https://music.amazon.es/podcasts/8d708ffa-7ef7-42f0-878d-fe3575491bef/veredillas-fm" target="_blank" class="sh-ov-chip sh-ov-chip--amazon">
      <div class="icon-mask amazon-icon" style="width:16px;height:16px;background-color:currentColor"></div>
      Amazon
    </a>
    <a href="https://podcasts.apple.com/es/podcast/veredillas-fm/id1870103081" target="_blank" class="sh-ov-chip sh-ov-chip--apple">
      <div class="icon-mask apple-icon" style="width:16px;height:16px;background-color:currentColor"></div>
      Apple
    </a>
  </div>
</div>

<style>
/* ─────────────────────────────────────────
   HEADER SHELL
───────────────────────────────────────── */
.sh {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 9000;
  font-family: var(--font-body);
  /* Scroll-hide/show */
  transform: translateY(0);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

.sh.is-hidden {
  transform: translateY(-110%);
}

/* Gradient accent line on top */
.sh-accent {
  height: 2px;
  background: linear-gradient(90deg,
    #8b5cf6 0%,
    #ec4899 35%,
    #0ea5e9 65%,
    #8b5cf6 100%
  );
  background-size: 200% 100%;
  animation: sh-accent-slide 5s linear infinite;
}

@keyframes sh-accent-slide {
  0%   { background-position: 0% 0%; }
  100% { background-position: 200% 0%; }
}

/* Main bar – full width, glassmorphism */
.sh-inner {
  height: 68px;
  width: 100%;
  /* Transparent glass – starts very transparent */
  background: rgba(4, 4, 8, 0.35);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid rgba(255,255,255,0.07);
  box-shadow: 0 1px 40px rgba(0,0,0,0.15);
  transition: background 0.4s ease, box-shadow 0.4s ease;
}

/* Inner wrapper: max-width + padding */
.sh-inner-wrap {
  max-width: 1400px;
  margin: 0 auto;
  height: 100%;
  padding: 0 2.5rem;
  display: flex;
  align-items: center;
  gap: 2rem;
}

/* Scrolled – slightly more opaque but never fully solid */
.sh.is-scrolled .sh-inner {
  background: rgba(4, 4, 8, 0.72);
  box-shadow: 0 4px 48px rgba(0,0,0,0.4);
}

:global([data-theme="light"]) .sh-inner {
  background: rgba(255, 255, 255, 0.45);
  border-bottom-color: rgba(0,0,0,0.06);
  box-shadow: 0 1px 24px rgba(0,0,0,0.06);
}

:global([data-theme="light"]) .sh.is-scrolled .sh-inner {
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 4px 32px rgba(0,0,0,0.1);
}

/* ─────────────────────────────────────────
   LOGO
───────────────────────────────────────── */
.sh-logo {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  text-decoration: none;
  flex-shrink: 0;
  position: relative;
  margin-right: 0.5rem;
}

.sh-logo-ring {
  position: absolute;
  inset: -4px;
  border-radius: 12px;
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  opacity: 0;
  transition: opacity 0.3s;
  z-index: -1;
  filter: blur(8px);
}

.sh-logo:hover .sh-logo-ring { opacity: 0.45; }

.sh-logo-img {
  width: 34px;
  height: 34px;
  border-radius: 9px;
  object-fit: cover;
  display: block;
  position: relative;
  z-index: 1;
  transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
}

.sh-logo:hover .sh-logo-img { transform: scale(1.08) rotate(-2deg); }

.sh-logo-text {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 600;
  letter-spacing: -0.03em;
  color: var(--color-text-main);
  white-space: nowrap;
}

.sh-logo-text b {
  font-weight: 800;
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ─────────────────────────────────────────
   DESKTOP NAV
───────────────────────────────────────── */
.sh-nav {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  margin-left: 0.75rem;
}

.sh-nav-item {
  position: relative;
}

.sh-nav-link,
.sh-nav-btn {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 1rem;
  border-radius: 9px;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text-muted);
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
  text-decoration: none;
  transition: color 0.2s, background 0.2s;
  white-space: nowrap;
  letter-spacing: -0.01em;
}

.sh-nav-link:hover,
.sh-nav-btn:hover {
  color: var(--color-text-main);
  background: rgba(255,255,255,0.06);
}

:global([data-theme="light"]) .sh-nav-link:hover,
:global([data-theme="light"]) .sh-nav-btn:hover {
  background: rgba(0,0,0,0.05);
}

/* Active – underline */
.sh-nav-item.is-active .sh-nav-link,
.sh-nav-item.is-active .sh-nav-btn {
  color: var(--color-text-main);
}

.sh-nav-item.is-active .sh-nav-link::after,
.sh-nav-item.is-active .sh-nav-btn::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0.875rem;
  right: 0.875rem;
  height: 2px;
  border-radius: 2px;
  background: linear-gradient(90deg, #8b5cf6, #ec4899);
}

.sh-caret {
  opacity: 0.5;
  transition: transform 0.22s ease;
  flex-shrink: 0;
}

.sh-nav-item.has-dd:hover .sh-caret { transform: rotate(180deg); }

/* ─────────────────────────────────────────
   DROPDOWN
───────────────────────────────────────── */
.sh-dd {
  position: absolute;
  top: calc(100% + 10px);
  left: 0;
  min-width: 210px;
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-4px) scale(0.97);
  transform-origin: top left;
  transition:
    opacity 0.18s ease,
    transform 0.18s ease,
    visibility 0s linear 0.18s;
  pointer-events: none;
}

/* Bridge gap */
.sh-dd::before {
  content: '';
  position: absolute;
  top: -12px;
  left: -16px;
  right: -16px;
  height: 12px;
}

.sh-nav-item.has-dd:hover .sh-dd {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
  pointer-events: auto;
  transition:
    opacity 0.18s ease,
    transform 0.18s ease,
    visibility 0s linear 0s;
}

.sh-dd-inner {
  background: rgba(12, 10, 22, 0.97);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border: 1px solid rgba(139,92,246,0.2);
  border-radius: 14px;
  padding: 0.5rem;
  box-shadow:
    0 24px 64px rgba(0,0,0,0.5),
    0 0 0 1px rgba(255,255,255,0.04) inset;
}

:global([data-theme="light"]) .sh-dd-inner {
  background: rgba(255,255,255,0.98);
  border-color: rgba(139,92,246,0.15);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12);
}

.sh-dd-link {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  padding: 0.575rem 0.875rem;
  border-radius: 9px;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: all 0.15s;
  letter-spacing: -0.01em;
}

.sh-dd-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
  transition: background 0.15s, transform 0.15s;
}

:global([data-theme="light"]) .sh-dd-dot {
  background: rgba(0,0,0,0.15);
}

.sh-dd-link:hover {
  background: rgba(139,92,246,0.12);
  color: #e9d5ff;
}

:global([data-theme="light"]) .sh-dd-link:hover {
  background: rgba(139,92,246,0.08);
  color: #6d28d9;
}

.sh-dd-link:hover .sh-dd-dot {
  background: #8b5cf6;
  transform: scale(1.3);
}

.sh-dd-link.is-active {
  color: #c4b5fd;
  background: rgba(139,92,246,0.15);
}

:global([data-theme="light"]) .sh-dd-link.is-active {
  color: #7c3aed;
  background: rgba(139,92,246,0.1);
}

.sh-dd-link.is-active .sh-dd-dot {
  background: linear-gradient(135deg, #8b5cf6, #ec4899);
}

/* ─────────────────────────────────────────
   DROPDOWN EXTRAS
───────────────────────────────────────── */
.sh-dd-label {
  flex: 1;
}

.sh-dd-badge {
  display: inline-flex;
  align-items: center;
  font-size: 0.65rem;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 99px;
  background: rgba(139,92,246,0.25);
  color: #c4b5fd;
  letter-spacing: 0.04em;
  white-space: nowrap;
}

:global([data-theme="light"]) .sh-dd-badge {
  background: rgba(139,92,246,0.12);
  color: #7c3aed;
}

.sh-dd-ext {
  opacity: 0.4;
  flex-shrink: 0;
}

.sh-dd-link.is-external {
  color: var(--color-text-dim);
}

.sh-dd-link.is-external:hover {
  color: var(--color-text-muted);
}

.sh-dd-divider {
  height: 1px;
  background: rgba(255,255,255,0.08);
  margin: 0.375rem 0.5rem;
  border-radius: 1px;
}

:global([data-theme="light"]) .sh-dd-divider {
  background: rgba(0,0,0,0.07);
}

/* ─────────────────────────────────────────
   ACTIONS
───────────────────────────────────────── */
.sh-actions {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-left: auto;
}

.sh-sep {
  width: 1px;
  height: 22px;
  background: rgba(255,255,255,0.1);
  margin: 0 0.375rem;
}

:global([data-theme="light"]) .sh-sep {
  background: rgba(0,0,0,0.1);
}

/* ─────────────────────────────────────────
   CTA EN DIRECTO
───────────────────────────────────────── */
.sh-cta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.45rem 1rem;
  border-radius: 99px;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.01em;
  text-decoration: none;
  color: #fca5a5;
  border: 1px solid rgba(239,68,68,0.3);
  background: rgba(239,68,68,0.08);
  transition: all 0.2s;
  white-space: nowrap;
}

.sh-cta:hover {
  background: rgba(239,68,68,0.18);
  border-color: rgba(239,68,68,0.5);
  color: #fecaca;
}

.sh-cta-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #ef4444;
  flex-shrink: 0;
  animation: sh-pulse 2s ease-in-out infinite;
}

.sh-chip {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 0.3rem 0.625rem;
  border-radius: 99px;
  font-size: 0.75rem;
  font-weight: 600;
  text-decoration: none;
  border: 1px solid transparent;
  transition: all 0.2s;
  white-space: nowrap;
}

.sh-chip--spotify {
  color: #1DB954;
  border-color: rgba(29,185,84,0.25);
  background: rgba(29,185,84,0.08);
}
.sh-chip--spotify:hover {
  background: rgba(29,185,84,0.18);
  border-color: rgba(29,185,84,0.5);
}

.sh-chip--apple {
  color: #A335EE;
  border-color: rgba(163,53,238,0.25);
  background: rgba(163,53,238,0.08);
}
.sh-chip--apple:hover {
  background: rgba(163,53,238,0.18);
  border-color: rgba(163,53,238,0.5);
}

/* ─────────────────────────────────────────
   LIVE BANNER
───────────────────────────────────────── */
.sh-live {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  height: 32px;
  background: rgba(239,68,68,0.1);
  border-bottom: 1px solid rgba(239,68,68,0.2);
  font-size: 0.78rem;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  text-decoration: none;
  transition: background 0.2s;
  letter-spacing: 0.01em;
}

.sh-live:hover { background: rgba(239,68,68,0.16); }
.sh-live.hidden { display: none !important; }

.sh-live-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #ef4444;
