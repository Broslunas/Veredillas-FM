---
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-[#030304] border-t border-white/5 py-20 md:py-32 mt-auto">
  <!-- Decorative Blobs -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] pointer-events-none -z-10 translate-y-[-50%]"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none -z-10 translate-y-[50%]"></div>
  
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[length:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,black,transparent)] pointer-events-none opacity-20"></div>

  <div class="w-full max-w-[1400px] mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-20">
      
      <!-- Column 1: Brand & Bio -->
      <div class="lg:col-span-1 space-y-8">
        <div class="space-y-6">
          <h3 class="text-2xl font-black tracking-tighter text-white font-display">
            Veredillas <span class="text-gradient">FM</span>
          </h3>
          <p class="text-zinc-400 text-sm leading-relaxed max-w-xs">Donde te mantenemos al pendiente de los temas más candentes.</p>
          
          <div class="flex items-center gap-2 text-zinc-500 text-xs font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Canarias, España</span>
          </div>

          <div class="flex flex-col gap-2">
            <a href="/politica-de-privacidad" class="text-zinc-500 text-xs hover:text-white transition-colors">• Política de Privacidad</a>
            <a href="/terminos-y-condiciones" class="text-zinc-500 text-xs hover:text-white transition-colors">• Términos y Condiciones</a>
            <a href="/cookies" class="text-zinc-500 text-xs hover:text-white transition-colors">• Política de Cookies</a>
          </div>
        </div>
      </div>

      <!-- Column 2: Explora -->
      <div>
        <div class="mb-6 space-y-2">
            <div class="h-[1px] w-6 bg-primary rounded-full mb-3 opacity-50"></div>
            <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Explora</h4>
        </div>
        <ul class="space-y-3">
          <li><a href="/" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Inicio</a></li>
          <li><a href="/ep" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Episodios</a></li>
          <li><a href="/live" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">En Vivo</a></li>
          <li><a href="/blog" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Blog</a></li>
          <li><a href="/galeria" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Galería</a></li>
          <li><a href="/calendario" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Calendario</a></li>
          <li><a href="/stats" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] inline-block">Estadísticas</a></li>
        </ul>
      </div>

      <!-- Column 3: Comunidad -->
      <div>
        <div class="mb-6 space-y-2">
            <div class="h-[1px] w-6 bg-secondary rounded-full mb-3 opacity-50"></div>
            <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Comunidad</h4>
        </div>
        <ul class="space-y-3">
          <li><a href="/usuarios" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Oyentes</a></li>
          <li><a href="/about" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Sobre Nosotros</a></li>
          <li><a href="/equipo" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Equipo</a></li>
          <li><a href="/entrevistas" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Entrevistas</a></li>
          <li><a href="/invitados" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Invitados</a></li>
          <li><a href="/faq" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Preguntas (FAQ)</a></li>
          <li><a href="/solicitar-entrevista" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] inline-block">Participar</a></li>
        </ul>
      </div>

      <!-- Column 4: Conecta -->
      <div>
        <div class="mb-6 space-y-2">
            <div class="h-[1px] w-6 bg-accent rounded-full mb-3 opacity-50"></div>
            <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Conecta</h4>
        </div>
        <ul class="space-y-3">
          <li>
            <a href="https://www.instagram.com/veredillasfm.es/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#E4405F] transition-all text-[0.9rem] flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-[#E4405F]"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
              Instagram
            </a>
          </li>
          <li>
            <a href="https://www.tiktok.com/@veredillas.fm" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#00F2EA] transition-all text-[0.9rem] flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tiktok" viewBox="0 0 16 16">
                <path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3z"/>
              </svg>              TikTok
            </a>
          </li>
          <li>
            <a href="https://www.youtube.com/@VeredillasFM" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#FF0000] transition-all text-[0.9rem] flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-zinc-500 group-hover:text-[#FF0000]"><path d="M21.54 6.46a2.5 2.5 0 0 0-1.77-1.77C18.58 4 12 4 12 4s-6.58 0-7.77.69A2.5 2.5 0 0 0 2.23 6.46C1.53 7.64 1 9.08 1 12s.53 4.36 1.23 5.54a2.5 2.5 0 0 0 1.77 1.77C5.42 20 12 20 12 20s6.58 0 7.77-.69a2.5 2.5 0 0 0 1.77-1.77C22.47 16.36 23 14.92 23 12s-.53-4.36-1.23-5.54zM10 16V8l6 4-6 4z"/></svg>
              YouTube
            </a>
          </li>
          <li>
            <a href="https://open.spotify.com/show/6mXWyLhzhET5EHk1p72j18" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#1DB954] transition-all text-[0.9rem] flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-zinc-500 group-hover:text-[#1DB954]"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.494 17.318c-.216.353-.66.467-1.013.252-2.775-1.698-6.265-2.083-10.38-1.14-.403.092-.806-.168-.897-.57-.09-.404.168-.807.57-.898 4.542-1.04 8.448-.61 11.472 1.237.353.216.467.66.252 1.013l-.004.006zm1.488-3.324c-.272.443-.85.586-1.293.314-3.238-1.99-8.175-2.58-12.003-1.41-.5.15-1.03-.134-1.18-.634-.15-.5.134-1.03.634-1.18 4.316-1.318 9.77-0.67 13.528 1.62.443.27.586.85.314 1.293zm.14-3.412c-3.88-2.304-10.28-2.518-13.985-1.393-.604.183-1.248-.157-1.43-.76-.184-.604.156-1.248.76-1.43 4.305-1.306 11.39-1.06 15.86 1.594.548.326.732 1.03.406 1.577-.327.548-1.03.732-1.577.406l.006.006z"/></svg>
              Spotify
            </a>
          </li>
          <li>
            <a href="https://github.com/broslunas/veredillas-fm" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-white transition-all text-[0.9rem] flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-white"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>
          </li>
          <li>
            <a href="https://music.amazon.es/podcasts/8d708ffa-7ef7-42f0-878d-fe3575491bef/veredillas-fm" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#3CD0D9] transition-all text-[0.9rem] flex items-center gap-2 group">
              <div class="w-[18px] h-[18px] bg-zinc-500 group-hover:bg-[#3CD0D9] [mask-image:url('/svg/amazon-music.svg')] [mask-size:contain] [mask-repeat:no-repeat] [mask-position:center]"></div>
              Amazon Music
            </a>
          </li>
          <li>
            <a href="https://podcasts.apple.com/es/podcast/veredillas-fm/id1870103081" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#A335EE] transition-all text-[0.9rem] flex items-center gap-2 group">
               <div class="w-[18px] h-[18px] bg-zinc-500 group-hover:bg-[#A335EE] [mask-image:url('/svg/apple-podcasts.svg')] [mask-size:contain] [mask-repeat:no-repeat] [mask-position:center]"></div>
              Apple Podcasts
            </a>
          </li>
          <li>
            <a href="https://go.ivoox.com/sq/3098219" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#F45F31] transition-all text-[0.9rem] flex items-center gap-2 group">
              <div class="w-[18px] h-[18px] bg-zinc-500 group-hover:bg-[#F45F31] [mask-image:url('/svg/ivoox.svg')] [mask-size:contain] [mask-repeat:no-repeat] [mask-position:center]"></div>
              iVoox
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 5: Contact -->
      <div class="lg:col-span-1 space-y-6">
        <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Contacto</h4>
        <p class="text-zinc-400 text-[0.9rem] leading-relaxed">¿Tienes una sugerencia para el programa o simplemente quieres saludar?</p>
        
        <a href="/contacto" class="w-full inline-flex items-center justify-center gap-2 py-3 px-4 bg-primary hover:bg-primary/90 text-white font-bold rounded-xl transition-all hover:-translate-y-0.5 group decoration-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Ir a Contacto
        </a>

        <div class="relative group/email">
          <div class="flex items-center justify-between p-3 bg-white/5 border border-white/10 rounded-xl text-zinc-300 text-xs transition-all hover:bg-white/10 hover:border-white/20">
            <span class="truncate">contacto@veredillasfm.es</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          </div>
          <button 
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" 
            onclick="navigator.clipboard.writeText('contacto@veredillasfm.es'); window.showToast ? window.showToast('Email copiado al portapapeles', 'success') : alert('Email copiado');"
            aria-label="Copiar email"
          ></button>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 text-zinc-500 text-xs">
       <p>&copy; {currentYear} Veredillas FM. Todos los derechos reservados.</p>
       <div class="flex items-center gap-1.5 opacity-70 hover:opacity-100 transition-all cursor-default text-[0.7rem] bg-white/5 px-3 py-1.5 rounded-full border border-white/5">
          Diseñado y desarrollado por <span class="text-white font-medium">Pablo Luna</span>
       </div>
    </div>
  </div>
</footer>
