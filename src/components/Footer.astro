          </li>
          <li>
            <a href="/solicitar-entrevista" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-secondary transition-colors"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
