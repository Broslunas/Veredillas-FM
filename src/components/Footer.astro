---
const currentYear = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-[#030304] border-t border-white/5 py-20 md:py-32 mt-auto">
  <!-- Decorative Blobs -->
  <div class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] pointer-events-none -z-10 translate-y-[-50%]"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-secondary/5 rounded-full blur-[120px] pointer-events-none -z-10 translate-y-[50%]"></div>
  
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[length:40px_40px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_50%,black,transparent)] pointer-events-none opacity-20"></div>

  <div class="w-full max-w-[1400px] mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-20">
      
      <!-- Column 1: Brand & Bio -->
      <div class="lg:col-span-1 space-y-8">
        <div class="space-y-6">
          <h3 class="text-2xl font-black tracking-tighter text-white font-display">
            Veredillas <span class="text-gradient">FM</span>
          </h3>
          <p class="text-zinc-400 text-sm leading-relaxed max-w-xs">Donde te mantenemos al pendiente de los temas más candentes.</p>
          
          <div class="flex items-center gap-2 text-zinc-500 text-xs font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70 text-primary"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Canarias, España</span>
          </div>

          <div class="flex flex-col gap-3">
            <a href="/politica-de-privacidad" class="text-zinc-500 text-xs hover:text-white transition-colors flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              Política de Privacidad
            </a>
            <a href="/terminos-y-condiciones" class="text-zinc-500 text-xs hover:text-white transition-colors flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14.5 2 14.5 7.5 20 7.5"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>
              Términos y Condiciones
            </a>
            <a href="/cookies" class="text-zinc-500 text-xs hover:text-white transition-colors flex items-center gap-2 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5Z"/><path d="M8.5 8.5v.01"/><path d="M16 15.5v.01"/><path d="M12 12v.01"/><path d="M11 17v.01"/><path d="M7 14v.01"/></svg>
              Política de Cookies
            </a>
          </div>
        </div>
      </div>

      <!-- Column 2: Explora -->
      <div>
        <div class="mb-6 space-y-2">
            <div class="h-[1px] w-6 bg-primary rounded-full mb-3 opacity-50"></div>
            <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Explora</h4>
        </div>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Inicio
            </a>
          </li>
          <li>
            <a href="/ep" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
              Episodios
            </a>
          </li>
          <li>
            <a href="/live" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M7.76 7.76a6 6 0 0 0 0 8.49"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
              En Vivo
            </a>
          </li>
          <li>
            <a href="/blog" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
              Blog
            </a>
          </li>
          <li>
            <a href="/galeria" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
              Galería
            </a>
          </li>
          <li>
            <a href="/calendario" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              Calendario
            </a>
          </li>
          <li>
            <a href="/stats" class="text-zinc-400 hover:text-primary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-primary transition-colors"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>
              Estadísticas
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Comunidad -->
      <div>
        <div class="mb-6 space-y-2">
            <div class="h-[1px] w-6 bg-secondary rounded-full mb-3 opacity-50"></div>
            <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Comunidad</h4>
        </div>
        <ul class="space-y-3">
          <li>
            <a href="/usuarios" class="text-zinc-400 hover:text-secondary transition-all text-[0.9rem] flex items-center gap-2.5 group">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500 group-hover:text-secondary transition-colors"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
