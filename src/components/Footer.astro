      <!-- Column 5: Contact -->
      <div class="lg:col-span-1 space-y-6">
        <h4 class="text-white font-black text-[0.7rem] uppercase tracking-[0.2em] font-display">Contacto</h4>
        <p class="text-zinc-400 text-[0.9rem] leading-relaxed">¿Tienes una sugerencia para el programa o simplemente quieres saludar?</p>
        
        <a href="/contacto" class="w-full inline-flex items-center justify-center gap-2 py-3 px-4 bg-primary hover:bg-primary/90 text-white font-bold rounded-xl transition-all hover:-translate-y-0.5 group decoration-none">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:rotate-12 transition-transform"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Ir a Contacto
        </a>

        <div class="relative group/email">
          <div class="flex items-center justify-between p-3 bg-white/5 border border-white/10 rounded-xl text-zinc-300 text-xs transition-all hover:bg-white/10 hover:border-white/20">
            <span class="truncate">contacto@veredillasfm.es</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          </div>
          <button 
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" 
            onclick="navigator.clipboard.writeText('contacto@veredillasfm.es'); window.showToast ? window.showToast('Email copiado al portapapeles', 'success') : alert('Email copiado');"
            aria-label="Copiar email"
          ></button>
        </div>
      </div>
