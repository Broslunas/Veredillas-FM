---
const currentPath = Astro.url.pathname;
const navLinks = [
  { group: 'Overview', items: [
      { href: '/dashboard/admin', label: '📊 Dashboard' },
      { href: '/dashboard/admin/user-stats', label: '📈 Analíticas' },
  ]},
  { group: 'Usuarios', items: [
      { href: '/dashboard/admin/users', label: '👥 Usuarios' },
      { href: '/dashboard/admin/comments', label: '💬 Comentarios' },
      { href: '/dashboard/admin/interviews', label: '📅 Entrevistas' },
  ]},
  { group: 'Contenido', items: [
      { href: '/dashboard/admin/content', label: '🎙️ Episodios' },
      { href: '/dashboard/admin/social-clips', label: '📱 Social' },
      { href: '/dashboard/admin/buffer', label: '🦬 Buffer' },
  ]},
  { group: 'Utilidades', items: [
      { href: '/dashboard/admin/live', label: '🔴 Live' },
      { href: '/dashboard/admin/push', label: '🔔 Push' },
      { href: '/dashboard/admin/wrapped', label: '🎁 Wrapped' },
      { href: '/studio/remote', label: '🎙️ Studio' },
  ]},
];

const isActive = (href: string) => {
    if (href === '/dashboard/admin') return currentPath === '/dashboard/admin';
    return currentPath.startsWith(href);
};
---

<nav class="mb-8 flex flex-wrap items-center gap-x-8 gap-y-4 p-5 bg-zinc-900/40 border border-white/10 rounded-3xl backdrop-blur-xl">
    {navLinks.map((group) => (
      <div class="flex items-center gap-3">
        <span class="text-[0.6rem] font-black uppercase tracking-[0.25em] text-zinc-600 border-r border-white/5 pr-3 py-1">{group.group}</span>
        <div class="flex flex-wrap gap-1.5">
          {group.items.map(({ href, label }) => (
            <a 
              href={href} 
              class:list={[
                "px-3.5 py-1.5 text-xs font-bold rounded-xl transition-all duration-300 border",
                {
                  "bg-violet-500/20 text-violet-400 border-violet-500/30 shadow-[0_0_20px_-5px_rgba(139,92,246,0.3)] scale-105": isActive(href),
                  "bg-white/5 text-zinc-400 border-white/5 hover:bg-white/10 hover:text-zinc-200 hover:border-white/10": !isActive(href)
                }
              ]}
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    ))}
</nav>

