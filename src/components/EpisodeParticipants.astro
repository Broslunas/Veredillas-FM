---
import { getCollection } from 'astro:content';
import { getCollection } from 'astro:content';
import SidebarWidget from './SidebarWidget.astro';

interface Props {
  participants?: string[];
}

const { participants } = Astro.props;

// If no participants listed, render nothing
if (!participants || participants.length === 0) {
  return;
}

const allGuests = await getCollection('guests');
const episodeGuests = allGuests.filter(guest => participants.includes(guest.data.name));

// If no matching guests found, render nothing
if (episodeGuests.length === 0) {
  return;
}
---

<SidebarWidget title="Invitados Especiales" isOpen={false}>
  <ul class="flex flex-col gap-2 list-none p-0 m-0">
    {episodeGuests.map(guest => (
      <li>
        <div class="flex items-center gap-4 py-1">
          {guest.data.image ? (
            <img 
              src={guest.data.image} 
              alt={guest.data.name} 
              width={48} 
              height={48} 
              class="w-12 h-12 rounded-full object-cover border-2 border-primary" 
            />
          ) : (
            <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center border-2 border-primary text-[var(--color-text-muted)]">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
          )}
          <div class="flex flex-col justify-center">
            <div class="flex items-center gap-2">
              <span class="font-semibold text-base text-[var(--color-text-main)] leading-tight break-words">{guest.data.name}</span>
              {guest.data.social?.instagram && (
                <a 
                  href={guest.data.social.instagram} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="text-[var(--color-text-muted)] hover:text-primary transition-colors duration-200 flex items-center"
                  title={`Instagram de ${guest.data.name}`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              )}
            </div>
            {guest.data.role && <span class="text-[0.8rem] text-[var(--color-text-muted)] leading-tight mt-0.5">{guest.data.role}</span>}
          </div>
        </div>
      </li>
    ))}
  </ul>
</SidebarWidget>
