---
export const prerender = false;

// Esta página sirve como puente de confianza para evitar pérdida de contexto 'opener'
// y problemas de cookies SameSite en navegadores estrictos.
const scriptUrl = "https://script.google.com/a/macros/canariaseducacion.es/s/AKfycbxwL1A4BGFkCkqDfYm4nKNDSfK9VoIS8-Sx-WDJN5fLxfcNgyDO7i26dwuf39jIBfsJ/exec";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Conectando con @canariaseducacion.es</title>
    <style>
        body {
            background-color: #0f172a;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            font-family: system-ui, -apple-system, sans-serif;
            text-align: center;
        }
        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid rgba(255, 255, 255, 0.1);
            border-left-color: #00adef;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 1.5rem;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .logo { width: 80px; height: 80px; margin-bottom: 20px; border-radius: 12px; }
    </style>
</head>
<body>
    <div class="card">
        <div class="spinner"></div>
        <h2>Verificando cuenta educativa...</h2>
        <p style="opacity: 0.7;">Redirigiéndote de forma segura a Google</p>
    </div>

    <script define:vars={{ scriptUrl }}>
        // Esperamos un segundo para que el usuario sepa qué pasa (mejor UX)
        // y luego redirigimos al script de Apps Script
        setTimeout(() => {
            window.location.replace(scriptUrl);
        }, 800);
    </script>
</body>
</html>
