---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SocialShare from '../../components/SocialShare.astro';
import ShareCardGenerator from '../../components/ShareCardGenerator.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const formattedDate = entry.data.pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  image={entry.data.image || "/logo.webp"}
  imageAlt={entry.data.title}
  type="article"
  publishedTime={entry.data.pubDate.toISOString()}
  author={entry.data.author}
  tags={entry.data.tags || []}
>
    <!-- Post Header Hero Section -->
    <header class="relative pt-24 pb-16 md:pt-32 md:pb-24 overflow-hidden bg-background">
        <!-- Optional Background Image Blur -->
        {entry.data.image && (
            <div class="absolute inset-0 z-0">
                <img src={entry.data.image} alt="" class="w-full h-full object-cover opacity-10 filter blur-3xl scale-110" />
                <div class="absolute inset-0 bg-gradient-to-b from-background/50 via-background to-background"></div>
            </div>
        )}

        <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <!-- Meta Info -->
            <div class="flex items-center justify-center space-x-3 text-sm md:text-base font-semibold tracking-wider text-primary uppercase mb-6 animate-fade-in-up">
                <time>{formattedDate}</time>
                <span class="text-white/30">•</span>
                <span class="text-secondary">{entry.data.author}</span>
            </div>

            <!-- Tags -->
            {entry.data.tags && entry.data.tags.length > 0 && (
                <div class="flex flex-wrap justify-center gap-2 mb-8 animate-fade-in-up" style="animation-delay: 100ms;">
                    {entry.data.tags.map((tag: string) => (
                        <a
                            href={`/blog?tag=${tag}`}
                            class="inline-block px-4 py-1.5 rounded-full text-sm font-medium bg-primary/10 text-primary border border-primary/20 hover:bg-primary hover:text-white hover:border-primary transition-all duration-300 hover:-translate-y-0.5 shadow-sm hover:shadow-[0_0_15px_rgba(139,92,246,0.4)]"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}

            <!-- Title -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-10 leading-tight md:leading-tight lg:leading-tight drop-shadow-lg animate-fade-in-up" style="animation-delay: 200ms;">
                {entry.data.title}
            </h1>

            <!-- Featured Image -->
            {entry.data.image && (
                <div class="relative max-w-5xl mx-auto rounded-3xl overflow-hidden shadow-2xl shadow-primary/20 ring-1 ring-white/10 animate-fade-in-up" style="animation-delay: 300ms;">
                    <div class="aspect-w-16 aspect-h-9 md:aspect-video">
                        <img
                            src={entry.data.image}
                            alt={entry.data.title}
                            class="w-full h-full object-cover hover:scale-105 transition-transform duration-700 ease-out"
                        />
                    </div>
                </div>
            )}
        </div>
    </header>

    <!-- Post Content Container -->
    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 relative z-10">
        <div class="bg-white/5 backdrop-blur-sm rounded-3xl border border-white/10 p-6 md:p-10 lg:p-12 shadow-xl">
            <!-- Content Styling using Tailwind child selectors since @tailwindcss/typography might not be available -->
            <div class="prose-content text-lg md:text-xl leading-relaxed text-white/80
                        [&>p]:mb-8 [&>p:last-child]:mb-0
                        [&>h2]:text-3xl [&>h2]:font-bold [&>h2]:text-white [&>h2]:mt-14 [&>h2]:mb-6 [&>h2]:border-b [&>h2]:border-white/10 [&>h2]:pb-2
                        [&>h3]:text-2xl [&>h3]:font-bold [&>h3]:text-white/90 [&>h3]:mt-10 [&>h3]:mb-4
                        [&>ul]:mb-8 [&>ul]:list-disc [&>ul]:pl-6 [&>ul>li]:mb-2 [&>ul>li]:pl-2 [&>ul>li::marker]:text-primary
                        [&>ol]:mb-8 [&>ol]:list-decimal [&>ol]:pl-6 [&>ol>li]:mb-2 [&>ol>li]:pl-2 [&>ol>li::marker]:text-primary
                        [&>a]:text-primary [&>a]:underline [&>a]:underline-offset-4 [&>a]:decoration-primary/40 hover:[&>a]:decoration-primary [&>a]:transition-colors
                        [&>blockquote]:border-l-4 [&>blockquote]:border-primary [&>blockquote]:pl-6 [&>blockquote]:italic [&>blockquote]:text-white/60 [&>blockquote]:my-8 [&>blockquote]:bg-primary/5 [&>blockquote]:py-3 [&>blockquote]:pr-4 [&>blockquote]:rounded-r-lg
                        [&>img]:rounded-2xl [&>img]:shadow-lg [&>img]:my-10 [&>img]:mx-auto [&>img]:max-w-full
                        [&>strong]:text-white [&>strong]:font-semibold
                        [&>code]:text-secondary [&>code]:bg-white/10 [&>code]:px-1.5 [&>code]:py-0.5 [&>code]:rounded-md [&>code]:text-sm
                        [&>pre]:bg-black/40 [&>pre]:border [&>pre]:border-white/10 [&>pre]:p-6 [&>pre]:rounded-xl [&>pre]:overflow-x-auto [&>pre]:my-8 [&>pre>code]:text-white/90 [&>pre>code]:bg-transparent [&>pre>code]:p-0">
                <Content />
            </div>

            <!-- Share Section -->
            <div class="mt-16 pt-8 border-t border-white/10 flex flex-col items-center">
                <h3 class="text-xl font-bold text-white mb-6">¿Te ha gustado este artículo?</h3>
                <SocialShare title={entry.data.title} image={entry.data.image || "/logo.webp"} />
            </div>
        </div>
    </article>

    <ShareCardGenerator 
        title={entry.data.title} 
        image={entry.data.image || "/logo.webp"} 
        triggerId="blog-story-trigger" 
    />
</Layout>