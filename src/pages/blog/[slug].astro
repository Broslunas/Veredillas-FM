---
import { getCollection } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SocialShare from '../../components/SocialShare.astro';
import ShareCardGenerator from '../../components/ShareCardGenerator.astro';
import Comments from '../../components/Comments.astro';
import SidebarWidget from '../../components/SidebarWidget.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AdImpresoras from '../../components/AdImpresoras.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const formattedDate = entry.data.pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const relativeOgImageUrl = entry.data.image || `/logo.webp`;
---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  image={entry.data.image || "/logo.webp"}
  imageAlt={entry.data.title}
  type="article"
  publishedTime={entry.data.pubDate.toISOString()}
  author={entry.data.author}
  tags={entry.data.tags || []}
>
    <!-- Post Cinema Layout Container -->
    <div class="page-bg"></div>

    <div class="cinema-layout container">
        <Breadcrumbs className="col-span-full mb-4" customLabel={entry.data.title} />
        <main class="main-content" style="overflow-x: hidden; min-width: 0;">
            <!-- HERO / BANNER -->
            <section class="player-section section-fade">
                {entry.data.image && (
                    <div class="player-wrapper shadow-2xl relative mb-6">
                        <div class="cinema-player-box group">
                            <div class="aspect-video bg-[#0f0f0f] rounded-2xl flex items-center justify-center overflow-hidden border border-white/5 relative">
                                <img
                                    src={entry.data.image}
                                    alt={entry.data.title}
                                    width={1280}
                                    height={720}
                                    class="absolute inset-0 w-full h-full object-cover"
                                />
                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-80"></div>
                            </div>
                        </div>
                    </div>
                )}

                <!-- Info Header -->
                <header class="player-info py-8">
                    <div class="mb-4 flex gap-2">
                        {entry.data.tags && entry.data.tags.slice(0, 2).map((tag: string) => (
                            <span class="px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest bg-primary/20 text-primary border border-primary/20">
                                {tag}
                            </span>
                        ))}
                    </div>
                    <h1 class="text-3xl md:text-5xl font-black mb-6 tracking-tight leading-[1.1] text-glow">
                        {entry.data.title}
                    </h1>
                    <div class="flex flex-wrap items-center justify-between gap-6 pb-8 border-b border-white/5">
                        <div class="author-meta flex items-center gap-4">
                            <div class="relative">
                                <img
                                    src="/logo.webp"
                                    alt="Veredillas FM"
                                    width={48}
                                    height={48}
                                    class="w-12 h-12 rounded-2xl border border-white/10 shadow-lg object-cover"
                                />
                                <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-primary rounded-full border-2 border-[#121212] flex items-center justify-center">
                                    <div class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></div>
                                </div>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest leading-none mb-1">Escrito por</span>
                                <p class="font-black text-zinc-100 leading-tight text-lg">{entry.data.author}</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-6">
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest leading-none mb-1">Publicado</span>
                                <p class="text-zinc-300 font-bold">{formattedDate}</p>
                            </div>
                            <div class="w-px h-8 bg-white/5 hidden md:block"></div>
                            <button id="scroll-to-comments" class="hidden md:flex flex-col items-end group cursor-pointer">
                                <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest leading-none mb-1">Conversación</span>
                                <p class="text-primary font-black group-hover:underline underline-offset-4 transition-all">Ver comentarios</p>
                            </button>
                        </div>
                    </div>
                </header>
            </section>

            <!-- CONTENT -->
            <section class="description-section glass-panel p-6 mb-8 section-fade">
                <div class="mb-4">
                    <span class="text-sm font-bold uppercase tracking-wider text-zinc-400">Contenido</span>
                </div>

                <div class="content-body prose prose-invert max-w-none mb-8">
                    <Content />
                </div>
            </section>

            <!-- Ad Before Comments -->
            <div class="mb-12 section-fade">
                <AdImpresoras variant="leaderboard" />
            </div>

            <!-- COMMENTS AREA -->
            <section id="comments-wrapper" class="comments-section mb-20 section-fade">
                <div class="flex items-center gap-4 mb-8">
                    <h2 class="text-xl font-black">Comentarios</h2>
                </div>
                <Comments slug={`blog-${slug}`} />
            </section>
        </main>

        <!-- SIDEBAR -->
        <aside class="sidebar-column">
            <div class="sticky top-24 space-y-6">

                <SidebarWidget title="Detalles del Post" isOpen={true}>
                    <ul class="details-list text-sm">
                        <li class="flex justify-between py-3 border-b border-white/5">
                            <span class="text-zinc-500 font-medium">Fecha</span>
                            <span class="font-bold text-zinc-200">{formattedDate}</span>
                        </li>
                        <li class="flex justify-between py-3 border-b border-white/5">
                            <span class="text-zinc-500 font-medium">Autor</span>
                            <span class="font-bold text-zinc-200">{entry.data.author}</span>
                        </li>
                        <li class="flex justify-between py-3 border-b border-white/5">
                            <span class="text-zinc-500 font-medium">Lectura</span>
                            <span class="font-bold text-zinc-200">5 min</span>
                        </li>
                        {entry.data.tags && entry.data.tags.length > 0 && (
                            <li class="pt-6">
                                <span class="text-[10px] font-black uppercase tracking-widest text-zinc-500 block mb-3">Etiquetas</span>
                                <div class="flex flex-wrap gap-2">
                                    {entry.data.tags.map((tag: string) => (
                                        <a
                                            href={`/blog?tag=${tag}`}
                                            class="tag-chip text-[10px] font-black uppercase px-3 py-1.5 bg-white/5 hover:bg-primary/20 hover:text-primary border border-white/5 hover:border-primary/20 transition-all rounded-lg"
                                        >
                                            #{tag}
                                        </a>
                                    ))}
                                </div>
                            </li>
                        )}
                    </ul>
                </SidebarWidget>

                <!-- Share Widget in Sidebar -->
                <SidebarWidget title="Compartir" isOpen={true}>
                    <SocialShare
                        title={entry.data.title}
                        image={entry.data.image || relativeOgImageUrl}
                        variant="sidebar"
                    />
                </SidebarWidget>

                <!-- Ad in Sidebar -->
                <div class="section-fade">
                    <AdImpresoras variant="skyscraper" />
                </div>

            </div>
        </aside>
    </div>

    <ShareCardGenerator 
        title={entry.data.title} 
        image={entry.data.image || relativeOgImageUrl}
        triggerId="blog-story-trigger" 
    />
</Layout>

<style>
    .page-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.15), transparent 70%),
                    #09090b;
        z-index: -1;
        pointer-events: none;
    }

    .cinema-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 3rem;
        padding-top: 1rem;
        max-width: 1600px;
        margin: 0 auto;
        overflow-x: hidden;
    }

    @media (max-width: 1200px) {
        .cinema-layout {
            grid-template-columns: 1fr;
        }
        .sidebar-column {
            order: 2;
        }
        .sidebar-column .sticky {
            position: relative;
            top: 0;
        }
    }

    /* ====== SMALL DEVICES (≤768px) ====== */
    @media (max-width: 768px) {
        .cinema-layout {
            gap: 1.25rem;
            padding-top: 0.5rem;
        }

        .player-wrapper {
            border-radius: 12px;
        }

        .player-info {
            padding: 1rem 0;
        }

        .player-info h1 {
            font-size: 1.5rem !important;
            line-height: 1.25;
            margin-bottom: 0.5rem;
        }

        .description-section.glass-panel {
            padding: 1.25rem;
            border-radius: 14px;
            margin-bottom: 1.25rem;
        }

        .description-section .content-body {
            font-size: 0.95rem;
            line-height: 1.7;
        }

        .description-section .content-body :global(h2) {
            font-size: 1.25rem;
            margin-top: 1.5rem;
        }

        .comments-section {
            margin-bottom: 5rem;
        }

        .comments-section h2 {
            font-size: 1.15rem;
        }

        /* Player info author row */
        .player-info .author-meta img {
            width: 2rem;
            height: 2rem;
        }

        .player-info .author-meta p.font-bold {
            font-size: 0.9rem;
        }

        /* Sidebar details on mobile */
        .sidebar-column .details-list li {
            padding: 0.625rem 0;
        }
    }

    /* ====== EXTRA SMALL DEVICES (≤480px) ====== */
    @media (max-width: 480px) {
        .cinema-layout {
            gap: 1rem;
            padding-top: 0.25rem;
        }

        .cinema-layout.container {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .main-content {
            overflow-x: hidden;
            min-width: 0;
        }

        .player-info h1 {
            font-size: 1.25rem !important;
            word-break: break-word;
        }

        .description-section.glass-panel {
            padding: 1rem;
            border-radius: 12px;
            margin-bottom: 1rem;
        }

        /* Comments */
        .comments-section .flex.items-center.gap-4 {
            margin-bottom: 1rem;
        }

        /* Player wrapper */
        .player-wrapper {
            border-radius: 10px;
        }

        /* Sidebar on very small screens */
        .sidebar-column {
            overflow-x: hidden;
        }
    }

    .text-glow {
        text-shadow: 0 0 30px rgba(139, 92, 246, 0.2);
    }

    .player-wrapper {
        background: #000;
        border-radius: 32px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    }
    
    @media (max-width: 768px) {
        .player-wrapper {
            border-radius: 16px;
        }
    }

    .cinema-player-box {
        width: 100%;
        position: relative;
    }

    /* Content Body Typography */
    .content-body {
        line-height: 1.8;
        font-size: 1.15rem;
        color: #e4e4e7;
    }

    .content-body :global(h2) {
        font-weight: 900;
        letter-spacing: -0.04em;
        margin-top: 3.5rem;
        margin-bottom: 1.5rem;
        font-size: 2.25rem;
        color: #fff;
        line-height: 1.1;
    }
    .content-body :global(h3) {
        font-weight: 800;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        font-size: 1.75rem;
        color: rgba(255,255,255,0.9);
        letter-spacing: -0.02em;
    }
    .content-body :global(a) {
        color: var(--color-primary);
        text-decoration: underline;
        text-decoration-color: rgba(139, 92, 246, 0.4);
        text-underline-offset: 4px;
        transition: all 0.2s ease;
        font-weight: 600;
    }
    .content-body :global(a:hover) {
        text-decoration-color: var(--color-primary);
        background: rgba(139, 92, 246, 0.1);
    }
    .content-body :global(ul) {
        list-style-type: none;
        padding-left: 0.5rem;
        margin-bottom: 2rem;
    }
    .content-body :global(ul li) {
        position: relative;
        padding-left: 1.75rem;
        margin-bottom: 0.75rem;
    }
    .content-body :global(ul li::before) {
        content: "";
        position: absolute;
        left: 0;
        top: 0.6em;
        width: 8px;
        height: 8px;
        background: var(--color-primary);
        border-radius: 2px;
        transform: rotate(45deg);
    }
    .content-body :global(ol) {
        list-style-type: decimal;
        padding-left: 1.5rem;
        margin-bottom: 2rem;
        color: #a1a1aa;
    }
    .content-body :global(li) {
        margin-bottom: 0.75rem;
    }
    .content-body :global(p) {
        margin-bottom: 2rem;
    }
    .content-body :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding: 2rem;
        font-style: italic;
        color: #fff;
        font-size: 1.5rem;
        font-weight: 600;
        line-height: 1.4;
        margin: 3rem 0;
        background: linear-gradient(to right, rgba(139, 92, 246, 0.1), transparent);
        border-radius: 0 24px 24px 0;
    }
    .content-body :global(img) {
        border-radius: 24px;
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.6);
        margin: 3.5rem auto;
        max-width: 100%;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .glass-panel {
        background: rgba(15, 15, 18, 0.6);
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 28px;
        box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.3);
    }

    .tag-chip {
        color: #a1a1aa;
    }

    /* Animation on enter */
    .section-fade {
        animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        animation-fill-mode: both;
    }

    @keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script>
    const initCinemaSection = () => {
        // Observer for fade-in animations
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('opacity-100');
                    entry.target.classList.remove('opacity-0', 'translate-y-8');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        document.querySelectorAll('.section-fade').forEach((el) => {
            observer.observe(el);
        });

        // Scroll to comments logic
        const scrollBtn = document.getElementById('scroll-to-comments');
        const commentsWrapper = document.getElementById('comments-wrapper');
        
        if (scrollBtn && commentsWrapper) {
            scrollBtn.addEventListener('click', () => {
                commentsWrapper.scrollIntoView({ behavior: 'smooth' });
            });
        }
    };

    document.addEventListener("DOMContentLoaded", initCinemaSection);
    document.addEventListener("astro:page-load", initCinemaSection);
</script>