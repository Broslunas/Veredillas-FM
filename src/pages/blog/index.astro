---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get unique tags
const allTags = ['Todos', ...new Set(posts.flatMap(post => post.data.tags || []))];

// Cache this page in the Edge for 15 minutes
Astro.response.headers.set('Cache-Control', 's-maxage=900, stale-while-revalidate=450');
---

<Layout 
  title="Blog"
  description="Lee las últimas noticias, historias y acontecimientos del IES Veredillas. Descubre el día a día de nuestro instituto contado por los propios estudiantes."
  image="/logo.webp"
  imageAlt="Blog Veredillas FM - Noticias y actualidad del IES Veredillas"
  tags={['blog', 'noticias escolares', 'IES Veredillas', 'actualidad estudiantil', 'vida escolar']}
>
    <!-- Background Decor from ep/index.astro -->
    <div class="page-bg"></div>

    <div class="container page-wrapper">
        <header class="page-header fade-in">
            <h1>Blog de <br><span class="text-gradient">Veredillas FM</span></h1>
            <p class="mt-4 text-xl md:text-2xl text-white/80 max-w-2xl mx-auto font-medium leading-relaxed mb-12">
                Noticias, historias y el día a día de nuestro instituto contado por los propios estudiantes.
            </p>

            <div class="controls-wrapper">
                <!-- Search + Category Toggles -->
                <div class="controls-row controls-row--bottom" style="padding-top: 1.5rem; padding-bottom: 1.5rem; justify-content: center; flex-wrap: wrap;">

                    <div class="flex flex-wrap justify-center gap-3 animate-fade-in-up" id="blog-category-filters">
                        {allTags.map(tag => (
                            <button
                                class={`filter-btn season-btn
                                        ${tag === 'Todos' ? 'active' : ''}`}
                                data-filter={tag}
                            >
                                {tag}
                            </button>
                        ))}
                    </div>

                </div>
            </div>
        </header>

        <!-- Blog Grid Content using ep/index.astro layout patterns -->
        <div class="episodes-grid" id="blog-grid">
            {sortedPosts.map((post, index) => (
                <article 
                    class="episode-item post-item fade-in-up group relative flex flex-col h-full bg-[#131313] backdrop-blur-md rounded-[20px] border border-white/5 overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] hover:border-primary/50"
                    data-tags={post.data.tags?.join(',') || ''}
                    style={`--delay: ${index % 6}; view-transition-name: blog-${post.slug};`}
                >
                    <a href={`/blog/${post.slug}`} class="flex flex-col h-full">
                        {post.data.image ? (
                             <div class="relative w-full aspect-[16/9] overflow-hidden bg-black/20">
                                <img
                                    src={post.data.image}
                                    alt={post.data.title}
                                    loading="lazy"
                                    class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110"
                                />
                                {/* Overlay gradient */}
                                <div class="absolute inset-0 bg-gradient-to-t from-[#131313] via-[#131313]/20 to-transparent opacity-80 group-hover:opacity-60 transition-opacity duration-300"></div>
                            </div>
                        ) : (
                            <div class="relative w-full aspect-[16/9] overflow-hidden bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
                                <span class="text-white/40 font-semibold tracking-widest uppercase">Veredillas FM</span>
                            </div>
                        )}

                        <div class="flex flex-col flex-grow p-6">
                            <div class="flex items-center justify-between mb-3 text-[0.75rem] text-zinc-400 uppercase font-semibold tracking-wider">
                                <time datetime={post.data.pubDate.toISOString()}>
                                    {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
                                </time>
                                {post.data.tags && post.data.tags[0] && (
                                    <span class="text-secondary">
                                        {post.data.tags[0]}
                                    </span>
                                )}
                            </div>

                            <h3 class="text-xl font-bold text-white mb-3 leading-tight group-hover:text-primary transition-colors duration-300 line-clamp-2">
                                {post.data.title}
                            </h3>

                            <p class="text-[0.95rem] text-zinc-400 mb-6 line-clamp-3 leading-relaxed flex-grow">
                                {post.data.description}
                            </p>

                            <div class="mt-auto flex justify-between items-center pt-4 border-t border-white/5 text-[0.875rem] text-zinc-500 font-semibold">
                                <span class="text-primary opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                                    Leer artículo
                                </span>
                            </div>
                        </div>
                    </a>
                </article>
            ))}
        </div>
        
        <div id="no-results" class="hidden flex-col items-center justify-center py-20 text-center animate-fade-in-up">
            <div class="w-24 h-24 mb-6 rounded-full bg-white/5 flex items-center justify-center border border-white/10">
                <svg class="w-12 h-12 text-white/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                </svg>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">No hay resultados</h3>
            <p class="text-white/60 mb-8 max-w-md">No hemos encontrado ningún artículo que coincida con esta categoría. Prueba a seleccionar otra.</p>
            <button id="reset-filter" class="px-6 py-3 rounded-full bg-primary text-white font-medium hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
                Ver todos los artículos
            </button>
        </div>
    </div>
</Layout>

<style>
    /* Add missing Episode Player styles to match ep/index.astro exactly */
    .page-bg {
        position: fixed;
        top: 0; left: 0; width: 100%; height: 100vh;
        background: radial-gradient(circle at 50% 0%, rgba(139, 92, 246, 0.08), transparent 60%);
        z-index: -1;
        pointer-events: none;
    }

    .page-wrapper {
        padding: 2rem var(--spacing-md) 6rem;
        max-width: 1400px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        max-width: 1100px;
        margin: 0 auto 3.5rem;
        position: relative;
        z-index: 200;
    }

    h1 {
        font-size: clamp(2.5rem, 5vw, 4rem);
        line-height: 1.1;
        margin-bottom: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .controls-wrapper {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: rgba(255, 255, 255, 0.04);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        width: 100%;
        margin: 0 auto;
        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.2),
            0 0 0 1px rgba(255, 255, 255, 0.05);
        overflow: visible;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .controls-wrapper:hover {
        box-shadow:
            0 15px 40px rgba(0, 0, 0, 0.3),
            0 0 0 1px rgba(255, 255, 255, 0.1);
    }

    .controls-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding: 1rem 1.5rem;
    }

    .season-btn {
        background: transparent;
        border: none;
        color: var(--color-text-muted);
        padding: 0.45rem 1.1rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 9px;
        cursor: pointer;
        transition: all 0.25s ease;
        white-space: nowrap;
    }

    .season-btn:hover { color: var(--color-text-main); }

    .season-btn.active {
        color: white;
        background: var(--color-primary);
        box-shadow: 0 2px 10px rgba(139, 92, 246, 0.35);
    }

    .episodes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 2.5rem;
        margin-bottom: var(--spacing-2xl);
        min-height: 800px;
        align-items: stretch;
        isolation: isolate;
    }

    .episode-item {
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.4s ease;
        opacity: 0;
        height: 100%;
        contain: layout;
        will-change: transform, opacity;
        content-visibility: auto;
        contain-intrinsic-size: 320px 500px;
    }

    .episode-item.is-visible {
        animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(40px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterBtns = document.querySelectorAll('.filter-btn');
        const items = document.querySelectorAll('.post-item');
        const noResults = document.getElementById('no-results');
        const resetBtn = document.getElementById('reset-filter');

        // Add intersection observer matching ep/index.astro logic
        const observerOptions = { root: null, rootMargin: '100px', threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target as HTMLElement;
                    el.classList.add('is-visible');
                    observer.unobserve(el);
                }
            });
        }, observerOptions);
        items.forEach(item => observer.observe(item));

        // Simplified active logic for the 'season-btn' style
        const activeClasses = ['active'];
        const inactiveClasses = [];

        // Helper to get current tag from URL
        function getTagFromUrl() {
            const params = new URLSearchParams(window.location.search);
            return params.get('tag') || 'Todos';
        }

        // Helper to update URL
        function setTagInUrl(tag: string) {
            const url = new URL(window.location.href);
            if (tag === 'Todos') {
                url.searchParams.delete('tag');
            } else {
                url.searchParams.set('tag', tag);
            }
            window.history.pushState({}, '', url);
        }

        function filterItems() {
            const category = getTagFromUrl();
            let visibleCount = 0;

            // Update Active State
            filterBtns.forEach(btn => {
                const isSelected = btn.getAttribute('data-filter') === category;

                if (isSelected) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });

            // Show/Hide Items
            items.forEach((item) => {
                const itemEl = item as HTMLElement;
                const tags = itemEl.getAttribute('data-tags')?.split(',') || [];
                
                if (category === 'Todos' || tags.includes(category)) {
                    itemEl.style.display = '';
                    // Trigger reflow to restart animation if needed
                    void itemEl.offsetWidth;
                    itemEl.classList.add('is-visible'); // We use is-visible from intersection observer pattern
                    visibleCount++;
                } else {
                    itemEl.style.display = 'none';
                    itemEl.classList.remove('is-visible');
                }
            });

            // Empty State
            if (visibleCount === 0) {
                noResults?.classList.remove('hidden');
                noResults?.classList.add('flex');
            } else {
                noResults?.classList.add('hidden');
                noResults?.classList.remove('flex');
            }
        }

        // Initial Filter
        filterItems();

        // Listen for popstate (browser back/forward)
        window.addEventListener('popstate', filterItems);

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const category = btn.getAttribute('data-filter') || 'Todos';
                setTagInUrl(category);
                filterItems();
            });
        });
        
        resetBtn?.addEventListener('click', () => {
            setTagInUrl('Todos');
            filterItems();
        });
    });
</script>