    }

    .time-block span:first-child {
        font-size: 1.25rem;
        font-weight: 800;
        line-height: 1;
        font-variant-numeric: tabular-nums;
    }
    
    @media (min-width: 640px) {
        .time-block span:first-child { font-size: 1.5rem; }
    }

    .cd-label {
        font-size: 0.7rem;
        color: var(--color-text-muted);
        margin-top: 0.25rem;
        font-weight: 600;
    }

