        flex-direction: column;
        align-items: center;
        background: rgba(0, 0, 0, 0.2);
        padding: 0.5rem 0.75rem;
        border-radius: var(--radius-md);
        border: 1px solid rgba(255, 255, 255, 0.05);
        min-width: 50px;
    }
    
