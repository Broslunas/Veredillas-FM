        border: 1px solid rgba(255, 75, 75, 0.3);
    }

    @keyframes blink {
        from { opacity: 1; box-shadow: 0 0 10px rgba(255, 75, 75, 0.2); }
        to { opacity: 0.5; box-shadow: none; }
    }

    #events-container {
        transition: opacity 0.3s ease;
        margin: 0 auto 4rem;
        width: 100%;
    }

    .view-timeline {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 900px;
    }

    .view-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
        max-width: 1100px;
    }

    .view-grid .event-card {
        flex-direction: column;
        align-items: stretch;
        padding: 1.5rem;
        gap: 1.5rem;
    }

    .view-grid .event-card::before {
        width: 100%;
