        box-shadow: 0 0 0 0 rgba(87, 137, 255, 0.7);
        animation: pulse 2s infinite;
        display: none;
    }

    @media (min-width: 640px) {
        .pulse-indicator { display: block; }
    }

    @keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(87, 137, 255, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(87, 137, 255, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(87, 137, 255, 0); }
    }

    .banner-label {
        font-size: 0.9rem;
        color: var(--color-primary, #5789FF);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
    }

    .banner-title {
        font-size: 1.5rem;
        margin-top: 0.25rem;
        color: var(--color-text-main);
    }

    .countdown-timer {
        display: flex;
        gap: 0.5rem;
        margin-top: 1.5rem;
    }

    @media (min-width: 768px) {
        .countdown-timer { margin-top: 0; gap: 1rem; }
    }

    .time-block {
