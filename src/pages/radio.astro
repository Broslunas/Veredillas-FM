---

<Layout 
    title="Sintonizador de Radio - Veredillas FM"
    description="Escucha tus emisoras favoritas directamente desde Veredillas FM. Selecciona entre una variedad de géneros mientras esperas nuestros próximos estrenos."
>
    <!-- Background Decor -->
    <div class="radio-background">
        <div class="glow glow-1"></div>
        <div class="glow glow-2"></div>
        <div class="grid-lines"></div>
    </div>

    <div class="container mx-auto px-4 py-12 relative z-10">
        <Breadcrumbs />
        
        <header class="mb-12 text-center">
            <div class="inline-flex items-center gap-3 px-4 py-2 bg-primary/10 border border-primary/20 rounded-full mb-6">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-primary"></span>
                </span>
                <span class="text-xs font-black uppercase tracking-[0.2em] text-primary">Sintonizador Premiere</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black mb-6 tracking-tighter text-white">
                Radio <span class="text-gradient">Veredillas</span>
            </h1>
            <p class="text-zinc-400 max-w-2xl mx-auto text-lg leading-relaxed">
                Hemos integrado las emisoras del contador de estrenos en una sola página. Elige tu ambiente y disfruta de la música sin interrupciones.
            </p>
        </header>

        <!-- Player Board -->
        <div class="max-w-6xl mx-auto">
            <div class="main-player-console bg-zinc-900/40 backdrop-blur-3xl border border-white/5 rounded-[40px] p-8 md:p-12 mb-12 shadow-2xl relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent pointer-events-none"></div>
                
                <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 items-center">
                    <div class="flex flex-col md:flex-row items-center gap-8">
                        <div class="station-visual relative">
                            <div class="equalizer-overlay absolute inset-0 flex items-end justify-center gap-1 p-8 opacity-0 transition-opacity duration-500" id="global-eq">
                                <div class="eq-bar"></div>
                                <div class="eq-bar"></div>
                                <div class="eq-bar"></div>
                                <div class="eq-bar"></div>
                                <div class="eq-bar"></div>
                            </div>
                            <img src="/logo.webp" id="active-station-logo" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-[32px] shadow-2xl border border-white/10" alt="Station Logo" />
                        </div>
                        
                        <div class="text-center md:text-left">
                            <span class="text-primary font-bold text-sm tracking-widest uppercase mb-2 block" id="active-station-genre">Selecciona una emisora</span>
                            <h2 class="text-4xl md:text-5xl font-black text-white mb-4" id="active-station-name">Veredillas Player</h2>
                            <p class="text-zinc-500 text-lg max-w-md" id="active-station-desc">Haz clic en cualquier emisora de abajo para empezar a escuchar en directo.</p>
                            
                            <div class="mt-8 flex flex-wrap justify-center md:justify-start gap-4">
                                <button id="master-play-btn" class="px-10 py-5 bg-white text-black font-black rounded-full hover:scale-105 active:scale-95 transition-all flex items-center gap-3 shadow-xl shadow-white/10 disabled:opacity-50 disabled:cursor-not-allowed">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                                    REPRODUCIR
                                </button>
                                <div class="volume-control-horizontal flex items-center gap-4 bg-white/5 border border-white/5 px-6 py-4 rounded-full">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path></svg>
                                    <input type="range" id="master-volume" min="0" max="1" step="0.01" value="0.5" class="w-24 h-1 bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-white" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="hidden lg:block border-l border-white/5 pl-12 h-full">
                        <div class="space-y-6">
                            <h4 class="text-white font-bold opacity-50 uppercase text-xs tracking-widest">Información</h4>
                            <div class="stat">
                                <span class="block text-[10px] text-zinc-600 uppercase font-black mb-1">Status</span>
                                <span class="text-emerald-500 font-mono text-sm flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                                    READY TO STREAM
                                </span>
                            </div>
                            <div class="stat">
                                <span class="block text-[10px] text-zinc-600 uppercase font-black mb-1">Source</span>
                                <span class="text-zinc-400 font-mono text-xs truncate max-w-[200px]" id="active-station-url">None Selected</span>
                            </div>
                            <div class="stat">
                                <span class="block text-[10px] text-zinc-600 uppercase font-black mb-1">Quality</span>
                                <span class="text-zinc-400 font-mono text-xs">High Definition / MP3</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Grid of Stations -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {radioStations.map((station) => (
                    <button 
                        class="station-card group bg-zinc-900/20 hover:bg-white/5 border border-white/5 hover:border-white/10 p-6 rounded-[32px] transition-all duration-300 text-left relative overflow-hidden"
                        data-station-url={station.url}
                        data-station-name={station.name}
                        data-station-genre={station.genre}
                        data-station-desc={station.description}
                        data-station-logo={station.logo}
                    >
                        <div class="flex items-center gap-4 mb-4">
                            <img src={station.logo} class="w-16 h-16 rounded-2xl object-cover border border-white/10 group-hover:scale-105 transition-transform" alt={station.name} />
                            <div>
                                <h3 class="text-white font-bold text-lg group-hover:text-primary transition-colors">{station.name}</h3>
                                <span class="text-zinc-500 text-xs uppercase tracking-tighter">{station.genre}</span>
                            </div>
                        </div>
                        <p class="text-zinc-400 text-sm line-clamp-2 leading-relaxed">
                            {station.description}
                        </p>
                        <div class="active-indicator absolute top-4 right-4 opacity-0 transition-opacity">
                            <div class="w-3 h-3 bg-primary rounded-full shadow-[0_0_10px_var(--color-primary)]"></div>
                        </div>
                    </button>
                ))}
            </div>
        </div>
    </div>

    <audio id="radio-backend-audio" preload="none"></audio>
</Layout>

<style>
    .radio-background {
        position: fixed;
        inset: 0;
        background: #050505;
        z-index: -1;
        overflow: hidden;
    }

    .glow {
        position: absolute;
        width: 60vw;
        height: 60vw;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
    }

    .glow-1 {
        top: -10vw;
        left: -10vw;
        background: radial-gradient(circle, var(--color-primary), transparent);
        animation: float-slow 20s infinite alternate;
    }

    .glow-2 {
        bottom: -10vw;
        right: -10vw;
        background: radial-gradient(circle, #3b82f6, transparent);
        animation: float-slow 25s infinite alternate-reverse;
    }

    .grid-lines {
        position: absolute;
        inset: 0;
        background-image: 
            linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 40px 40px;
        mask-image: radial-gradient(ellipse at center, black, transparent);
    }

    @keyframes float-slow {
        from { transform: translate(0, 0); }
        to { transform: translate(10vw, 5vh); }
    }

    /* Console Styling */
    .eq-bar {
        width: 8px;
        background: white;
        border-radius: 4px;
        animation: eq-dance 0.8s infinite ease-in-out;
    }

    .eq-bar:nth-child(2) { animation-delay: 0.1s; }
    .eq-bar:nth-child(3) { animation-delay: 0.2s; }
    .eq-bar:nth-child(4) { animation-delay: 0.3s; }
    .eq-bar:nth-child(5) { animation-delay: 0.4s; }

    @keyframes eq-dance {
        0%, 100% { height: 10px; opacity: 0.3; }
        50% { height: 100%; opacity: 1; }
    }

    .station-card.active {
        background: rgba(var(--color-primary-rgb), 0.1);
        border-color: var(--color-primary);
    }

    .station-card.active .active-indicator {
        opacity: 1;
    }

    /* Custom range input */
    input[type=range]::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 16px;
        width: 16px;
        border-radius: 50%;
        background: white;
        cursor: pointer;
        box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const audio = document.getElementById('radio-backend-audio') as HTMLAudioElement;
        const playBtn = document.getElementById('master-play-btn');
        const volSlider = document.getElementById('master-volume') as HTMLInputElement;
        const stationCards = document.querySelectorAll('.station-card');
        const eqOverlay = document.getElementById('global-eq');
        
        // UI elements
        const uiName = document.getElementById('active-station-name');
        const uiGenre = document.getElementById('active-station-genre');
        const uiDesc = document.getElementById('active-station-desc');
        const uiLogo = document.getElementById('active-station-logo') as HTMLImageElement;
        const uiUrl = document.getElementById('active-station-url');

        let isPlaying = false;
        let currentUrl = "";

        // Set initial volume
        if (audio) audio.volume = parseFloat(volSlider.value);

        function updatePlayIcon(playing: boolean) {
            if (!playBtn) return;
            if (playing) {
                playBtn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
                    PAUSAR
                `;
                eqOverlay?.style.setProperty('opacity', '1');
            } else {
                playBtn.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    REPRODUCIR
                `;
                eqOverlay?.style.setProperty('opacity', '0');
            }
        }

        stationCards.forEach(card => {
            card.addEventListener('click', () => {
                const url = card.getAttribute('data-station-url');
                const name = card.getAttribute('data-station-name');
                const genre = card.getAttribute('data-station-genre');
                const desc = card.getAttribute('data-station-desc');
                const logo = card.getAttribute('data-station-logo');

                if (!url || !uiName || !uiGenre || !uiDesc || !uiLogo || !uiUrl) return;

                // Mark current as active
                stationCards.forEach(c => c.classList.remove('active'));
                card.classList.add('active');

                // Update UI
                uiName.textContent = name;
                uiGenre.textContent = genre;
                uiDesc.textContent = desc;
                uiLogo.src = logo || "/logo.webp";
                uiUrl.textContent = url;

                // Load and play
                if (currentUrl !== url) {
                    currentUrl = url;
                    audio.src = url;
                }
                
                audio.play().then(() => {
                    isPlaying = true;
                    updatePlayIcon(true);
                }).catch(err => {
                    console.error("Audio play failed:", err);
                    isPlaying = false;
                    updatePlayIcon(false);
                });
            });
        });

        playBtn?.addEventListener('click', () => {
            if (!currentUrl) return;

            if (isPlaying) {
                audio.pause();
                isPlaying = false;
            } else {
                audio.play();
                isPlaying = true;
            }
            updatePlayIcon(isPlaying);
        });

        volSlider?.addEventListener('input', (e) => {
            const val = parseFloat((e.target as HTMLInputElement).value);
            audio.volume = val;
        });

        // Handle errors
        audio.addEventListener('error', (e) => {
            console.error("Audio error event:", e);
            isPlaying = false;
            updatePlayIcon(false);
            if (uiDesc) uiDesc.textContent = "Error al conectar con la emisora. El stream puede estar fuera de línea.";
            if (uiDesc) uiDesc.style.color = "#ef4444";
        });
    });
</script>
