---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Radio En Directo | Veredillas FM" description="Escucha la emisión en directo de Veredillas FM con el reproductor completo y panel DJ.">
  <main class="min-h-[calc(100vh-80px)] py-12 px-4 relative overflow-x-hidden bg-[radial-gradient(circle_at_top,#0a0a0c_0%,var(--color-bg)_100%)]">
    
    <div class="radio-page-container max-w-6xl mx-auto relative z-10">
      
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="badge inline-block bg-primary text-white px-4 py-1 rounded-full text-xs font-bold tracking-wider uppercase shadow-[0_0_15px_rgba(139,92,246,0.5)] mb-4">En Directo</div>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent">Veredillas FM Radio</h1>
        <p class="text-zinc-400 max-w-md mx-auto">Sintoniza nuestra emisión 24/7 y descubre la mejor música sin interrupciones.</p>
      </div>

      <!-- Tabs Navigation -->
      <div class="flex justify-center gap-4 mb-10 border-b border-white/5 pb-4">
        <button class="tab-btn active px-6 py-2.5 rounded-xl font-bold text-sm bg-primary text-white border border-primary transition-all shadow-[0_0_20px_rgba(139,92,246,0.3)]" data-target="tab-player">Reproductor</button>
        <button class="tab-btn px-6 py-2.5 rounded-xl font-bold text-sm bg-white/5 text-gray-400 border border-transparent hover:bg-white/10 hover:text-white transition-all hidden" data-target="tab-dj" id="dj-tab-btn">Panel DJ PRO</button>
      </div>

      <div class="tabs-content relative min-h-[500px]">
        
        <!-- TAB: REPRODUCTOR -->
        <div id="tab-player" class="tab-pane active flex flex-col items-center animate-fade-in">
          
          <div class="player-box bg-surface/40 backdrop-blur-xl border border-white/10 p-10 rounded-[2.5rem] w-full max-w-2xl shadow-[0_30px_60px_rgba(0,0,0,0.5)] flex flex-col items-center relative">
            
            <button class="voice-toggle-btn enabled absolute top-6 right-6 w-11 h-11 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-all z-20 shadow-lg" aria-label="Activar/Desactivar voz de locutor" title="Locutor: ON">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
            </button>

            <!-- Visualizer / Artwork placeholder -->
            <div class="w-56 h-56 rounded-full bg-gradient-to-br from-primary/20 to-accent/20 border-[6px] border-white/5 flex items-center justify-center shadow-[0_0_50px_rgba(139,92,246,0.15)] mb-10 relative overflow-hidden">
              <div class="absolute inset-0 rounded-full bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1),transparent_70%)] pointer-events-none"></div>
              <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary opacity-80"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            </div>
            
            <div class="w-full">
                <div class="player-grid grid grid-cols-[60px_1fr_60px] gap-6 items-center w-full">
                    <div class="grid-left flex justify-center">
                        <button class="music-btn music-toggle-btn w-16 h-16 rounded-full bg-primary text-white shadow-[0_0_25px_rgba(139,92,246,0.4)] flex items-center justify-center hover:scale-105 active:scale-95 transition-all" aria-label="Activar música de fondo">
                            <svg class="play-icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            <svg class="pause-icon hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                        </button>
                    </div>
                    
                    <div class="grid-center flex flex-col items-center w-full relative z-50">
                        <div class="custom-select-wrapper w-full relative">
                            <div class="custom-select-trigger flex items-center justify-between w-full bg-black/40 border border-white/10 px-6 py-4 rounded-2xl cursor-pointer backdrop-blur-md hover:bg-white/5 transition-colors" tabindex="0">
                                <span class="selection font-semibold text-white">Veredillas FM Radio</span>
                                <div class="arrow w-2.5 h-2.5 border-b-2 border-r-2 border-white/50 transform rotate-45 transition-transform"></div>
                            </div>
                            <div class="custom-options absolute bottom-[calc(100%+8px)] left-0 w-full bg-[#111] border border-white/10 rounded-2xl z-50 opacity-0 invisible transform translate-y-2 transition-all max-h-[300px] overflow-y-auto shadow-2xl backdrop-blur-xl">
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://radio.veredillasfm.es/stream">Veredillas FM Radio</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://27833.live.streamtheworld.com/LOS40_URBAN.mp3">Los 40 Urban</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors selected bg-primary/20 text-white" data-value="https://stream.zeno.fm/0r0xa792kwzuv">Lofi Chill</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://s1.we4stream.com:2020/stream/locaurban">Loca Urban</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://28503.live.streamtheworld.com/LOS40_CAT.mp3">Los 40</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://listen.technobase.fm/tunein-mp3">Techno</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://sunaer-stream.com:7113/LA_MUEVE_CADENA_HD">La MUEVE FM</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="https://stream-177.zeno.fm/gwmx5szrc0hvv?zt=eyJhbGciOiJIUzI1NiJ9.eyJzdHJlYW0iOiJnd214NXN6cmMwaHZ2IiwiaG9zdCI6InN0cmVhbS0xNzcuemVuby5mbSIsInJ0dGwiOjUsImp0aSI6Ild6UHlGOHdzUkRLeVRHalhZY004SlEiLCJpYXQiOjE3NzUyMTIwMjEsImV4cCI6MTc3NTIxMjA4MX0.NrAFqkqJUVyckzTl0C0RqzdCDxEkgQxGfBkS47sENnQ">Rock FM</div>
                                <div class="custom-option px-6 py-3.5 cursor-pointer text-sm text-gray-300 hover:bg-primary/20 hover:text-white transition-colors" data-value="http://streaming.indalteco.net:8002/dial.mp3">Cadena Dial</div>
                            </div>
                        </div>

                        <div class="mt-5 flex items-center gap-3 bg-black/20 px-4 py-2 rounded-full border border-white/5">
                           <div class="equalizer flex items-end h-3 gap-[2px]">
                                <span class="bar bar-1 w-[3px] bg-primary rounded-sm h-[4px]"></span>
                                <span class="bar bar-2 w-[3px] bg-primary rounded-sm h-[4px]"></span>
                                <span class="bar bar-3 w-[3px] bg-primary rounded-sm h-[4px]"></span>
                                <span class="bar bar-4 w-[3px] bg-primary rounded-sm h-[4px]"></span>
                            </div>
                            <span class="music-label text-sm text-gray-300 font-medium">Lista para sonar</span>
                        </div>

                        <audio class="waiting-music" preload="none" loop>
                            <source src="https://radio.veredillasfm.es/stream" type="audio/mpeg">
                        </audio>
                    </div>

                    <div class="grid-right flex justify-center relative group">
                        <button class="volume-btn w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors shadow-lg">
                            <svg class="volume-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5L6 9H2v6h4l5 4V5z"></path><path class="volume-waves" d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path class="volume-waves-outer" d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>
                        </button>

                        <div class="volume-slider-popup absolute bottom-full mb-3 left-1/2 -translate-x-1/2 bg-[#1a1a1f] border border-white/10 p-4 rounded-[1.5rem] shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all flex flex-col items-center h-[140px] z-50">
                            <input type="range" class="volume-slider vertical -rotate-90 origin-center translate-y-[50px] w-[100px] h-[4px] bg-white/10 rounded-lg appearance-none cursor-pointer outline-none [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-4 [&::-webkit-slider-thumb]:h-4 [&::-webkit-slider-thumb]:bg-white [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:shadow-lg" min="0" max="1" step="0.01" value="0.5" aria-label="Volumen">
                        </div>
                    </div>
                </div>
            </div>
          </div>
        </div>

        <!-- TAB: DJ PANEL -->
        <div id="tab-dj" class="tab-pane hidden w-full animate-fade-in">
            <div class="bg-surface/40 backdrop-blur-xl border border-cyan-500/20 rounded-[2.5rem] p-6 lg:p-8 shadow-[0_30px_60px_rgba(0,0,0,0.5)]">
                
                <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-8 pb-6 border-b border-white/5">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center border border-cyan-500/20 text-cyan-400 shadow-[0_0_20px_rgba(6,182,212,0.2)]">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="21" x2="14" y1="4" y2="4"/><line x1="10" x2="3" y1="4" y2="4"/><line x1="21" x2="12" y1="12" y2="12"/><line x1="8" x2="3" y1="12" y2="12"/><line x1="21" x2="16" y1="20" y2="20"/><line x1="12" x2="3" y1="20" y2="20"/><line x1="14" x2="14" y1="2" y2="6"/><line x1="8" x2="8" y1="10" y2="14"/><line x1="16" x2="16" y1="18" y2="22"/></svg>
                        </div>
                        <div>
                            <h3 class="text-white font-extrabold text-2xl m-0 leading-none tracking-tight">Panel de Control DJ</h3>
                            <p class="text-sm text-gray-400 mt-1.5">Gestiona la emisión en directo</p>
                        </div>
                    </div>
                    <div id="dj-status-badge" class="px-4 py-2 rounded-full text-xs font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_15px_currentColor]">OFFLINE</div>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    
                    <!-- Control Column -->
                    <div class="flex flex-col gap-6">
                        <div class="bg-black/40 border border-white/5 rounded-2xl p-6 flex flex-col gap-2 relative overflow-hidden shadow-inner">
                            <div class="absolute -right-4 -top-4 w-24 h-24 bg-cyan-500/10 blur-2xl rounded-full"></div>
                            <div class="text-xs text-gray-400 uppercase tracking-widest font-bold">Sonando ahora</div>
                            <div class="flex items-center gap-3 mt-1">
                                <div class="text-cyan-400 animate-[spin_4s_linear_infinite] shrink-0">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="2"/></svg>
                                </div>
                                <span id="dj-current-song" class="text-xl text-white font-bold truncate drop-shadow-[0_0_10px_rgba(0,229,255,0.3)]">Ninguna canción</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <button id="dj-btn-play" class="flex items-center justify-center gap-2 py-4 rounded-2xl font-bold text-sm bg-gradient-to-br from-emerald-400/20 to-emerald-400/5 text-emerald-400 border border-emerald-400/40 hover:bg-emerald-400/25 hover:shadow-[0_0_20px_rgba(52,211,153,0.3)] transition-all active:scale-95">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg> Emitir
                            </button>
                            <button id="dj-btn-stop" class="flex items-center justify-center gap-2 py-4 rounded-2xl font-bold text-sm bg-gradient-to-br from-orange-500/20 to-orange-500/5 text-orange-500 border border-orange-500/40 hover:bg-orange-500/25 hover:shadow-[0_0_20px_rgba(249,115,22,0.3)] transition-all active:scale-95">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect width="14" height="14" x="5" y="5" rx="2" ry="2"/></svg> Cortar
                            </button>
                            <button id="dj-btn-skip" class="flex items-center justify-center gap-2 py-4 rounded-2xl font-bold text-sm bg-white/5 text-white border border-white/10 hover:bg-white/15 transition-all active:scale-95 shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" x2="19" y1="5" y2="19" stroke="currentColor" stroke-width="3"/></svg> Saltar
                            </button>
                            <button id="dj-btn-sync" class="flex items-center justify-center gap-2 py-4 rounded-2xl font-bold text-sm bg-gradient-to-br from-violet-500/20 to-violet-500/5 text-violet-400 border border-violet-500/40 hover:bg-violet-500/25 hover:shadow-[0_0_20px_rgba(139,92,246,0.3)] transition-all active:scale-95">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg> Sync
                            </button>
                        </div>

                        <div class="bg-black/40 p-5 rounded-2xl border border-white/5 shadow-inner">
                            <div class="text-xs text-gray-400 uppercase tracking-widest font-bold mb-3">Lanzar Playlist</div>
                            <div class="flex gap-3">
                                <input type="text" id="dj-playlist-input" placeholder="Nombre (ej. Pop, Rock)" class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-400 focus:bg-cyan-400/5 transition-colors">
                                <button id="dj-btn-playlist" class="bg-cyan-500 hover:bg-cyan-400 text-black font-bold px-5 py-3 rounded-xl text-sm transition-colors shadow-[0_0_15px_rgba(6,182,212,0.4)]">Play</button>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div class="bg-black/40 p-5 rounded-2xl border border-white/5 flex flex-col gap-4 shadow-inner">
                                <div class="text-xs text-gray-400 uppercase tracking-widest font-bold">Ajustes</div>
                                <label class="flex items-center justify-between cursor-pointer group">
                                    <span class="text-sm font-medium text-white group-hover:text-cyan-300 transition-colors">Bucle</span>
                                    <input type="checkbox" id="dj-setting-loop" class="sr-only peer">
                                    <div class="w-10 h-5 bg-white/10 rounded-full peer peer-checked:bg-cyan-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 peer-checked:after:border-white relative"></div>
                                </label>
                                <label class="flex items-center justify-between cursor-pointer group">
                                    <span class="text-sm font-medium text-white group-hover:text-cyan-300 transition-colors">Aleatorio</span>
                                    <input type="checkbox" id="dj-setting-shuffle" class="sr-only peer">
                                    <div class="w-10 h-5 bg-white/10 rounded-full peer peer-checked:bg-cyan-500 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-5 peer-checked:after:border-white relative"></div>
                                </label>
                            </div>

                            <div class="bg-black/40 p-5 rounded-2xl border border-white/5 flex flex-col justify-between shadow-inner">
                                <div class="text-xs text-gray-400 uppercase tracking-widest font-bold mb-2">Cookies NetEase</div>
                                <label class="cursor-pointer flex flex-col items-center justify-center border-2 border-dashed border-white/20 rounded-xl p-3 hover:border-cyan-400/50 hover:bg-cyan-400/5 transition-all text-center h-full min-h-[70px]">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" class="text-gray-400 mb-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                                    <span class="text-xs font-medium text-gray-400">Subir .txt</span>
                                    <input type="file" id="dj-cookies-file" accept=".txt" class="hidden">
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Search Column -->
                    <div class="bg-black/40 p-6 rounded-2xl border border-white/5 flex flex-col h-[600px] shadow-inner">
                        <div class="flex items-center gap-3 mb-5 shrink-0">
                            <div class="text-cyan-400">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                            </div>
                            <h4 class="text-white font-bold text-lg m-0">Biblioteca Local</h4>
                        </div>
                        
                        <div class="flex gap-2 mb-5 shrink-0">
                            <input type="text" id="dj-search-input" placeholder="Buscar pistas..." class="flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-cyan-400 focus:bg-cyan-400/5 transition-colors">
                            <button id="dj-btn-search" class="bg-violet-600 hover:bg-violet-500 text-white font-bold px-5 py-3 rounded-xl text-sm transition-colors shadow-[0_4px_15px_rgba(124,58,237,0.4)]">Buscar</button>
                        </div>

                        <div id="dj-results-list" class="flex-1 overflow-y-auto pr-2 flex flex-col gap-3 scrollbar-thin scrollbar-thumb-white/20 scrollbar-track-transparent pb-4">
                            <div class="text-gray-500 text-sm font-medium text-center mt-10">Usa el buscador para encontrar canciones</div>
                        </div>
                    </div>

                    <!-- Queue Column -->
                    <div class="bg-black/40 p-6 rounded-2xl border border-white/5 flex flex-col h-[600px] shadow-inner">
                        <div class="flex items-center justify-between mb-5 shrink-0 border-b border-white/5 pb-4">
                            <div class="flex items-center gap-3">
                                <div class="text-orange-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                                </div>
                                <h4 class="text-white font-bold text-lg m-0">Cola de Rep.</h4>
                                <span id="dj-queue-count" class="bg-white/10 text-white text-xs px-2.5 py-0.5 rounded-full ml-1 font-mono font-bold">0</span>
                            </div>
                            <button id="dj-btn-clear-queue" class="text-xs font-bold text-red-400 hover:text-red-300 hover:bg-red-500/10 px-3 py-1.5 rounded-lg transition-colors" title="Vaciar cola">Vaciar</button>
                        </div>

                        <div id="dj-queue-list" class="flex-1 overflow-y-auto pr-2 flex flex-col gap-3 scrollbar-thin scrollbar-thumb-white/20 scrollbar-track-transparent pb-4">
                            <div class="text-gray-500 text-sm font-medium text-center mt-10">La cola está vacía</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

      </div>

      <div class="now-playing-corner" id="now-playing-corner">
          <div class="now-playing-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
          </div>
          <div class="now-playing-info">
              <div class="now-playing-label">Sonando en directo</div>
              <div class="now-playing-title" id="corner-song-title">Ninguna canción</div>
          </div>
      </div>

    </div>
  </main>
</Layout>

<style>
    /* Utilities & Animations */
    .animate-fade-in {
        animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Player specific */
    .music-toggle-btn.playing .play-icon { display: none; }
    .music-toggle-btn.playing .pause-icon { display: block; }
    
    .voice-toggle-btn.enabled {
        border-color: var(--color-primary);
        color: var(--color-primary);
        background: rgba(139, 92, 246, 0.15);
    }

    /* Equalizer */
    .equalizer .bar {
        animation: eq 1s infinite ease-in-out;
        animation-play-state: paused;
    }
    .music-toggle-btn.playing ~ .grid-center .equalizer .bar, 
    .music-toggle-btn.playing ~ * .equalizer .bar,
    .equalizer.playing .bar {
        animation-play-state: running;
    }
    
    .bar-1 { height: 6px; }
    .bar-2 { height: 12px; }
    .bar-3 { height: 8px; }
    .bar-4 { height: 5px; }

    @keyframes eq {
        0%, 100% { height: 4px; }
        50% { height: 12px; }
    }

    /* Custom Select */
    .custom-select-wrapper.open .arrow {
        transform: rotate(-135deg);
        margin-top: 4px;
    }
    .custom-select-wrapper.open .custom-options {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    /* Now Playing Corner Widget */
    .now-playing-corner {
        position: fixed;
        bottom: 24px;
        left: 24px;
        background: rgba(10, 10, 12, 0.85);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(139, 92, 246, 0.3);
        border-radius: 16px;
        padding: 14px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6), inset 0 1px 1px rgba(255,255,255,0.1);
        transform: translateY(150%) scale(0.9);
        opacity: 0;
        transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 50;
        max-width: 320px;
        text-align: left;
    }

    .now-playing-corner.visible {
        transform: translateY(0) scale(1);
        opacity: 1;
    }

    .now-playing-corner .now-playing-icon {
        background: rgba(139, 92, 246, 0.1);
        color: var(--color-primary);
        padding: 10px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: pulseGlow 2s infinite;
    }

    @keyframes pulseGlow {
        0%, 100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4); }
        50% { box-shadow: 0 0 0 10px rgba(139, 92, 246, 0); }
    }

    .now-playing-corner .now-playing-info {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .now-playing-corner .now-playing-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        color: var(--color-primary);
        letter-spacing: 0.1em;
        font-weight: 800;
        margin-bottom: 3px;
    }

    .now-playing-corner .now-playing-title {
        font-size: 0.9rem;
        color: white;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-weight: 600;
        text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
</style>

<script>
    class RadioPlayer {
        el: HTMLElement;
        audio: HTMLAudioElement | null;
        musicBtn: HTMLElement | null;
        musicLabel: HTMLElement | null;
        vibeSelectWrapper: HTMLElement | null;
        vibeSelectTrigger: HTMLElement | null;
        vibeOptions: NodeListOf<HTMLElement>;
        selectionText: HTMLElement | null;
        volumeSlider: HTMLInputElement | null;
        isPlaying: boolean = false;
        currentUrl: string;
        hasPlayedTTS: boolean = false;

        // Tabs & DJ
        djTabBtn: HTMLElement | null;
        djStatusBadge: HTMLElement | null;
        djCurrentSong: HTMLElement | null;
        djBtnPlay: HTMLElement | null;
        djBtnStop: HTMLElement | null;
        djBtnSkip: HTMLElement | null;
        djBtnSync: HTMLElement | null;
        djSearchInput: HTMLInputElement | null;
        djBtnSearch: HTMLElement | null;
        djResultsList: HTMLElement | null;
        djPlaylistInput: HTMLInputElement | null;
        djBtnPlaylist: HTMLElement | null;
        djSettingLoop: HTMLInputElement | null;
        djSettingShuffle: HTMLInputElement | null;
        djCookiesFile: HTMLInputElement | null;
        djBtnClearQueue: HTMLElement | null;
        djQueueList: HTMLElement | null;
        djQueueCount: HTMLElement | null;
        djPollInterval: number | undefined;
        cornerPollInterval: number | undefined;

        // Settings
        ttsSettings = {
            enabled: true,
            voice: 'aura-2-selena-es'
        };

        constructor(el: HTMLElement) {
            this.el = el;
            this.audio = el.querySelector('.waiting-music');
            this.musicBtn = el.querySelector('.music-toggle-btn');
            this.musicLabel = el.querySelector('.music-label');
            
            this.vibeSelectWrapper = el.querySelector('.custom-select-wrapper');
            this.vibeSelectTrigger = el.querySelector('.custom-select-trigger');
            this.vibeOptions = el.querySelectorAll('.custom-option');
            this.selectionText = el.querySelector('.selection');
            this.volumeSlider = el.querySelector('.volume-slider');

            this.currentUrl = "https://radio.veredillasfm.es/stream";

            this.djTabBtn = el.querySelector('#dj-tab-btn');
            this.djStatusBadge = el.querySelector('#dj-status-badge');
            this.djCurrentSong = el.querySelector('#dj-current-song');
            this.djBtnPlay = el.querySelector('#dj-btn-play');
            this.djBtnStop = el.querySelector('#dj-btn-stop');
            this.djBtnSkip = el.querySelector('#dj-btn-skip');
            this.djBtnSync = el.querySelector('#dj-btn-sync');
            this.djSearchInput = el.querySelector('#dj-search-input');
            this.djBtnSearch = el.querySelector('#dj-btn-search');
            this.djResultsList = el.querySelector('#dj-results-list');
            this.djPlaylistInput = el.querySelector('#dj-playlist-input');
            this.djBtnPlaylist = el.querySelector('#dj-btn-playlist');
            this.djSettingLoop = el.querySelector('#dj-setting-loop');
            this.djSettingShuffle = el.querySelector('#dj-setting-shuffle');
            this.djCookiesFile = el.querySelector('#dj-cookies-file');
            this.djBtnClearQueue = el.querySelector('#dj-btn-clear-queue');
            this.djQueueList = el.querySelector('#dj-queue-list');
            this.djQueueCount = el.querySelector('#dj-queue-count');

            this.setupTabs();
            this.setupDJControls();
            this.loadSettings();
            this.setupAudio();
            this.setupVoiceSettings();
            this.loadLastStation();
        }

        setupTabs() {
            const tabBtns = this.el.querySelectorAll('.tab-btn');
            const tabPanes = this.el.querySelectorAll('.tab-pane');

            tabBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    // Reset all buttons
                    tabBtns.forEach(b => {
                        b.classList.remove('active', 'bg-primary', 'text-white', 'border-primary', 'shadow-[0_0_20px_rgba(139,92,246,0.3)]');
                        b.classList.add('bg-white/5', 'text-gray-400', 'border-transparent');
                    });
                    
                    // Activate clicked button
                    btn.classList.add('active', 'bg-primary', 'text-white', 'border-primary', 'shadow-[0_0_20px_rgba(139,92,246,0.3)]');
                    btn.classList.remove('bg-white/5', 'text-gray-400', 'border-transparent');

                    // Hide all panes
                    tabPanes.forEach(pane => {
                        pane.classList.remove('active', 'flex');
                        pane.classList.add('hidden');
                    });
                    
                    // Show target pane
                    const targetId = btn.getAttribute('data-target');
                    const targetPane = document.getElementById(targetId || '');
                    if (targetPane) {
                        targetPane.classList.add('active');
                        targetPane.classList.remove('hidden');
                        if(targetId === 'tab-player') targetPane.classList.add('flex');
                        
                        // Handle DJ polling
                        if (targetId === 'tab-dj') {
                            this.pollStatus();
                            if (!this.djPollInterval) {
                                this.djPollInterval = window.setInterval(() => this.pollStatus(), 5000);
                            }
                        } else {
                            if (this.djPollInterval) {
                                clearInterval(this.djPollInterval);
                                this.djPollInterval = undefined;
                            }
                        }
                    }
                });
            });
        }

        loadSettings() {
            const saved = localStorage.getItem('veredillas_tts_settings');
            if (saved) {
                try {
                    this.ttsSettings = JSON.parse(saved);
                } catch(e) {}
            }
            this.applySettingsToUI();
        }

        saveSettings() {
            localStorage.setItem('veredillas_tts_settings', JSON.stringify(this.ttsSettings));
        }

        setupVoiceSettings() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            toggleBtn?.addEventListener('click', () => {
                this.ttsSettings.enabled = !this.ttsSettings.enabled;
                this.saveSettings();
                this.applySettingsToUI();
                if (this.ttsSettings.enabled) {
                    this.playTTS(true);
                }
            });
        }

        applySettingsToUI() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            if (toggleBtn) {
                if (this.ttsSettings.enabled) {
                    toggleBtn.classList.add('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: ON');
                } else {
                    toggleBtn.classList.remove('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: OFF');
                }
            }
        }

        loadLastStation() {
            const lastUrl = localStorage.getItem('veredillas_last_station');
            if (lastUrl) {
                const optionsArray = Array.from(this.vibeOptions);
                const foundOption = optionsArray.find(opt => opt.dataset.value === lastUrl);
                if (foundOption) {
                    this.switchGenre(foundOption);
                }
            }
        }

        setupAudio() {
            if (!this.musicBtn || !this.audio) return;

            this.musicBtn.addEventListener('click', (e) => {
                e.preventDefault();
                this.toggleMusic();
            });

            if(this.vibeSelectTrigger && this.vibeSelectWrapper) {
                this.vibeSelectTrigger.addEventListener('click', () => {
                    this.vibeSelectWrapper?.classList.toggle('open');
                });
                
                document.addEventListener('click', (e) => {
                    if(this.vibeSelectWrapper && !this.vibeSelectWrapper.contains(e.target as Node)) {
                        this.vibeSelectWrapper.classList.remove('open');
                    }
                });
            }

            this.vibeOptions.forEach(option => {
                option.addEventListener('click', () => {
                   this.switchGenre(option);
                   this.vibeSelectWrapper?.classList.remove('open');
                });
            });
            
            this.audio.volume = 0.5;
            
            if(this.volumeSlider) {
                this.volumeSlider.addEventListener('input', (e) => {
                    const val = parseFloat((e.target as HTMLInputElement).value);
                    if(this.audio) this.audio.volume = val;
                    this.updateVolumeIcon(val);
                });
            }
            
            this.audio.addEventListener('error', (e) => {
                if(this.musicLabel) this.musicLabel.textContent = "Error de conexión";
                this.isPlaying = false;
                this.musicBtn?.classList.remove('playing');
                this.syncEqualizer();
            });
        }

        syncEqualizer() {
            const equalizer = this.el.querySelector('.equalizer');
            if (equalizer) {
                if (this.isPlaying) {
                    equalizer.classList.add('playing');
                } else {
                    equalizer.classList.remove('playing');
                }
            }
            
            const eqBars = this.el.querySelectorAll('.equalizer .bar');
            eqBars.forEach(bar => {
                (bar as HTMLElement).style.animationPlayState = this.isPlaying ? 'running' : 'paused';
            });
        }

        async fadeVolume(audio: HTMLAudioElement, target: number, duration: number) {
            const startVolume = audio.volume;
            const diff = target - startVolume;
            const startTime = performance.now();

            return new Promise<void>(resolve => {
                const tick = (now: number) => {
                    const elapsed = now - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    audio.volume = startVolume + diff * progress;

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    } else {
                        resolve();
                    }
                };
                requestAnimationFrame(tick);
            });
        }

        async playTTS(force = false) {
            if (!this.ttsSettings.enabled && !force) return;
            if (this.hasPlayedTTS && !force) return;
            this.hasPlayedTTS = true;

            const selectedModel = force ? this.ttsSettings.voice : (this.ttsSettings.voice || 'aura-2-selena-es');
            const stationName = this.selectionText?.textContent || "la radio";
            
            let userName = "amigo";
            let currentListeners = document.getElementById('listener-number')?.textContent || "varios oyentes";
            
            try {
                const sessionStr = localStorage.getItem('user-session');
                if (sessionStr) {
                    const session = JSON.parse(sessionStr);
                    if (session.name) userName = session.name.split(' ')[0];
                }
            } catch(e) {}

            const variations = [
                `¡Hola, ${userName}! Estás escuchando ${stationName} en Veredillas efe-eme. Relájate y disfruta de la música.`,
                `Bienvenido a la zona de confort, ${userName}. Sube el volumen que la mejor música suena ahora en ${stationName}.`,
                `¡Wazaaaa, ${userName}! Acabas de conectarte a ${stationName}. Ponte cómodo y disfruta.`,
                `Tu aura aumenta +10000 solo por estar escuchando ${stationName} en Veredillas efe-eme. ¡Dale caña, ${userName}!`,
                `Ya somos ${currentListeners} escuchando en directo. Gracias por unirte a ${stationName}, ${userName}.`
            ];

            let phrase = variations[Math.floor(Math.random() * variations.length)];
            
            try {
                const response = await fetch('/api/tts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: phrase, model: selectedModel })
                });

                if (!response.ok) throw new Error('TTS failed');

                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const ttsAudio = new Audio(url);
                
                const originalVolume = this.audio?.volume || 0.5;
                if (this.audio) await this.fadeVolume(this.audio, originalVolume * 0.15, 1000);

                ttsAudio.play();
                ttsAudio.onended = async () => {
                    if (this.audio) await this.fadeVolume(this.audio, originalVolume, 1200);
                    URL.revokeObjectURL(url);
                };
            } catch (error) {
                console.error('TTS error:', error);
            }
        }

        setupDJControls() {
            if (!this.djBtnPlay) return;

            this.djBtnPlay.addEventListener('click', () => this.apiPlay());
            this.djBtnStop?.addEventListener('click', () => this.apiStop());
            this.djBtnSkip?.addEventListener('click', () => this.apiSkip());
            this.djBtnSync?.addEventListener('click', () => this.syncStream());
            
            this.djBtnSearch?.addEventListener('click', () => {
                const query = this.djSearchInput?.value || '';
                this.apiSearch(query);
            });

            this.djSearchInput?.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    this.apiSearch(this.djSearchInput?.value || '');
                }
            });

            this.djBtnPlaylist?.addEventListener('click', () => {
                const name = this.djPlaylistInput?.value || '';
                this.apiPlayPlaylist(name);
            });
            
            this.djSettingLoop?.addEventListener('change', () => {
                this.apiUpdateSettings(this.djSettingLoop!.checked, this.djSettingShuffle!.checked);
            });
            this.djSettingShuffle?.addEventListener('change', () => {
                this.apiUpdateSettings(this.djSettingLoop!.checked, this.djSettingShuffle!.checked);
            });
            
            this.djBtnClearQueue?.addEventListener('click', () => this.apiClearQueue());
            
            this.djCookiesFile?.addEventListener('change', (e) => {
                const file = (e.target as HTMLInputElement).files?.[0];
                if (file) {
                    this.apiUploadCookies(file);
                }
            });
        }

        syncStream() {
            if (this.currentUrl === 'https://radio.veredillasfm.es/stream' && this.audio) {
                this.audio.src = `https://radio.veredillasfm.es/stream?t=${new Date().getTime()}`;
                if (this.isPlaying) {
                    this.audio.play().catch(e => console.error("Error syncing stream:", e));
                }
                
                if (this.djBtnSync) {
                    const originalText = this.djBtnSync.innerHTML;
                    this.djBtnSync.innerHTML = '✅ Sinc.';
                    setTimeout(() => {
                        if (this.djBtnSync) this.djBtnSync.innerHTML = originalText;
                    }, 2000);
                }
            }
        }

        async apiPlay() {
            try {
                await fetch('https://radio.veredillasfm.es/api/play', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiStop() {
            try {
                await fetch('https://radio.veredillasfm.es/api/stop', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiSkip() {
            try {
                await fetch('https://radio.veredillasfm.es/api/skip', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiSearch(query: string) {
            if (!this.djResultsList) return;
            this.djResultsList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-10">Buscando...</div>';
            
            try {
                const url = new URL('https://radio.veredillasfm.es/api/search');
                if (query) url.searchParams.append('q', query);
                
                const res = await fetch(url.toString());
                const data = await res.json();
                
                if (data.results && data.results.length > 0) {
                    this.djResultsList.innerHTML = '';
                    data.results.forEach((item: any) => {
                        const div = document.createElement('div');
                        div.className = 'flex flex-col gap-3 bg-white/5 border border-white/10 p-4 rounded-xl hover:bg-white/10 hover:border-cyan-500/30 transition-all';
                        div.innerHTML = `
                            <span class="text-white text-sm font-bold truncate" title="${item.title}">${item.title}</span>
                            <div class="flex items-center gap-2">
                                <button class="play-specific flex-1 py-2 rounded-lg bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs font-bold hover:bg-emerald-500/20 transition-colors" data-idx="${item.index}">▶ Play</button>
                                <button class="queue-next flex-1 py-2 rounded-lg bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 text-xs font-bold hover:bg-cyan-500/20 transition-colors" data-idx="${item.index}">+ Sig</button>
                                <button class="queue-last flex-1 py-2 rounded-lg bg-white/5 text-gray-300 border border-white/10 text-xs font-bold hover:bg-white/10 transition-colors" data-idx="${item.index}">+ Fin</button>
                            </div>
                        `;
                        this.djResultsList?.appendChild(div);
                    });

                    this.djResultsList.querySelectorAll('.play-specific').forEach(btn => {
                        btn.addEventListener('click', (e) => this.apiPlaySpecific(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0')));
                    });
                    this.djResultsList.querySelectorAll('.queue-next').forEach(btn => {
                        btn.addEventListener('click', (e) => this.apiQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0'), 'queue_next'));
                    });
                    this.djResultsList.querySelectorAll('.queue-last').forEach(btn => {
                        btn.addEventListener('click', (e) => this.apiQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0'), 'queue_last'));
                    });
                } else {
                    this.djResultsList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-10">No se encontraron resultados.</div>';
                }
            } catch (err) {
                this.djResultsList.innerHTML = '<div class="text-red-400 text-sm text-center mt-10">Error al buscar.</div>';
            }
        }

        async apiQueue(index: number, action: string) {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index, action })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiPlaySpecific(index: number) {
            try {
                await fetch('https://radio.veredillasfm.es/api/play-specific', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiPlayPlaylist(playlistName: string) {
            if (!playlistName) return;
            try {
                await fetch('https://radio.veredillasfm.es/api/play-playlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playlistName })
                });
                this.pollStatus();
                if (this.djPlaylistInput) this.djPlaylistInput.value = '';
            } catch (err) {}
        }

        async apiRemoveQueue(index: number) {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue/remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiClearQueue() {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue/clear', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiUpdateSettings(loop: boolean, shuffle: boolean) {
            try {
                await fetch('https://radio.veredillasfm.es/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ loop, shuffle })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiUploadCookies(file: File) {
            try {
                const formData = new FormData();
                formData.append('cookies', file);
                await fetch('https://radio.veredillasfm.es/api/cookies', {
                    method: 'POST',
                    body: formData
                });
                if (this.djCookiesFile) this.djCookiesFile.value = '';
            } catch (err) {}
        }

        async pollStatus() {
            const djTab = document.getElementById('tab-dj');
            if (!djTab || !djTab.classList.contains('active')) return;

            try {
                const res = await fetch('https://radio.veredillasfm.es/api/status');
                const data = await res.json();

                if (this.djStatusBadge) {
                    if (data.isPlaying) {
                        this.djStatusBadge.className = 'px-4 py-2 rounded-full text-xs font-extrabold tracking-widest uppercase bg-emerald-500/15 text-emerald-400 border border-emerald-500/30 shadow-[0_0_15px_currentColor]';
                        this.djStatusBadge.textContent = 'ONLINE';
                    } else {
                        this.djStatusBadge.className = 'px-4 py-2 rounded-full text-xs font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_15px_currentColor]';
                        this.djStatusBadge.textContent = 'OFFLINE';
                    }
                }

                if (this.djCurrentSong) {
                    this.djCurrentSong.textContent = (data.isPlaying && data.currentSongMeta?.title) ? data.currentSongMeta.title : 'Ninguna canción';
                }

                if (data.radioSettings) {
                    if (this.djSettingLoop && this.djSettingLoop !== document.activeElement) {
                        this.djSettingLoop.checked = data.radioSettings.loop;
                    }
                    if (this.djSettingShuffle && this.djSettingShuffle !== document.activeElement) {
                        this.djSettingShuffle.checked = data.radioSettings.shuffle;
                    }
                }

                if (data.playQueue && this.djQueueList) {
                    if (this.djQueueCount) this.djQueueCount.textContent = data.playQueue.length;
                    
                    if (data.playQueue.length === 0) {
                        this.djQueueList.innerHTML = '<div class="text-gray-500 text-sm font-medium text-center mt-10">La cola está vacía</div>';
                    } else {
                        this.djQueueList.innerHTML = '';
                        data.playQueue.forEach((song: any, idx: number) => {
                            const div = document.createElement('div');
                            div.className = 'flex items-center justify-between bg-white/5 border border-white/5 p-3.5 rounded-xl hover:bg-white/10 transition-colors group';
                            div.innerHTML = `
                                <div class="flex flex-col overflow-hidden pr-2">
                                    <span class="text-white text-sm font-bold truncate" title="${song.title}">${song.title}</span>
                                    ${song.duration ? `<span class="text-xs text-gray-500 font-mono mt-1">${Math.floor(song.duration/60)}:${String(Math.floor(song.duration%60)).padStart(2,'0')}</span>` : ''}
                                </div>
                                <button class="btn-remove-queue shrink-0 w-9 h-9 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20 flex items-center justify-center lg:opacity-0 group-hover:opacity-100 hover:bg-red-500/20 transition-all" data-idx="${idx}">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                </button>
                            `;
                            this.djQueueList?.appendChild(div);
                        });
                        this.djQueueList.querySelectorAll('.btn-remove-queue').forEach(btn => {
                            btn.addEventListener('click', (e) => this.apiRemoveQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0')));
                        });
                    }
                }

            } catch (err) {
                if (this.djStatusBadge) {
                    this.djStatusBadge.className = 'px-4 py-2 rounded-full text-xs font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_15px_currentColor]';
                    this.djStatusBadge.textContent = 'OFFLINE';
                }
                if (this.djCurrentSong) this.djCurrentSong.textContent = 'Servidor inalcanzable';
            }
        }

        switchGenre(option: HTMLElement) {
            this.vibeOptions.forEach(opt => opt.classList.remove('selected', 'bg-primary/20', 'text-white'));
            option.classList.add('selected', 'bg-primary/20', 'text-white');

            const newUrl = option.dataset.value;
            const genreName = option.textContent || "Música";
            
            if(this.selectionText) this.selectionText.textContent = genreName;
            
            if (newUrl && this.audio) {
                this.currentUrl = newUrl;
                
                if (newUrl === 'https://radio.veredillasfm.es/stream') {
                    this.audio.src = `${newUrl}?t=${new Date().getTime()}`;
                } else {
                    this.audio.src = newUrl;
                }
                
                if (newUrl === 'https://radio.veredillasfm.es/stream' && this.djTabBtn) {
                    this.djTabBtn.classList.remove('hidden');
                } else if (this.djTabBtn) {
                    this.djTabBtn.classList.add('hidden');
                    
                    if (this.djTabBtn.classList.contains('active')) {
                        const playerTabBtn = this.el.querySelector('.tab-btn[data-target="tab-player"]') as HTMLElement;
                        if (playerTabBtn) playerTabBtn.click();
                    }
                }

                localStorage.setItem('veredillas_last_station', newUrl);
                
                if (this.isPlaying) {
                     if(this.musicLabel) this.musicLabel.textContent = `Conectando con ${genreName}...`;
                     this.audio.play().then(() => {
                         if(this.musicLabel) this.musicLabel.textContent = `Sonando: ${genreName}`;
                         this.startCornerPoll();
                     }).catch(e => {
                         this.isPlaying = false;
                         this.musicBtn?.classList.remove('playing');
                         this.syncEqualizer();
                         this.stopCornerPoll();
                     });
                } else {
                    if(this.musicLabel) this.musicLabel.textContent = `Lista para sonar`;
                }
            }
        }

        updateVolumeIcon(volume: number) {
            const waves = this.el.querySelector('.volume-waves') as HTMLElement;
            const outerWaves = this.el.querySelector('.volume-waves-outer') as HTMLElement;
            
            if(!waves || !outerWaves) return;

            if (volume === 0) {
                waves.style.opacity = '0';
                outerWaves.style.opacity = '0';
            } else if (volume < 0.5) {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '0';
            } else {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '1';
            }
        }

        toggleMusic() {
            if (!this.audio || !this.musicBtn) return;

            if (this.isPlaying) {
                this.audio.pause();
                this.isPlaying = false;
                this.musicBtn.classList.remove('playing');
                if(this.musicLabel) this.musicLabel.textContent = `Lista para sonar`;
                this.syncEqualizer();
                this.stopCornerPoll();
            } else {
                if(this.musicLabel) this.musicLabel.textContent = "Conectando...";
                
                this.audio.play().then(() => {
                    this.isPlaying = true;
                    this.musicBtn!.classList.add('playing');
                    const genreName = this.selectionText ? this.selectionText.textContent : "Música";
                    if(this.musicLabel) this.musicLabel!.textContent = `Sonando: ${genreName}`;
                    
                    this.syncEqualizer();
                    this.playTTS();
                    this.startCornerPoll();
                }).catch(e => {
                    this.isPlaying = false;
                    this.musicBtn!.classList.remove('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = "No disponible";
                    this.syncEqualizer();
                    this.stopCornerPoll();
                });
            }
        }

        startCornerPoll() {
            if (this.currentUrl !== 'https://radio.veredillasfm.es/stream' || !this.isPlaying) {
                const cornerWidget = document.getElementById('now-playing-corner');
                if (cornerWidget) cornerWidget.classList.remove('visible');
                return;
            }

            this.updateCornerStatus();
            
            if (!this.cornerPollInterval) {
                this.cornerPollInterval = window.setInterval(() => this.updateCornerStatus(), 5000);
            }
        }

        stopCornerPoll() {
            if (this.cornerPollInterval) {
                clearInterval(this.cornerPollInterval);
                this.cornerPollInterval = undefined;
            }
            const cornerWidget = document.getElementById('now-playing-corner');
            if (cornerWidget) cornerWidget.classList.remove('visible');
        }

        async updateCornerStatus() {
            if (this.currentUrl !== 'https://radio.veredillasfm.es/stream' || !this.isPlaying) {
                this.stopCornerPoll();
                return;
            }

            try {
                const res = await fetch('https://radio.veredillasfm.es/api/status');
                const data = await res.json();
                
                const cornerTitle = document.getElementById('corner-song-title');
                const cornerWidget = document.getElementById('now-playing-corner');
                
                if (data.isPlaying && data.currentSongMeta && data.currentSongMeta.title) {
                    if (cornerTitle) cornerTitle.textContent = data.currentSongMeta.title;
                    if (cornerWidget) cornerWidget.classList.add('visible');
                } else {
                    if (cornerWidget) cornerWidget.classList.remove('visible');
                }
            } catch (err) {
                const cornerWidget = document.getElementById('now-playing-corner');
                if (cornerWidget) cornerWidget.classList.remove('visible');
            }
        }
    }

    document.addEventListener('astro:page-load', () => {
        const el = document.querySelector('.radio-page-container');
        if (el) new RadioPlayer(el as HTMLElement);
    });

    document.addEventListener('DOMContentLoaded', () => {
        const el = document.querySelector('.radio-page-container');
        if (el) new RadioPlayer(el as HTMLElement);
    });
</script>