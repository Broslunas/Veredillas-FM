---
import Layout from '@/layouts/Layout.astro';
import { getUserFromCookie } from '@/lib/auth';
import User from '@/models/User';
import dbConnect from '@/lib/mongodb';

import RadioBackground from '@/components/radio/RadioBackground.astro';
import MainPlayer from '@/components/radio/MainPlayer.astro';
import SidebarQueue from '@/components/radio/SidebarQueue.astro';
import DJPanelModal from '@/components/radio/DJPanelModal.astro';

export const prerender = false;

const cookieHeader = Astro.request.headers.get('cookie');
const userPayload = getUserFromCookie(cookieHeader);

let isRegistered = false;
let isAdmin = false;

if (userPayload) {
    isRegistered = true;
    await dbConnect();
    const currentUser = await User.findById(userPayload.userId);
    if (currentUser) {
        isAdmin = currentUser.role === 'admin' || currentUser.role === 'owner';
    }
}
---

<Layout title="Radio En Directo | Veredillas FM" description="Escucha la emisión en directo de Veredillas FM.">
  <main class="min-h-[calc(100vh-80px)] py-12 px-4 flex items-center justify-center bg-[#050505] relative overflow-hidden">
    
    <RadioBackground />

    <div class="radio-page-container w-full max-w-6xl mx-auto relative z-10 flex flex-col lg:flex-row gap-8 items-center lg:items-start justify-center" data-is-registered={isRegistered.toString()} data-is-admin={isAdmin.toString()}>

        <MainPlayer isRegistered={isRegistered} />

        <SidebarQueue isAdmin={isAdmin} />

        <DJPanelModal isRegistered={isRegistered} isAdmin={isAdmin} />

    </div>
  </main>
</Layout>

<script>
    import * as htmlToImage from 'html-to-image';

    class RadioPlayerMinimal {
        el: HTMLElement;
        audio: HTMLAudioElement | null;
        musicBtn: HTMLElement | null;
        musicLabel: HTMLElement | null;
        volumeSlider: HTMLInputElement | null;
        volumeContainer: HTMLElement | null;
        isPlaying: boolean = false;
        hasPlayedTTS: boolean = false;
        
        isRegistered: boolean = false;
        isAdmin: boolean = false;

        // UI toggles
        cinemaBtn: HTMLElement | null;
        shareBtn: HTMLElement | null;

        // Web Audio API
        audioContext: AudioContext | null = null;
        analyser: AnalyserNode | null = null;
        source: MediaElementAudioSourceNode | null = null;
        dataArray: Uint8Array | null = null;
        visualizerReqId: number | null = null;

        // DJ AI Status
        currentSongTitle: string = '';
        nextSongTimeoutId: number | null = null;
        lastKnownQueue: any[] = [];

        // DJ Panel elements
        djTriggerBtn: HTMLElement | null;
        djModalOverlay: HTMLElement | null;
        djCloseBtn: HTMLElement | null;
        
        djStatusBadge: HTMLElement | null;
        djCurrentSong: HTMLElement | null;
        djBtnPlay: HTMLElement | null;
        djBtnStop: HTMLElement | null;
        djBtnSkip: HTMLElement | null;
        djBtnSync: HTMLElement | null;
        djSearchInput: HTMLInputElement | null;
        djBtnSearch: HTMLElement | null;
        djResultsList: HTMLElement | null;
        djPlaylistInput: HTMLInputElement | null;
        djBtnPlaylist: HTMLElement | null;
        djSettingLoop: HTMLInputElement | null;
        djSettingShuffle: HTMLInputElement | null;
        djCookiesFile: HTMLInputElement | null;
        djBtnClearQueue: HTMLElement | null;
        djQueueList: HTMLElement | null;
        djQueueCount: HTMLElement | null;
        
        publicQueueList: HTMLElement | null;

        pollInterval: number | undefined;

        // Settings
        ttsSettings = {
            enabled: true,
            voice: 'aura-2-selena-es'
        };

        constructor(el: HTMLElement) {
            this.el = el;
            
            this.isRegistered = el.dataset.isRegistered === 'true';
            this.isAdmin = el.dataset.isAdmin === 'true';

            this.audio = el.querySelector('.waiting-music');
            this.musicBtn = el.querySelector('.music-toggle-btn');
            this.musicLabel = el.querySelector('.music-label');
            this.volumeSlider = el.querySelector('.volume-slider');
            this.volumeContainer = el.querySelector('.vertical-volume-container');

            this.cinemaBtn = el.querySelector('.cinema-toggle-btn');
            this.shareBtn = el.querySelector('.share-btn');

            this.djTriggerBtn = el.querySelector('#dj-trigger-btn');
            this.djModalOverlay = el.querySelector('#dj-modal-overlay');
            this.djCloseBtn = el.querySelector('#dj-close-btn');

            this.djStatusBadge = el.querySelector('#dj-status-badge');
            this.djCurrentSong = el.querySelector('#dj-current-song');
            this.djBtnPlay = el.querySelector('#dj-btn-play');
            this.djBtnStop = el.querySelector('#dj-btn-stop');
            this.djBtnSkip = el.querySelector('#dj-btn-skip');
            this.djBtnSync = el.querySelector('#dj-btn-sync');
            this.djSearchInput = el.querySelector('#dj-search-input');
            this.djBtnSearch = el.querySelector('#dj-btn-search');
            this.djResultsList = el.querySelector('#dj-results-list');
            this.djPlaylistInput = el.querySelector('#dj-playlist-input');
            this.djBtnPlaylist = el.querySelector('#dj-btn-playlist');
            this.djSettingLoop = el.querySelector('#dj-setting-loop');
            this.djSettingShuffle = el.querySelector('#dj-setting-shuffle');
            this.djCookiesFile = el.querySelector('#dj-cookies-file');
            this.djBtnClearQueue = el.querySelector('#dj-btn-clear-queue');
            this.djQueueList = el.querySelector('#dj-queue-list');
            this.djQueueCount = el.querySelector('#dj-queue-count');
            
            this.publicQueueList = el.querySelector('#public-queue-list');

            this.loadSettings();
            this.setupAudio();
            this.setupVoiceSettings();
            this.setupCinemaMode();
            this.setupShareCard();
            if (this.isRegistered) {
                this.setupDJControls();
            }
            
            // Iniciar polling global para la cola pública y status de radio
            this.pollStatus();
            this.pollInterval = window.setInterval(() => this.pollStatus(), 5000);
        }

        initVisualizer() {
            if (this.audioContext) return;

            const AudioContext = window.AudioContext || (window as any).webkitAudioContext;
            if (!AudioContext) return;

            try {
                this.audioContext = new AudioContext();
                this.analyser = this.audioContext.createAnalyser();
                
                if (this.audio) {
                    this.source = this.audioContext.createMediaElementSource(this.audio);
                    this.source.connect(this.analyser);
                    this.analyser.connect(this.audioContext.destination);
                }

                this.analyser.fftSize = 256;
                const bufferLength = this.analyser.frequencyBinCount;
                this.dataArray = new Uint8Array(bufferLength);

                const visualize = () => {
                    if (!this.analyser || !this.dataArray || !this.isPlaying) {
                        this.visualizerReqId = requestAnimationFrame(visualize);
                        return;
                    }

                    this.analyser.getByteFrequencyData(this.dataArray);
                    
                    let sum = 0;
                    for (let i = 0; i < 8; i++) {
                        sum += this.dataArray[i];
                    }
                    const avgBass = sum / 8;
                    
                    const scale = 1 + (avgBass / 255) * 0.4;
                    document.documentElement.style.setProperty('--bass-scale', scale.toString());
                    
                    this.visualizerReqId = requestAnimationFrame(visualize);
                };

                visualize();
            } catch (err) {
                console.error("Web Audio API Error:", err);
            }
        }

        setupCinemaMode() {
            if (!this.cinemaBtn) return;
            
            this.cinemaBtn.addEventListener('click', () => {
                const isCinema = document.body.classList.contains('cinema-mode');
                const header = document.querySelector('header');
                const footer = document.querySelector('footer');
                const main = document.querySelector('main');
                const countdown = this.el.querySelector('.premiere-countdown');
                const sidebar = this.el.parentElement?.querySelector('.queue-sidebar');
                const djBtn = this.el.querySelector('#dj-trigger-btn');
                
                if (isCinema) {
                    document.body.classList.remove('cinema-mode');
                    if (header) (header as HTMLElement).style.display = '';
                    if (footer) (footer as HTMLElement).style.display = '';
                    if (main) {
                        (main as HTMLElement).style.minHeight = '';
                        (main as HTMLElement).style.padding = '';
                    }
                    if (countdown) {
                        (countdown as HTMLElement).style.boxShadow = '';
                        (countdown as HTMLElement).style.border = '';
                        (countdown as HTMLElement).style.background = '';
                        (countdown as HTMLElement).style.transform = '';
                    }
                    if (sidebar) (sidebar as HTMLElement).style.display = '';
                    if (djBtn) (djBtn as HTMLElement).style.display = '';
                    
                    if (document.fullscreenElement) {
                        document.exitFullscreen().catch(err => console.error(err));
                    }
                } else {
                    document.body.classList.add('cinema-mode');
                    if (header) (header as HTMLElement).style.display = 'none';
                    if (footer) (footer as HTMLElement).style.display = 'none';
                    if (main) {
                        (main as HTMLElement).style.minHeight = '100vh';
                        (main as HTMLElement).style.padding = '0';
                    }
                    if (countdown) {
                        (countdown as HTMLElement).style.boxShadow = 'none';
                        (countdown as HTMLElement).style.border = 'none';
                        (countdown as HTMLElement).style.background = 'transparent';
                        (countdown as HTMLElement).style.transform = 'scale(1.1)';
                    }
                    if (sidebar) (sidebar as HTMLElement).style.display = 'none';
                    if (djBtn) (djBtn as HTMLElement).style.display = 'none';
                    
                    document.documentElement.requestFullscreen().catch(err => console.error(err));
                }
            });

            document.addEventListener('fullscreenchange', () => {
                if (!document.fullscreenElement) {
                    const isCinema = document.body.classList.contains('cinema-mode');
                    if(isCinema) this.cinemaBtn?.click();
                }
            });
        }

        setupShareCard() {
            if (!this.shareBtn) return;

            this.shareBtn.addEventListener('click', async () => {
                const template = document.getElementById('share-card-template');
                const titleEl = document.getElementById('share-song-title');
                
                if (!template || !titleEl) return;
                
                // Animación de loading en el botón
                const originalHTML = this.shareBtn!.innerHTML;
                this.shareBtn!.innerHTML = `<svg class="animate-spin" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>`;
                
                titleEl.textContent = this.currentSongTitle || "Veredillas FM Radio";

                template.style.top = '0';
                template.style.left = '0';
                template.style.zIndex = '-99';
                template.style.opacity = '1';

                try {
                    const dataUrl = await htmlToImage.toPng(template, { 
                        quality: 0.95,
                        width: 1080,
                        height: 1920
                    });

                    const link = document.createElement('a');
                    link.download = 'veredillas-fm-story.png';
                    link.href = dataUrl;
                    link.click();
                } catch (err) {
                    console.error('Error generating share card:', err);
                } finally {
                    template.style.top = '-9999px';
                    template.style.left = '-9999px';
                    this.shareBtn!.innerHTML = originalHTML;
                }
            });
        }

        loadSettings() {
            const saved = localStorage.getItem('veredillas_tts_settings');
            if (saved) {
                try {
                    this.ttsSettings = JSON.parse(saved);
                } catch(e) { console.error("Error loading TTS settings", e); }
            }
            this.applySettingsToUI();
        }

        saveSettings() {
            localStorage.setItem('veredillas_tts_settings', JSON.stringify(this.ttsSettings));
        }

        setupVoiceSettings() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            
            toggleBtn?.addEventListener('click', () => {
                this.ttsSettings.enabled = !this.ttsSettings.enabled;
                this.saveSettings();
                this.applySettingsToUI();
                
                if (this.ttsSettings.enabled && this.isPlaying) {
                    this.playTTS(true);
                }
            });
        }

        applySettingsToUI() {
            const toggleBtn = this.el.querySelector('.voice-toggle-btn');
            if (toggleBtn) {
                if (this.ttsSettings.enabled) {
                    toggleBtn.classList.add('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: ON');
                } else {
                    toggleBtn.classList.remove('enabled');
                    toggleBtn.setAttribute('title', 'Locutor: OFF');
                }
            }
        }

        setupAudio() {
            if (!this.musicBtn || !this.audio) return;

            this.musicBtn.addEventListener('click', (e) => {
                e.preventDefault();
                this.toggleMusic();
            });

            this.audio.volume = 0.5;
            
            if(this.volumeSlider) {
                this.volumeSlider.addEventListener('input', (e) => {
                    const val = parseFloat((e.target as HTMLInputElement).value);
                    if(this.audio) this.audio.volume = val;
                    this.updateVolumeIcon(val);
                });
            }
            
            this.audio.addEventListener('error', (e) => {
                console.error('Audio stream error');
                if(this.musicLabel) this.musicLabel.textContent = "Error de conexión";
                this.isPlaying = false;
                this.musicBtn?.classList.remove('playing');
                this.updateVolumeVisibility();
            });
        }

        async fadeVolume(audio: HTMLAudioElement, target: number, duration: number) {
            const startVolume = audio.volume;
            const diff = target - startVolume;
            const startTime = performance.now();

            return new Promise<void>(resolve => {
                const tick = (now: number) => {
                    const elapsed = now - startTime;
                    const progress = Math.min(elapsed / duration, 1);
                    audio.volume = startVolume + diff * progress;

                    if (progress < 1) {
                        requestAnimationFrame(tick);
                    } else {
                        resolve();
                    }
                };
                requestAnimationFrame(tick);
            });
        }

        async playTTS(force = false) {
            if (!this.ttsSettings.enabled && !force) return;
            if (this.hasPlayedTTS && !force) return;
            this.hasPlayedTTS = true;

            const selectedModel = force ? this.ttsSettings.voice : (this.ttsSettings.voice || 'aura-2-selena-es');
            let userName = "amigo";
            
            try {
                const sessionStr = localStorage.getItem('user-session');
                if (sessionStr) {
                    const session = JSON.parse(sessionStr);
                    if (session.name) userName = session.name.split(' ')[0];
                }
            } catch(e) {}

            const variations = [
                `¡Hola, ${userName}! Estás escuchando Veredillas efe-eme en directo. Relájate y disfruta.`,
                `Bienvenido a la radio, ${userName}. Sube el volumen que la mejor música suena ahora.`,
                `Sintonizando la frecuencia oficial de Veredillas efe-eme. ¡Dale caña, ${userName}!`
            ];

            let phrase = variations[Math.floor(Math.random() * variations.length)];
            
            try {
                const response = await fetch('/api/tts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: phrase, model: selectedModel })
                });

                if (!response.ok) throw new Error('TTS failed');

                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const ttsAudio = new Audio(url);
                
                const originalVolume = this.audio?.volume || 0.5;
                if (this.audio) await this.fadeVolume(this.audio, originalVolume * 0.15, 1000);

                ttsAudio.play();
                ttsAudio.onended = async () => {
                    if (this.audio) await this.fadeVolume(this.audio, originalVolume, 1200);
                    URL.revokeObjectURL(url);
                };
            } catch (error) {
                console.error('TTS error:', error);
            }
        }

        updateVolumeIcon(volume: number) {
            const waves = this.el.querySelector('.volume-waves') as HTMLElement;
            const outerWaves = this.el.querySelector('.volume-waves-outer') as HTMLElement;
            
            if(!waves || !outerWaves) return;

            if (volume === 0) {
                waves.style.opacity = '0';
                outerWaves.style.opacity = '0';
            } else if (volume < 0.5) {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '0';
            } else {
                waves.style.opacity = '1';
                outerWaves.style.opacity = '1';
            }
        }

        updateVolumeVisibility() {
            if (this.isPlaying) {
                this.volumeContainer?.classList.add('show');
            } else {
                this.volumeContainer?.classList.remove('show');
            }
        }

        toggleMusic() {
            if (!this.audio || !this.musicBtn) return;

            if (this.isPlaying) {
                this.audio.pause();
                this.isPlaying = false;
                this.musicBtn.classList.remove('playing');
                if(this.musicLabel) this.musicLabel.textContent = `Activar Radio`;
            } else {
                if(this.musicLabel) this.musicLabel.textContent = "Conectando...";
                
                this.audio.src = `https://radio.veredillasfm.es/stream?t=${new Date().getTime()}`;
                
                this.audio.play().then(() => {
                    this.isPlaying = true;
                    this.initVisualizer();
                    this.musicBtn!.classList.add('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = `En directo`;
                    this.playTTS();
                }).catch(e => {
                    console.error("Audio play failed:", e);
                    this.isPlaying = false;
                    this.musicBtn!.classList.remove('playing');
                    if(this.musicLabel) this.musicLabel!.textContent = "No disponible";
                }).finally(() => {
                    this.updateVolumeVisibility();
                });
            }
            this.updateVolumeVisibility();
        }

        setupDJControls() {
            if (this.djTriggerBtn && this.djModalOverlay && this.djCloseBtn) {
                this.djTriggerBtn.addEventListener('click', () => {
                    this.djModalOverlay?.classList.add('open');
                });
                this.djCloseBtn.addEventListener('click', () => {
                    this.djModalOverlay?.classList.remove('open');
                });
                this.djModalOverlay.addEventListener('click', (e) => {
                    if (e.target === this.djModalOverlay) {
                        this.djModalOverlay?.classList.remove('open');
                    }
                });
            }

            if (this.isAdmin) {
                this.djBtnPlay?.addEventListener('click', () => this.apiPlay());
                this.djBtnStop?.addEventListener('click', () => this.apiStop());
                this.djBtnSkip?.addEventListener('click', () => this.apiSkip());
                this.djBtnSync?.addEventListener('click', () => this.syncStream());
                this.djBtnPlaylist?.addEventListener('click', () => {
                    this.apiPlayPlaylist(this.djPlaylistInput?.value || '');
                });
                this.djSettingLoop?.addEventListener('change', () => {
                    this.apiUpdateSettings(this.djSettingLoop!.checked, this.djSettingShuffle!.checked);
                });
                this.djSettingShuffle?.addEventListener('change', () => {
                    this.apiUpdateSettings(this.djSettingLoop!.checked, this.djSettingShuffle!.checked);
                });
                this.djBtnClearQueue?.addEventListener('click', () => this.apiClearQueue());
                this.djCookiesFile?.addEventListener('change', (e) => {
                    const file = (e.target as HTMLInputElement).files?.[0];
                    if (file) this.apiUploadCookies(file);
                });
            }
            
            this.djBtnSearch?.addEventListener('click', () => {
                this.apiSearch(this.djSearchInput?.value || '');
            });
            this.djSearchInput?.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') {
                    this.apiSearch(this.djSearchInput?.value || '');
                }
            });
        }

        syncStream() {
            if (this.audio) {
                this.audio.src = `https://radio.veredillasfm.es/stream?t=${new Date().getTime()}`;
                if (this.isPlaying) {
                    this.audio.play().catch(e => console.error("Error syncing stream:", e));
                }
            }
        }

        async apiPlay() {
            try {
                await fetch('https://radio.veredillasfm.es/api/play', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiStop() {
            try {
                await fetch('https://radio.veredillasfm.es/api/stop', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiSkip() {
            try {
                await fetch('https://radio.veredillasfm.es/api/skip', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiSearch(query: string) {
            if (!this.djResultsList) return;
            this.djResultsList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-5">Buscando...</div>';
            
            try {
                const url = new URL('https://radio.veredillasfm.es/api/search');
                if (query) url.searchParams.append('q', query);
                
                const res = await fetch(url.toString());
                const data = await res.json();
                
                if (data.results && data.results.length > 0) {
                    this.djResultsList.innerHTML = '';
                    data.results.forEach((item: any) => {
                        const div = document.createElement('div');
                        div.className = 'flex flex-col gap-2 bg-white/5 border border-white/10 p-3 rounded-xl hover:bg-white/10 hover:border-cyan-500/30 transition-all';
                        
                        let buttonsHTML = '';
                        if (this.isAdmin) {
                            buttonsHTML += `<button class="dj-action-btn play-specific flex-1 py-1.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs font-semibold hover:bg-emerald-500/20 transition-colors" data-idx="${item.index}" title="Reproducir ahora">▶ Play</button>`;
                        }
                        buttonsHTML += `
                            <button class="dj-action-btn queue queue-next flex-1 py-1.5 rounded bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 text-xs font-semibold hover:bg-cyan-500/20 transition-colors" data-idx="${item.index}" title="Siguiente">+ Sig</button>
                            <button class="dj-action-btn queue queue-last flex-1 py-1.5 rounded bg-white/5 text-gray-300 border border-white/10 text-xs font-semibold hover:bg-white/10 transition-colors" data-idx="${item.index}" title="Al final">+ Fin</button>
                        `;

                        div.innerHTML = `
                            <span class="text-white text-sm font-medium truncate" title="${item.title}">${item.title}</span>
                            <div class="flex items-center gap-2">
                                ${buttonsHTML}
                            </div>
                        `;
                        this.djResultsList?.appendChild(div);
                    });

                    if (this.isAdmin) {
                        this.djResultsList.querySelectorAll('.play-specific').forEach(btn => {
                            btn.addEventListener('click', (e) => this.apiPlaySpecific(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0')));
                        });
                    }
                    this.djResultsList.querySelectorAll('.queue-next').forEach(btn => {
                        btn.addEventListener('click', (e) => this.apiQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0'), 'queue_next'));
                    });
                    this.djResultsList.querySelectorAll('.queue-last').forEach(btn => {
                        btn.addEventListener('click', (e) => this.apiQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0'), 'queue_last'));
                    });

                } else {
                    this.djResultsList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-5">No se encontraron resultados.</div>';
                }
            } catch (err) {
                this.djResultsList.innerHTML = '<div class="text-red-400 text-sm text-center mt-5">Error al buscar.</div>';
            }
        }

        async apiQueue(index: number, action: string) {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index, action })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiPlaySpecific(index: number) {
            try {
                await fetch('https://radio.veredillasfm.es/api/play-specific', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiPlayPlaylist(playlistName: string) {
            if (!playlistName) return;
            try {
                await fetch('https://radio.veredillasfm.es/api/play-playlist', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ playlistName })
                });
                this.pollStatus();
                if (this.djPlaylistInput) this.djPlaylistInput.value = '';
            } catch (err) {}
        }

        async apiRemoveQueue(index: number) {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue/remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ index })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiClearQueue() {
            try {
                await fetch('https://radio.veredillasfm.es/api/queue/clear', { method: 'POST' });
                this.pollStatus();
            } catch (err) {}
        }

        async apiUpdateSettings(loop: boolean, shuffle: boolean) {
            try {
                await fetch('https://radio.veredillasfm.es/api/settings', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ loop, shuffle })
                });
                this.pollStatus();
            } catch (err) {}
        }

        async apiUploadCookies(file: File) {
            try {
                const formData = new FormData();
                formData.append('cookies', file);
                await fetch('https://radio.veredillasfm.es/api/cookies', {
                    method: 'POST',
                    body: formData
                });
                if (this.djCookiesFile) this.djCookiesFile.value = '';
            } catch (err) {}
        }

        async playNextSongIntro(currentSongMeta: any, nextSongMeta: any) {
            if (!this.ttsSettings.enabled || !this.isPlaying) return;

            let currentArtist = "un artista increíble";
            let currentTitle = "este temazo";
            if (currentSongMeta && currentSongMeta.title) {
                const parts = currentSongMeta.title.split(' - ');
                if (parts.length > 1) {
                    currentTitle = parts[0].trim();
                    currentArtist = parts.slice(1).join(' - ').trim();
                } else {
                    currentTitle = currentSongMeta.title;
                }
            }

            let nextArtist = "";
            let nextTitle = "";
            if (nextSongMeta && nextSongMeta.title) {
                const parts = nextSongMeta.title.split(' - ');
                if (parts.length > 1) {
                    nextTitle = parts[0].trim();
                    nextArtist = parts.slice(1).join(' - ').trim();
                } else {
                    nextTitle = nextSongMeta.title;
                }
            }

            let userName = "familia";
            try {
                const sessionStr = localStorage.getItem('user-session');
                if (sessionStr) {
                    const session = JSON.parse(sessionStr);
                    if (session.name) userName = session.name.split(' ')[0];
                }
            } catch(e) {}

            let phrase = "";
            if (nextTitle && nextArtist) {
                const templates = [
                    `¡Qué locura de tema nos acaba de regalar ${currentArtist}! Pero ojo, ${userName}, porque no bajamos el ritmo. Prepárate porque ahora entra ${nextArtist} con ${nextTitle}. ¡Súbele a Veredillas efe eme!`,
                    `Ahí lo tenías, ${currentTitle} sonando duro. Y si creías que eso era todo, espera a escuchar lo que sigue. En exclusiva, ${nextTitle} de ${nextArtist}. Solo aquí, en tu radio favorita.`,
                    `¡Familia! La vibra está por las nubes después de escuchar a ${currentArtist}. Vamos a mantener la energía a tope porque se viene ${nextArtist} con ${nextTitle}. ¡No te lo pierdas!`,
                    `Tremendo palo este de ${currentTitle}. Y la cosa se pone aún mejor. Acomódate bien, ${userName}, porque llega ${nextArtist} directo a tus oídos con ${nextTitle}.`,
                    `Estás sintonizando Veredillas efe eme. Despedimos a ${currentArtist} y le damos la bienvenida a ${nextArtist} con su temazo, ${nextTitle}. ¡Disfrútalo!`,
                    `¡Uf, qué buena rolita de ${currentArtist}! Seguimos activos en cabina y ahora toca el turno de ${nextTitle}, lo nuevo de ${nextArtist}. Sube ese volumen.`,
                    `La música no para en Veredillas efe eme. Después de este exitazo, nos vamos con ${nextArtist} y su increíble tema, ${nextTitle}. ¡Vámonos!`,
                    `Si te gustó lo de ${currentArtist}, lo que viene te va a encantar. Directamente para ti, ${userName}, suena ${nextTitle} de ${nextArtist}. ¡Pura calidad!`,
                    `¡Seguimos rompiendo la antena! Atrás quedó ${currentTitle} y nos metemos de lleno con el sonido único de ${nextArtist} cantando ${nextTitle}.`,
                    `¡Wow, qué energía! Así suena ${currentArtist} en Veredillas efe eme. Y ahora, prepárate para cantar a todo pulmón con ${nextArtist} y su éxito ${nextTitle}.`,
                    `¡Vaya, vaya! Terminamos de gozar con ${currentArtist}, pero aquí en Veredillas efe eme la fiesta apenas comienza. Atento a lo que suena ahora: ${nextTitle} de ${nextArtist}.`,
                    `Qué buena onda nos dejó ${currentArtist}. Si estás escuchando esto, ${userName}, ponte cómodo porque el siguiente hit es ${nextTitle}, interpretado por ${nextArtist}.`,
                    `¡Se encendió la cabina! Acabamos de vibrar con ${currentTitle}, y para seguir con el mismo mood, te dejamos con ${nextArtist} y su temón, ${nextTitle}.`,
                    `Nadie pone la música como Veredillas efe eme. Despídete de ${currentArtist}, porque ya está en la pista ${nextArtist} con ${nextTitle}. ¡A romperla!`,
                    `Pausa tus problemas, ${userName}, porque acaba de terminar ${currentTitle} y se viene un bombazo: nada menos que ${nextArtist} trayéndonos ${nextTitle}.`,
                    `Acabamos de escuchar a ${currentArtist}, dejando la vara altísima. Pero no te preocupes, que ahora viene ${nextArtist} con ${nextTitle} para seguir dándolo todo.`,
                    `El flow no se negocia aquí en Veredillas efe eme. Se va ${currentTitle} pero entra ${nextTitle}, de la mano de ${nextArtist}. Sube, sube el volumen.`,
                    `¡Menudo viaje musical con ${currentArtist}! Agárrate fuerte porque la siguiente pista es brutal. Con ustedes, ${nextArtist} y ${nextTitle}.`,
                    `Si estabas bailando con ${currentTitle}, no pares todavía. Llegó el momento de ${nextArtist} con ${nextTitle}. ¡Directo a tu cerebro!`,
                    `¡Atención, ${userName}! Ya pasó ${currentArtist}, y lo que te tengo preparado ahora es oro puro. Escucha bien: esto es ${nextTitle} de ${nextArtist} en Veredillas efe eme.`
                ];
                phrase = templates[Math.floor(Math.random() * templates.length)];
            } else {
                const fallbackTemplates = [
                    `¡Vaya temazo acabamos de escuchar de ${currentArtist}! Seguimos con la mejor selección musical aquí en Veredillas efe eme.`,
                    `Ese fue ${currentArtist} rompiéndola. No te despegues, ${userName}, porque seguimos con mucha más música buena.`,
                    `Estás en Veredillas efe eme. Después de este increíble tema de ${currentArtist}, seguimos con más éxitos imparables.`,
                    `Pura buena vibra con ${currentTitle}. Quédate con nosotros que la música no se detiene ni un segundo.`,
                    `¡Eso estuvo genial! Despedimos a ${currentArtist} y seguimos adelante. Ya sabes que en Veredillas efe eme suenan los mejores.`,
                    `¡Qué nivel el de ${currentArtist}! Sigue en sintonía, ${userName}, porque la próxima canción te va a volar la cabeza.`
                ];
                phrase = fallbackTemplates[Math.floor(Math.random() * fallbackTemplates.length)];
            }

            try {
                // Use the configured voice, defaulting to the expressive male voice 'aura-2-aquila-es' or 'aura-orion-en'
                const selectedModel = this.ttsSettings.voice || 'aura-orion-en'; 

                const response = await fetch('/api/tts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: phrase, model: selectedModel })
                });

                if (!response.ok) throw new Error('TTS failed');

                const blob = await response.blob();
                const url = URL.createObjectURL(blob);
                const ttsAudio = new Audio(url);
                
                const originalVolume = this.audio?.volume || 0.5;
                if (this.audio) await this.fadeVolume(this.audio, originalVolume * 0.15, 1500);

                ttsAudio.play();
                ttsAudio.onended = async () => {
                    if (this.audio) await this.fadeVolume(this.audio, originalVolume, 2000);
                    URL.revokeObjectURL(url);
                };
            } catch (error) {
                console.error('DJ AI TTS error:', error);
            }
        }

        async pollStatus() {
            try {
                const res = await fetch('https://radio.veredillasfm.es/api/status');
                const data = await res.json();
                
                // Actualizar widget de esquina
                const cornerTitle = document.getElementById('corner-song-title');
                const cornerWidget = document.getElementById('now-playing-corner');
                
                if (data.isPlaying && data.currentSongMeta && data.currentSongMeta.title) {
                    if (cornerTitle) cornerTitle.textContent = data.currentSongMeta.title;
                    if (this.isPlaying) {
                        if (cornerWidget) cornerWidget.classList.add('visible');
                    }

                    // --- DJ AI LOGIC ---
                    if (this.currentSongTitle !== data.currentSongMeta.title) {
                        this.currentSongTitle = data.currentSongMeta.title;
                        
                        if (this.nextSongTimeoutId) {
                            clearTimeout(this.nextSongTimeoutId);
                            this.nextSongTimeoutId = null;
                        }

                        // Schedule the next song intro if duration is known and long enough
                        if (data.currentSongMeta.duration && data.currentSongMeta.duration > 30) {
                            // Schedule for 20 seconds before the song ends
                            // Subtract a small buffer (e.g. 2.5s) to account for polling delay
                            const timeoutSeconds = data.currentSongMeta.duration - 20 - 2.5;
                            if (timeoutSeconds > 0) {
                                this.nextSongTimeoutId = window.setTimeout(() => {
                                    this.playNextSongIntro(data.currentSongMeta, this.lastKnownQueue?.[0]);
                                }, timeoutSeconds * 1000);
                            }
                        }
                    }
                    // -------------------

                } else {
                    if (cornerWidget) cornerWidget.classList.remove('visible');
                }

                // Guardar la cola para el DJ AI
                this.lastKnownQueue = data.playQueue || [];
                if (this.publicQueueList) {
                    if (data.playQueue && data.playQueue.length > 0) {
                        this.publicQueueList.innerHTML = '';
                        data.playQueue.slice(0, 15).forEach((song: any, idx: number) => {
                            const div = document.createElement('div');
                            div.className = 'flex items-center justify-between bg-white/5 border border-white/10 p-3.5 rounded-xl hover:bg-white/10 transition-colors';
                            div.innerHTML = `
                                <div class="flex flex-col overflow-hidden pr-2 w-full">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="text-xs font-bold text-gray-500 w-4">${idx + 1}.</span>
                                        <span class="text-white text-sm font-semibold truncate" title="${song.title}">${song.title}</span>
                                    </div>
                                    ${song.duration ? `<span class="text-xs text-gray-400 font-mono ml-6">${Math.floor(song.duration/60)}:${String(Math.floor(song.duration%60)).padStart(2,'0')}</span>` : ''}
                                </div>
                            `;
                            this.publicQueueList?.appendChild(div);
                        });
                        if(data.playQueue.length > 15) {
                            const more = document.createElement('div');
                            more.className = 'text-xs text-center text-gray-500 mt-2 font-medium';
                            more.textContent = `+ ${data.playQueue.length - 15} canciones más...`;
                            this.publicQueueList.appendChild(more);
                        }
                    } else {
                        this.publicQueueList.innerHTML = '<div class="text-gray-500 text-sm font-medium text-center mt-10">La cola está vacía</div>';
                    }
                }

                // Si el modal de DJ está abierto, actualizar datos
                if (this.isRegistered && this.djModalOverlay && this.djModalOverlay.classList.contains('open')) {
                    if (this.djStatusBadge) {
                        if (data.isPlaying) {
                            this.djStatusBadge.className = 'px-3 py-1 rounded-full text-[0.65rem] font-extrabold tracking-widest uppercase bg-emerald-500/15 text-emerald-400 border border-emerald-500/30 shadow-[0_0_10px_currentColor]';
                            this.djStatusBadge.textContent = 'ONLINE';
                        } else {
                            this.djStatusBadge.className = 'px-3 py-1 rounded-full text-[0.65rem] font-extrabold tracking-widest uppercase bg-orange-500/15 text-orange-500 border border-orange-500/30 shadow-[0_0_10px_currentColor]';
                            this.djStatusBadge.textContent = 'OFFLINE';
                        }
                    }

                    if (this.djCurrentSong) {
                        this.djCurrentSong.textContent = (data.isPlaying && data.currentSongMeta?.title) ? data.currentSongMeta.title : 'Ninguna canción';
                    }

                    if (data.radioSettings) {
                        if (this.djSettingLoop && this.djSettingLoop !== document.activeElement) {
                            this.djSettingLoop.checked = data.radioSettings.loop;
                        }
                        if (this.djSettingShuffle && this.djSettingShuffle !== document.activeElement) {
                            this.djSettingShuffle.checked = data.radioSettings.shuffle;
                        }
                    }

                    if (data.playQueue && this.djQueueList) {
                        if (this.djQueueCount) this.djQueueCount.textContent = data.playQueue.length;
                        
                        if (data.playQueue.length === 0) {
                            this.djQueueList.innerHTML = '<div class="text-gray-500 text-sm text-center mt-10">La cola está vacía</div>';
                        } else {
                            this.djQueueList.innerHTML = '';
                            data.playQueue.forEach((song: any, idx: number) => {
                                const div = document.createElement('div');
                                div.className = 'flex items-center justify-between bg-white/5 border border-white/5 p-3 rounded-xl hover:bg-white/10 transition-colors group';
                                
                                let removeBtnHTML = '';
                                if (this.isAdmin) {
                                    removeBtnHTML = `
                                    <button class="dj-btn-remove-queue shrink-0 w-8 h-8 rounded-lg bg-red-500/10 text-red-400 border border-red-500/20 flex items-center justify-center lg:opacity-0 group-hover:opacity-100 hover:bg-red-500/20 transition-all" data-idx="${idx}" title="Eliminar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                                    </button>`;
                                }

                                div.innerHTML = `
                                    <div class="flex flex-col overflow-hidden pr-2">
                                        <span class="text-white text-sm font-medium truncate" title="${song.title}">${song.title}</span>
                                        ${song.duration ? `<span class="text-xs text-gray-500 font-mono">${Math.floor(song.duration/60)}:${String(Math.floor(song.duration%60)).padStart(2,'0')}</span>` : ''}
                                    </div>
                                    ${removeBtnHTML}
                                `;
                                this.djQueueList?.appendChild(div);
                            });
                            
                            if (this.isAdmin) {
                                this.djQueueList.querySelectorAll('.dj-btn-remove-queue').forEach(btn => {
                                    btn.addEventListener('click', (e) => this.apiRemoveQueue(parseInt((e.currentTarget as HTMLElement).dataset.idx || '0')));
                                });
                            }
                        }
                    }
                }
            } catch (err) {
                const cornerWidget = document.getElementById('now-playing-corner');
                if (cornerWidget) cornerWidget.classList.remove('visible');
                
                if (this.publicQueueList) {
                    this.publicQueueList.innerHTML = '<div class="text-red-400 text-sm font-medium text-center mt-10">Desconectado del servidor</div>';
                }
            }
        }
    }

    document.addEventListener('astro:page-load', () => {
        const els = document.querySelectorAll('.radio-page-container');
        els.forEach(el => new RadioPlayerMinimal(el as HTMLElement));
    });

    document.addEventListener('DOMContentLoaded', () => {
        const els = document.querySelectorAll('.radio-page-container');
        els.forEach(el => new RadioPlayerMinimal(el as HTMLElement));
    });
</script>