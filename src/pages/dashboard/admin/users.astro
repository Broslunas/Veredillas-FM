                <button id="closeViewModal" class="w-8 h-8 flex items-center justify-center rounded-lg text-zinc-500 hover:text-white hover:bg-white/10 transition-all">&times;</button>
            </div>
            
            <div id="viewUserDetails" class="p-6 overflow-y-auto" style="max-height: calc(90vh - 80px);">
