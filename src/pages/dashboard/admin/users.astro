                        <div class="flex items-center gap-4 text-xs text-zinc-500 font-mono flex-wrap">
                            <span class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                Registro: <span id="viewJoined" class="text-zinc-300"></span>
                            </span>
                            <span class="flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                Último: <span id="viewLastActive" class="text-zinc-300"></span>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 text-center">
                        <div class="w-9 h-9 mx-auto mb-2 rounded-lg bg-violet-500/15 flex items-center justify-center text-violet-400">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        </div>
                        <p class="text-[0.6rem] uppercase tracking-wider text-zinc-500 font-bold mb-0.5">Tiempo</p>
                        <p id="viewListeningTime" class="text-lg font-extrabold text-white font-mono"></p>
                    </div>
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 text-center">
                        <div class="w-9 h-9 mx-auto mb-2 rounded-lg bg-emerald-500/15 flex items-center justify-center text-emerald-400">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        </div>
                        <p class="text-[0.6rem] uppercase tracking-wider text-zinc-500 font-bold mb-0.5">Completados</p>
                        <p id="viewCompletedCount" class="text-lg font-extrabold text-white"></p>
                    </div>
                    <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 text-center">
                        <div class="w-9 h-9 mx-auto mb-2 rounded-lg bg-amber-500/15 flex items-center justify-center text-amber-400">
