---
import Layout from '../../../layouts/Layout.astro';
import AdminNav from '../../../components/admin/AdminNav.astro';
import { getUserFromCookie } from '../../../lib/auth';
import User from '../../../models/User';
import dbConnect from '../../../lib/mongodb';
import { getCollection } from 'astro:content';

export const prerender = false;

const cookieHeader = Astro.request.headers.get('cookie');
const userPayload = getUserFromCookie(cookieHeader);

if (!userPayload) {
  return Astro.redirect('/404');
}

await dbConnect();

const currentUser = await User.findById(userPayload.userId);
if (!currentUser || (currentUser.role !== 'admin' && currentUser.role !== 'owner')) {
  return Astro.redirect('/404'); 
}

const users = await User.find({}).sort({ createdAt: -1 });

// Fetch Episodes & Clips for Client-side enrichment
const allEpisodes = await getCollection('episodios');
const episodesData: Record<string, { title: string, image: string }> = {};
const clipsData: Record<string, { title: string, episodeSlug: string, image: string }> = {};

allEpisodes.forEach(e => {
    const epImage = typeof e.data.image === 'string' ? e.data.image : (e.data.image as any)?.src || '';
    episodesData[e.slug] = {
        title: e.data.title,
        image: epImage
    };
    if (e.data.clips) {
        e.data.clips.forEach((clip: any) => {
             const match = clip.url.match(/(?:youtube\.com\/shorts\/|youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^?&]+)/);
             const videoId = match ? match[1] : null;
             if (videoId) {
                 clipsData[videoId] = {
                     title: clip.title,
                     episodeSlug: e.slug,
                     image: epImage
                 };
             }
        });
    }
});

function formatTime(seconds: number) {
    const h = Math.floor(seconds / 3600);
    const m = Math.floor((seconds % 3600) / 60);
    return `${h}h ${m}m`;
}

// Stats Computation
const now = new Date();
const thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);

const totalUsers = users.length;
const adminCount = users.filter(u => u.role === 'admin' || u.role === 'owner').length;
const subscribedCount = users.filter(u => u.newsletter).length;
const activeRecentCount = users.filter(u => u.lastActiveAt && new Date(u.lastActiveAt) > thirtyDaysAgo).length;
const newThisWeek = users.filter(u => new Date(u.createdAt) > sevenDaysAgo).length;
const totalListeningTime = users.reduce((acc, u) => acc + (u.listeningTime || 0), 0);
const avgListeningTime = totalUsers > 0 ? Math.round(totalListeningTime / totalUsers) : 0;
---

<Layout title="Gestión de Usuarios - Admin" robots="noindex, nofollow">
    <!-- Background Effects -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
        <div class="absolute -top-48 -left-48 w-[600px] h-[600px] rounded-full bg-violet-600/[0.07] blur-[100px] animate-blob-float"></div>
        <div class="absolute -bottom-48 -right-48 w-[600px] h-[600px] rounded-full bg-pink-500/[0.07] blur-[100px] animate-blob-float-reverse"></div>
        <div class="absolute inset-0 opacity-40 pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 40px 40px; mask-image: radial-gradient(circle at center, black 40%, transparent 100%);"></div>
    </div>

    <div class="max-w-[1600px] mx-auto px-4 sm:px-6 lg:px-8 py-6 animate-fade-in-up" id="adminContainer" data-episodes={JSON.stringify(episodesData)} data-clips={JSON.stringify(clipsData)}>
        
        <!-- Header -->
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight bg-gradient-to-r from-white via-violet-400 to-pink-400 bg-clip-text text-transparent drop-shadow-[0_0_30px_rgba(167,139,250,0.4)]">
                    Usuarios
                </h1>
                <p class="text-zinc-400 text-lg mt-1 tracking-wide">
                    Gestión completa de la base de usuarios
                </p>
            </div>
            <div class="flex items-center gap-3 flex-wrap">
                <button id="exportUsersBtn" class="group flex items-center gap-2 px-4 py-2.5 bg-zinc-800/60 border border-white/10 rounded-xl text-sm font-semibold text-zinc-300 hover:bg-zinc-700/60 hover:text-white hover:border-white/20 transition-all duration-300 backdrop-blur-xl" title="Exportar usuarios a CSV">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                    <span>Exportar</span>
                </button>
                <button id="sendBulkNewsletterBtn" class="group flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-violet-600 to-fuchsia-600 rounded-xl text-sm font-bold text-white shadow-[0_4px_15px_rgba(139,92,246,0.3)] hover:shadow-[0_8px_25px_rgba(139,92,246,0.5)] hover:-translate-y-0.5 hover:brightness-110 active:translate-y-0 active:scale-[0.98] transition-all duration-300" title="Enviar newsletter a todos los suscritos">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                    <span>Enviar a Todos</span>
                </button>
            </div>
        </div>

        <AdminNav />

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-violet-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-violet-500/15 flex items-center justify-center text-violet-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Total</p>
                        <p class="text-xl font-extrabold text-white">{totalUsers}</p>
                    </div>
                </div>
            </div>
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-emerald-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-emerald-500/15 flex items-center justify-center text-emerald-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Activos 30d</p>
                        <p class="text-xl font-extrabold text-white">{activeRecentCount}</p>
                    </div>
                </div>
            </div>
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-sky-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-sky-500/15 flex items-center justify-center text-sky-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Suscritos</p>
                        <p class="text-xl font-extrabold text-white">{subscribedCount}<span class="text-xs text-zinc-500 ml-1">/ {totalUsers}</span></p>
                    </div>
                </div>
            </div>
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-amber-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-amber-500/15 flex items-center justify-center text-amber-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20v-6M6 20V10M18 20V4"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Nuevos 7d</p>
                        <p class="text-xl font-extrabold text-white">+{newThisWeek}</p>
                    </div>
                </div>
            </div>
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-pink-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-pink-500/15 flex items-center justify-center text-pink-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Tiempo Total</p>
                        <p class="text-xl font-extrabold text-white">{formatTime(totalListeningTime)}</p>
                    </div>
                </div>
            </div>
            <div class="group relative bg-zinc-900/50 border border-white/[0.06] rounded-2xl p-4 backdrop-blur-xl hover:border-indigo-500/30 hover:bg-zinc-800/40 transition-all duration-300 hover:-translate-y-1">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-indigo-500/15 flex items-center justify-center text-indigo-400 shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
                    </div>
                    <div>
                        <p class="text-[0.65rem] uppercase tracking-wider text-zinc-500 font-bold">Media/User</p>
                        <p class="text-xl font-extrabold text-white">{formatTime(avgListeningTime)}</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search & Filters Bar -->
        <div class="bg-zinc-900/40 border border-white/[0.06] rounded-2xl p-4 mb-6 backdrop-blur-xl">
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
                <!-- Search Input -->
                <div class="relative flex-1">
                    <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-zinc-500 pointer-events-none" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input 
                        type="text" 
                        id="searchInput" 
                        placeholder="Buscar por nombre, email..." 
                        class="w-full pl-10 pr-4 py-2.5 bg-black/30 border border-white/[0.08] rounded-xl text-sm text-white placeholder:text-zinc-600 focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/10 transition-all"
                    />
                </div>
                <!-- Filter: Role -->
                <select id="filterRole" class="px-3 py-2.5 bg-black/30 border border-white/[0.08] rounded-xl text-sm text-zinc-300 focus:outline-none focus:border-violet-500/50 transition-all cursor-pointer appearance-none min-w-[140px]">
                    <option value="all">Todos los roles</option>
                    <option value="user">👤 Usuarios</option>
                    <option value="admin">🛡️ Admins</option>
                    <option value="owner">👑 Owners</option>
                </select>
                <!-- Filter: Newsletter -->
                <select id="filterNewsletter" class="px-3 py-2.5 bg-black/30 border border-white/[0.08] rounded-xl text-sm text-zinc-300 focus:outline-none focus:border-violet-500/50 transition-all cursor-pointer appearance-none min-w-[140px]">
                    <option value="all">Newsletter: Todos</option>
                    <option value="subscribed">✅ Suscritos</option>
                    <option value="unsubscribed">❌ No suscritos</option>
                </select>
                <!-- Sort -->
                <select id="sortBy" class="px-3 py-2.5 bg-black/30 border border-white/[0.08] rounded-xl text-sm text-zinc-300 focus:outline-none focus:border-violet-500/50 transition-all cursor-pointer appearance-none min-w-[160px]">
                    <option value="newest">📅 Más recientes</option>
                    <option value="oldest">📅 Más antiguos</option>
                    <option value="name">🔤 Nombre A-Z</option>
                    <option value="listening">🎧 Más escuchado</option>
                    <option value="streak">🔥 Mayor racha</option>
                    <option value="lastActive">⚡ Último activo</option>
                </select>
                <!-- Results counter -->
                <div id="resultsCounter" class="hidden sm:flex items-center gap-1.5 px-3 py-2.5 bg-violet-500/10 border border-violet-500/20 rounded-xl text-xs font-bold text-violet-400 whitespace-nowrap">
                    <span id="resultsCount">{totalUsers}</span> resultados
                </div>
            </div>
        </div>

        <!-- Users Table / List -->
        <div class="bg-zinc-900/40 border border-white/[0.06] rounded-2xl backdrop-blur-xl overflow-hidden shadow-[0_20px_40px_-10px_rgba(0,0,0,0.4)]">
            <!-- Table Header (Desktop) -->
            <div class="hidden lg:grid grid-cols-[minmax(200px,2fr)_minmax(180px,2fr)_100px_120px_120px_100px_90px_100px_140px] gap-2 px-5 py-3 border-b border-white/[0.05] text-[0.7rem] uppercase tracking-[0.12em] font-bold text-zinc-500">
                <span>Usuario</span>
                <span>Email</span>
                <span>Rol</span>
                <span>Registro</span>
                <span>Último Acceso</span>
                <span>Tiempo</span>
                <span>Racha</span>
                <span>Newsletter</span>
                <span class="text-right">Acciones</span>
            </div>

            <!-- User Rows -->
            <div id="usersListContainer">
                {users.map((user, index) => {
                    const isCurrentUser = user._id.toString() === currentUser._id.toString();
                    const daysAgo = user.lastActiveAt ? Math.floor((now.getTime() - new Date(user.lastActiveAt).getTime()) / (1000 * 60 * 60 * 24)) : -1;
                    const isActive = daysAgo >= 0 && 7 >= daysAgo;
                    const isInactive = daysAgo >= 31 || daysAgo === -1;
                    
                    return (
                        <div 
                            class="user-row group grid grid-cols-1 lg:grid-cols-[minmax(200px,2fr)_minmax(180px,2fr)_100px_120px_120px_100px_90px_100px_140px] gap-2 lg:gap-2 px-5 py-3.5 border-b border-white/[0.03] hover:bg-white/[0.03] transition-all duration-200 relative"
                            data-name={user.name.toLowerCase()}
                            data-email={user.email.toLowerCase()}
                            data-role={user.role}
                            data-newsletter={user.newsletter ? 'subscribed' : 'unsubscribed'}
                            data-created={new Date(user.createdAt).getTime()}
                            data-listening={user.listeningTime || 0}
                            data-streak={user.currentStreak || 0}
                            data-last-active={user.lastActiveAt ? new Date(user.lastActiveAt).getTime() : 0}
                            style={`animation-delay: ${index * 20}ms`}
                        >
                            {/* User Avatar + Name */}
                            <div class="flex items-center gap-3 min-w-0">
                                <div class="relative shrink-0">
                                    <img 
                                        src={user.picture || `https://ui-avatars.com/api/?name=${user.name}&background=7c3aed&color=fff&size=80`} 
                                        alt={user.name} 
                                        class="w-10 h-10 rounded-full object-cover ring-2 ring-white/10 shadow-lg"
                                        loading="lazy"
                                    />
                                    <div class={`absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 rounded-full border-2 border-zinc-900 ${isActive ? 'bg-emerald-500 shadow-[0_0_6px_rgba(52,211,153,0.6)]' : isInactive ? 'bg-zinc-600' : 'bg-amber-500'}`}></div>
                                </div>
                                <div class="min-w-0">
                                    <div class="flex items-center gap-1.5">
                                        <span class="font-bold text-white text-sm truncate">{user.name}</span>
                                        {isCurrentUser && <span class="text-[0.6rem] px-1.5 py-0.5 bg-violet-500/20 text-violet-400 rounded-md font-bold">TÚ</span>}
                                    </div>
                                    <span class="lg:hidden text-xs text-zinc-500 truncate block">{user.email}</span>
                                </div>
                            </div>
                            
                            {/* Email */}
                            <div class="hidden lg:flex items-center min-w-0">
                                <span class="text-sm text-zinc-400 truncate" title={user.email}>{user.email}</span>
                            </div>
                            
                            {/* Role Badge */}
                            <div class="hidden lg:flex items-center">
                                <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-[0.7rem] font-bold uppercase tracking-wide ${
                                    user.role === 'owner' 
                                        ? 'bg-pink-500/15 text-pink-300 border border-pink-500/30 shadow-[0_0_10px_rgba(244,114,182,0.15)]' 
                                        : user.role === 'admin' 
                                        ? 'bg-violet-500/15 text-violet-300 border border-violet-500/30 shadow-[0_0_10px_rgba(139,92,246,0.15)]' 
                                        : 'bg-white/[0.04] text-zinc-400 border border-white/[0.08]'
                                }`}>
                                    {user.role === 'owner' ? '👑' : user.role === 'admin' ? '🛡️' : '👤'} {user.role}
                                </span>
                            </div>
                            
                            {/* Registration Date */}
                            <div class="hidden lg:flex items-center">
                                <span class="text-xs text-zinc-500 font-mono" title={new Date(user.createdAt).toLocaleString()}>
                                    {new Date(user.createdAt).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: '2-digit' })}
                                </span>
                            </div>
                            
                            {/* Last Active */}
                            <div class="hidden lg:flex items-center">
                                <span class={`text-xs font-mono ${isActive ? 'text-emerald-400' : isInactive ? 'text-zinc-600' : 'text-zinc-400'}`} title={user.lastActiveAt ? new Date(user.lastActiveAt).toLocaleString() : 'Nunca'}>
                                    {daysAgo === 0 ? 'Hoy' : daysAgo === 1 ? 'Ayer' : daysAgo > 0 ? `Hace ${daysAgo}d` : 'Nunca'}
                                </span>
                            </div>
                            
                            {/* Listening Time */}
                            <div class="hidden lg:flex items-center">
                                <span class="text-xs text-zinc-300 font-mono font-semibold">{formatTime(user.listeningTime || 0)}</span>
                            </div>
                            
                            {/* Streak */}
                            <div class="hidden lg:flex items-center">
                                <span class="text-xs font-mono">
                                    {(user.currentStreak || 0) > 0 
                                        ? <span class="text-amber-400 font-bold">🔥 {user.currentStreak}</span> 
                                        : <span class="text-zinc-600">-</span>
                                    }
                                </span>
                            </div>
                            
                            {/* Newsletter Status */}
                            <div class="hidden lg:flex items-center">
                                {user.newsletter 
                                    ? <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[0.7rem] font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">✓ Suscrito</span>
                                    : <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[0.7rem] font-semibold bg-red-500/10 text-red-400 border border-red-500/20">✗ No</span>
                                }
                            </div>
                            
                            {/* Actions */}
                            <div class="flex items-center justify-end gap-1.5">
                                <button class="view-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-zinc-400 hover:text-white hover:bg-violet-500/20 hover:border-violet-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(139,92,246,0.2)] transition-all duration-200" data-user={JSON.stringify(user)} aria-label="Ver detalles" title="Ver Detalles">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                </button>
                                <button class="edit-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-zinc-400 hover:text-white hover:bg-sky-500/20 hover:border-sky-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(14,165,233,0.2)] transition-all duration-200" data-user={JSON.stringify(user)} aria-label="Editar usuario" title="Editar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </button>
                                <button class="test-to-me-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-zinc-400 hover:text-indigo-400 hover:bg-indigo-500/20 hover:border-indigo-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(99,102,241,0.2)] transition-all duration-200" data-id={user._id} data-name={user.name} aria-label="Enviarme prueba" title="Enviarme prueba a mí">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                                </button>
                                <button class="warn-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-amber-500/70 hover:text-amber-400 hover:bg-amber-500/20 hover:border-amber-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(245,158,11,0.2)] transition-all duration-200" data-id={user._id} data-name={user.name} aria-label="Enviar advertencia" title="Enviar Advertencia por Email">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                                </button>
                                <button class="audit-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-violet-400 hover:text-violet-300 hover:bg-violet-500/20 hover:border-violet-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(139,92,246,0.2)] transition-all duration-200" data-user={JSON.stringify(user)} aria-label="Audit de actividad" title="Audit de Actividad Detallado">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                                </button>
                                {!isCurrentUser && (
                                    <button class="delete-btn p-2 rounded-lg bg-white/[0.03] border border-white/[0.05] text-zinc-400 hover:text-red-400 hover:bg-red-500/20 hover:border-red-500/40 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(239,68,68,0.2)] transition-all duration-200" data-id={user._id} aria-label="Eliminar usuario" title="Eliminar">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                    </button>
                                )}
                            </div>
                            
                            {/* Mobile extra info row */}
                            <div class="lg:hidden flex flex-wrap items-center gap-2 mt-1">
                                <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[0.65rem] font-bold uppercase ${
                                    user.role === 'owner' ? 'bg-pink-500/15 text-pink-300' : user.role === 'admin' ? 'bg-violet-500/15 text-violet-300' : 'bg-white/[0.04] text-zinc-500'
                                }`}>{user.role}</span>
                                <span class="text-[0.65rem] text-zinc-600">•</span>
                                <span class="text-[0.65rem] text-zinc-500 font-mono">{formatTime(user.listeningTime || 0)}</span>
                                <span class="text-[0.65rem] text-zinc-600">•</span>
                                {user.newsletter 
                                    ? <span class="text-[0.65rem] text-emerald-400">Suscrito</span>
                                    : <span class="text-[0.65rem] text-red-400">No suscrito</span>
                                }
                                {(user.currentStreak || 0) > 0 && (
                                    <>
                                        <span class="text-[0.65rem] text-zinc-600">•</span>
                                        <span class="text-[0.65rem] text-amber-400">🔥{user.currentStreak}</span>
                                    </>
                                )}
                            </div>
                        </div>
                    );
                })}
            </div>

            <!-- No Results -->
            <div id="noResults" class="hidden py-16 text-center">
                <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-zinc-800/60 flex items-center justify-center text-zinc-600">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></svg>
                </div>
                <p class="text-zinc-500 text-sm font-semibold">No se encontraron usuarios</p>
                <p class="text-zinc-600 text-xs mt-1">Intenta cambiar los filtros de búsqueda</p>
            </div>
        </div>
    </div>

