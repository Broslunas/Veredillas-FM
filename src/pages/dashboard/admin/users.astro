                            Historial de Reproducción
                        </h4>
                        <div class="space-y-2 max-h-[400px] overflow-y-auto pr-1 custom-scrollbar" id="viewHistoryList"></div>
                    </div>
                    
                    <!-- Sidebar: Favorites & Clips -->
                    <div class="space-y-6">
                        <div>
                            <h4 class="text-xs uppercase tracking-[0.1em] font-bold text-pink-400 mb-3 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                                Episodios Favoritos
                            </h4>
                            <div class="space-y-1.5 max-h-[200px] overflow-y-auto pr-1 custom-scrollbar" id="viewFavoritesList"></div>
                        </div>
                        <div>
                            <h4 class="text-xs uppercase tracking-[0.1em] font-bold text-sky-400 mb-3 flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect width="15" height="14" x="1" y="5" rx="2" ry="2"/></svg>
                                Clips Guardados (<span id="viewClipsCount">0</span>)
                            </h4>
                            <div class="space-y-1.5 max-h-[200px] overflow-y-auto pr-1 custom-scrollbar" id="viewClipsList"></div>
                        </div>
                    </div>
                </div>

                 </div>
             </div>
         </div>
     </div>
 
