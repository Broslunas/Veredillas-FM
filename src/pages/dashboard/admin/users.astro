    <!-- EDIT USER MODAL -->
    <!-- ═══════════════════════════════════════════════════ -->
    <div id="editUserModal" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300" style="display:none;">
        <div class="modal-inner bg-zinc-950/95 border border-white/10 w-full max-w-[600px] rounded-3xl shadow-[0_0_60px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.05)] max-h-[90vh] overflow-y-auto transform translate-y-5 scale-95 transition-all duration-300">
            <div class="flex items-center justify-between p-6 border-b border-white/[0.06]">
                <h3 class="text-xl font-extrabold bg-gradient-to-r from-white to-violet-400 bg-clip-text text-transparent">Editar Usuario</h3>
                <button id="closeModal" class="w-8 h-8 flex items-center justify-center rounded-lg text-zinc-500 hover:text-white hover:bg-white/10 transition-all">&times;</button>
            </div>
            <form id="editUserForm" class="p-6 space-y-5">
                <input type="hidden" id="editUserId" name="userId" />
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="editName" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Nombre</label>
                        <input type="text" id="editName" name="name" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/10 transition-all" required />
                    </div>
                    <div>
                        <label for="editEmail" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Email</label>
                        <input type="email" id="editEmail" name="email" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/10 transition-all" required />
                    </div>
                </div>

                <div>
                    <label for="editBio" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Bio</label>
                    <textarea id="editBio" name="bio" rows="2" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 focus:ring-2 focus:ring-violet-500/10 transition-all resize-none"></textarea>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="editRole" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Rol</label>
                        <select id="editRole" name="role" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all cursor-pointer">
                            <option value="user">Usuario</option>
                            <option value="admin">Administrador</option>
                            <option value="owner">Dueño</option>
                        </select>
                    </div>
                    <div></div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Tiempo Escuchado</label>
                    <div class="grid grid-cols-3 gap-2">
                        <div class="relative">
                            <input type="number" id="editListeningHours" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all pr-8" placeholder="0" min="0" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[0.65rem] text-zinc-600 font-bold">HRS</span>
                        </div>
                        <div class="relative">
                            <input type="number" id="editListeningMinutes" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all pr-8" placeholder="0" min="0" max="59" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[0.65rem] text-zinc-600 font-bold">MIN</span>
                        </div>
                        <div class="relative">
                            <input type="number" id="editListeningSeconds" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all pr-8" placeholder="0" min="0" max="59" />
                            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-[0.65rem] text-zinc-600 font-bold">SEG</span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label for="editCurrentStreak" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Racha Actual</label>
                        <input type="number" id="editCurrentStreak" name="currentStreak" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all" min="0" />
                    </div>
                    <div>
                        <label for="editMaxStreak" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Racha Máxima</label>
                        <input type="number" id="editMaxStreak" name="maxStreak" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all" min="0" />
                    </div>
                </div>

                <div>
                    <label for="editFavorites" class="block text-xs font-semibold text-zinc-400 mb-1.5 uppercase tracking-wider">Episodios Favoritos <span class="text-zinc-600 normal-case">(slugs separados por coma)</span></label>
                    <input type="text" id="editFavorites" name="favorites" class="w-full px-4 py-2.5 bg-black/40 border border-white/[0.08] rounded-xl text-sm text-white focus:outline-none focus:border-violet-500/50 transition-all" placeholder="ep-1, ep-2" />
                </div>

                <!-- Newsletter Toggle -->
                <label class="flex items-center gap-4 p-4 bg-white/[0.02] border border-white/[0.06] rounded-xl cursor-pointer hover:bg-white/[0.04] transition-colors group">
                    <input type="checkbox" id="editNewsletter" name="newsletter" class="sr-only peer" />
                    <div class="w-11 h-6 bg-zinc-700 rounded-full relative peer-checked:bg-violet-600 transition-colors after:content-[''] after:absolute after:left-[2px] after:top-[2px] after:w-5 after:h-5 after:bg-white after:rounded-full after:shadow-md after:transition-transform peer-checked:after:translate-x-5"></div>
                    <span class="text-sm font-medium text-zinc-300 group-hover:text-white transition-colors">Suscrito a la Newsletter</span>
                </label>

                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" id="cancelEdit" class="px-5 py-2.5 bg-transparent border border-white/10 text-zinc-400 rounded-xl font-semibold text-sm hover:bg-white/[0.05] hover:text-white transition-all">Cancelar</button>
                    <button type="submit" class="px-6 py-2.5 bg-gradient-to-r from-violet-600 to-violet-500 text-white rounded-xl font-bold text-sm shadow-[0_4px_15px_rgba(139,92,246,0.3)] hover:-translate-y-0.5 hover:shadow-[0_8px_25px_rgba(139,92,246,0.5)] hover:brightness-110 transition-all">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>

