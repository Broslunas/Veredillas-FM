    <div id="viewUserModal" class="fixed inset-0 bg-black/60 backdrop-blur-xl z-[100] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300" style="display:none;">
        <div class="modal-inner bg-zinc-950/95 border border-white/10 w-full max-w-[950px] rounded-3xl shadow-[0_0_60px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.05)] max-h-[90vh] overflow-hidden transform translate-y-5 scale-95 transition-all duration-300">
            <div class="flex items-center justify-between p-6 border-b border-white/[0.06]">
