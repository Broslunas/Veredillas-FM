<script>
    declare var Plyr: any;
    import {
        syncPlaybackData,
        recordListen,
    } from "../../services/player/playbackSync";

    const parseTime = (t: string) => {
        const parts = t.split(":").map(Number);
        if (parts.length === 2) return parts[0] * 60 + parts[1];
        if (parts.length === 3)
            return parts[0] * 3600 + parts[1] * 60 + parts[2];
        return 0;
    };

    const initCinemaSection = () => {
        const playerBox = document.getElementById("episode-player-inner");
        if (!playerBox) {
            console.warn("[Cinema] #episode-player-inner not found in DOM.");
            return;
        }

        const audioUrl = playerBox.getAttribute("data-audio-url");
        const spotifyUrl = playerBox.getAttribute("data-spotify-url");
        let videoUrl = playerBox.getAttribute("data-video-url");

        const title = playerBox.getAttribute("data-title") || "";
        const image = playerBox.getAttribute("data-image") || "";
        const author = playerBox.getAttribute("data-author") || "";
        const transStr = playerBox.getAttribute("data-transcription");
        const transcription = transStr ? JSON.parse(transStr) : null;

        // --- HELPER: CONVERT YT URL TO EMBED ---
        const getEmbedVideoUrl = (url: string) => {
            if (!url) return "";
            try {
                const u = new URL(url);
                if (
                    u.hostname.includes("youtube.com") ||
                    u.hostname.includes("youtu.be")
                ) {
                    if (u.pathname.includes("/embed/")) return url;
                    let videoId = "";
                    if (u.hostname.includes("youtu.be")) {
                        videoId = u.pathname.slice(1);
                    } else {
                        videoId = u.searchParams.get("v") || "";
                    }
                    if (videoId)
                        return `https://www.youtube.com/embed/${videoId}?autoplay=0&modestbranding=1&rel=0`;
                }
            } catch (e) {
                console.error("[Cinema] Video URL conversion failed:", e);
            }
            return url;
        };

        // If it's a video, render with Plyr to hide YouTube branding
        const videoContainer = document.getElementById(
            "video-player-container",
        );
        if (videoUrl && !spotifyUrl && videoContainer) {
            const finalVideoUrl = getEmbedVideoUrl(videoUrl);

            videoContainer.innerHTML = `
                <div class="plyr-video-wrapper shadow-2xl rounded-2xl overflow-hidden border border-zinc-800/50 bg-[#0f0f0f] relative group">
                    <div class="plyr__video-embed" id="video-player">
                        <iframe 
                            src="${finalVideoUrl}" 
                            allowfullscreen 
                            allowtransparency 
                            allow="autoplay"
                        ></iframe>
                    </div>

                    <!-- Integrated Mode Switcher for Video -->
                    <div class="video-mode-switcher absolute top-6 right-6 z-50 flex items-center gap-1 bg-black/60 backdrop-blur-xl p-1 rounded-xl border border-white/10 opacity-0 group-hover:opacity-100 transition-all duration-300">
                         <button 
                            class="btn-to-audio px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-white hover:bg-white/5 transition-all"
                         >
                            🎧 Audio
                         </button>
                         <button 
                            class="px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-white/10 text-white shadow-sm border border-white/10 cursor-default"
                            disabled
                         >
                            📺 Video
                         </button>
                    </div>
                </div>
            `;

            // Attach listener for the video-mode switcher button
            const btnToAudio = videoContainer.querySelector(".btn-to-audio");
            if (btnToAudio) {
                btnToAudio.addEventListener("click", () => {
                    document.dispatchEvent(
                        new CustomEvent("veredillas:switch-mode", {
                            detail: { mode: "audio" },
                        }),
                    );
                });
            }

            // Initialize Plyr for Video
            const videoElement = document.getElementById("video-player");
            let player: any = null;
            if (videoElement) {
                player = new Plyr(videoElement, {
                    controls: [
                        "play-large",
                        "restart",
                        "rewind",
                        "play",
                        "fast-forward",
                        "progress",
                        "current-time",
                        "duration",
                        "mute",
                        "volume",
                        "captions",
                        "settings",
                        "pip",
                        "airplay",
                        "fullscreen",
                    ],
                    settings: ["captions", "quality", "speed", "loop"],
                    speed: {
                        selected: 1,
                        options: [0.5, 0.75, 1, 1.25, 1.5, 2, 4],
                    },
                    keyboard: {
                        focused: true,
                        global: true,
                    },
                    tooltips: {
                        controls: true,
                        seek: true,
                    },
                    youtube: {
                        noCookie: true,
                        modestbranding: 1,
                        rel: 0,
                        iv_load_policy: 3,
                        showinfo: 0,
                        autoplay: 0,
                    },
                });

                // Hide placeholder when player is ready
                player.on("ready", () => {
                    const placeholder = videoContainer.querySelector(
                        ".player-placeholder-visual",
                    );
                    if (placeholder) {
                        (placeholder as HTMLElement).style.display = "none";
                    }

                    // --- CHAPTER MARKERS INJECTION ---
                    const sectionsRaw = playerBox.getAttribute("data-sections");
                    if (sectionsRaw && sectionsRaw !== "null") {
                        const sections = JSON.parse(sectionsRaw);

                        const injectMarkers = () => {
                            if (!player.duration || player.duration <= 0) {
                                // Try again if duration not yet available
                                setTimeout(injectMarkers, 1000);
                                return;
                            }

                            const progress =
                                videoContainer.querySelector(".plyr__progress");
                            if (!progress) return;

                            // Remove existing if any
                            progress
                                .querySelectorAll(".plyr-section-marker")
                                .forEach((m) => m.remove());

                            sections.forEach((section: any) => {
                                const time = parseTime(section.time);
                                const percentage =
                                    (time / player.duration) * 100;

                                if (percentage > 100) return;

                                const marker = document.createElement("div");
                                marker.className = "plyr-section-marker";
                                marker.style.left = `${percentage}%`;
                                marker.innerHTML = `
                                    <div class="plyr-marker-tooltip">
                                        <span class="marker-time">${section.time}</span>
                                        <span class="marker-title">${section.title}</span>
                                    </div>
                                `;
                                marker.addEventListener("click", (e) => {
                                    e.stopPropagation();
                                    player.currentTime = time;
                                });
                                progress.appendChild(marker);
                            });
                        };

                        // Check on ready, loadedmetadata and with a small delay
                        setTimeout(injectMarkers, 1000);
                        player.on("loadedmetadata", injectMarkers);
                    }
                });

                // --- VIDEO ANALYTICS ---
                if (playerBox && playerBox.getAttribute("data-slug")) {
                    const slug = playerBox.getAttribute("data-slug")!;
                    const localKey = `vfm-progress-${slug}`;
                    let hasRestored = false;

                    // Get saved progress from localStorage first (instant)
                    let savedProgress = 0;
                    try {
                        savedProgress = parseFloat(
                            localStorage.getItem(localKey) || "0",
                        );
                    } catch (e) {}

                    // Fetch from server and apply when Plyr is ready
                    const applyRestore = () => {
                        if (hasRestored || savedProgress <= 0) return;

                        // Don't restore if near the end
                        if (
                            player.duration > 0 &&
                            savedProgress >= player.duration * 0.95
                        ) {
                            hasRestored = true;
                            return;
                        }

                        player.currentTime = savedProgress;
                        hasRestored = true;
                        // @ts-ignore
                        if (window.showToast) {
                            const mins = Math.floor(savedProgress / 60);
                            const secs = Math.floor(savedProgress % 60);
                            // @ts-ignore
                            window.showToast(
                                `Progreso restaurado en ${mins}:${secs.toString().padStart(2, "0")} 📺`,
                                "info",
                            );
                        }
                    };

                    // Fetch from server (may override local if bigger)
                    fetch(`/api/user/episode-state?slug=${slug}`)
                        .then((res) => res.json())
                        .then((data) => {
                            if (
                                data.savedProgress &&
                                data.savedProgress > 0 &&
                                data.savedProgress >= savedProgress
                            ) {
                                savedProgress = data.savedProgress;
                            }
                            // Try to apply if player is already ready
                            if (player.duration > 0) applyRestore();
                        })
                        .catch((e) =>
                            console.warn("[Video] Failed to fetch state:", e),
                        );

                    // Apply when Plyr signals ready
                    player.on("ready", () => {
                        applyRestore();
                    });

                    // Also try on loadedmetadata and canplay as fallbacks
                    player.on("loadedmetadata", () => applyRestore());
                    player.on("canplay", () => applyRestore());

                    let lastReportedTime = 0;
                    let lastSyncTime = Date.now();
                    let trackingInterval: any = null;

                    const sync = (isClosing = false) => {
                        const now = Date.now();
                        const deltaSeconds = (now - lastSyncTime) / 1000;
                        const currentVideoTime = player.currentTime;

                        // Save to localStorage immediately
                        try {
                            localStorage.setItem(
                                localKey,
                                String(currentVideoTime),
                            );
                        } catch (e) {}

                        if (deltaSeconds > 1 || isClosing) {
                            syncPlaybackData({
                                slug,
                                increment: deltaSeconds,
                                progress: currentVideoTime,
                                duration: player.duration || 0,
                            });
                            lastSyncTime = now;
                            lastReportedTime = currentVideoTime;
                        }
                    };

                    player.on("play", () => {
                        recordListen(slug);
                        lastSyncTime = Date.now();
                        trackingInterval = setInterval(sync, 15000);
                    });

                    player.on("pause", () => {
                        if (trackingInterval) clearInterval(trackingInterval);
                        sync();
                    });

                    player.on("timeupdate", () => {
                        document.dispatchEvent(
                            new CustomEvent("veredillas:audio-timeupdate", {
                                detail: { currentTime: player.currentTime },
                            }),
                        );
                    });

                    player.on("ended", () => {
                        if (trackingInterval) clearInterval(trackingInterval);
                        sync(true);

                        // --- VIDEO END SCREEN ---
                        const nextEpisodesRaw =
                            playerBox.getAttribute("data-next-episodes");
                        if (nextEpisodesRaw) {
                            const nextEpisodes = JSON.parse(nextEpisodesRaw);
                            const overlay = document.createElement("div");
                            overlay.className =
                                "video-end-overlay absolute inset-0 z-[100] bg-black/95 backdrop-blur-2xl flex flex-col items-center justify-center p-6 text-center animate-vfm-fade-in";

                            overlay.innerHTML = `
                                <button class="close-overlay absolute top-4 right-4 text-white/40 hover:text-white transition-colors p-2 hover:bg-white/5 rounded-full">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                                </button>
                                <div class="mb-10">
                                    <h3 class="text-[#8b5cf6] text-[10px] font-black uppercase tracking-[0.4em] mb-3">Video finalizado</h3>
                                    <h2 class="text-3xl font-black text-white tracking-tight">¿Qué quieres ver ahora?</h2>
                                </div>
                                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 w-full max-w-5xl">
                                    ${nextEpisodes
                                        .map(
                                            (ep: any) => `
                                        <a href="/ep/${ep.slug}" class="group/card flex flex-col bg-white/[0.03] border border-white/10 rounded-2xl overflow-hidden hover:border-[#8b5cf6] transition-all duration-500 hover:shadow-[0_20px_40px_-10px_rgba(0,0,0,0.5)] hover:-translate-y-1">
                                            <div class="aspect-video relative overflow-hidden bg-zinc-900/50">
                                                ${
                                                    ep.image
                                                        ? `<img src="${ep.image}" alt="" class="w-full h-full object-cover grayscale opacity-80 group-hover/card:grayscale-0 group-hover/card:opacity-100 group-hover/card:scale-105 transition-all duration-700" />`
                                                        : `<div class="w-full h-full flex items-center justify-center opacity-20"><svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/><line x1="8" x2="16" y1="22" y2="22"/></svg></div>`
                                                }
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60 group-hover/card:opacity-30 transition-opacity"></div>
                                                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/card:opacity-100 transition-all duration-300 scale-90 group-hover/card:scale-100">
                                                    <div class="bg-[#8b5cf6] text-white p-3 rounded-full shadow-2xl shadow-[#8b5cf6]/40">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M7 4v16l13-8z"></path></svg>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="p-5 text-left">
                                                <div class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em] mb-2 flex items-center justify-between">
                                                    <span>T${ep.season} • E${ep.episode}</span>
                                                    ${ep.duration ? `<span class="text-zinc-600">${ep.duration}</span>` : ""}
                                                </div>
                                                <h4 class="text-base font-bold text-white line-clamp-2 leading-snug group-hover/card:text-[#8b5cf6] transition-colors">${ep.title}</h4>
                                            </div>
                                        </a>
                                    `,
                                        )
                                        .join("")}
                                </div>
                                <div class="mt-12">
                                    <button class="replay-btn bg-white/5 hover:bg-white/10 border border-white/10 text-white px-8 py-3 rounded-full text-xs font-black uppercase tracking-widest transition-all flex items-center gap-3 active:scale-95">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                                        Repetir video
                                    </button>
                                </div>
                            `;

                            const videoWrapper = videoContainer.querySelector(
                                ".plyr-video-wrapper",
                            );
                            if (videoWrapper) {
                                videoWrapper.appendChild(overlay);

                                overlay
                                    .querySelector(".close-overlay")
                                    ?.addEventListener("click", () =>
                                        overlay.remove(),
                                    );
                                overlay
                                    .querySelector(".replay-btn")
                                    ?.addEventListener("click", () => {
                                        player.currentTime = 0;
                                        player.play();
                                        overlay.remove();
                                    });
                            }
                        }
                    });

                    // Listen for sync from Audio -> Video
                    document.addEventListener(
                        "veredillas:sync-playback",
                        (e: any) => {
                            const {
                                time,
                                playing,
                                slug: incomingSlug,
                            } = e.detail;
                            if (slug === incomingSlug && player) {
                                player.currentTime = time;
                                if (playing) {
                                    setTimeout(() => player.play(), 500); // Small delay to allow buffer
                                } else {
                                    player.pause();
                                }
                            }
                        },
                    );

                    // Listen for direct seek from Transcript/Chapters -> Video
                    document.addEventListener(
                        "veredillas:audio-seek",
                        (e: any) => {
                            // Only respond if video is NOT hidden
                            if (videoContainer.classList.contains("hidden"))
                                return;

                            const { time } = e.detail;
                            if (player) {
                                player.currentTime = time;
                                // Auto-play on seek for better UX
                                player.play();
                            }
                        },
                    );
                }
            }
        }

        // If it's Spotify, render iframe (Spotify mode usually takes over entirely)
        if (spotifyUrl) {
            let finalUrl = spotifyUrl;
            if (!finalUrl.includes("/embed/")) {
                try {
                    const urlObj = new URL(finalUrl);
                    const segments = urlObj.pathname.split("/").filter(Boolean);
                    if (segments[0] !== "embed")
                        finalUrl = `${urlObj.origin}/embed${urlObj.pathname}`;
                } catch (e) {
                    console.error("[Cinema] Spotify URL processing failed", e);
                }
            }

            playerBox.innerHTML = `
                <div class="spotify-cinema-wrapper relative group">
                    <div class="spotify-cinema py-12 px-2 flex justify-center bg-zinc-950 rounded-2xl">
                        <iframe 
                            style="border-radius:12px" 
                            src="${finalUrl}" 
                            width="100%" 
                            height="352" 
                            frameBorder="0" 
                            allowfullscreen="" 
                            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
                            loading="lazy"
                            class="max-w-4xl w-full"
                        ></iframe>
                    </div>

                    ${
                        videoUrl
                            ? `
                    <!-- Integrated Mode Switcher for Spotify/Audio -->
                    <div class="spotify-mode-switcher absolute top-6 right-6 z-50 flex items-center gap-1 bg-black/60 backdrop-blur-xl p-1 rounded-xl border border-white/10 opacity-0 group-hover:opacity-100 transition-all duration-300">
                         <button 
                            class="px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-white/10 text-white shadow-sm border border-white/10 cursor-default"
                            disabled
                         >
                            🎧 Audio
                         </button>
                         <button 
                            class="btn-to-video px-3 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-white/40 hover:text-white hover:bg-white/5 transition-all"
                         >
                            📺 Vídeo
                         </button>
                    </div>
                    `
                            : ""
                    }
                </div>
             `;

            const btnToVideo = playerBox.querySelector(".btn-to-video");
            if (btnToVideo) {
                btnToVideo.addEventListener("click", () => {
                    document.dispatchEvent(
                        new CustomEvent("veredillas:switch-mode", {
                            detail: { mode: "video" },
                        }),
                    );
                });
            }
            return;
        }

        // Use global variables or fetch them in the handler
    };

    // --- UNIFIED MODE SWITCHER LOGIC ---
    const handleModeSwitch = (e: any) => {
        const requestedMode = e.detail?.mode;

        const videoContainer = document.getElementById(
            "video-player-container",
        );
        const audioContainer = document.getElementById(
            "audio-player-container",
        );
        const playerBox = document.getElementById("episode-player-inner");

        if (!videoContainer || !audioContainer || !playerBox) return;

        const isVideoCurrentlyVisible =
            !videoContainer.classList.contains("hidden");
        const targetMode =
            requestedMode || (isVideoCurrentlyVisible ? "audio" : "video");

        if (targetMode === "audio" && isVideoCurrentlyVisible) {
            // --- SWITCH TO AUDIO ---
            videoContainer.classList.add("hidden");
            audioContainer.classList.remove("hidden");

            // Stop video and BROADCAST time to audio
            const iframe = videoContainer.querySelector("iframe");
            if (iframe) {
                const originalSrc = iframe.src;
                iframe.src = "";
                setTimeout(() => {
                    iframe.src = originalSrc;
                }, 100);
            }
        } else if (targetMode === "video" && !isVideoCurrentlyVisible) {
            // --- SWITCH TO VIDEO ---
            audioContainer.classList.add("hidden");
            videoContainer.classList.remove("hidden");

            // Sync playback state from Audio to Video
            const audio = audioContainer.querySelector("audio");
            if (audio) {
                const time = audio.currentTime;
                const playing = !audio.paused;

                audio.pause();

                // Fire event so Plyr can pick it up
                document.dispatchEvent(
                    new CustomEvent("veredillas:sync-playback", {
                        detail: {
                            time,
                            playing,
                            slug: playerBox.getAttribute("data-slug"),
                        },
                    }),
                );
            }
        }
    };

    // Listen for internal player requests (Added once globally)
    document.addEventListener("veredillas:switch-mode", handleModeSwitch);

    // Runs on standard loads and transitions
    document.addEventListener("DOMContentLoaded", initCinemaSection);
    document.addEventListener("astro:page-load", initCinemaSection);

    // Initial check if script runs AFTER DOMContentLoaded
    if (
        document.readyState === "complete" ||
        document.readyState === "interactive"
    ) {
        initCinemaSection();
    }

    // Cleanup on before-preparation to stop any stray audio if navigating
    document.addEventListener("astro:before-preparation", () => {
        // Only stop the in-page episode audio, not the global persistent player
        const episodeAudio = document.querySelector("#audio-player-container audio, #video-player-container audio");
        if (episodeAudio) {
            (episodeAudio as HTMLAudioElement).pause();
            (episodeAudio as HTMLAudioElement).src = "";
        }
    });
    // Listen for sync requests (e.g. from Video Player)
    document.addEventListener("veredillas:sync-playback", (e: any) => {
        const { time, slug: incomingSlug } = e.detail;
        const playerBox = document.getElementById("episode-player-inner");
        const currentSlug = playerBox?.getAttribute("data-slug");

        if (incomingSlug === currentSlug) {
            const audio = document.querySelector<HTMLAudioElement>("#audio-player-container audio");
            if (audio) {
                audio.currentTime = time;
            }
        }
    });
</script>
