---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';
import SocialShare from '../../components/SocialShare.astro';
import RelatedEpisodes from '../../components/RelatedEpisodes.astro';
import EpisodeParticipants from '../../components/EpisodeParticipants.astro';
import TranscriptionWidget from '../../components/TranscriptionWidget.astro';
import EpisodeSections from '../../components/EpisodeSections.astro';
import EpisodeClips from '../../components/EpisodeClips.astro';
import SidebarWidget from '../../components/SidebarWidget.astro';
import FavoriteButton from '../../components/FavoriteButton.astro';
import EpisodeRating from '../../components/EpisodeRating.astro';

import PremiereCountdown from '../../components/PremiereCountdown.astro';
import LiveChat from '../../components/LiveChat.astro';
import ListenerCount from '../../components/ListenerCount.astro';
import EpisodeActions from '../../components/EpisodeActions.astro';
import CinemaAudioPlayer from '../../components/player/CinemaAudioPlayer.tsx';

export const prerender = true;

export async function getStaticPaths() {
  const episodes = await getCollection('episodios');
  return episodes.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

if (!entry) {
  return Astro.redirect('/404');
}
const { Content } = await entry.render();

const formattedDate = entry.data.pubDate.toLocaleDateString('es-ES', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const isPremiere = entry.data.isPremiere ?? false;
const isUpcoming = isPremiere && (new Date() < entry.data.pubDate);

// Calculate if premiere ended
let hasPremiereEnded = false;
let premiereEndTimeMs = 0;
if (isPremiere && entry.data.duration) {
    const durationStr = entry.data.duration;
    let durationMs = 0;
    
    if (durationStr.toLowerCase().includes('min')) {
        durationMs = parseInt(durationStr) * 60 * 1000;
    } else if (durationStr.includes(':')) {
        const parts = durationStr.split(':').map(Number);
        if (parts.length === 2) durationMs = (parts[0] * 60 + parts[1]) * 1000;
        else if (parts.length === 3) durationMs = (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000;
    }
    
    const premiereEndTime = new Date(entry.data.pubDate.getTime() + durationMs);
    premiereEndTimeMs = premiereEndTime.getTime();
    hasPremiereEnded = new Date() > premiereEndTime;
}


// State definition for static shell
let savedProgress = 0;
let listenedEpisodes: string[] = [];
let favoriteEpisodes: string[] = [];

// --- Schema.org data ---
const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? 'https://veredillasfm.es';
const canonicalEpisodeUrl = `${siteUrl}/ep/${slug}`;
const ogImageUrl = `${siteUrl}/og/${slug}.png`;

// Build PodcastEpisode JSON-LD
const podcastEpisodeSchema = {
    "@context": "https://schema.org",
    "@type": "PodcastEpisode",
    "@id": canonicalEpisodeUrl,
    "url": canonicalEpisodeUrl,
    "name": entry.data.title,
    "description": entry.data.description,
    "datePublished": entry.data.pubDate.toISOString(),
    ...(entry.data.duration ? { "duration": (() => {
        const dur = entry.data.duration!;
        if (dur.includes('?')) return undefined;
        // "37 min" or "37min"
        const minOnly = dur.match(/^(\d+)\s*min/i);
        if (minOnly) return `PT${minOnly[1]}M`;
        // "1h 30min"
        const hourMin = dur.match(/(\d+)\s*h[a-z]*\s*(\d+)?\s*m?/i);
        if (hourMin) return `PT${hourMin[1]}H${hourMin[2] ?? '0'}M`;
        // "MM:SS" or "HH:MM:SS"
        const parts = dur.split(':').map(Number);
        if (parts.length === 2) return `PT${parts[0]}M${parts[1]}S`;
        if (parts.length === 3) return `PT${parts[0]}H${parts[1]}M${parts[2]}S`;
        return undefined;
    })() } : {}),
    "image": entry.data.image ? (entry.data.image.startsWith('http') ? entry.data.image : `${siteUrl}${entry.data.image}`) : ogImageUrl,
    "thumbnailUrl": entry.data.image ? (entry.data.image.startsWith('http') ? entry.data.image : `${siteUrl}${entry.data.image}`) : ogImageUrl,
    ...(entry.data.audioUrl ? { "associatedMedia": { "@type": "MediaObject", "contentUrl": entry.data.audioUrl } } : {}),
    ...(entry.data.spotifyUrl ? { "sameAs": [entry.data.spotifyUrl] } : {}),
    "partOfSeries": {
        "@type": "PodcastSeries",
        "@id": siteUrl,
        "name": "Veredillas FM",
        "description": "El podcast oficial del IES Veredillas. Entrevistas exclusivas, noticias del instituto, cultura estudiantil y mucho más.",
        "url": siteUrl,
        "image": `${siteUrl}/logo.webp`
    },
    "episodeNumber": entry.data.episode,
    ...(entry.data.season !== undefined ? { "partOfSeason": { "@type": "PodcastSeason", "seasonNumber": entry.data.season } } : {}),
    "author": { "@type": "Person", "name": entry.data.author },
    "publisher": {
        "@type": "Organization",
        "name": "Veredillas FM",
        "url": siteUrl,
        "logo": { "@type": "ImageObject", "url": `${siteUrl}/logo.webp` }
    },
    "keywords": entry.data.tags?.join(', '),
    "inLanguage": "es-ES"
};

const timeToSeconds = (timeStr: string) => {
  const parts = timeStr.split(':').map(Number);
  if (parts.length === 2) return parts[0] * 60 + parts[1];
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  return 0;
};

const formattedTranscription = entry.data.transcription?.map(t => ({
  ...t,
  time: timeToSeconds(t.time)
}));

---

<Layout 
  title={entry.data.title} 
  description={entry.data.description}
  image={`/og/${slug}.png`}
  imageAlt={entry.data.title}
  type="article"
  publishedTime={entry.data.pubDate.toISOString()}
  author={entry.data.author}
  tags={[`Temporada ${entry.data.season}`, `Episodio ${entry.data.episode}`, 'podcast', 'audio']}
  canonicalURL={canonicalEpisodeUrl}
>
    <!-- Schema.org PodcastEpisode Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(podcastEpisodeSchema)} slot="head" />
    
    <div class="cinema-layout container">
        <main class="main-content">
            
            {entry.data.warningMessage && (
                <div class="warning-banner glass-panel p-5 mb-8 border-l-4 border-amber-500/50 flex items-start gap-4 section-fade">
                    <div class="bg-amber-500/10 p-2.5 rounded-xl border border-amber-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
                            <path d="M12 9v4"/>
                            <path d="M12 17h.01"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-500/80 mb-1.5">Aviso de contenido / Nota importante</p>
                        <p class="text-zinc-100 text-[15px] leading-relaxed font-medium">
                            {entry.data.warningMessage}
                        </p>
                    </div>
                </div>
            )}
            <!-- 1. THE PLAYER AREA -->
            <section class="player-section section-fade">
                <div class="player-wrapper shadow-2xl relative">
                    {/* 1. SWITCHER BUTTON (Overlay) - Moved outside dynamic container for persistence */}
                    {entry.data.videoUrl && entry.data.audioUrl && (
                        <div class="player-mode-switch absolute top-6 right-6 z-[60]">
                                <button 
                                    id="btn-switch-mode"
                                    class="group/btn flex items-center gap-2.5 px-6 py-3 rounded-full bg-black/80 hover:bg-[#8b5cf6] border border-white/10 hover:border-white/20 transition-all text-[11px] font-black uppercase tracking-widest text-white backdrop-blur-xl shadow-2xl scale-95 hover:scale-100 active:scale-95"
                                >
                                    <span class="mode-icon text-lg transition-transform group-hover/btn:rotate-12">🎧</span>
                                    <span class="mode-text">Escuchar Episodio</span>
                                </button>
                        </div>
                    )}

                    {isUpcoming && (
                        <div id="premiere-countdown-wrapper">
                            <PremiereCountdown targetDate={entry.data.pubDate} title={entry.data.title} />
                        </div>
                    )}
                    
                    <div id="premiere-player-wrapper" class:list={{"hidden": isUpcoming}} style={isUpcoming ? "display:none;" : ""}>
                         <!-- We'll use a direct player placement here -->                         <div 
                             id="episode-player-inner" 
                             class="cinema-player-box group"
                             data-audio-url={entry.data.audioUrl}
                             data-spotify-url={entry.data.spotifyUrl}
                             data-title={entry.data.title}
                             data-image={entry.data.image}
                             data-author={entry.data.author}
                             data-slug={entry.slug}
                             data-is-premiere={isPremiere}
                             data-video-url={entry.data.videoUrl}
                             data-transcription={entry.data.transcription ? JSON.stringify(entry.data.transcription) : null}
                         >

                            {/* Standard Audio Player Section (Hidden if video mode by default) */}
                            <div id="audio-player-container" class={entry.data.videoUrl ? "hidden" : "block"}>
                                <CinemaAudioPlayer 
                                    client:load
                                    audioUrl={entry.data.audioUrl || ''}
                                    title={entry.data.title || ''}
                                    cover={entry.data.image || ''}
                                    author={entry.data.author || 'Veredillas FM'}
                                    transcription={formattedTranscription}
                                    slug={entry.slug}
                                />
                            </div>

                            {/* Video Player Section */}
                            <div id="video-player-container" class={!entry.data.videoUrl ? "hidden" : "block"}>
                                 {/* Filled by JS */}
                            </div>
                            
                            {!entry.data.audioUrl && !entry.data.spotifyUrl && !entry.data.videoUrl && (
                                <div class="player-skeleton bg-zinc-900 rounded-xl aspect-video flex items-center justify-center border border-zinc-800">
                                    <span class="text-zinc-500 font-medium">Contenido no disponible</span>
                                </div>
                            )}
                         </div>

                    </div>
                </div>

                <!-- Info Header (Below Player) -->
                <header class="player-info py-6">
                    <h1 class="text-2xl md:text-3xl font-black mb-2 tracking-tight">{entry.data.title}</h1>
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div class="author-meta flex items-center gap-3">
                            <img src="/logo.webp" alt="Veredillas FM" class="w-10 h-10 rounded-full border border-zinc-800" />
                            <div>
                                <p class="font-bold text-zinc-100">{entry.data.author}</p>
                                <p class="text-xs text-zinc-500">{formattedDate}</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                             <ListenerCount onlyCurrentPath={true} />
                             <EpisodeRating slug={entry.slug} />
                             <FavoriteButton episodeSlug={entry.slug} />
                        </div>
                    </div>
                </header>
            </section>


            <!-- 2. DESCRIPTION / CONTENT AREA -->
            <section class="description-section glass-panel p-6 mb-8">
                <div class="flex items-center justify-between mb-4 border-b border-zinc-800 pb-4">
                    <span class="text-sm font-bold uppercase tracking-wider text-zinc-400">Descripción</span>
                    <EpisodeActions 
                        title={entry.data.title} 
                        audioUrl={entry.data.audioUrl} 
                        image={entry.data.image} 
                        slug={entry.slug} 
                        guests={entry.data.participants}
                        duration={entry.data.duration}
                    />
                </div>
                
                <div class="content-body prose prose-invert max-w-none mb-8">
                    <Content />
                </div>

                <!-- Extras inline for Cinema mode -->
                <div class="mt-8 pt-8 border-t border-zinc-800">
                    <EpisodeSections sections={entry.data.sections} />
                    <TranscriptionWidget transcription={entry.data.transcription} />
                </div>
            </section>

            <!-- 3. COMMENTS AREA -->
            <section id="comments-wrapper" class="comments-section mb-20">
                <div class="flex items-center gap-4 mb-8">
                    <h2 class="text-xl font-black">Comentarios</h2>
                </div>
                {isPremiere && !hasPremiereEnded ? (
                    <div class="chat-integration mb-8">
                         <LiveChat slug={entry.slug} />
                    </div>
                ) : (
                    <Comments slug={entry.slug} />
                )}
            </section>
        </main>

        <!-- SIDEBAR -->
        <aside class="sidebar-column">
             <div class="sticky top-24 space-y-6">
                 <EpisodeParticipants participants={entry.data.participants} />
                 
                 <SidebarWidget title="Detalles" isOpen={true}>
                    <ul class="details-list text-sm">
                        <li class="flex justify-between py-2 border-b border-zinc-800/50">
                            <span class="text-zinc-500">Temporada</span>
                            <span class="font-bold">{entry.data.season}</span>
                        </li>
                        <li class="flex justify-between py-2 border-b border-zinc-800/50">
                            <span class="text-zinc-500">Episodio</span>
                            <span class="font-bold">{entry.data.episode}</span>
                        </li>
                        <li class="flex justify-between py-2 border-b border-zinc-800/50">
                            <span class="text-zinc-500">Duración</span>
                            <span class="font-bold uppercase">{entry.data.duration}</span>
                        </li>
                        {entry.data.tags && (
                            <li class="pt-4">
                                <div class="flex flex-wrap gap-2">
                                    {entry.data.tags.map(tag => (
                                        <a href={`/ep?tag=${tag}`} class="tag-chip text-[10px] font-bold uppercase px-2 py-1 bg-zinc-800 hover:bg-primary transition-colors rounded">#{tag}</a>
                                    ))}
                                </div>
                            </li>
                        )}
                    </ul>
                 </SidebarWidget>

                 <EpisodeClips clips={entry.data.clips} />

                 <!-- Sidebar Discovery Widgets would go here -->
                 <div class="related-wrapper pt-4">
                    <h3 class="text-sm font-black uppercase tracking-[0.2em] text-zinc-500 mb-4">Siguiente episodio</h3>
                    <RelatedEpisodes 
                        currentSlug={entry.slug} 
                        tags={entry.data.tags} 
                        limit={4}
                    />
                 </div>
             </div>
        </aside>
    </div>
</Layout>

<style>
    .cinema-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 3rem;
        padding-top: 1rem;
        max-width: 1600px;
        margin: 0 auto;
    }

    @media (max-width: 1280px) {
        .cinema-layout {
            grid-template-columns: minmax(0, 1fr) 320px;
            gap: 2rem;
        }
    }

    @media (max-width: 1024px) {
        .cinema-layout {
            grid-template-columns: 1fr;
        }
        .sidebar-column {
            order: 2;
        }
        .sidebar-column .sticky {
            position: relative;
            top: 0;
        }
    }

    .player-wrapper {
        background: #000;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .cinema-player-box {
        min-height: 200px;
        width: 100%;
        position: relative;
    }

    /* Content Body Typography */
    .content-body {
        line-height: 1.8;
        font-size: 1.05rem;
        color: #d4d4d8;
    }

    .content-body :global(h2) {
        font-weight: 900;
        letter-spacing: -0.02em;
        margin-top: 2rem;
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .glass-panel {
        background: rgba(24, 24, 27, 0.4);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.03);
        border-radius: 20px;
    }

    .tag-chip {
        color: #a1a1aa;
    }

    .tag-chip:hover {
        color: white;
    }

    /* Animation on enter */
    .section-fade {
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    declare var Plyr: any;
    import { syncPlaybackData, recordListen } from '../../services/player/playbackSync';

    const initCinemaSection = () => {
        const playerBox = document.getElementById('episode-player-inner');
        if (!playerBox) {
            console.warn('[Cinema] #episode-player-inner not found in DOM.');
            return;
        }

        const audioUrl = playerBox.getAttribute('data-audio-url');
        const spotifyUrl = playerBox.getAttribute('data-spotify-url');
        let videoUrl = playerBox.getAttribute('data-video-url');
        
        console.log('[Cinema] Initializing Player Section:', { audioUrl, spotifyUrl, videoUrl });

        const title = playerBox.getAttribute('data-title') || '';
        const image = playerBox.getAttribute('data-image') || '';
        const author = playerBox.getAttribute('data-author') || '';
        const transStr = playerBox.getAttribute('data-transcription');
        const transcription = transStr ? JSON.parse(transStr) : null;

        // --- HELPER: CONVERT YT URL TO EMBED ---
        const getEmbedVideoUrl = (url: string) => {
            if (!url) return '';
            try {
                const u = new URL(url);
                if (u.hostname.includes('youtube.com') || u.hostname.includes('youtu.be')) {
                    if (u.pathname.includes('/embed/')) return url;
                    let videoId = '';
                    if (u.hostname.includes('youtu.be')) {
                        videoId = u.pathname.slice(1);
                    } else {
                        videoId = u.searchParams.get('v') || '';
                    }
                    if (videoId) return `https://www.youtube.com/embed/${videoId}?autoplay=0&modestbranding=1&rel=0`;
                }
            } catch(e) {
                console.error('[Cinema] Video URL conversion failed:', e);
            }
            return url;
        };

        // If it's a video, render with Plyr to hide YouTube branding
        const videoContainer = document.getElementById('video-player-container');
        if (videoUrl && !spotifyUrl && videoContainer) {
            const finalVideoUrl = getEmbedVideoUrl(videoUrl);
            console.log('[Cinema] Rendering Video Mode with Plyr:', finalVideoUrl);
            
            videoContainer.innerHTML = `
                <div class="plyr-video-wrapper shadow-2xl rounded-2xl overflow-hidden border border-zinc-800/50 bg-[#0f0f0f]">
                    <div class="plyr__video-embed" id="video-player">
                        <iframe 
                            src="${finalVideoUrl}" 
                            allowfullscreen 
                            allowtransparency 
                            allow="autoplay"
                        ></iframe>
                    </div>
                </div>
            `;

            // Initialize Plyr for Video
            const videoElement = document.getElementById('video-player');
            if (videoElement) {
                const player = new Plyr(videoElement, {
                    controls: [
                        'play-large', 'play', 'progress', 'current-time', 
                        'mute', 'volume', 'captions', 'settings', 'pip', 'airplay', 'fullscreen'
                    ],
                    youtube: { 
                        noCookie: true, 
                        modestbranding: 1, 
                        rel: 0, 
                        iv_load_policy: 3, 
                        showinfo: 0 
                    }
                });

                // --- VIDEO ANALYTICS ---
                if (playerBox && playerBox.getAttribute('data-slug')) {
                    const slug = playerBox.getAttribute('data-slug')!;
                    
                    // FETCH SAVED PROGRESS
                    fetch(`/api/user/episode-state?slug=${slug}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.savedProgress && data.savedProgress > 0) {
                                console.log(`[Video] Restoring progress: ${data.savedProgress}s`);
                                player.currentTime = data.savedProgress;
                                // @ts-ignore
                                if (window.showToast) window.showToast("He restaurado tu progreso del vídeo 📺", "info");
                            }
                        })
                        .catch(e => console.warn('[Video] Failed to fetch state:', e));

                    let lastReportedTime = 0;
                    let lastSyncTime = Date.now();
                    let trackingInterval: any = null;

                    const sync = (isClosing = false) => {
                        const now = Date.now();
                        const deltaSeconds = (now - lastSyncTime) / 1000;
                        const currentVideoTime = player.currentTime;
                        
                        if (deltaSeconds > 1 || isClosing) {
                             syncPlaybackData({
                                slug,
                                increment: deltaSeconds,
                                progress: currentVideoTime,
                                duration: player.duration || 0
                             });
                             lastSyncTime = now;
                             lastReportedTime = currentVideoTime;
                        }
                    };

                    player.on('play', () => {
                        recordListen(slug);
                        lastSyncTime = Date.now();
                        trackingInterval = setInterval(sync, 15000);
                    });

                    player.on('pause', () => {
                        if (trackingInterval) clearInterval(trackingInterval);
                        sync();
                    });

                    player.on('ended', () => {
                        if (trackingInterval) clearInterval(trackingInterval);
                        sync(true);
                    });
                }
            }
        }

        // If it's Spotify, render iframe (Spotify mode usually takes over entirely)
        if (spotifyUrl) {
             console.log('[Cinema] Rendering Spotify Mode:', spotifyUrl);
             let finalUrl = spotifyUrl;
             if (!finalUrl.includes('/embed/')) {
                  try {
                      const urlObj = new URL(finalUrl);
                      const segments = urlObj.pathname.split('/').filter(Boolean);
                      if (segments[0] !== 'embed') finalUrl = `${urlObj.origin}/embed${urlObj.pathname}`;
                  } catch(e) { console.error('[Cinema] Spotify URL processing failed', e); }
             }

             playerBox.innerHTML = `
                <div class="spotify-cinema py-12 px-2 flex justify-center bg-zinc-950 rounded-2xl">
                    <iframe 
                        style="border-radius:12px" 
                        src="${finalUrl}" 
                        width="100%" 
                        height="352" 
                        frameBorder="0" 
                        allowfullscreen="" 
                        allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" 
                        loading="lazy"
                        class="max-w-4xl w-full"
                    ></iframe>
                </div>
             `;
             return;
        }

        // --- MODE SWITCHER LOGIC ---
        const btnSwitch = document.getElementById('btn-switch-mode');
        const audioContainer = document.getElementById('audio-player-container');

        if (btnSwitch && audioContainer && videoContainer) {
            console.log('[Cinema] Switcher logic ready: Attaching event listener.');
            
            // Remove any existing listeners if this runs multiple times
            const newBtn = btnSwitch.cloneNode(true) as HTMLElement;
            btnSwitch.parentNode?.replaceChild(newBtn, btnSwitch);

            newBtn.addEventListener('click', (e) => {
                e.preventDefault();
                const isVideoCurrentlyVisible = !videoContainer.classList.contains('hidden');
                console.log('[Cinema] Switching Mode. Currently showing video:', isVideoCurrentlyVisible);
                
                if (isVideoCurrentlyVisible) {
                    // --- SWITCH TO AUDIO ---
                    videoContainer.classList.add('hidden');
                    audioContainer.classList.remove('hidden');
                    newBtn.innerHTML = '<span class="mode-icon text-sm">📺</span> <span class="mode-text">Ver Video</span>';
                    
                    // Stop video if playing
                    const iframe = videoContainer.querySelector('iframe');
                    if (iframe) {
                        const originalSrc = iframe.src;
                        iframe.src = ''; 
                        setTimeout(() => { iframe.src = originalSrc; }, 100);
                    }
                } else {
                    // --- SWITCH TO VIDEO ---
                    audioContainer.classList.add('hidden');
                    videoContainer.classList.remove('hidden');
                    newBtn.innerHTML = '<span class="mode-icon text-sm">🎧</span> <span class="mode-text">Escuchar Episodio</span>';
                    
                    // Stop audio if playing
                    const audio = audioContainer.querySelector('audio');
                    if (audio) {
                        console.log('[Cinema] Pausing background audio.');
                        audio.pause();
                    }
                }
            });
        } else if (btnSwitch) {
            console.warn('[Cinema] Mode switcher elements missing:', { audioContainer: !!audioContainer, videoContainer: !!videoContainer });
        }
    };

    // Runs on standard loads and transitions
    document.addEventListener('DOMContentLoaded', initCinemaSection);
    document.addEventListener('astro:page-load', initCinemaSection);

    // Initial check if script runs AFTER DOMContentLoaded
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
        initCinemaSection();
    }

    // Cleanup on before-preparation to stop any stray audio if navigating
    document.addEventListener('astro:before-preparation', () => {
         const audio = document.querySelector('audio');
         if (audio) {
             audio.pause();
             audio.src = '';
         }
    });
</script>
