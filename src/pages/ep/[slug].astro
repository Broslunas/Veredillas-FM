---
import { getCollection } from "astro:content";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Comments from "../../components/Comments.astro";
import SocialShare from "../../components/SocialShare.astro";
import RelatedEpisodes from "../../components/RelatedEpisodes.astro";
import EpisodeParticipants from "../../components/EpisodeParticipants.astro";
import TranscriptionWidget from "../../components/TranscriptionWidget.astro";
import EpisodeSections from "../../components/EpisodeSections.astro";
import EpisodeClips from "../../components/EpisodeClips.astro";
import SidebarWidget from "../../components/SidebarWidget.astro";
import FavoriteButton from "../../components/FavoriteButton.astro";
import EpisodeRating from "../../components/EpisodeRating.astro";
import LikeDislikeGroup from "../../components/LikeDislikeGroup.astro";
import PlaylistManager from "../../components/PlaylistManager.astro";
import PlaylistSidebar from "../../components/PlaylistSidebar.astro";

import PremiereCountdown from "../../components/PremiereCountdown.astro";
import LiveChat from "../../components/LiveChat.astro";
import ListenerCount from "../../components/ListenerCount.astro";
import EpisodeActions from "../../components/EpisodeActions.astro";
import CinemaAudioPlayer from "../../components/player/CinemaAudioPlayer.tsx";
import EpisodeQuiz from "../../components/EpisodeQuiz.tsx";
import QuizModal from "../../components/QuizModal.tsx";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

export const prerender = true;

export async function getStaticPaths() {
    const episodes = await getCollection("episodios");
    return episodes.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;

if (!entry) {
    return Astro.redirect("/404");
}
const { Content } = await entry.render();

const formattedDate = entry.data.pubDate.toLocaleDateString("es-ES", {
    year: "numeric",
    month: "long",
    day: "numeric",
});

const isPremiere = entry.data.isPremiere ?? false;
const isUpcoming = isPremiere && new Date() < entry.data.pubDate;

// Calculate if premiere ended
let hasPremiereEnded = false;
let premiereEndTimeMs = 0;
if (isPremiere && entry.data.duration) {
    const durationStr = entry.data.duration;
    let durationMs = 0;

    if (durationStr.toLowerCase().includes("min")) {
        durationMs = parseInt(durationStr) * 60 * 1000;
    } else if (durationStr.includes(":")) {
        const parts = durationStr.split(":").map(Number);
        if (parts.length === 2) durationMs = (parts[0] * 60 + parts[1]) * 1000;
        else if (parts.length === 3)
            durationMs = (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000;
    }

    const premiereEndTime = new Date(entry.data.pubDate.getTime() + durationMs);
    premiereEndTimeMs = premiereEndTime.getTime();
    hasPremiereEnded = new Date() > premiereEndTime;
}

// State definition for static shell
let savedProgress = 0;
let listenedEpisodes: string[] = [];
let favoriteEpisodes: string[] = [];

// --- Schema.org data ---
const siteUrl =
    Astro.site?.href?.replace(/\/$/, "") ?? "https://www.veredillasfm.es";
const canonicalEpisodeUrl = `${siteUrl}/ep/${slug}`;
const ogImageUrl = `${siteUrl}/og/${slug}.png`;
const relativeOgImageUrl = `/og/${slug}.png`;

// Build PodcastEpisode JSON-LD
const podcastEpisodeSchema = {
    "@context": "https://schema.org",
    "@type": "PodcastEpisode",
    "@id": canonicalEpisodeUrl,
    url: canonicalEpisodeUrl,
    name: entry.data.title,
    description: entry.data.description,
    datePublished: entry.data.pubDate.toISOString(),
    ...(entry.data.duration
        ? {
              duration: (() => {
                  const dur = entry.data.duration!;
                  if (dur.includes("?")) return undefined;
                  // "37 min" or "37min"
                  const minOnly = dur.match(/^(\d+)\s*min/i);
                  if (minOnly) return `PT${minOnly[1]}M`;
                  // "1h 30min"
                  const hourMin = dur.match(/(\d+)\s*h[a-z]*\s*(\d+)?\s*m?/i);
                  if (hourMin) return `PT${hourMin[1]}H${hourMin[2] ?? "0"}M`;
                  // "MM:SS" or "HH:MM:SS"
                  const parts = dur.split(":").map(Number);
                  if (parts.length === 2) return `PT${parts[0]}M${parts[1]}S`;
                  if (parts.length === 3)
                      return `PT${parts[0]}H${parts[1]}M${parts[2]}S`;
                  return undefined;
              })(),
          }
        : {}),
    image: entry.data.image
        ? entry.data.image.startsWith("http")
            ? entry.data.image
            : `${siteUrl}${entry.data.image}`
        : ogImageUrl,
    thumbnailUrl: entry.data.image
        ? entry.data.image.startsWith("http")
            ? entry.data.image
            : `${siteUrl}${entry.data.image}`
        : ogImageUrl,
    ...(entry.data.audioUrl
        ? {
              associatedMedia: {
                  "@type": "MediaObject",
                  contentUrl: entry.data.audioUrl,
              },
          }
        : {}),
    ...(entry.data.spotifyUrl ? { sameAs: [entry.data.spotifyUrl] } : {}),
    partOfSeries: {
        "@type": "PodcastSeries",
        "@id": siteUrl,
        name: "Veredillas FM",
        description:
            "El podcast oficial del IES Veredillas. Entrevistas exclusivas, noticias del instituto, cultura estudiantil y mucho más.",
        url: siteUrl,
        image: `${siteUrl}/logo.webp`,
    },
    episodeNumber: entry.data.episode,
    ...(entry.data.season !== undefined
        ? {
              partOfSeason: {
                  "@type": "PodcastSeason",
                  seasonNumber: entry.data.season,
              },
          }
        : {}),
    author: { "@type": "Person", name: entry.data.author },
    publisher: {
        "@type": "Organization",
        name: "Veredillas FM",
        url: siteUrl,
        logo: { "@type": "ImageObject", url: `${siteUrl}/logo.webp` },
    },
    keywords: entry.data.tags?.join(", "),
    inLanguage: "es-ES",
};

const timeToSeconds = (timeStr: string) => {
    const parts = timeStr.split(":").map(Number);
    if (parts.length === 2) return parts[0] * 60 + parts[1];
    if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
    return 0;
};

const formattedTranscription = entry.data.transcription?.map((t) => ({
    ...t,
    time: timeToSeconds(t.time),
}));

const participantsSlugs = entry.data.participants || [];
const allGuests = await getCollection("guests");
const episodeGuests = allGuests.filter((guest) =>
    participantsSlugs.includes(guest.data.name),
);

// --- Next episodes logic for the end screen ---
const allEpisodes = await getCollection("episodios");
const now = new Date();
const candidates = allEpisodes
    .filter((ep) => ep.slug !== slug && ep.data.pubDate <= now)
    .map((ep) => {
        const episodeTags = ep.data.tags || [];
        const contextMatches = episodeTags.filter((t) =>
            entry.data.tags?.includes(t),
        ).length;
        return {
            ep,
            score: contextMatches * 3,
            date: ep.data.pubDate.valueOf(),
        };
    });

candidates.sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return b.date - a.date;
});

const nextEpisodes = candidates.slice(0, 3).map((c) => ({
    slug: c.ep.slug,
    title: c.ep.data.title,
    image: c.ep.data.image,
    author: c.ep.data.author,
    duration: c.ep.data.duration,
    season: c.ep.data.season,
    episode: c.ep.data.episode,
}));
---

<Layout
    title={entry.data.title}
    description={entry.data.description}
    image={`/og/${slug}.png`}
    imageAlt={entry.data.title}
    type="article"
    publishedTime={entry.data.pubDate.toISOString()}
    author={entry.data.author}
    tags={[
        `Temporada ${entry.data.season}`,
        `Episodio ${entry.data.episode}`,
        "podcast",
        "audio",
    ]}
    canonicalURL={canonicalEpisodeUrl}
>
    <!-- Schema.org PodcastEpisode Structured Data -->
    <!-- Global player sync: register this episode so the persistent bar reflects it -->
    {entry.data.audioUrl && !isUpcoming && (
        <script is:inline
            data-audio-url={entry.data.audioUrl}
            data-title={entry.data.title}
            data-author={entry.data.author}
            data-cover={entry.data.image || '/logo.webp'}
            data-slug={entry.slug}
            data-href={`/ep/${entry.slug}`}
        >
            (function() {
                var s = document.currentScript;
                var detail = {
                    audioUrl: s.dataset.audioUrl,
                    title: s.dataset.title,
                    author: s.dataset.author,
                    cover: s.dataset.cover,
                    slug: s.dataset.slug,
                    href: s.dataset.href,
                    autoplay: false, // don't auto-play; user controls the in-page player
                };
                // Fire immediately or after page-load
                function fire() {
                    document.dispatchEvent(new CustomEvent('veredillas:play-episode', { detail: detail }));
                }
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', fire, { once: true });
                } else {
                    fire();
                }
            })();
        </script>
    )}
    <script
        type="application/ld+json"
        set:html={JSON.stringify(podcastEpisodeSchema)}
        slot="head"
    />

    <div class="cinema-layout container">
        <Breadcrumbs className="col-span-full mb-4" customLabel={entry.data.title} />
        {
            isPremiere && (
                /* 0. PREMIERE STAGE (Player + Chat side-by-side)
                   Always rendered in HTML; client JS shows/hides based on real-time premiere end */
                <div
                    id="premiere-stage-block"
                    class="premiere-stage section-fade"
                    style={hasPremiereEnded ? "display:none;" : ""}
                >
                    <div class="player-stage-wrapper shadow-2xl relative">
                        {
                            isUpcoming && (
                                <div id="premiere-countdown-wrapper">
                                    <PremiereCountdown
                                        targetDate={entry.data.pubDate}
                                        title={entry.data.title}
                                    />
                                </div>
                            )
                        }

                        <div
                            id="premiere-player-wrapper"
                            class:list={{ hidden: isUpcoming }}
                            style={isUpcoming ? "display:none;" : ""}
                        >
                            <div
                                id="episode-player-inner"
                                class="cinema-player-box group"
                                data-audio-url={entry.data.audioUrl}
                                data-spotify-url={entry.data.spotifyUrl}
                                data-title={entry.data.title}
                                data-image={entry.data.image}
                                data-author={entry.data.author}
                                data-slug={entry.slug}
                                data-is-premiere={isPremiere}
                                data-video-url={entry.data.videoUrl}
                                data-transcription={entry.data.transcription
                                    ? JSON.stringify(entry.data.transcription)
                                    : null}
                                data-sections={entry.data.sections
                                    ? JSON.stringify(entry.data.sections)
                                    : null}
                                data-next-episodes={JSON.stringify(nextEpisodes)}
                            >
                                <div id="audio-player-container" class={entry.data.videoUrl ? "hidden" : "block relative"}>
                                    <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0f0f0f] rounded-2xl flex items-center justify-center overflow-hidden border border-white/5">
                                        <div class="loader-vfm flex flex-col items-center gap-4">
                                            <div class="loader-spinner"></div>
                                            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Sintonizando...</span>
                                        </div>
                                    </div>
                                    <CinemaAudioPlayer
                                        client:load
                                        audioUrl={entry.data.audioUrl || ""}
                                        title={entry.data.title || ""}
                                        cover={entry.data.image || ""}
                                        author={entry.data.author || "Veredillas FM"}
                                        transcription={formattedTranscription}
                                        slug={entry.slug}
                                        videoUrl={entry.data.videoUrl}
                                        sections={entry.data.sections}
                                        nextEpisodes={nextEpisodes}
                                    />
                                </div>

                                <div id="video-player-container" class={!entry.data.videoUrl ? "hidden" : "block relative"}>
                                    <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0a0a0a] rounded-2xl flex items-center justify-center border border-white/5">
                                        <div class="loader-vfm flex flex-col items-center gap-4">
                                            <div class="loader-spinner !border-t-red-500"></div>
                                            <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Iniciando Video...</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="chat-stage-wrapper">
                        <LiveChat slug={entry.slug} />
                    </div>
                </div>
            )
        }

        <main class="main-content" style="overflow-x: hidden; min-width: 0;">
            {
                entry.data.warningMessage && (
                    <div class="warning-banner glass-panel p-5 mb-8 border-l-4 border-amber-500/50 flex items-start gap-4 section-fade">
                        <div class="bg-amber-500/10 p-2.5 rounded-xl border border-amber-500/20">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                class="w-6 h-6 text-amber-500"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
                                <path d="M12 9v4" />
                                <path d="M12 17h.01" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-xs font-black uppercase tracking-[0.2em] text-amber-500/80 mb-1.5">
                                Aviso de contenido / Nota importante
                            </p>
                            <p class="text-zinc-100 text-[15px] leading-relaxed font-medium">
                                {entry.data.warningMessage}
                            </p>
                        </div>
                    </div>
                )
            }
            {
                isPremiere ? (
                    /* 1. THE PLAYER AREA (Post-premiere, only for isPremiere episodes)
                       Always rendered; client JS shows it when premiere has ended */
                    <section
                        id="post-premiere-player-block"
                        class="player-section section-fade"
                        style={!hasPremiereEnded ? "display:none;" : ""}
                    >
                        <div class="player-wrapper shadow-2xl relative">
                            <div
                                id="static-player-wrapper"
                                style=""
                            >
                                <div
                                    id="episode-player-inner-post"
                                    class="cinema-player-box group"
                                    data-audio-url={entry.data.audioUrl}
                                    data-spotify-url={entry.data.spotifyUrl}
                                    data-title={entry.data.title}
                                    data-image={entry.data.image}
                                    data-author={entry.data.author}
                                    data-slug={entry.slug}
                                    data-is-premiere={isPremiere}
                                    data-video-url={entry.data.videoUrl}
                                    data-transcription={entry.data.transcription
                                        ? JSON.stringify(entry.data.transcription)
                                        : null}
                                    data-sections={entry.data.sections
                                        ? JSON.stringify(entry.data.sections)
                                        : null}
                                    data-next-episodes={JSON.stringify(nextEpisodes)}
                                >
                                    <div id="audio-player-container-post" class={entry.data.videoUrl ? "hidden" : "block relative"}>
                                        <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0f0f0f] rounded-2xl flex items-center justify-center overflow-hidden border border-white/5">
                                            <div class="loader-vfm flex flex-col items-center gap-4">
                                                <div class="loader-spinner"></div>
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Sintonizando...</span>
                                            </div>
                                        </div>
                                        <CinemaAudioPlayer
                                            client:load
                                            audioUrl={entry.data.audioUrl || ""}
                                            title={entry.data.title || ""}
                                            cover={entry.data.image || ""}
                                            author={entry.data.author || "Veredillas FM"}
                                            transcription={formattedTranscription}
                                            slug={entry.slug}
                                            videoUrl={entry.data.videoUrl}
                                            sections={entry.data.sections}
                                            nextEpisodes={nextEpisodes}
                                        />
                                    </div>

                                    <div id="video-player-container-post" class={!entry.data.videoUrl ? "hidden" : "block relative"}>
                                        <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0a0a0a] rounded-2xl flex items-center justify-center border border-white/5">
                                            <div class="loader-vfm flex flex-col items-center gap-4">
                                                <div class="loader-spinner !border-t-red-500"></div>
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Iniciando Video...</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                ) : (
                    /* 1. THE PLAYER AREA (Non-premiere episodes) */
                    <section class="player-section section-fade">
                        <div class="player-wrapper shadow-2xl relative">
                            {
                                isUpcoming && (
                                    <div id="countdown-wrapper">
                                        <PremiereCountdown
                                            targetDate={entry.data.pubDate}
                                            title={entry.data.title}
                                        />
                                    </div>
                                )
                            }

                            <div
                                id="static-player-wrapper"
                                class:list={{ hidden: isUpcoming }}
                                style={isUpcoming ? "display:none;" : ""}
                            >
                                <div
                                    id="episode-player-inner"
                                    class="cinema-player-box group"
                                    data-audio-url={entry.data.audioUrl}
                                    data-spotify-url={entry.data.spotifyUrl}
                                    data-title={entry.data.title}
                                    data-image={entry.data.image}
                                    data-author={entry.data.author}
                                    data-slug={entry.slug}
                                    data-is-premiere={isPremiere}
                                    data-video-url={entry.data.videoUrl}
                                    data-transcription={entry.data.transcription
                                        ? JSON.stringify(entry.data.transcription)
                                        : null}
                                    data-sections={entry.data.sections
                                        ? JSON.stringify(entry.data.sections)
                                        : null}
                                    data-next-episodes={JSON.stringify(nextEpisodes)}
                                >
                                    <div id="audio-player-container" class={entry.data.videoUrl ? "hidden" : "block relative"}>
                                        <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0f0f0f] rounded-2xl flex items-center justify-center overflow-hidden border border-white/5">
                                            <div class="loader-vfm flex flex-col items-center gap-4">
                                                <div class="loader-spinner"></div>
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Sintonizando...</span>
                                            </div>
                                        </div>
                                        <CinemaAudioPlayer
                                            client:load
                                            audioUrl={entry.data.audioUrl || ""}
                                            title={entry.data.title || ""}
                                            cover={entry.data.image || ""}
                                            author={entry.data.author || "Veredillas FM"}
                                            transcription={formattedTranscription}
                                            slug={entry.slug}
                                            videoUrl={entry.data.videoUrl}
                                            sections={entry.data.sections}
                                            nextEpisodes={nextEpisodes}
                                        />
                                    </div>

                                    <div id="video-player-container" class={!entry.data.videoUrl ? "hidden" : "block relative"}>
                                        <div class="player-placeholder-visual absolute inset-0 z-0 bg-[#0a0a0a] rounded-2xl flex items-center justify-center border border-white/5">
                                            <div class="loader-vfm flex flex-col items-center gap-4">
                                                <div class="loader-spinner !border-t-red-500"></div>
                                                <span class="text-[10px] font-black uppercase tracking-[0.2em] text-white/30 animate-pulse">Iniciando Video...</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                )
            }

            <header class="player-info py-6">
                <h1 class="text-2xl md:text-3xl font-black mb-4 tracking-tight">
                    {entry.data.title}
                </h1>
                <div class="flex flex-wrap items-center justify-between gap-4 pb-6 border-b border-zinc-800/50">
                    <div class="author-meta flex items-center gap-3">
                        <img src="/logo.webp" alt="Veredillas FM" width={40} height={40} class="w-10 h-10 rounded-full border border-zinc-800" />
                        <div class="flex flex-col">
                            <p class="font-bold text-zinc-100 leading-tight">{entry.data.author}</p>
                            <p class="text-xs text-zinc-500">{formattedDate}</p>
                        </div>

                        {
                            episodeGuests.length > 0 && (
                                <div class="collaborators-mini-list flex items-center -space-x-3 ml-2 pl-4 border-l border-zinc-800/80 h-8 self-center">
                                    {episodeGuests.map((guest, idx) => (
                                        <div class="relative group" title={guest.data.name} style={`z-index: ${episodeGuests.length - idx}`}>
                                            {guest.data.image ? (
                                                <img src={guest.data.image} alt={guest.data.name} width={32} height={32} class="w-8 h-8 rounded-full border-2 border-zinc-950 object-cover ring-1 ring-white/5 group-hover:scale-110 group-hover:ring-primary/50 transition-all duration-300" />
                                            ) : (
                                                <div class="w-8 h-8 rounded-full bg-zinc-800 border-2 border-zinc-950 flex items-center justify-center ring-1 ring-white/5 group-hover:scale-110 transition-all duration-300">
                                                    <span class="text-[9px] font-black text-zinc-500 uppercase">{guest.data.name.substring(0, 2)}</span>
                                                </div>
                                            )}
                                            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2.5 py-1.5 bg-black/95 backdrop-blur-xl border border-white/10 rounded-lg text-[9px] font-black text-white opacity-0 group-hover:opacity-100 transition-all duration-300 pointer-events-none whitespace-nowrap uppercase tracking-[0.1em] shadow-2xl z-50">
                                                {guest.data.name}
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            )
                        }
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-2 md:mt-0">
                        <ListenerCount onlyCurrentPath={true} />
                        <EpisodeRating slug={entry.slug} />
                        <FavoriteButton episodeSlug={entry.slug} />
                        <LikeDislikeGroup episodeSlug={entry.slug} />
                        <PlaylistManager episodeSlug={entry.slug} />
                    </div>
                </div>

                <div class="flex items-center py-4">
                    <EpisodeActions
                        title={entry.data.title}
                        audioUrl={entry.data.audioUrl}
                        image={entry.data.image || relativeOgImageUrl}
                        slug={entry.slug}
                        guests={entry.data.participants}
                        duration={entry.data.duration}
                        quiz={entry.data.quiz}
                    />
                </div>
            </header>

            <section class="description-section glass-panel p-6 mb-8">
                <div class="mb-4">
                    <span class="text-sm font-bold uppercase tracking-wider text-zinc-400">Descripción</span>
                </div>
                <div class="content-body prose prose-invert max-w-none mb-8">
                    <Content />
                </div>
                <div class="mt-8 pt-8 border-t border-zinc-800">
                    <EpisodeSections sections={entry.data.sections} />
                    <TranscriptionWidget transcription={entry.data.transcription} />
                </div>
            </section>

            <!-- 3. COMMENTS AREA -->
            <section
                id="comments-wrapper"
                class="comments-section mb-20"
                style={isPremiere && !hasPremiereEnded ? "display:none;" : ""}
            >
                <div class="flex items-center gap-4 mb-8">
                    <h2 class="text-xl font-black">Comentarios</h2>
                </div>
                <Comments slug={entry.slug} />
            </section>

        </main>

        <!-- SIDEBAR -->
        <aside class="sidebar-column">
            <div class="sticky top-24 space-y-6">
                <PlaylistSidebar currentSlug={entry.slug} />

                <EpisodeParticipants participants={entry.data.participants} />

                <SidebarWidget title="Detalles" isOpen={true}>
                    <ul class="details-list text-sm">
                        <li
                            class="flex justify-between py-2 border-b border-zinc-800/50"
                        >
                            <span class="text-zinc-500">Temporada</span>
                            <span class="font-bold">{entry.data.season}</span>
                        </li>
                        <li
                            class="flex justify-between py-2 border-b border-zinc-800/50"
                        >
                            <span class="text-zinc-500">Episodio</span>
                            <span class="font-bold">{entry.data.episode}</span>
                        </li>
                        <li
                            class="flex justify-between py-2 border-b border-zinc-800/50"
                        >
                            <span class="text-zinc-500">Duración</span>
                            <span class="font-bold uppercase"
                                >{entry.data.duration}</span
                            >
                        </li>
                        {
                            entry.data.tags && (
                                <li class="pt-4">
                                    <div class="flex flex-wrap gap-2">
                                        {entry.data.tags.map((tag) => (
                                            <a
                                                href={`/ep?tag=${tag}`}
                                                class="tag-chip text-[10px] font-bold uppercase px-2 py-1 bg-zinc-800 hover:bg-primary transition-colors rounded"
                                            >
                                                #{tag}
                                            </a>
                                        ))}
                                    </div>
                                </li>
                            )
                        }
                    </ul>
                </SidebarWidget>

                <EpisodeClips clips={entry.data.clips} />

                <!-- Sidebar Discovery Widgets would go here -->
                <div class="related-wrapper pt-4">
                    <h3
                        class="text-sm font-black uppercase tracking-[0.2em] text-zinc-500 mb-4"
                    >
                        Siguiente episodio
                    </h3>
                    <RelatedEpisodes
                        currentSlug={entry.slug}
                        tags={entry.data.tags}
                        limit={4}
                    />
                </div>
            </div>
        </aside>
    </div>

    <SocialShare
        isModal={true}
        triggerId="action-share-episode"
        title={entry.data.title}
        image={entry.data.image || relativeOgImageUrl}
    />
    {
        entry.data.quiz && (
            <QuizModal
                client:only="react"
                quiz={entry.data.quiz}
                episodeTitle={entry.data.title}
                episodeSlug={entry.slug}
            />
        )
    }

    {isPremiere && premiereEndTimeMs > 0 && (
        <script
            is:inline
            data-premiere-end-ms={premiereEndTimeMs}
        >
            (function () {
                var endMs = parseInt(document.currentScript.dataset.premiereEndMs, 10);
                if (!endMs) return;

                function applyPremiereState() {
                    var now = Date.now();
                    var ended = now >= endMs;

                    var premiereBlock = document.getElementById('premiere-stage-block');
                    var postBlock = document.getElementById('post-premiere-player-block');
                    var commentsBlock = document.getElementById('comments-wrapper');

                    if (premiereBlock) premiereBlock.style.display = ended ? 'none' : '';
                    if (postBlock) postBlock.style.display = ended ? '' : 'none';
                    if (commentsBlock) commentsBlock.style.display = ended ? '' : 'none';

                    return ended;
                }

                // Apply immediately on load
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', applyPremiereState);
                } else {
                    applyPremiereState();
                }

                // Poll every 10 seconds until premiere ends
                var interval = setInterval(function () {
                    var ended = applyPremiereState();
                    if (ended) clearInterval(interval);
                }, 10000);
            })();
        </script>
    )}
</Layout>

