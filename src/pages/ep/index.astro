---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import EpisodeCard from '../../components/EpisodeCard.astro';
import { getCollection } from 'astro:content';

const allEpisodes = await getCollection('episodios');
const sortedEpisodes = allEpisodes.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get unique seasons and sort them
const uniqueSeasons = [...new Set(sortedEpisodes.map(ep => ep.data.season).filter(Boolean))].sort((a, b) => (a as number) - (b as number));

// Load guests collection to get images and roles
const allGuests = await getCollection('guests');
const guestMap = new Map(allGuests.map(g => [g.data.name.toLowerCase().trim(), g.data]));

// Get unique guests across all episodes, sorted alphabetically
const uniqueGuestNames = [...new Set(
    sortedEpisodes
        .flatMap(ep => ep.data.participants || [])
        .map(g => g.trim())
        .filter(Boolean)
)].sort((a, b) => a.localeCompare(b, 'es'));

// Build enriched guest list with image/role from collection
const uniqueGuests = uniqueGuestNames.map(name => {
    const data = guestMap.get(name.toLowerCase().trim());
    return {
        name,
        image: data?.image || null,
        role: data?.role || null,
    };
});

const parseDuration = (d: string | undefined): number => {
    if (!d) return 0;
    // Handle HH:MM:SS or MM:SS
    if (d.includes(':')) {
        const parts = d.split(':').map(Number);
        if (parts.length === 3) return parts[0] * 60 + parts[1] + parts[2] / 60;
        if (parts.length === 2) return parts[0] + parts[1] / 60;
    }
    const minutes = d.match(/(\d+)\s*min/);
    const hours = d.match(/(\d+)\s*h/);
    let total = 0;
    if (hours) total += parseInt(hours[1]) * 60;
    if (minutes) total += parseInt(minutes[1]);
    return total;
};

const getSchoolYear = (date: Date): string => {
    const year = date.getFullYear();
    const month = date.getMonth(); // 0-indexed, 8 is September
    if (month >= 8) {
        return `${year.toString().slice(-2)}/${(year + 1).toString().slice(-2)}`;
    }
    return `${(year - 1).toString().slice(-2)}/${year.toString().slice(-2)}`;
};

const episodesWithMeta = sortedEpisodes.map(post => {
    const searchContent = `${post.data.title} ${post.data.description || ''} ${post.data.participants?.join(' ') || ''}`.toLowerCase();
    const participantsStr = (post.data.participants || []).join('|').toLowerCase();
    const tagsStr = (post.data.tags || []).join('|').toLowerCase();
    const durationMin = parseDuration(post.data.duration);
    const schoolYear = getSchoolYear(post.data.pubDate);
    
    return {
        post,
        searchContent,
        participantsStr,
        tagsStr,
        durationMin,
        schoolYear
    };
});

// Get unique school years and subjects
const uniqueSchoolYears = [...new Set(episodesWithMeta.map(e => e.schoolYear))].sort();
const uniqueSubjects = [...new Set(sortedEpisodes.flatMap(ep => ep.data.tags || []))].sort((a, b) => a.localeCompare(b, 'es'));

const buildNow = new Date();
---

<Layout 
  title="Episodios"
  description="Escucha todos los episodios del podcast Veredillas FM. Entrevistas exclusivas, debates, noticias del instituto y contenido original creado por estudiantes."
  image="/logo.webp"
  imageAlt="Episodios de Veredillas FM - Todos los podcasts del IES Veredillas"
  tags={['podcast', 'episodios', 'IES Veredillas', 'audio', 'entrevistas', 'contenido estudiantil']}
>
    <!-- Background Decor -->
    <div class="page-bg"></div>

    <div class="container page-wrapper">
        <header class="page-header fade-in">
            <h1>Explora todos los <br><span class="text-gradient">Episodios</span></h1>
            
            <div class="controls-wrapper">
                <!-- Row 1: Season Selector -->
                <div class="controls-row controls-row--top">
                    <div class="season-selector-wrapper">
                        <span class="control-label">Temporada</span>
                        <div class="season-selector" id="season-selector">
                            <button class="season-btn active" data-season="all">
                                Todas
                            </button>
                            {uniqueSeasons.map(season => (
                                <button class="season-btn" data-season={season}>
                                    {season}ª
                                </button>
                            ))}
                        </div>
                    </div>
                </div>

                <div class="controls-divider-h"></div>

                <!-- Row 2: Search + Guest + Toggle -->
                <div class="controls-row controls-row--bottom">
                    <!-- Search Bar -->
                    <div class="search-widget">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        <input type="text" id="episode-search" placeholder="Buscar episodios..." class="search-input" autocomplete="off" />
                    </div>

                    <!-- Custom Guest Dropdown -->
                    {uniqueGuests.length > 0 && (
                        <div class="guest-dropdown" id="guest-dropdown" role="combobox" aria-expanded="false" aria-haspopup="listbox">
                            <!-- Trigger button -->
                            <button class="guest-trigger" id="guest-trigger" type="button" aria-label="Filtrar por invitado">
                                <span class="guest-trigger-avatar" id="guest-trigger-avatar">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                </span>
                                <span class="guest-trigger-label" id="guest-trigger-label">Invitado</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="guest-chevron"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>

                            <!-- Dropdown panel -->
                            <div class="guest-panel" id="guest-panel" role="listbox" aria-label="Lista de invitados">
                                <div class="guest-panel-inner">
                                    <!-- "All" option -->
                                    <button class="guest-option guest-option--all active" data-value="" role="option" aria-selected="true">
                                        <span class="guest-option-avatar guest-option-avatar--all">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                        </span>
                                        <span class="guest-option-info">
                                            <span class="guest-option-name">Todos los invitados</span>
                                        </span>
                                        <span class="guest-option-check">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                        </span>
                                    </button>

                                    <div class="guest-panel-divider"></div>

                                    <!-- Guest options -->
                                    {uniqueGuests.map(guest => (
                                        <button 
                                            class="guest-option"
                                            data-value={guest.name.toLowerCase()}
                                            data-image={guest.image || ''}
                                            data-name={guest.name}
                                            role="option"
                                            aria-selected="false"
                                        >
                                            <span class="guest-option-avatar">
                                                {guest.image ? (
                                                    <img src={guest.image} alt={guest.name} loading="lazy" />
                                                ) : (
                                                    <span class="guest-option-initials">{guest.name.charAt(0).toUpperCase()}</span>
                                                )}
                                            </span>
                                            <span class="guest-option-info">
                                                <span class="guest-option-name">{guest.name}</span>
                                                {guest.role && <span class="guest-option-role">{guest.role}</span>}
                                            </span>
                                            <span class="guest-option-check">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            </span>
                                        </button>
                                    ))}
                                </div>
                            </div>
                        </div>
                    )}

                    <!-- Advanced Filters Toggle -->
                    <button id="adv-filters-toggle" class="adv-filters-toggle" aria-expanded="false" aria-label="Mostrar filtros avanzados">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 16-4 4-4-4"/><path d="M17 20V4"/><path d="m3 8 4-4 4 4"/><path d="M7 4v16"/></svg>
                        <span>Filtros</span>
                        <span class="adv-filters-badge hidden" id="adv-filters-badge">0</span>
                    </button>

                    <!-- Toggle for Upcoming -->
                    <div class="toggle-group">
                        <span class="toggle-label">Próximos</span>
                        <label class="switch">
                            <input type="checkbox" id="upcoming-toggle">
                            <span class="slider round"></span>
                        </label>
                    </div>
                </div>

                <!-- Advanced Filters Panel -->
                <div id="adv-filters-panel" class="adv-filters-panel hidden">
                    <div class="adv-filters-grid">
                        <!-- Duration Filter -->
                        <div class="adv-filter-group">
                            <label>Duración</label>
                            <div class="duration-chips">
                                <button class="duration-chip" data-min="0" data-max="999">Cualquiera</button>
                                <button class="duration-chip" data-min="0" data-max="15">Corto (<15min)</button>
                                <button class="duration-chip" data-min="15" data-max="45">Medio (15-45min)</button>
                                <button class="duration-chip" data-min="45" data-max="999">Largo (>45min)</button>
                            </div>
                        </div>

                        <!-- School Year Filter -->
                        <div class="adv-filter-group">
                            <label>Año Escolar</label>
                            <select id="school-year-filter" class="adv-select">
                                <option value="">Todos los años</option>
                                {uniqueSchoolYears.map(year => (
                                    <option value={year}>{year}</option>
                                ))}
                            </select>
                        </div>

                        <!-- Subject/Tag Filter -->
                        <div class="adv-filter-group">
                            <label>Asignatura / Tema</label>
                            <select id="subject-filter" class="adv-select">
                                <option value="">Todas las asignaturas</option>
                                {uniqueSubjects.map(subject => (
                                    <option value={subject.toLowerCase()}>{subject}</option>
                                ))}
                            </select>
                        </div>
                    </div>
                </div>

                <div class="controls-divider-h"></div>

                <!-- Active Filters Display -->
                <div id="active-filters-container" class="active-filters hidden">
                    <span class="active-filters-label">Filtrado por:</span>
                    <div id="active-filters-list" class="active-filters-list"></div>
                </div>
            </div>
        </header>

        <div class="episodes-grid" id="episodes-grid">
            {episodesWithMeta.map(({ post, searchContent, participantsStr, tagsStr, durationMin, schoolYear }, index) => {
                 const isUpcomingAtBuildTime = post.data.pubDate > buildNow;
                 return (
                    <div 
                        class={`episode-item fade-in-up ${isUpcomingAtBuildTime ? 'is-upcoming-hidden' : ''}`}
                        data-pub-date={post.data.pubDate.toISOString()}
                        data-search-content={searchContent}
                        data-season={post.data.season || 'unknown'}
                        data-participants={participantsStr}
                        data-tags={tagsStr}
                        data-duration-min={durationMin}
                        data-school-year={schoolYear}
                        style={`--delay: ${index % 6}; view-transition-name: ep-${post.slug};`}
                    >
                         <EpisodeCard post={post} />
                    </div>
                );
            })}
        </div>
        
        <div id="pagination-container" class="pagination-container"></div>

        <div id="no-results" class="no-results hidden">
            <span class="no-results-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            </span>
            <h3>No hay episodios para mostrar</h3>
            <p>Prueba a cambiar tus filtros o activa el interruptor de "Próximos estrenos".</p>
            <button id="reset-filter" class="btn btn-primary">Restablecer filtros</button>
        </div>
    </div>
</Layout>

<script>
    function initFilters() {
        const items = document.querySelectorAll('.episode-item');
        const upcomingToggle = document.getElementById('upcoming-toggle') as HTMLInputElement;
        const searchInput = document.getElementById('episode-search') as HTMLInputElement;
        const seasonBtns = document.querySelectorAll('.season-btn');
        const noResults = document.getElementById('no-results');
        const resetBtn = document.getElementById('reset-filter');

        // Advanced filter elements
        const advFiltersToggle = document.getElementById('adv-filters-toggle');
        const advFiltersPanel = document.getElementById('adv-filters-panel');
        const advFiltersBadge = document.getElementById('adv-filters-badge');
        const durationChips = document.querySelectorAll('.duration-chip');
        const schoolYearFilter = document.getElementById('school-year-filter') as HTMLSelectElement;
        const subjectFilter = document.getElementById('subject-filter') as HTMLSelectElement;

        // Restore guest dropdown elements
        const guestDropdown = document.getElementById('guest-dropdown');
        const guestTrigger = document.getElementById('guest-trigger');
        const guestPanel = document.getElementById('guest-panel');
        const guestTriggerLabel = document.getElementById('guest-trigger-label');
        const guestTriggerAvatar = document.getElementById('guest-trigger-avatar');
        const guestOptions = document.querySelectorAll('.guest-option');

        if (!upcomingToggle || !searchInput) return;

        let currentSeason = 'all';
        let selectedGuest = '';
        let selectedGuestName = '';
        let selectedTag = new URLSearchParams(window.location.search).get('tag')?.toLowerCase() || '';
        let selectedDuration = { min: 0, max: 999 };
        let selectedDurationLabel = 'Cualquiera';
        let selectedSchoolYear = '';
        let selectedSubject = '';
        
        let currentPage = 1;
        const ITEMS_PER_PAGE = 12;

        // Initial setup for tag if present
        if (selectedTag) {
            selectedSubject = selectedTag;
            if (subjectFilter) subjectFilter.value = selectedTag;
        }

        // ── Advanced Filters Toggle ──────────────────────────────────────
        advFiltersToggle?.addEventListener('click', () => {
            const isExpanded = advFiltersToggle.getAttribute('aria-expanded') === 'true';
            advFiltersToggle.setAttribute('aria-expanded', (!isExpanded).toString());
            advFiltersPanel?.classList.toggle('hidden');
            advFiltersToggle.classList.toggle('active');
        });

        durationChips.forEach(chip => {
            if (chip.getAttribute('data-min') === '0' && chip.getAttribute('data-max') === '999') {
                chip.classList.add('active');
            }
            chip.addEventListener('click', () => {
                durationChips.forEach(c => c.classList.remove('active'));
                chip.classList.add('active');
                selectedDuration = {
                    min: parseInt(chip.getAttribute('data-min') || '0'),
                    max: parseInt(chip.getAttribute('data-max') || '999')
                };
                selectedDurationLabel = chip.textContent || 'Cualquiera';
                filterItems(false);
            });
        });

        schoolYearFilter?.addEventListener('change', () => {
            selectedSchoolYear = schoolYearFilter.value;
            filterItems(false);
        });

        subjectFilter?.addEventListener('change', () => {
            selectedSubject = subjectFilter.value;
            filterItems(false);
        });

        // ── Optimized Filter Cache ──────────────────────────────────────
        const episodeData = Array.from(items).map(item => {
            const el = item as HTMLElement;
            return {
                el,
                pubDate: new Date(el.getAttribute('data-pub-date') || ''),
                searchContent: el.getAttribute('data-search-content') || '',
                season: el.getAttribute('data-season') || '',
                participants: (el.getAttribute('data-participants') || '').split('|').map(p => p.trim()),
                tags: (el.getAttribute('data-tags') || '').split('|').map(t => t.trim()),
                durationMin: parseInt(el.getAttribute('data-duration-min') || '0'),
                schoolYear: el.getAttribute('data-school-year') || ''
            };
        });

        // ── Intersection Observer for animations ─────────────────────────
        const observerOptions = {
            root: null,
            rootMargin: '100px',
            threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target as HTMLElement;
                    el.classList.add('is-visible');
                    // Stop observing once visible to prevent re-triggering
                    observer.unobserve(el);
                }
            });
        }, observerOptions);

        items.forEach(item => observer.observe(item));

        // ── Debounce function ───────────────────────────────────────────
        function debounce(func: Function, wait: number) {
            let timeout: any = null;
            return function executedFunction(...args: any[]) {
                const later = () => {
                    timeout = null;
                    func(...args);
                };
                if (timeout) clearTimeout(timeout);
                timeout = window.setTimeout(later, wait);
            };
        }

        // ── Custom dropdown logic ──────────────────────────────────────
        function openDropdown() {
            guestPanel?.classList.add('open');
            guestDropdown?.setAttribute('aria-expanded', 'true');
            guestTrigger?.classList.add('open');
        }

        function closeDropdown() {
            guestPanel?.classList.remove('open');
            guestDropdown?.setAttribute('aria-expanded', 'false');
            guestTrigger?.classList.remove('open');
        }

        function toggleDropdown() {
            guestPanel?.classList.contains('open') ? closeDropdown() : openDropdown();
        }

        guestTrigger?.addEventListener('click', (e) => {
            e.stopPropagation();
            toggleDropdown();
        });

        document.addEventListener('click', (e) => {
            if (guestDropdown && !guestDropdown.contains(e.target as Node)) {
                closeDropdown();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeDropdown();
        });

        guestOptions.forEach(option => {
            option.addEventListener('click', () => {
                const value = (option as HTMLElement).getAttribute('data-value') || '';
                const name = (option as HTMLElement).getAttribute('data-name') || '';
                const image = (option as HTMLElement).getAttribute('data-image') || '';

                selectedGuest = value;
                selectedGuestName = name;

                guestOptions.forEach(o => {
                    o.classList.remove('active');
                    o.setAttribute('aria-selected', 'false');
                });
                option.classList.add('active');
                option.setAttribute('aria-selected', 'true');

                if (guestTriggerLabel) {
                    guestTriggerLabel.textContent = value === '' ? 'Invitado' : name;
                }
                if (guestTriggerAvatar) {
                    if (value === '') {
                        guestTriggerAvatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
                    } else if (image) {
                        guestTriggerAvatar.innerHTML = `<img src="${image}" alt="${name}" />`;
                    } else {
                        guestTriggerAvatar.innerHTML = `<span class="trigger-initials">${name.charAt(0).toUpperCase()}</span>`;
                    }
                }

                if (value !== '') {
                    guestTrigger?.classList.add('has-selection');
                } else {
                    guestTrigger?.classList.remove('has-selection');
                }

                closeDropdown();
                filterItems(false);
            });
        });

        // ── Main filter function ───────────────────────────────────────
        function filterItems(fromPagination = false) {
            if (fromPagination !== true) {
                currentPage = 1;
            }
            const now = new Date();
            const showUpcoming = upcomingToggle.checked;
            const searchTerm = searchInput.value.toLowerCase().trim();
            let visibleCount = 0;
            let activeAdvFilterCount = 0;

            if (selectedDuration.min !== 0 || selectedDuration.max !== 999) activeAdvFilterCount++;
            if (selectedSchoolYear !== '') activeAdvFilterCount++;
            if (selectedSubject !== '') activeAdvFilterCount++;

            if (advFiltersBadge) {
                if (activeAdvFilterCount > 0) {
                    advFiltersBadge.textContent = activeAdvFilterCount.toString();
                    advFiltersBadge.classList.remove('hidden');
                } else {
                    advFiltersBadge.classList.add('hidden');
                }
            }

            const activeFiltersContainer = document.getElementById('active-filters-container');
            const activeFiltersList = document.getElementById('active-filters-list');

            // Update active filters UI
            if (activeFiltersList && activeFiltersContainer) {
                activeFiltersList.innerHTML = '';
                let hasAnyActive = false;

                if (selectedGuest) {
                    hasAnyActive = true;
                    activeFiltersList.innerHTML += `
                        <span class="filter-chip">
                            Invitado: ${selectedGuestName}
                            <button id="clear-guest-chip" class="clear-chip-btn">&times;</button>
                        </span>
                    `;
                }

                if (selectedSubject || selectedTag) {
                    hasAnyActive = true;
                    activeFiltersList.innerHTML += `
                        <span class="filter-chip">
                            #${selectedSubject || selectedTag}
                            <button id="clear-tag" class="clear-chip-btn">&times;</button>
                        </span>
                    `;
                }

                if (selectedSchoolYear) {
                    hasAnyActive = true;
                    activeFiltersList.innerHTML += `
                        <span class="filter-chip">
                            Año: ${selectedSchoolYear}
                            <button id="clear-school-year" class="clear-chip-btn">&times;</button>
                        </span>
                    `;
                }

                if (selectedDuration.max !== 999 || selectedDuration.min !== 0) {
                    hasAnyActive = true;
                    activeFiltersList.innerHTML += `
                        <span class="filter-chip">
                            Duración: ${selectedDurationLabel}
                            <button id="clear-duration" class="clear-chip-btn">&times;</button>
                        </span>
                    `;
                }

                if (hasAnyActive) {
                    activeFiltersContainer.classList.remove('hidden');
                    
                    // Add listeners for individual clear buttons
                    document.getElementById('clear-tag')?.addEventListener('click', () => {
                        selectedTag = '';
                        selectedSubject = '';
                        if (subjectFilter) subjectFilter.value = '';
                        window.history.replaceState({}, '', window.location.pathname);
                        filterItems(false);
                    });
                    document.getElementById('clear-guest-chip')?.addEventListener('click', () => {
                        selectedGuest = '';
                        selectedGuestName = '';
                        // Reset guest dropdown UI
                        guestOptions.forEach(o => o.classList.remove('active'));
                        document.querySelector('.guest-option--all')?.classList.add('active');
                        if (guestTriggerLabel) guestTriggerLabel.textContent = 'Invitado';
                        guestTrigger?.classList.remove('has-selection');
                        filterItems(false);
                    });
                    document.getElementById('clear-school-year')?.addEventListener('click', () => {
                        selectedSchoolYear = '';
                        if (schoolYearFilter) schoolYearFilter.value = '';
                        filterItems(false);
                    });
                    document.getElementById('clear-duration')?.addEventListener('click', () => {
                        selectedDuration = { min: 0, max: 999 };
                        durationChips.forEach(c => c.classList.remove('active'));
                        document.querySelector('.duration-chip[data-min="0"][data-max="999"]')?.classList.add('active');
                        filterItems(false);
                    });
                } else {
                    activeFiltersContainer.classList.add('hidden');
                }
            }

            const updateDisplay = () => {
                const matchedItems: any[] = [];
                episodeData.forEach((data) => {
                    const { el, pubDate, searchContent, season, participants, tags, durationMin, schoolYear } = data;
                    
                    const isUpcoming = pubDate > now;
                    const diffInHours = (pubDate.getTime() - now.getTime()) / (1000 * 60 * 60);
                    const isAboutToPremiere = isUpcoming && diffInHours <= 2;
                    
                    const matchesSeason = currentSeason === 'all' || season === currentSeason;
                    const matchesUpcoming = showUpcoming || !isUpcoming || isAboutToPremiere;
                    const matchesSearch = searchTerm === '' || searchContent.includes(searchTerm);
                    const matchesGuest = selectedGuest === '' || participants.includes(selectedGuest);
                    const matchesTag = (selectedSubject === '' && selectedTag === '') || 
                                     tags.some(t => t === selectedSubject || t === selectedTag);
                    const matchesDuration = durationMin >= selectedDuration.min && durationMin <= selectedDuration.max;
                    const matchesSchoolYear = selectedSchoolYear === '' || schoolYear === selectedSchoolYear;

                    if (matchesSeason && matchesUpcoming && matchesSearch && matchesGuest && matchesTag && matchesDuration && matchesSchoolYear) {
                        matchedItems.push({ data, isUpcoming, isAboutToPremiere });
                    } else {
                        el.classList.add('hidden-anim');
                        el.style.display = 'none';
                    }
                });

                visibleCount = matchedItems.length;
                const totalPages = Math.ceil(visibleCount / ITEMS_PER_PAGE);
                if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

                const startIndex = (currentPage - 1) * ITEMS_PER_PAGE;
                const endIndex = startIndex + ITEMS_PER_PAGE;

                matchedItems.forEach((item, index) => {
                    const { el } = item.data;
                    if (index >= startIndex && index < endIndex) {
                        el.classList.remove('hidden-anim');
                        el.classList.remove('is-upcoming-hidden');
                        
                        const badge = el.querySelector('.dynamic-upcoming-badge') as HTMLElement | null;
                        const badgeText = badge?.querySelector('.badge-text');
                        
                        if (badge) {
                            if (item.isUpcoming) {
                                badge.classList.remove('hidden');
                                if (item.isAboutToPremiere && badgeText) {
                                    badgeText.textContent = '¡Falta muy poco!';
                                    badge.classList.remove('bg-primary/90', 'shadow-primary/30');
                                    badge.classList.add('bg-red-600/90', 'shadow-red-600/30');
                                }
                            } else {
                                badge.classList.add('hidden');
                            }
                        }

                        el.style.display = 'block';
                    } else {
                        el.classList.add('hidden-anim');
                        el.style.display = 'none';
                    }
                });

                renderPagination(totalPages);

                if (visibleCount === 0) {
                    noResults?.classList.remove('hidden');
                } else {
                    noResults?.classList.add('hidden');
                }
            };

            function renderPagination(totalPages: number) {
                const container = document.getElementById('pagination-container');
                if (!container) return;
                
                if (totalPages <= 1) {
                    container.innerHTML = '';
                    return;
                }

                let html = '';
                
                html += `<button class="page-btn" data-page="prev" ${currentPage === 1 ? 'disabled' : ''}><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg><span>Anterior</span></button>`;
                
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }

                if (startPage > 1) {
                    html += `<button class="page-btn" data-page="1">1</button>`;
                    if (startPage > 2) html += `<span class="page-dots">...</span>`;
                }

                for (let i = startPage; i <= endPage; i++) {
                    html += `<button class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
                }

                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) html += `<span class="page-dots">...</span>`;
                    html += `<button class="page-btn" data-page="${totalPages}">${totalPages}</button>`;
                }

                html += `<button class="page-btn" data-page="next" ${currentPage === totalPages ? 'disabled' : ''}><span>Siguiente</span><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></button>`;

                container.innerHTML = html;

                const btns = container.querySelectorAll('.page-btn:not([disabled])');
                btns.forEach(btn => {
                    btn.addEventListener('click', () => {
                        const page = btn.getAttribute('data-page');
                        if (page === 'prev') currentPage--;
                        else if (page === 'next') currentPage++;
                        else currentPage = parseInt(page || '1');
                        
                        filterItems(true);
                        
                        // Scroll top to the grid, but maintaining a bit of padding for the fixed navbar
                        const grid = document.getElementById('episodes-grid');
                        if (grid) {
                            const y = grid.getBoundingClientRect().top + window.scrollY - 120;
                            window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
                        }
                    });
                });
            }

            // @ts-ignore
            if (document.startViewTransition) {
                // @ts-ignore
                document.startViewTransition(() => updateDisplay());
            } else {
                updateDisplay();
            }
        }

        const debouncedFilter = debounce(() => filterItems(false), 150);

        // Season Buttons Logic
        seasonBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                seasonBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentSeason = btn.getAttribute('data-season') || 'all';
                filterItems(false);
            });
        });

        // Event Listeners
        searchInput.addEventListener('input', () => {
            if (searchInput.value === '') filterItems(false);
            else debouncedFilter();
        });
        
        upcomingToggle.addEventListener('change', () => filterItems(false));
        
        resetBtn?.addEventListener('click', () => {
            searchInput.value = '';
            upcomingToggle.checked = false;
            selectedGuest = '';
            selectedGuestName = '';
            selectedTag = '';
            selectedSubject = '';
            selectedSchoolYear = '';
            selectedDuration = { min: 0, max: 999 };
            currentSeason = 'all';
            
            // Clear UI elements
            if (schoolYearFilter) schoolYearFilter.value = '';
            if (subjectFilter) subjectFilter.value = '';
            durationChips.forEach(c => c.classList.remove('active'));
            document.querySelector('.duration-chip[data-min="0"][data-max="999"]')?.classList.add('active');

            // Clear URL search params without reload
            window.history.replaceState({}, '', window.location.pathname);

            seasonBtns.forEach(b => b.classList.remove('active'));
            document.querySelector('.season-btn[data-season="all"]')?.classList.add('active');

            guestOptions.forEach(o => {
                o.classList.remove('active');
                o.setAttribute('aria-selected', 'false');
            });
            document.querySelector('.guest-option--all')?.classList.add('active');
            document.querySelector('.guest-option--all')?.setAttribute('aria-selected', 'true');
            if (guestTriggerLabel) guestTriggerLabel.textContent = 'Invitado';
            if (guestTriggerAvatar) guestTriggerAvatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`;
            guestTrigger?.classList.remove('has-selection');
            
            filterItems(false);
        });

        // Initial call
        filterItems(false);
    }

    document.addEventListener('DOMContentLoaded', initFilters);
    document.addEventListener('astro:page-load', initFilters);
</script>

