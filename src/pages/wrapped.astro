                                <img src={firstEpisodeInfo.data.image} alt={firstEpisodeInfo.data.title} class="w-full h-full object-cover" crossorigin="anonymous" />
                            </div>
                            <h3 class="text-xl font-bold text-white mb-2 slide-fade-up">{firstEpisodeInfo.data.title}</h3>
                            <p class="text-sky-200 slide-fade-up">Tu primera escucha del año</p>
