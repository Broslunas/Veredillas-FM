                         <p class="text-2xl font-black text-white capitalize">{topTag}</p>
                    </div>
                </div>
            </div>

            <!-- Slide 6: Top Podcast & Recicla -->
            <div class="story-slide bg-gradient-to-tl from-purple-900 via-fuchsia-800 to-pink-700">
                 <div class="slide-content p-8 flex flex-col justify-center h-full text-center">
                    <p class="text-xl font-bold text-pink-200 mb-8 slide-fade tracking-widest uppercase">Obsesión Pura</p>
                    {topEpisodeInfo ? (
                        <>
                            <h2 class="text-4xl font-black text-white mb-6 slide-pop leading-tight">Te enganchaste perdidamente a</h2>
                            <div class="relative w-40 h-40 mx-auto mb-6 slide-fade-up shadow-2xl rounded-2xl overflow-hidden ring-4 ring-pink-400 ring-offset-4 ring-offset-fuchsia-800">
                                <img src={topEpisodeInfo.image} alt={topEpisodeInfo.title} class="w-full h-full object-cover" crossorigin="anonymous" />
                            </div>
                            <h3 class="text-xl font-bold text-white mb-4 slide-fade-up">{topEpisodeInfo.title}</h3>
                            
                            {mostRepeatsCount > 1 ? (
                                <p class="text-pink-100 slide-fade-up font-medium text-lg bg-black/20 p-4 rounded-xl">O te quedaste dormido, o te encantó: lo repetiste <span class="font-bold text-white text-2xl">{mostRepeatsCount}</span> veces.</p>
                            ) : (
                                <p class="text-pink-100 slide-fade-up font-medium text-lg bg-black/20 p-4 rounded-xl">Tu absoluto favorito del año.</p>
                            )}
                        </>
                    ) : (
                        <h2 class="text-4xl font-black text-white slide-pop">¡El misterio! Tus reproducciones están tan repartidas que todos son tus favoritos.</h2>
                    )}
                </div>
            </div>

            <!-- Slide 7: Comunidad -->
            <div class="story-slide bg-gradient-to-bl from-indigo-900 via-indigo-700 to-blue-800">
                 <div class="slide-content p-8 flex flex-col justify-center h-full text-center">
                    <p class="text-xl font-bold text-indigo-200 mb-8 slide-fade tracking-widest uppercase">Echando Humo</p>
                    <h2 class="text-4xl font-black text-white mb-8 slide-pop leading-tight">No fuiste un oyente fantasma.</h2>
                    
                    <div class="grid grid-cols-2 gap-4 slide-fade-up">
                        <div class="bg-white/10 backdrop-blur rounded-2xl p-4 border border-white/20 flex flex-col items-center justify-center">
                            <span class="text-4xl font-black text-white block mb-1">{commentsCount}</span>
                            <span class="text-[10px] font-bold text-indigo-200 uppercase">Comentarios</span>
                        </div>
                        <div class="bg-white/10 backdrop-blur rounded-2xl p-4 border border-white/20 flex flex-col items-center justify-center">
                            <span class="text-4xl font-black text-white block mb-1">{chatCount}</span>
                            <span class="text-[10px] font-bold text-indigo-200 uppercase">Msjs en Chat</span>
                        </div>
                        <div class="bg-white/10 backdrop-blur rounded-2xl p-4 border border-white/20 col-span-2 flex flex-col items-center justify-center relative overflow-hidden">
                            <span class="text-5xl font-black text-white block mb-1 relative z-10">{totalInteractions}</span>
                            <span class="text-xs font-bold text-indigo-200 uppercase relative z-10">Interacciones Totales</span>
                            <div class="absolute -right-4 -bottom-4 text-7xl opacity-20">💬</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Slide 5: Summary -->
            <div class="story-slide bg-black">
                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-violet-900/30 to-violet-900 opacity-80"></div>
                 <div class="slide-content p-6 flex flex-col items-center justify-center h-full relative z-10 w-full">
                    
                    <div id="share-card" class="bg-gradient-to-br from-zinc-900 border border-white/20 to-black p-8 rounded-3xl w-full max-w-sm shadow-[0_0_50px_rgba(139,92,246,0.3)] slide-pop mx-auto relative overflow-hidden">
                        <!-- Watermark ONLY visible internally during capture of full slide -->
                        <div class="watermark-overlay absolute bottom-4 right-4 flex items-center gap-2 opacity-0 pointer-events-none">
                            <img src="/logo.webp" class="w-4 h-4 object-contain brightness-0 invert" crossorigin="anonymous" />
