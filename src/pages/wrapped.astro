                        </div>
                        <div class="flex items-center gap-3 mb-6">
                            <img src="/logo.webp" class="w-8 h-8 object-contain" />
                            <span class="text-sm font-bold tracking-widest text-white">WRAPPED {year}</span>
                        </div>
                        
                        <div class="mb-8">
                            <p class="text-zinc-400 text-xs font-bold uppercase tracking-wider mb-1">Perfil de Oyente</p>
                            <h2 class="text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-pink-400 to-violet-400">{archetype}</h2>
                        </div>
                        
                        <div class="space-y-4 mb-8">
                            <div class="flex justify-between items-center border-b border-white/10 pb-2">
                                <span class="text-white/60">Minutos totales</span>
                                <span class="text-white font-bold text-xl">{yearListeningMinutes}</span>
                            </div>
                            <div class="flex justify-between items-center border-b border-white/10 pb-2">
                                <span class="text-white/60">Episodios diferentes</span>
                                <span class="text-white font-bold text-xl">{uniqueEpisodes}</span>
                            </div>
                            {topEpisodeInfo && (
                                <div class="flex justify-between items-center pb-2">
                                    <span class="text-white/60">Top Podcast</span>
                                    <span class="text-white font-bold w-32 truncate text-right">{topEpisodeInfo.title}</span>
                                </div>
                            )}
                        </div>
                        
                        <div class="flex items-center gap-3">
                            <img src={user.picture || '/logo.webp'} class="w-10 h-10 rounded-full border border-white/20" crossorigin="anonymous" />
                            <p class="text-sm font-bold text-white">{user.name}</p>
                        </div>
                    </div>

                    <p class="text-zinc-400 mt-6 text-center slide-fade-up download-ui-elements">Elige qué recuerdo llevarte</p>
                    
                    <div class="flex flex-col gap-3 mt-4 w-full max-w-sm slide-fade-up relative z-[60] download-ui-elements">
                        <button data-download="7" class="download-btn w-full px-6 py-3 bg-gradient-to-r from-pink-500 to-violet-600 hover:from-pink-400 hover:to-violet-500 text-white font-bold rounded-xl flex items-center justify-center gap-2 transition-colors shadow-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                            <span>Descargar Resumen Completo</span>
                        </button>
                        
                        <div class="grid grid-cols-4 gap-2">
                            <button data-download="2" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[10px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-1">⌚ Minutos</button>
                            <button data-download="3" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[10px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-1">🔥 Racha</button>
                            <button data-download="5" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[10px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-1">⭐ Top #1</button>
                            <button data-download="6" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[10px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-1">💬 Social</button>
                        </div>
                    </div>

                    <button onclick="window.location.href='/dashboard'" class="mt-8 px-8 py-3 bg-white text-black font-bold rounded-full slide-fade-up hover:scale-105 transition-transform w-full max-w-sm z-20 download-ui-elements">
                        Volver al Dashboard
                    </button>
                </div>
            </div>

        </div>
    </div>
</Layout>

<script>
    import * as htmlToImage from 'html-to-image';

    document.addEventListener('DOMContentLoaded', () => {
        const slides = document.querySelectorAll('.story-slide');
        const progressFills = document.querySelectorAll('.fill');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const downloadBtn = document.getElementById('download-btn');
        let currentSlide = 0;
        const totalSlides = slides.length;
        const SLIDE_DURATION = 5000; // 5 seconds per slide
        let slideTimer:any;
        let startTime:number;
        let remainingTime = SLIDE_DURATION;
        let isPaused = false;

        function resetAnimations(slide: Element) {
            const animatedEls = slide.querySelectorAll('.slide-pop, .slide-fade, .slide-fade-up');
            animatedEls.forEach(el => {
                (el as HTMLElement).style.animation = 'none';
                (el as HTMLElement).offsetHeight; /* trigger reflow */
                (el as HTMLElement).style.animation = '';
            });
        }

        function showSlide(index: number) {
            slides.forEach((slide, i) => {
                slide.classList.remove('active');
                if (i === index) {
                    slide.classList.add('active');
                    resetAnimations(slide);
                }
            });

            // Handle touch areas so they don't block buttons on final slide
            if (index === totalSlides - 1) {
                if(nextBtn) nextBtn.style.display = 'none';
                if(prevBtn) prevBtn.style.width = '15%'; // small area on the left to go back
            } else {
                if(nextBtn) nextBtn.style.display = 'block';
                if(prevBtn) prevBtn.style.width = '33.333333%';
            }

            progressFills.forEach((fill, i) => {
                (fill as HTMLElement).style.transition = 'none';
                if (i < index) {
                    (fill as HTMLElement).style.width = '100%';
                } else if (i === index) {
                    (fill as HTMLElement).style.width = '0%';
                    // Slight delay to allow transition to apply after zeroing
                    setTimeout(() => {
                        (fill as HTMLElement).style.transition = `width ${SLIDE_DURATION}ms linear`;
                        (fill as HTMLElement).style.width = '100%';
                    }, 50);
                } else {
                    (fill as HTMLElement).style.width = '0%';
                }
            });

            clearTimeout(slideTimer);
            startTimer();
        }

        function startTimer() {
            if(isPaused) return;
            startTime = Date.now();
            slideTimer = setTimeout(() => {
                nextSlide();
            }, remainingTime);
        }

        function nextSlide() {
            if (currentSlide < totalSlides - 1) {
                currentSlide++;
                remainingTime = SLIDE_DURATION;
                showSlide(currentSlide);
            } else {
                // If at the end, maybe stay there or redirect
                const lastFill = progressFills[currentSlide] as HTMLElement;
                if(lastFill) lastFill.style.width = '100%';
            }
        }

        function prevSlide() {
            if (currentSlide > 0) {
                currentSlide--;
                remainingTime = SLIDE_DURATION;
                showSlide(currentSlide);
            } else {
                // Reset first slide
                remainingTime = SLIDE_DURATION;
                showSlide(currentSlide);
            }
        }

        prevBtn?.addEventListener('click', () => {
            prevSlide();
        });

        nextBtn?.addEventListener('click', () => {
            nextSlide();
        });

        // Touch hold to pause
        document.addEventListener('mousedown', () => { isPaused = true; clearTimeout(slideTimer); const fill = progressFills[currentSlide] as HTMLElement; if(fill) { const computed = window.getComputedStyle(fill).width; fill.style.transition = 'none'; fill.style.width = computed; } });
        document.addEventListener('mouseup', () => { 
            if(isPaused) {
                isPaused = false; 
                // calculate remaining
                const fill = progressFills[currentSlide] as HTMLElement;
                const parent = fill.parentElement;
                if(fill && parent) {
                    const pct = parseFloat(fill.style.width) / parseFloat(window.getComputedStyle(parent).width) || 0;
                    remainingTime = SLIDE_DURATION * (1 - pct);
                    fill.style.transition = `width ${remainingTime}ms linear`;
                    fill.style.width = '100%';
                }
                startTimer();
            }
        });
        
        document.addEventListener('touchstart', () => { isPaused = true; clearTimeout(slideTimer); const fill = progressFills[currentSlide] as HTMLElement; if(fill) { const computed = window.getComputedStyle(fill).width; fill.style.transition = 'none'; fill.style.width = computed; } });
        document.addEventListener('touchend', () => { 
             if(isPaused) {
                isPaused = false; 
                const fill = progressFills[currentSlide] as HTMLElement;
                const parent = fill.parentElement;
                if(fill && parent) {
                    const pct = parseFloat(fill.style.width) / parseFloat(window.getComputedStyle(parent).width) || 0;
                    remainingTime = SLIDE_DURATION * (1 - pct);
                    fill.style.transition = `width ${remainingTime}ms linear`;
                    fill.style.width = '100%';
                }
                startTimer();
            }
        });

        // Init
        setTimeout(() => showSlide(0), 100);

        // Download logic
        const downloadBtns = document.querySelectorAll('.download-btn');
        downloadBtns.forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.stopPropagation(); // Prevent trigger touch next slide
                isPaused = true;
                clearTimeout(slideTimer);
                
                const originalText = btn.innerHTML;
                btn.innerHTML = 'Generando...';
                
                const targetIndex = parseInt(btn.getAttribute('data-download') || '4');
                const targetSlide = slides[targetIndex] as HTMLElement;
                
                if (!targetSlide) return;

                // Temporarily hide elements not wanted in the download
                const container = document.querySelector('.stories-container') as HTMLElement;
                const oldRadius = container.style.borderRadius;
                container.style.borderRadius = '0'; // Flat edges look better for exports

                // Prep slide specifically for capture without breaking animation state
                targetSlide.classList.add('capture-override');
                targetSlide.style.opacity = '1';
                targetSlide.style.visibility = 'visible';
                targetSlide.style.zIndex = '999';

                // Add dynamic watermark
                const wm = document.createElement('div');
                wm.className = "absolute bottom-6 left-1/2 -translate-x-1/2 flex items-center gap-2 opacity-60 z-[100] capture-watermark";
                wm.innerHTML = `<img src="/logo.webp" class="w-5 h-5 object-contain" crossorigin="anonymous" /><span class="text-xs font-bold text-white tracking-[0.2em] uppercase" style="color: white; font-family: sans-serif;">VEREDILLAS FM</span>`;
                targetSlide.appendChild(wm);

                // Hide top progress bar if it's there
                const progress = document.querySelector('.story-progress') as HTMLElement;
                const oldProgressDisplay = progress?.style.display;
                if (progress) progress.style.display = 'none';

                try {
                    // Use html-to-image
                    const dataUrl = await htmlToImage.toPng(targetSlide, {
                        quality: 0.95,
                        pixelRatio: 2, // High res
                        backgroundColor: '#000000',
                        skipFonts: true, // Fixes known Firefox crash "font is undefined"
                        filter: (node: any) => {
                            // Exclude UI elements from the generated image natively
                            if (node?.classList?.contains('download-ui-elements')) {
                                return false;
                            }
                            return true;
                        }
                    });

                    // Download
                    const link = document.createElement('a');
                    link.download = `Veredillas_Wrapped_${targetIndex === 4 ? 'Resumen' : 'Slide_' + (targetIndex + 1)}.png`;
                    link.href = dataUrl;
                    link.click();

                    btn.innerHTML = '¡Descargado!';
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                    }, 2000);

                } catch (err) {
                    console.error('Error generating image', err);
                    btn.innerHTML = 'Error';
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                    }, 2000);
                } finally {
                    // Revert styles
                    const wmToRemove = targetSlide.querySelector('.capture-watermark');
                    if (wmToRemove) wmToRemove.remove();
                    
                    if (progress) progress.style.display = oldProgressDisplay;

                    targetSlide.classList.remove('capture-override');
                    targetSlide.style.opacity = '';
                    targetSlide.style.visibility = '';
                    targetSlide.style.zIndex = '';
                    container.style.borderRadius = oldRadius;

                    // Resume timer
                    isPaused = false;
                    startTimer();
                }
            });
        });
    });
</script>

<style>
    .story-slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s ease;
    }
    .story-slide.active {
        opacity: 1;
        visibility: visible;
        z-index: 20;
    }

    .story-progress {
        display: flex;
    }
    .progress-bar {
        flex: 1;
        height: 3px;
        background: rgba(255,255,255,0.2);
        border-radius: 2px;
        overflow: hidden;
    }
    .progress-bar .fill {
        height: 100%;
        width: 0%;
        background: white;
    }

    /* Animations */
    .slide-pop {
        opacity: 0;
        transform: scale(0.8);
        animation: popIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        animation-delay: 0.3s;
    }
    .slide-fade {
        opacity: 0;
        animation: fadeIn 1s ease forwards;
        animation-delay: 0.8s;
    }
    .slide-fade-up {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeUp 0.8s ease forwards;
        animation-delay: 1.2s;
    }

    @keyframes popIn {
        to { opacity: 1; transform: scale(1); }
    }
    @keyframes fadeIn {
        to { opacity: 1; }
    }
    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }

    .text-shadow-glow {
        text-shadow: 0 0 40px rgba(255,255,255,0.5);
    }

    /* Force visibility and disable animations for screenshots */
    .capture-override, .capture-override * {
        animation: none !important;
        transition: none !important;
        opacity: 1 !important;
        transform: none !important;
        visibility: visible !important;
    }

    .capture-override .download-ui-elements {
        display: none !important;
    }

    /* 3D Wireframe Cube for bg */
    .cube-wrap {
        perspective: 800px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .cube {
        width: 200px;
        height: 200px;
        position: relative;
        transform-style: preserve-3d;
        animation: spin 20s infinite linear;
    }
    .face {
        position: absolute;
        width: 200px;
        height: 200px;
        background: transparent;
        border: 2px solid rgba(255,255,255,0.1);
        box-shadow: 0 0 20px rgba(255,255,255,0.1) inset;
    }
    .front  { transform: translateZ(100px); }
    .back   { transform: rotateY(180deg) translateZ(100px); }
    .right  { transform: rotateY(90deg) translateZ(100px); }
    .left   { transform: rotateY(-90deg) translateZ(100px); }
    .top    { transform: rotateX(90deg) translateZ(100px); }
    .bottom { transform: rotateX(-90deg) translateZ(100px); }

    @keyframes spin {
        from { transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg); }
        to { transform: rotateX(360deg) rotateY(360deg) rotateZ(360deg); }
    }
</style>
