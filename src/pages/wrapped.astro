                            <button data-download="3" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[9px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-0.5">🔥<span>Racha</span></button>
                            <button data-download="9" class="download-btn bg-white/10 hover:bg-white/20 border border-white/20 rounded-lg py-2 text-[9px] font-bold text-white transition-colors flex flex-col items-center justify-center gap-0.5">💬<span>Social</span></button>
