---
import Layout from '../layouts/Layout.astro';
import AdImpresoras from '../components/AdImpresoras.astro';
---

<Layout 
  title="Showcase de Anuncios - Impresoras Veredillas"
  description="Demo de los diferentes layouts del componente de anuncios para el servicio de impresión."
>
  <div class="container py-12">
    <div class="text-center mb-16">
      <h1 class="text-5xl font-black mb-4">Anuncios <span class="text-primary">Profesionales</span></h1>
      <p class="text-zinc-400 text-xl max-w-2xl mx-auto">
        He creado un componente versátil que se adapta a cualquier rincón de la web. Aquí puedes ver todas las variantes disponibles.
      </p>
    </div>

    <section class="mb-20">
      <h2 class="text-2xl font-bold mb-8 border-b border-white/10 pb-4">1. Hero Variant (Para cabeceras o secciones destacadas)</h2>
      <AdImpresoras variant="hero" />
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_300px] gap-12 mb-20">
      <div>
        <h2 class="text-2xl font-bold mb-8 border-b border-white/10 pb-4">2. Leaderboard Variant (Para banners horizontales)</h2>
        <div class="bg-zinc-900/50 p-8 rounded-2xl flex justify-center">
          <AdImpresoras variant="leaderboard" />
        </div>

        <h2 class="text-2xl font-bold mb-8 border-b border-white/10 pb-4 mt-12">3. Square Variant (Para grids o contenido lateral)</h2>
        <div class="flex gap-8 flex-wrap">
          <AdImpresoras variant="square" />
          <AdImpresoras variant="square" theme="light" />
        </div>
      </div>

      <aside>
        <h2 class="text-2xl font-bold mb-8 border-b border-white/10 pb-4">4. Skyscraper</h2>
        <AdImpresoras variant="skyscraper" />
      </aside>
    </div>

    <section class="mb-20">
      <h2 class="text-2xl font-bold mb-8 border-b border-white/10 pb-4">5. Minimal Variant (Para pies de página o inline)</h2>
      <div class="flex flex-col gap-4">
        <AdImpresoras variant="minimal" />
        <AdImpresoras variant="minimal" theme="light" />
      </div>
    </section>
  </div>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
