---
export const prerender = true;
import Layout from '@/layouts/Layout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import fs from 'node:fs';
import path from 'node:path';

const filePath = path.join(process.cwd(), 'src/pages/copyright.astro');
let lastUpdated = 'Recientemente';
try {
  const stats = fs.statSync(filePath);
  lastUpdated = stats.mtime.toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
} catch (e) {
  lastUpdated = new Date().toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
const year = new Date().getFullYear();
---

<Layout title="Copyright y Derechos de Autor — Veredillas FM"
  description="Información sobre los derechos de autor y el contenido publicado en Veredillas FM. Todos los derechos reservados por el IES Las Veredillas y sus creadores."
>
  <main class="page-container">
    <div class="content-wrapper">
      <Breadcrumbs items={[{ label: 'Legales', href: '/aviso-legal' }, { label: 'Copyright' }]} />

      <!-- Hero -->
      <div class="hero">
        <div class="hero-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M14.83 14.83a4 4 0 1 1 0-5.66"/></svg>
          Propiedad Intelectual
        </div>
        <h1>Copyright y Derechos de Autor</h1>
        <p class="hero-subtitle">Todo el contenido de Veredillas FM está protegido por la legislación española e internacional sobre propiedad intelectual.</p>
        <p class="updated-date">Última actualización: {lastUpdated}</p>
      </div>

      <!-- TL;DR Summary -->
      <div class="summary-card">
        <h3>Resumen rápido (TL;DR)</h3>
        <div class="summary-grid">
          <div class="summary-item">
            <strong>Titularidad:</strong> Todo el contenido original es propiedad exclusiva de Veredillas FM.
          </div>
          <div class="summary-item">
            <strong>Uso permitido:</strong> Escucha personal y compartir enlaces oficiales.
          </div>
          <div class="summary-item">
            <strong>Prohibido:</strong> Copiar, redistribuir o lucrarse con nuestro contenido sin permiso.
          </div>
          <div class="summary-item">
            <strong>IA:</strong> Se prohíbe el uso de nuestro contenido para entrenamiento de modelos de IA sin autorización.
          </div>
        </div>
      </div>


      <!-- Copyright notice destacado -->
      <div class="notice-card">
        <div class="notice-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M14.83 14.83a4 4 0 1 1 0-5.66"/></svg>
        </div>
        <div>
          <h2 class="notice-title">Aviso de Copyright</h2>
          <p class="notice-text">© {year} Veredillas FM. Creado por Broslunas (Pablo Luna). Todos los derechos reservados. Queda estrictamente prohibida la reproducción, distribución, comunicación pública o transformación total o parcial de cualquier contenido de esta plataforma sin la autorización expresa y escrita de Veredillas FM.</p>
        </div>
      </div>

      <!-- Sections -->
      <section>
        <h2>1. Titularidad de los Contenidos</h2>
        <p>Veredillas FM (Broslunas) es titular exclusivo de los derechos de propiedad intelectual e industrial sobre todos los contenidos publicados en esta plataforma, incluyendo, pero no limitándose a:</p>
        <ul class="copyright-list">
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
            </div>
            <div><strong>Episodios y podcasts:</strong> Grabaciones de audio, guiones, escaletas, montajes y producciones sonoras publicadas en cualquiera de nuestras plataformas de distribución.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
            <div><strong>Material audiovisual:</strong> Vídeos, clips, contenido de redes sociales, fotografías, ilustraciones y gráficos de producción propia.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/></svg>
            </div>
            <div><strong>Contenido editorial:</strong> Artículos de blog, noticias, descripciones de episodios, entrevistas escritas y cualquier texto redactado por el equipo de Veredillas FM.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <div><strong>Identidad visual y marca:</strong> Logotipo, paleta de colores, tipografías corporativas, nombre comercial «Veredillas FM» y todos los elementos que integran la identidad gráfica.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </div>
            <div><strong>Software y plataforma:</strong> Código fuente, arquitectura de la aplicación, diseño de interfaces (UX/UI), bases de datos y sistemas de gamificación desarrollados para esta plataforma.</div>
          </li>
        </ul>
      </section>

      <section>
        <h2>2. Usos Prohibidos</h2>
        <p>Sin perjuicio de lo establecido en la legislación vigente, y salvo autorización expresa por escrito de Veredillas FM, queda terminantemente prohibido:</p>
        <ul class="copyright-list prohibited">
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Reproducir, copiar, distribuir o comunicar públicamente cualquier contenido de Veredillas FM en otros medios, plataformas o soportes.</div>
          </li>
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Descargar, almacenar o retransmitir los episodios de audio con fines comerciales o de distribución masiva.</div>
          </li>
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Utilizar el nombre, logotipo o imagen de marca «Veredillas FM» en productos, servicios o publicaciones de terceros.</div>
          </li>
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Modificar, adaptar, traducir, descompilar o crear obras derivadas a partir de nuestros contenidos o código fuente.</div>
          </li>
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Usar nuestros contenidos con fines formativos, académicos o empresariales sin la correspondiente licencia.</div>
          </li>
          <li>
            <div class="list-icon prohibited-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            </div>
            <div>Realizar scraping, ingesta automatizada de datos o cualquier proceso técnico que extraiga nuestros contenidos de forma masiva.</div>
          </li>
        </ul>
      </section>

      <section>
        <h2>3. Usos Permitidos</h2>
        <p>Con carácter general, se autoriza el uso de los contenidos de Veredillas FM en los siguientes supuestos, siempre que se cite la fuente de forma expresa y visible:</p>
        <ul class="copyright-list allowed">
          <li>
            <div class="list-icon allowed-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>Escucha personal y privada de los episodios a través de las plataformas oficiales de distribución.</div>
          </li>
          <li>
            <div class="list-icon allowed-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>Compartir los enlaces oficiales de los episodios o artículos en redes sociales, siempre apuntando a las fuentes originales.</div>
          </li>
          <li>
            <div class="list-icon allowed-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>Citar brevemente extractos de nuestro contenido con fines informativos o de crítica, indicando siempre «Veredillas FM» como fuente.</div>
          </li>
          <li>
            <div class="list-icon allowed-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <div>Incrustar el reproductor oficial de episodios en blogs o medios, utilizando únicamente los mecanismos de embedding habilitados por Veredillas FM.</div>
          </li>
        </ul>
      </section>

      <section>
        <h2>4. Contenido de Terceros</h2>
        <p>Algunos contenidos publicados en la plataforma pueden incluir material de terceros (música, efectos de sonido, imágenes), utilizados bajo las licencias correspondientes. Estos contenidos mantienen sus propios derechos de autor y no se transfieren al usuario final.</p>
        <p>Veredillas FM respeta escrupulosamente los derechos de propiedad intelectual ajenos. Si crees que algún contenido infringe tus derechos, contáctanos a través de <a href="mailto:contacto@veredillasfm.es">contacto@veredillasfm.es</a> y atenderemos tu solicitud a la mayor brevedad posible.</p>
      </section>

      <section>
        <h2>5. Contenido Generado por Usuarios</h2>
        <p>Al publicar comentarios, mensajes en el chat o cualquier otro contenido en la plataforma, el usuario garantiza que posee los derechos necesarios sobre dicho material y concede a Veredillas FM una licencia no exclusiva, gratuita, mundial y sublicenciable para usar, reproducir, modificar y distribuir dicho contenido en el contexto de los servicios de la plataforma.</p>
        <p>Veredillas FM no reivindica la titularidad del contenido generado por los usuarios, pero se reserva el derecho a retirar cualquier contenido que infrinja estos términos o la legislación vigente.</p>
      </section>

      <section>
        <h2>6. Marco Legal Aplicable</h2>
        <p>La protección de los contenidos de Veredillas FM se rige por las siguientes normativas:</p>
        <ul class="copyright-list">
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H2v15h7c1.7 0 3 1.3 3 3V7c0-2.2-1.8-4-4-4z"/><path d="M16 3h6v15h-7c-1.7 0-3 1.3-3 3V7c0-2.2 1.8-4 4-4z"/></svg>
            </div>
            <div><strong>Real Decreto Legislativo 1/1996</strong> — Texto Refundido de la Ley de Propiedad Intelectual (TRLPI), que protege los derechos de autor en España.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H2v15h7c1.7 0 3 1.3 3 3V7c0-2.2-1.8-4-4-4z"/><path d="M16 3h6v15h-7c-1.7 0-3 1.3-3 3V7c0-2.2 1.8-4 4-4z"/></svg>
            </div>
            <div><strong>Directiva 2019/790/UE</strong> — sobre los derechos de autor y derechos afines en el mercado único digital.</div>
          </li>
          <li>
            <div class="list-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H2v15h7c1.7 0 3 1.3 3 3V7c0-2.2-1.8-4-4-4z"/><path d="M16 3h6v15h-7c-1.7 0-3 1.3-3 3V7c0-2.2 1.8-4 4-4z"/></svg>
            </div>
            <div><strong>Convenio de Berna</strong> — para la protección de las obras literarias y artísticas, con alcance internacional.</div>
          </li>
        </ul>
      </section>

      <section>
        <h2>7. Solicitud de Licencias y Permisos</h2>
        <p>Si deseas utilizar cualquier contenido de Veredillas FM más allá de los usos permitidos descritos en esta política, debes solicitar autorización previa y por escrito. Para ello, contacta con nosotros indicando:</p>
        <ul class="copyright-list">
          <li>
            <div class="list-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><path d="M5 12h14"/></svg></div>
            <div>El contenido concreto que deseas utilizar.</div>
          </li>
          <li>
            <div class="list-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><path d="M5 12h14"/></svg></div>
            <div>El propósito y contexto del uso que quieres dar al contenido.</div>
          </li>
          <li>
            <div class="list-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><path d="M5 12h14"/></svg></div>
            <div>El medio o plataforma donde será publicado.</div>
          </li>
          <li>
            <div class="list-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><path d="M5 12h14"/></svg></div>
            <div>El periodo de tiempo durante el cual necesitas el permiso.</div>
          </li>
        </ul>
        <a href="/contacto" class="contact-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Solicitar Permiso de Uso
        </a>
      </section>

      <!-- Related links -->
      <div class="related-links">
        <h3>Documentos Relacionados</h3>
        <div class="related-grid">
          <a href="/terminos-y-condiciones" class="related-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14.5 2 14.5 7.5 20 7.5"/></svg>
            <span>Términos y Condiciones</span>
          </a>
          <a href="/politica-de-privacidad" class="related-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            <span>Política de Privacidad</span>
          </a>
          <a href="/cookies" class="related-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5Z"/></svg>
            <span>Política de Cookies</span>
          </a>
        </div>
      </div>

    </div>
  </main>
</Layout>

<style>
  .page-container {
    padding: var(--spacing-4xl) var(--spacing-lg);
    min-height: 80vh;
  }

  .content-wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  /* Hero */
  .hero {
    margin-bottom: 3rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    color: var(--color-text-heading);
    letter-spacing: -0.02em;
    font-weight: 800;
  }

  .hero-subtitle {
    font-size: 1.15rem;
    color: var(--color-text-body);
    line-height: 1.7;
    max-width: 680px;
    margin-bottom: 0.75rem;
  }

  .updated-date {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Summary Card */
  .summary-card {
    background: color-mix(in srgb, var(--color-text-heading) 4%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-text-heading) 10%, transparent);
    border-radius: 1.25rem;
    padding: 2rem;
    margin-bottom: 4rem;
  }

  .summary-card h3 {
    margin-bottom: 1.5rem;
    font-size: 1.25rem;
    color: var(--color-text-heading);
    font-weight: 700;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .summary-item {
    font-size: 0.95rem;
    color: var(--color-text-body);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .summary-item strong {
    color: var(--color-primary);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  /* Notice card */
  .notice-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-radius: 1rem;
    padding: 1.75rem;
    margin-bottom: 3.5rem;
  }

  .notice-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    background: color-mix(in srgb, var(--color-primary) 15%, transparent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .notice-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin-bottom: 0.5rem;
  }

  .notice-text {
    color: var(--color-text-body);
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
  }

  /* Sections */
  section {
    margin-bottom: 3rem;
