{
  "manifest_version": 3,
  "name": "Veredillas FM",
  "version": "2.0.0",
  "description": "El podcast oficial del IES Veredillas. Reproductor en segundo plano.",
  "action": {
    "default_title": "Veredillas FM",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "host_permissions": [
    "https://veredillasfm.es/*",
    "http://localhost:4321/*"
  ]
}
